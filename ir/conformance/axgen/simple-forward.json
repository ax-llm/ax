{
  "name": "simple-forward",
  "kind": "forward",
  "signature": "question:string -> answer:string",
  "input": {
    "question": "What is the capital of France?"
  },
  "responses": [
    {
      "content": "{\"answer\":\"Paris\"}"
    }
  ],
  "expected_output": {
    "answer": "Paris"
  },
  "expected_request": {
    "response_format": {
      "type": "json_schema",
      "schema": {
        "name": "output",
        "strict": true,
        "schema": {
          "type": "object",
          "title": "output",
          "properties": {
            "answer": {
              "type": "string"
            }
          },
          "required": ["answer"],
          "additionalProperties": false
        }
      }
    }
  },
  "expected_request_count": 1
}
