{
  "name": "parse-nested-flexible-json",
  "kind": "forward",
  "signature_spec": {
    "inputs": {
      "query": {
        "type": "string"
      }
    },
    "outputs": {
      "items": {
        "type": "object",
        "array": true,
        "fields": {
          "title": {
            "type": "string"
          },
          "payload": {
            "type": "json"
          }
        }
      }
    }
  },
  "input": {
    "query": "list items"
  },
  "responses": [
    {
      "content": "{\"items\":[{\"title\":\"First\",\"payload\":\"{\\\"k\\\":1,\\\"nested\\\":{\\\"a\\\":true}}\"},{\"title\":\"Second\",\"payload\":\"[1,2,3]\"}]}"
    }
  ],
  "expected_output": {
    "items": [
      {
        "title": "First",
        "payload": {
          "k": 1,
          "nested": {
            "a": true
          }
        }
      },
      {
        "title": "Second",
        "payload": [1, 2, 3]
      }
    ]
  },
  "expected_request_count": 1
}
