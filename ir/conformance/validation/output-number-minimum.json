{
  "expected_error_category": "validation",
  "expected_error_contains": "at least 18",
  "kind": "validate_output",
  "name": "output-number-minimum",
  "signature_spec": {
    "inputs": {
      "query": {
        "type": "string"
      }
    },
    "outputs": {
      "user": {
        "description": "User profile",
        "fields": {
          "username": {
            "max": 20,
            "min": 3,
            "type": "string"
          },
          "email": {
            "email": true,
            "optional": true,
            "type": "string"
          },
          "age": {
            "max": 120,
            "min": 18,
            "type": "number"
          }
        },
        "type": "object"
      }
    }
  },
  "ts_error_message": "Field 'age' failed validation: Number must be at least 18. You provided: 12.",
  "ts_error_name": "ValidationError",
  "values": {
    "user": {
      "age": 12,
      "username": "adalovelace"
    }
  }
}
