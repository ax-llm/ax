{
  "expected_error_category": "validation",
  "expected_error_contains": "valid email address",
  "kind": "validate_output",
  "name": "output-email-format",
  "signature_spec": {
    "inputs": {
      "query": {
        "type": "string"
      }
    },
    "outputs": {
      "user": {
        "description": "User profile",
        "fields": {
          "username": {
            "max": 20,
            "min": 3,
            "type": "string"
          },
          "email": {
            "email": true,
            "optional": true,
            "type": "string"
          },
          "age": {
            "max": 120,
            "min": 18,
            "type": "number"
          }
        },
        "type": "object"
      }
    }
  },
  "ts_error_message": "Field 'email' failed validation: String must be a valid email address. You provided: \"not-email\".",
  "ts_error_name": "ValidationError",
  "values": {
    "user": {
      "age": 36,
      "email": "not-email",
      "username": "adalovelace"
    }
  }
}
