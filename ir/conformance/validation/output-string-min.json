{
  "expected_error_category": "validation",
  "expected_error_contains": "at least 3 characters",
  "kind": "validate_output",
  "name": "output-string-min",
  "signature_spec": {
    "inputs": {
      "query": {
        "type": "string"
      }
    },
    "outputs": {
      "user": {
        "description": "User profile",
        "fields": {
          "username": {
            "max": 20,
            "min": 3,
            "type": "string"
          },
          "email": {
            "email": true,
            "optional": true,
            "type": "string"
          },
          "age": {
            "max": 120,
            "min": 18,
            "type": "number"
          }
        },
        "type": "object"
      }
    }
  },
  "ts_error_message": "Field 'username' failed validation: String must be at least 3 characters long. You provided: \"Al\" (2 characters).",
  "ts_error_name": "ValidationError",
  "values": {
    "user": {
      "age": 36,
      "username": "Al"
    }
  }
}
