            "finish_reason": "stop",
            "message": {
              "role": "assistant",
              "content": "ok"
            }
          }
        ]
      }
    }
  ],
  "expected_output": {
    "results": [
      {
        "index": 0,
        "id": "0",
        "content": "ok",
        "function_calls": [],
        "finish_reason": "stop"
      }
    ],
    "remote_id": "chatcmpl_alias",
    "model_usage": null
  },
  "expected_transport_request": {
    "json": {
      "max_completion_tokens": 64,
      "top_p": 0.8,
      "presence_penalty": 0.1,
      "frequency_penalty": 0.2,
      "stop": ["END"]
    }
  }
