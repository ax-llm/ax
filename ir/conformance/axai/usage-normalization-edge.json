{
  "name": "usage-normalization-edge",
  "kind": "ai_chat",
  "request": {
    "chat_prompt": [
      {
        "role": "user",
        "content": "usage"
      }
    ]
  },
  "transport_responses": [
    {
      "status": 200,
      "json": {
        "id": "chatcmpl_usage",
        "model": "gpt-4.1-mini",
        "usage": {
          "promptTokens": 10,
          "completionTokens": 5,
          "totalTokens": 15,
          "reasoningTokens": 2,
          "cacheReadTokens": 3,
          "cacheCreationTokens": 4
        },
        "choices": [
          {
            "index": 0,
            "finish_reason": "stop",
            "message": {
              "role": "assistant",
              "content": "ok"
            }
          }
        ]
      }
    }
  ],
  "expected_output": {
    "results": [
      {
        "index": 0,
        "id": "0",
        "content": "ok",
        "function_calls": [],
        "finish_reason": "stop"
      }
    ],
    "remote_id": "chatcmpl_usage",
    "model_usage": {
      "ai": "openai",
      "model": "gpt-4.1-mini",
      "tokens": {
        "prompt_tokens": 10,
        "completion_tokens": 5,
        "total_tokens": 15,
        "reasoning_tokens": 2,
        "cache_read_tokens": 3,
        "cache_creation_tokens": 4
      }
    }
  }
}
