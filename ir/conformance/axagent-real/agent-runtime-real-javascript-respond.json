{
  "kind": "agent_runtime_real",
  "name": "agent-runtime-real-javascript-respond",
  "runtime_engine": "javascript",
  "signature": "question:string -> answer:string",
  "input": {
    "question": "Use runtime"
  },
  "options": {
    "runtime": {
      "language": "JavaScript"
    }
  },
  "responses": [
    {
      "content": "{\"javascriptCode\":\"respond(\\\"Answer with the runtime value\\\", {\\\"answer\\\": \\\"from runtime\\\"})\"}"
    },
    {
      "content": "{\"answer\":\"from runtime\"}"
    }
  ],
  "expected_output": {
    "answer": "from runtime"
  },
  "expected_request_count": 2,
  "expected_request_contains": [
    "There is no executor phase",
    "await respond(task: string, evidence?: object)",
    "from runtime",
    "Answer Synthesis Agent"
  ],
  "expected_stage_request_not_contains": [
    {
      "absent": ["## Executor"],
      "index": 1
    }
  ]
}
