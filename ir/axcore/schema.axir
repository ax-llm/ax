module @ax.schema version "0.1" {
  dialect @ax.schema version "0.1"

  op ax.schema.record @AxFunctionJSONSchema {
    attr core_kind = "record"
    tag "src/ax/ai/types.ts"
    type fields = "type:string|list<string>,properties?:map<string,json>,required?:list<string>,items?:json,enum?:list<string>,additionalProperties?:bool"
  }

  op ax.schema.semantic @to_json_schema {
    attr core_kind = "func"
    attr emit_module = "schema"
    tag "src/ax/dsp/jsonSchema.ts"
    type signature = "(list<Field>) -> AxFunctionJSONSchema throws"
    body @entry(%fields: list<Field>, %schema_title: string, %options: json) {
      %schema = core.call @schema_to_json_schema_impl(%fields, %schema_title, %options)
      core.return %schema
    }
  }

  op ax.schema.semantic @schema_required_impl {
    attr core_kind = "func"
    attr emit_module = "schema"
    attr private = true
    tag "json-schema-required-core-helper"
    type signature = "(Field, json) -> bool"
    body @entry(%field: Field, %options: json) {
      %strict_camel = core.get %options["strictStructuredOutputs"] default false
      %strict_snake = core.get %options["strict_structured_outputs"] default false
      %strict = core.call intrinsic.or(%strict_camel, %strict_snake)
      %is_optional = core.get %field["is_optional"] default false
      %not_optional = core.call intrinsic.not(%is_optional)
      %required = core.call intrinsic.or(%strict, %not_optional)
      core.return %required
    }
  }

  op ax.schema.semantic @schema_flexible_json_as_string_impl {
    attr core_kind = "func"
    attr emit_module = "schema"
    attr private = true
    tag "json-schema-flexible-json-string-core-helper"
    type signature = "(FieldType, json) -> bool"
    body @entry(%typ: FieldType, %options: json) {
      %camel = core.get %options["flexibleJsonFieldsAsString"] default false
      %snake = core.get %options["flexible_json_fields_as_string"] default false
      %enabled = core.call intrinsic.or(%camel, %snake)
      %type_name = core.get %typ["name"]
      %is_json = core.call intrinsic.eq(%type_name, "json")
      %is_object = core.call intrinsic.eq(%type_name, "object")
      %fields = core.get %typ["fields"]
      %has_fields = core.call intrinsic.truthy(%fields)
      %unshaped = core.call intrinsic.not(%has_fields)
      %unshaped_object = core.call intrinsic.and(%is_object, %unshaped)
      %flexible_type = core.call intrinsic.or(%is_json, %unshaped_object)
      %as_string = core.call intrinsic.and(%enabled, %flexible_type)
      core.return %as_string
    }
  }

  op ax.schema.semantic @schema_json_type_impl {
    attr core_kind = "func"
    attr emit_module = "schema"
    attr private = true
    tag "json-schema-type-core-helper"
    type signature = "(string) -> json"
    body @entry(%type_name: string) {
      %string_types = core.list
      core.append %string_types, "string"
      core.append %string_types, "code"
      core.append %string_types, "url"
      core.append %string_types, "date"
      core.append %string_types, "datetime"
      core.append %string_types, "dateRange"
      core.append %string_types, "datetimeRange"
      core.append %string_types, "image"
      core.append %string_types, "audio"
      core.append %string_types, "file"
      %is_string = core.call intrinsic.contains(%string_types, %type_name)
      core.if %is_string {
        core.return "string"
      }
      %is_number = core.call intrinsic.eq(%type_name, "number")
      core.if %is_number {
        core.return "number"
      }
      %is_boolean = core.call intrinsic.eq(%type_name, "boolean")
      core.if %is_boolean {
        core.return "boolean"
      }
      %json_types = core.list
      core.append %json_types, "object"
      core.append %json_types, "array"
      core.append %json_types, "string"
      core.append %json_types, "number"
      core.append %json_types, "boolean"
      core.append %json_types, "null"
      %flexible_names = core.list
      core.append %flexible_names, "json"
      core.append %flexible_names, "object"
      %is_flexible = core.call intrinsic.contains(%flexible_names, %type_name)
      core.if %is_flexible {
        core.return %json_types
      }
      core.return "string"
    }
  }

  op ax.schema.semantic @schema_enhance_description_impl {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "schema"
    attr private = true
    tag "json-schema-description-core-helper"
    type signature = "(json, FieldType) -> json throws"
    body @entry(%base: json, %typ: FieldType) {
      %constraints = core.list
      %type_name = core.get %typ["name"]
      %format = core.get %typ["format"]
      %is_email = core.call intrinsic.eq(%format, "email")
      core.if %is_email {
        core.append %constraints, "Must be a valid email address format"
      }
      %url_formats = core.list
      core.append %url_formats, "uri"
      core.append %url_formats, "url"
      %format_url = core.call intrinsic.contains(%url_formats, %format)
      %type_url = core.call intrinsic.eq(%type_name, "url")
      %is_url = core.call intrinsic.or(%format_url, %type_url)
      core.if %is_url {
        core.append %constraints, "Must be a valid URL format"
      }
      %length_types = core.list
      core.append %length_types, "string"
      core.append %length_types, "code"
      core.append %length_types, "url"
      core.append %length_types, "date"
      core.append %length_types, "dateRange"
      core.append %length_types, "datetime"
      core.append %length_types, "datetimeRange"
      %has_length_constraints = core.call intrinsic.contains(%length_types, %type_name)
      core.if %has_length_constraints {
        %min_length = core.get %typ["min_length"]
        %max_length = core.get %typ["max_length"]
        %has_min = core.call intrinsic.is_not_none(%min_length)
        %has_max = core.call intrinsic.is_not_none(%max_length)
        %has_both = core.call intrinsic.and(%has_min, %has_max)
        core.if %has_both {
          %text = core.call intrinsic.string.format("Minimum length: {} characters, maximum length: {} characters", %min_length, %max_length)
          core.append %constraints, %text
        } else {
          core.if %has_min {
            %text = core.call intrinsic.string.format("Minimum length: {} characters", %min_length)
            core.append %constraints, %text
          } else {
            core.if %has_max {
              %text = core.call intrinsic.string.format("Maximum length: {} characters", %max_length)
              core.append %constraints, %text
            }
          }
        }
      }
      %is_number = core.call intrinsic.eq(%type_name, "number")
      core.if %is_number {
        %minimum = core.get %typ["minimum"]
        %maximum = core.get %typ["maximum"]
        %has_minimum = core.call intrinsic.is_not_none(%minimum)
        %has_maximum = core.call intrinsic.is_not_none(%maximum)
        %has_both = core.call intrinsic.and(%has_minimum, %has_maximum)
        core.if %has_both {
          %text = core.call intrinsic.string.format("Minimum value: {}, maximum value: {}", %minimum, %maximum)
          core.append %constraints, %text
        } else {
          core.if %has_minimum {
            %text = core.call intrinsic.string.format("Minimum value: {}", %minimum)
            core.append %constraints, %text
          } else {
            core.if %has_maximum {
              %text = core.call intrinsic.string.format("Maximum value: {}", %maximum)
              core.append %constraints, %text
            }
          }
        }
      }
      %pattern = core.get %typ["pattern"]
      %has_pattern = core.call intrinsic.is_not_none(%pattern)
      core.if %has_pattern {
        %pattern_description = core.get %typ["pattern_description"]
        %missing_pattern_description = core.call intrinsic.is_none(%pattern_description)
        core.if %missing_pattern_description {
          %message = core.call intrinsic.string.format("Field with pattern '{}' must include a patternDescription to explain the pattern to the LLM", %pattern)
          %error = core.call intrinsic.error.validation(%message)
          core.raise %error
        } else {
          core.append %constraints, %pattern_description
        }
      }
      %is_date = core.call intrinsic.eq(%type_name, "date")
      core.if %is_date {
        core.append %constraints, "Format: YYYY-MM-DD"
      }
      %is_date_range = core.call intrinsic.eq(%type_name, "dateRange")
      core.if %is_date_range {
        core.append %constraints, "Format: JSON object with start and end dates, or YYYY-MM-DD/YYYY-MM-DD"
      }
      %is_datetime = core.call intrinsic.eq(%type_name, "datetime")
      core.if %is_datetime {
        core.append %constraints, "Format: ISO 8601 date-time"
      }
      %is_datetime_range = core.call intrinsic.eq(%type_name, "datetimeRange")
      core.if %is_datetime_range {
        core.append %constraints, "Format: JSON object with start and end ISO 8601 date-times, or ISO interval start/end"
      }
      %constraint_count = core.call intrinsic.len(%constraints)
      %has_constraints = core.call intrinsic.gt(%constraint_count, 0)
      core.if %has_constraints {
        %constraint_text = core.string_join %constraints sep ". "
        %description = core.call intrinsic.description.append(%base, %constraint_text)
        core.return %description
      }
      core.return %base
    }
  }

  op ax.schema.semantic @schema_apply_constraints_impl {
    attr core_kind = "func"
    attr emit_module = "schema"
    attr private = true
    tag "json-schema-constraints-core-helper"
    type signature = "(json, FieldType) -> json"
    body @entry(%schema: json, %typ: FieldType) {
      %type_name = core.get %typ["name"]
      %string_types = core.list
      core.append %string_types, "string"
      core.append %string_types, "code"
      core.append %string_types, "url"
      core.append %string_types, "date"
      core.append %string_types, "dateRange"
      core.append %string_types, "datetime"
      core.append %string_types, "datetimeRange"
      %is_string_type = core.call intrinsic.contains(%string_types, %type_name)
      core.if %is_string_type {
        %min_length = core.get %typ["min_length"]
        %has_min = core.call intrinsic.is_not_none(%min_length)
        core.if %has_min {
          core.set %schema["minLength"] = %min_length
        }
        %max_length = core.get %typ["max_length"]
        %has_max = core.call intrinsic.is_not_none(%max_length)
        core.if %has_max {
          core.set %schema["maxLength"] = %max_length
        }
        %pattern = core.get %typ["pattern"]
        %has_pattern = core.call intrinsic.is_not_none(%pattern)
        core.if %has_pattern {
          core.set %schema["pattern"] = %pattern
        }
        %format = core.get %typ["format"]
        %has_format = core.call intrinsic.is_not_none(%format)
        core.if %has_format {
          core.set %schema["format"] = %format
        }
        %is_url = core.call intrinsic.eq(%type_name, "url")
        %missing_format = core.call intrinsic.not(%has_format)
        %default_url_format = core.call intrinsic.and(%is_url, %missing_format)
        core.if %default_url_format {
          core.set %schema["format"] = "uri"
        }
        %is_date = core.call intrinsic.eq(%type_name, "date")
        %default_date_format = core.call intrinsic.and(%is_date, %missing_format)
        core.if %default_date_format {
          core.set %schema["format"] = "date"
        }
        %is_datetime = core.call intrinsic.eq(%type_name, "datetime")
        %default_datetime_format = core.call intrinsic.and(%is_datetime, %missing_format)
        core.if %default_datetime_format {
          core.set %schema["format"] = "date-time"
        }
      } else {
        %is_number = core.call intrinsic.eq(%type_name, "number")
        core.if %is_number {
          %minimum = core.get %typ["minimum"]
          %has_minimum = core.call intrinsic.is_not_none(%minimum)
          core.if %has_minimum {
            core.set %schema["minimum"] = %minimum
          }
          %maximum = core.get %typ["maximum"]
          %has_maximum = core.call intrinsic.is_not_none(%maximum)
          core.if %has_maximum {
            core.set %schema["maximum"] = %maximum
          }
        }
      }
      core.return %schema
    }
  }

  op ax.schema.semantic @schema_nullable_optional_impl {
    attr core_kind = "func"
    attr emit_module = "schema"
    attr private = true
    tag "json-schema-nullable-optional-core-helper"
    type signature = "(json, Field, json) -> json"
    body @entry(%schema: json, %field: Field, %options: json) {
      %is_optional = core.get %field["is_optional"] default false
      %strict_camel = core.get %options["strictStructuredOutputs"] default false
      %strict_snake = core.get %options["strict_structured_outputs"] default false
      %strict = core.call intrinsic.or(%strict_camel, %strict_snake)
      %make_nullable = core.call intrinsic.and(%is_optional, %strict)
      core.if %make_nullable {
        %schema_type = core.get %schema["type"]
        %type_is_list = core.type_is %schema_type type "list"
        core.if %type_is_list {
          %has_null_type = core.call intrinsic.contains(%schema_type, "null")
          %needs_null_type = core.call intrinsic.not(%has_null_type)
          core.if %needs_null_type {
            core.append %schema_type, "null"
          }
        } else {
          %nullable_type = core.list
          core.append %nullable_type, %schema_type
          core.append %nullable_type, "null"
          core.set %schema["type"] = %nullable_type
        }
        %enum_values = core.get %schema["enum"]
        %enum_is_list = core.type_is %enum_values type "list"
        core.if %enum_is_list {
          %none = core.call intrinsic.none()
          %enum_has_null = core.call intrinsic.contains(%enum_values, %none)
          %enum_needs_null = core.call intrinsic.not(%enum_has_null)
          core.if %enum_needs_null {
            core.append %enum_values, %none
          }
        }
      }
      core.return %schema
    }
  }

  op ax.schema.semantic @schema_object_from_fields_impl {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "schema"
    attr private = true
    tag "json-schema-object-core-helper"
    type signature = "(json, bool, json) -> json throws"
    body @entry(%fields_map: json, %is_nested: bool, %options: json) {
      %schema = core.map
      %properties = core.map
      %required = core.list
      core.set %schema["type"] = "object"
      core.set %schema["properties"] = %properties
      core.set %schema["required"] = %required
      core.set %schema["additionalProperties"] = false
      %fields = core.call intrinsic.fields.from_map(%fields_map)
      core.for %field in %fields {
        %is_internal = core.get %field["is_internal"] default false
        %include = core.call intrinsic.not(%is_internal)
        core.if %include {
          %field_name = core.get %field["name"]
          %field_schema = core.call @schema_field_schema_impl(%field, %is_nested, %options)
          core.set %properties[%field_name] = %field_schema
          %is_required = core.call @schema_required_impl(%field, %options)
          core.if %is_required {
            core.append %required, %field_name
          }
        }
      }
      core.return %schema
    }
  }

  op ax.schema.semantic @schema_field_schema_impl {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "schema"
    attr private = true
    tag "json-schema-field-core-helper"
    type signature = "(Field, bool, json) -> json throws"
    body @entry(%field: Field, %is_nested: bool, %options: json) {
      %typ = core.get %field["type"]
      %type_name = core.get %typ["name"]
      %media_types = core.list
      core.append %media_types, "image"
      core.append %media_types, "audio"
      core.append %media_types, "file"
      %is_media = core.call intrinsic.contains(%media_types, %type_name)
      %nested_media = core.call intrinsic.and(%is_nested, %is_media)
      core.if %nested_media {
        %message = core.call intrinsic.string.format("Media type '{}' is not allowed in nested object fields", %type_name)
        %error = core.call intrinsic.error.validation(%message)
        core.raise %error
      }
      %schema = core.map
      %field_description = core.get %field["description"]
      %description = core.call @schema_enhance_description_impl(%field_description, %typ)
      %has_description = core.call intrinsic.truthy(%description)
      core.if %has_description {
        core.set %schema["description"] = %description
      }
      %is_array = core.get %typ["is_array"] default false
      core.if %is_array {
        core.set %schema["type"] = "array"
        %fields_map = core.get %typ["fields"]
        %has_fields = core.call intrinsic.truthy(%fields_map)
        core.if %has_fields {
          %items = core.call @schema_object_from_fields_impl(%fields_map, true, %options)
          %type_description = core.get %typ["description"]
          %has_type_description = core.call intrinsic.truthy(%type_description)
          core.if %has_type_description {
            core.set %items["description"] = %type_description
          }
          core.set %schema["items"] = %items
          %nullable = core.call @schema_nullable_optional_impl(%schema, %field, %options)
          core.return %nullable
        }
        %is_class = core.call intrinsic.eq(%type_name, "class")
        core.if %is_class {
          %items = core.map
          core.set %items["type"] = "string"
          %class_options = core.get %typ["options"]
          core.set %items["enum"] = %class_options
          core.set %schema["items"] = %items
          %nullable = core.call @schema_nullable_optional_impl(%schema, %field, %options)
          core.return %nullable
        }
        %items = core.map
        %flexible_string = core.call @schema_flexible_json_as_string_impl(%typ, %options)
        core.if %flexible_string {
          core.set %items["type"] = "string"
          %type_description = core.get %typ["description"]
          %item_base_description = core.call intrinsic.coalesce(%type_description, %field_description)
          %item_description = core.call @schema_enhance_description_impl(%item_base_description, %typ)
          %json_description = core.call intrinsic.description.append(%item_description, "Return this field as a JSON-encoded string that can be parsed with JSON.parse.")
          core.set %items["description"] = %json_description
        } else {
          %json_type = core.call @schema_json_type_impl(%type_name)
          core.set %items["type"] = %json_type
          %type_description = core.get %typ["description"]
          %item_base_description = core.call intrinsic.coalesce(%type_description, %field_description)
          %item_description = core.call @schema_enhance_description_impl(%item_base_description, %typ)
          %has_item_description = core.call intrinsic.truthy(%item_description)
          core.if %has_item_description {
            core.set %items["description"] = %item_description
          }
        }
        %items_with_constraints = core.call @schema_apply_constraints_impl(%items, %typ)
        core.set %schema["items"] = %items_with_constraints
        %nullable = core.call @schema_nullable_optional_impl(%schema, %field, %options)
        core.return %nullable
      }
      %fields_map = core.get %typ["fields"]
      %is_object = core.call intrinsic.eq(%type_name, "object")
      %has_fields = core.call intrinsic.truthy(%fields_map)
      %is_shaped_object = core.call intrinsic.and(%is_object, %has_fields)
      core.if %is_shaped_object {
        %object_schema = core.call @schema_object_from_fields_impl(%fields_map, true, %options)
        %updated = core.call intrinsic.map.update(%schema, %object_schema)
        %nullable = core.call @schema_nullable_optional_impl(%updated, %field, %options)
        core.return %nullable
      }
      %is_class = core.call intrinsic.eq(%type_name, "class")
      core.if %is_class {
        core.set %schema["type"] = "string"
        %class_options = core.get %typ["options"]
        core.set %schema["enum"] = %class_options
        %nullable = core.call @schema_nullable_optional_impl(%schema, %field, %options)
        core.return %nullable
      }
      %flexible_string = core.call @schema_flexible_json_as_string_impl(%typ, %options)
      core.if %flexible_string {
        core.set %schema["type"] = "string"
        %json_description = core.call intrinsic.description.append(%description, "Return this field as a JSON-encoded string that can be parsed with JSON.parse.")
        core.set %schema["description"] = %json_description
        %nullable = core.call @schema_nullable_optional_impl(%schema, %field, %options)
        core.return %nullable
      }
      %json_type = core.call @schema_json_type_impl(%type_name)
      core.set %schema["type"] = %json_type
      %is_audio = core.call intrinsic.eq(%type_name, "audio")
      core.if %is_audio {
        %audio_description = core.call intrinsic.description.append(%description, "Return plain text to synthesize as speech; do not return audio bytes or JSON audio objects.")
        core.set %schema["description"] = %audio_description
      }
      %schema_with_constraints = core.call @schema_apply_constraints_impl(%schema, %typ)
      %nullable = core.call @schema_nullable_optional_impl(%schema_with_constraints, %field, %options)
      core.return %nullable
    }
  }

  op ax.schema.semantic @schema_to_json_schema_impl {
    attr core_kind = "func"
    attr emit_module = "schema"
    attr private = true
    tag "json-schema-core-helper"
    type signature = "(list<Field>, string, json) -> AxFunctionJSONSchema throws"
    body @entry(%fields: list<Field>, %schema_title: string, %options: json) {
      %schema = core.map
      %properties = core.map
      %required = core.list
      core.set %schema["type"] = "object"
      core.set %schema["title"] = %schema_title
      core.set %schema["properties"] = %properties
      core.set %schema["required"] = %required
      core.set %schema["additionalProperties"] = false
      core.for %field in %fields {
        %is_internal = core.get %field["is_internal"] default false
        %include = core.call intrinsic.not(%is_internal)
        core.if %include {
          %field_name = core.get %field["name"]
          %field_schema = core.call @schema_field_schema_impl(%field, false, %options)
          core.set %properties[%field_name] = %field_schema
          %is_required = core.call @schema_required_impl(%field, %options)
          core.if %is_required {
            core.append %required, %field_name
          }
        }
      }
      core.return %schema
    }
  }

  op ax.schema.semantic @standard_schema_bridge {
    attr core_kind = "semantic"
    tag "src/ax/dsp/standardSchema.ts"
    type signature = "(external) -> list<Field>"
  }
}
