      %cached = core.get %field["is_cached"] default false
      %rendered_type = core.call @signature_render_type_impl(%typ, %cached)
      %field_name = core.get %state["value"]
      %entry = core.call intrinsic.string.format("{}:{}", %field_name, %rendered_type)
      %description = core.get %field["description"]
      %has_description = core.call intrinsic.truthy(%description)
      %type_name = core.get %typ["name"]
      %is_code = core.call intrinsic.eq(%type_name, "code")
      %language = core.get %typ["language"]
      %same_as_language = core.call intrinsic.eq(%description, %language)
      %implicit_code_description = core.call intrinsic.and(%is_code, %same_as_language)
      %not_implicit = core.call intrinsic.not(%implicit_code_description)
      %explicit_description = core.call intrinsic.and(%has_description, %not_implicit)
      core.if %explicit_description {
        %escaped = core.call @signature_escape_string_impl(%description)
        %entry = core.call intrinsic.string.format("{} \"{}\"", %entry, %escaped)
      }
      core.return %entry
    }
  }

  op ax.signature.semantic @signature_validate_field_shape_impl {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "signature"
    attr private = true
    tag "signature-field-validation-core-helper"
    type signature = "(Field, bool, bool) -> void throws"
    body @entry(%field: Field, %output: bool, %nested: bool) {
      %name = core.get %field["name"]
      %valid_name = core.regex_match %name pattern "^[A-Za-z_][A-Za-z0-9_]*$"
      %invalid_name = core.call intrinsic.not(%valid_name)
      core.if %invalid_name {
        %starts_number = core.regex_match %name pattern "^[0-9]"
        core.if %starts_number {
          %message = core.call intrinsic.string.format("Field name \"{}\" cannot start with a number", %name)
          %error = core.call intrinsic.error.signature(%message)
          core.raise %error
        } else {
          %message = core.call intrinsic.string.format("Invalid field name: \"{}\"", %name)
          %error = core.call intrinsic.error.signature(%message)
          core.raise %error
        }
      }
      %typ = core.get %field["type"]
      %type_name = core.get %typ["name"]
      %valid_types = core.list
      core.append %valid_types, "audio"
      core.append %valid_types, "boolean"
      core.append %valid_types, "class"
      core.append %valid_types, "code"
      core.append %valid_types, "date"
      core.append %valid_types, "dateRange"
      core.append %valid_types, "datetime"
      core.append %valid_types, "datetimeRange"
      core.append %valid_types, "file"
      core.append %valid_types, "image"
      core.append %valid_types, "json"
      core.append %valid_types, "number"
      core.append %valid_types, "object"
      core.append %valid_types, "string"
      core.append %valid_types, "url"
      %known_type = core.call intrinsic.contains(%valid_types, %type_name)
      %unknown_type = core.call intrinsic.not(%known_type)
      core.if %unknown_type {
        %message = core.call intrinsic.string.format("Invalid type \"{}\"", %type_name)
        %error = core.call intrinsic.error.signature(%message)
        core.raise %error
      }
      %media_types = core.list
      core.append %media_types, "image"
      core.append %media_types, "audio"
      core.append %media_types, "file"
      %is_media = core.call intrinsic.contains(%media_types, %type_name)
      %nested_media = core.call intrinsic.and(%nested, %is_media)
      core.if %nested_media {
        %message = core.call intrinsic.string.format("Media type '{}' is not allowed in nested object fields", %type_name)
        %error = core.call intrinsic.error.signature(%message)
        core.raise %error
      }
      %is_class = core.call intrinsic.eq(%type_name, "class")
      %is_input = core.call intrinsic.not(%output)
      %top_level = core.call intrinsic.not(%nested)
      %input_class_base = core.call intrinsic.and(%is_class, %is_input)
      %input_class = core.call intrinsic.and(%input_class_base, %top_level)
      core.if %input_class {
        %error = core.call intrinsic.error.signature("Input field cannot use the \"class\" type")
        core.raise %error
      }
      %class_options = core.get %typ["options"]
      %has_class_options = core.call intrinsic.truthy(%class_options)
      %missing_class_options = core.call intrinsic.not(%has_class_options)
      %class_without_options = core.call intrinsic.and(%is_class, %missing_class_options)
      core.if %class_without_options {
        %error = core.call intrinsic.error.signature("Missing class options after \"class\" type")
        core.raise %error
      }
      %is_internal = core.get %field["is_internal"] default false
      %internal_input = core.call intrinsic.and(%is_internal, %is_input)
      core.if %internal_input {
        %error = core.call intrinsic.error.signature("Input field cannot use the internal marker")
        core.raise %error
      }
      %is_image = core.call intrinsic.eq(%type_name, "image")
      %output_image = core.call intrinsic.and(%output, %is_image)
      core.if %output_image {
        %error = core.call intrinsic.error.signature("Image type is not supported in output fields")
        core.raise %error
      }
      %is_file = core.call intrinsic.eq(%type_name, "file")
      %output_file = core.call intrinsic.and(%output, %is_file)
      core.if %output_file {
        %error = core.call intrinsic.error.signature("File type is not supported in output fields")
        core.raise %error
      }
      %is_audio = core.call intrinsic.eq(%type_name, "audio")
      %is_array = core.get %typ["is_array"] default false
      %output_audio = core.call intrinsic.and(%output, %is_audio)
      %output_audio_array = core.call intrinsic.and(%output_audio, %is_array)
      core.if %output_audio_array {
        %error = core.call intrinsic.error.signature("Arrays of audio are not supported in output fields")
        core.raise %error
      }
      %nested_map = core.get %typ["fields"]
      %has_nested = core.call intrinsic.truthy(%nested_map)
      core.if %has_nested {
        %nested_fields = core.call intrinsic.fields.from_map(%nested_map)
        core.for %nested_field in %nested_fields {
          core.call @signature_validate_field_shape_impl(%nested_field, %output, true)
        }
      }
      core.return
    }
  }

  op ax.signature.semantic @signature_validate_impl {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "signature"
    attr private = true
    tag "signature-validation-core-helper"
    type signature = "(AxSignature) -> void throws"
    body @entry(%signature: AxSignature) {
      %inputs = core.get %signature["input_fields"]
      %outputs = core.get %signature["output_fields"]
      %input_count = core.call intrinsic.len(%inputs)
      %no_inputs = core.call intrinsic.eq(%input_count, 0)
      core.if %no_inputs {
        %error = core.call intrinsic.error.signature("No input fields specified")
        core.raise %error
      }
      %output_count = core.call intrinsic.len(%outputs)
      %no_outputs = core.call intrinsic.eq(%output_count, 0)
      core.if %no_outputs {
        %error = core.call intrinsic.error.signature("No output fields specified")
        core.raise %error
      }
      %seen_inputs = core.list
      core.for %field in %inputs {
        core.call @signature_validate_field_shape_impl(%field, false, false)
        %field_name = core.get %field["name"]
        %duplicate = core.call intrinsic.contains(%seen_inputs, %field_name)
        core.if %duplicate {
          %message = core.call intrinsic.string.format("Duplicate input field name: \"{}\"", %field_name)
          %error = core.call intrinsic.error.signature(%message)
          core.raise %error
        }
        core.append %seen_inputs, %field_name
      }
      %seen_outputs = core.list
      core.for %field in %outputs {
        core.call @signature_validate_field_shape_impl(%field, true, false)
        %field_name = core.get %field["name"]
        %collision = core.call intrinsic.contains(%seen_inputs, %field_name)
        core.if %collision {
          %message = core.call intrinsic.string.format("Field name \"{}\" appears in both inputs and outputs", %field_name)
          %error = core.call intrinsic.error.signature(%message)
          core.raise %error
        }
        %duplicate = core.call intrinsic.contains(%seen_outputs, %field_name)
        core.if %duplicate {
          %message = core.call intrinsic.string.format("Duplicate output field name: \"{}\"", %field_name)
          %error = core.call intrinsic.error.signature(%message)
          core.raise %error
        }
        core.append %seen_outputs, %field_name
      }
      core.return
    }
  }
}
