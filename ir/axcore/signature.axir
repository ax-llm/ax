module @ax.signature version "0.1" {
  dialect @ax.signature version "0.1"

  op ax.signature.record @FieldType {
    attr core_kind = "record"
    tag "src/ax/dsp/sig.ts"
    type fields = "name:string,isArray:bool,options?:list<string>,fields?:map<string,FieldType>,constraints?:json"
  }

  op ax.signature.record @Field {
    attr core_kind = "record"
    tag "src/ax/dsp/sig.ts"
    type fields = "name:string,type:FieldType,description?:string,title?:string,isOptional:bool,isInternal:bool,isCached:bool"
  }

  op ax.signature.record @SignatureBuilder {
    attr core_kind = "record"
    ref field = @Field
    tag "src/ax/dsp/sig.ts"
  }

  op ax.signature.semantic @parse_signature {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "signature"
    tag "src/ax/dsp/parser.ts"
    type signature = "(string) -> AxSignature throws"
    body @entry(%signature: string) {
      %parsed = core.call @signature_parse_impl(%signature)
      core.return %parsed
    }
  }

  op ax.signature.semantic @validate_signature {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "signature"
    tag "duplicate-fields"
    type signature = "(AxSignature) -> void throws"
    body @entry(%signature: AxSignature) {
      core.call @signature_validate_impl(%signature)
      core.return
    }
  }

  op ax.signature.semantic @signature_parse_impl {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "signature"
    attr private = true
    tag "signature-parser-core-helper"
    type signature = "(string) -> AxSignature throws"
    body @entry(%signature: string) {
      %text = core.string_trim %signature
      %text_len = core.call intrinsic.len(%text)
      %is_empty = core.call intrinsic.eq(%text_len, 0)
      core.if %is_empty {
        %error = core.call intrinsic.error.signature("Empty signature provided")
        core.raise %error
      }
      %prefix = core.call intrinsic.string.consume_optional_quoted_prefix(%text)
      %description = core.get %prefix["value"]
      %rest = core.get %prefix["rest"]
      %body = core.string_trim %rest
      %arrow = core.call intrinsic.string.find_outside_quotes(%body, "->")
      %missing_arrow = core.call intrinsic.lt(%arrow, 0)
      core.if %missing_arrow {
        %error = core.call intrinsic.error.signature("Expected \"->\"")
        core.raise %error
      }
      %left_raw = core.call intrinsic.string.slice(%body, 0, %arrow)
      %left = core.string_trim %left_raw
      %right_start = core.call intrinsic.add(%arrow, 2)
      %right_raw = core.call intrinsic.string.slice(%body, %right_start)
      %right = core.string_trim %right_raw
      %left_len = core.call intrinsic.len(%left)
      %left_empty = core.call intrinsic.eq(%left_len, 0)
      core.if %left_empty {
        %error = core.call intrinsic.error.signature("No input fields specified")
        core.raise %error
      }
      %right_len = core.call intrinsic.len(%right)
      %right_empty = core.call intrinsic.eq(%right_len, 0)
      core.if %right_empty {
        %error = core.call intrinsic.error.signature("No output fields specified")
        core.raise %error
      }
      %inputs = core.call @signature_parse_fields_impl(%left, false)
      %outputs = core.call @signature_parse_fields_impl(%right, true)
      %attrs = core.map
      core.set %attrs["inputs"] = %inputs
      core.set %attrs["outputs"] = %outputs
      core.set %attrs["description"] = %description
      %parsed = core.call intrinsic.record.new("AxSignature", %attrs)
      core.return %parsed
    }
  }

  op ax.signature.semantic @signature_parse_fields_impl {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "signature"
    attr private = true
    tag "signature-parser-field-list-core-helper"
    type signature = "(string, bool) -> list<Field> throws"
    body @entry(%text: string, %output: bool) {
      %parts = core.call intrinsic.string.split_outside_quotes(%text, ",")
      %fields = core.list
      core.for %part in %parts {
        %field = core.call @signature_parse_field_impl(%part, %output)
        core.append %fields, %field
      }
      core.return %fields
    }
  }

  op ax.signature.semantic @signature_parse_field_impl {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "signature"
    attr private = true
    tag "signature-parser-field-core-helper"
    type signature = "(string, bool) -> Field throws"
    body @entry(%raw: string, %output: bool) {
      %text = core.string_trim %raw
      %quoted_info = core.call intrinsic.string.extract_quoted_suffix(%text)
      %quoted = core.get %quoted_info["value"]
      %rest_after_quote = core.get %quoted_info["rest"]
      %rest_after_quote_trimmed = core.string_trim %rest_after_quote
      %has_extra = core.call intrinsic.truthy(%rest_after_quote_trimmed)
      core.if %has_extra {
        %error = core.call intrinsic.error.signature("Unexpected content after signature")
        core.raise %error
      }
      %head_raw = core.get %quoted_info["head"]
      %head = core.string_trim %head_raw
      %head_parts = core.call intrinsic.string.split_once(%head, ":")
      %name_part_raw = core.get %head_parts["left"]
      %type_part_raw = core.get %head_parts["right"]
      %name_part = core.string_trim %name_part_raw
      %type_part_trimmed = core.string_trim %type_part_raw
      %type_part = core.call intrinsic.string.default_if_empty(%type_part_trimmed, "string")
      %is_optional = core.call intrinsic.contains(%name_part, "?")
      %is_internal = core.call intrinsic.contains(%name_part, "!")
      %name_without_optional = core.call intrinsic.string.replace(%name_part, "?", "")
      %name_without_markers = core.call intrinsic.string.replace(%name_without_optional, "!", "")
      %name = core.string_trim %name_without_markers
      %type_words = core.call intrinsic.string.words(%type_part)
      %type_word_count = core.call intrinsic.len(%type_words)
      %extra_type_tokens = core.call intrinsic.gt(%type_word_count, 1)
      core.if %extra_type_tokens {
        %error = core.call intrinsic.error.signature("Unexpected content after signature")
        core.raise %error
      }
      %type_token = core.call intrinsic.list.get(%type_words, 0, "string")
      %array_info = core.call intrinsic.string.remove_suffix(%type_token, "[]")
      %type_name_raw = core.get %array_info["value"]
      %type_name = core.call intrinsic.string.default_if_empty(%type_name_raw, "string")
      %is_array = core.get %array_info["removed"]
      %is_class = core.call intrinsic.eq(%type_name, "class")
      core.if %is_class {
        %class_input = core.call intrinsic.not(%output)
        core.if %class_input {
          %error = core.call intrinsic.error.signature("Input field cannot use the \"class\" type")
          core.raise %error
        }
        %missing_quoted = core.call intrinsic.is_none(%quoted)
        core.if %missing_quoted {
          %error = core.call intrinsic.error.signature("Missing class options after \"class\" type")
          core.raise %error
        }
        %class_option_text = core.call intrinsic.string.replace(%quoted, "|", ",")
        %options = core.call intrinsic.string.split_trim_nonempty(%class_option_text, ",")
        %option_count = core.call intrinsic.len(%options)
        %empty_options = core.call intrinsic.eq(%option_count, 0)
        core.if %empty_options {
          %error = core.call intrinsic.error.signature("Missing class options after \"class\" type")
          core.raise %error
        }
        %type_attrs = core.map
        core.set %type_attrs["name"] = %type_name
        core.set %type_attrs["is_array"] = %is_array
        core.set %type_attrs["options"] = %options
        %field_type = core.call intrinsic.record.new("FieldType", %type_attrs)
        %none = core.call intrinsic.none()
        %field_attrs = core.map
        core.set %field_attrs["name"] = %name
        core.set %field_attrs["type"] = %field_type
        core.set %field_attrs["description"] = %none
        core.set %field_attrs["is_optional"] = %is_optional
        core.set %field_attrs["is_internal"] = %is_internal
        %field = core.call intrinsic.record.new("Field", %field_attrs)
        core.call @signature_validate_field_shape_impl(%field, %output, false)
        core.return %field
      }
      %type_attrs = core.map
      core.set %type_attrs["name"] = %type_name
      core.set %type_attrs["is_array"] = %is_array
      %field_type = core.call intrinsic.record.new("FieldType", %type_attrs)
      %field_attrs = core.map
      core.set %field_attrs["name"] = %name
      core.set %field_attrs["type"] = %field_type
      core.set %field_attrs["description"] = %quoted
      core.set %field_attrs["is_optional"] = %is_optional
      core.set %field_attrs["is_internal"] = %is_internal
      %field = core.call intrinsic.record.new("Field", %field_attrs)
      core.call @signature_validate_field_shape_impl(%field, %output, false)
      core.return %field
    }
  }

  op ax.signature.semantic @signature_validate_field_shape_impl {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "signature"
    attr private = true
    tag "signature-field-validation-core-helper"
    type signature = "(Field, bool, bool) -> void throws"
    body @entry(%field: Field, %output: bool, %nested: bool) {
      %name = core.get %field["name"]
      %valid_name = core.regex_match %name pattern "^[A-Za-z_][A-Za-z0-9_]*$"
      %invalid_name = core.call intrinsic.not(%valid_name)
      core.if %invalid_name {
        %starts_number = core.regex_match %name pattern "^[0-9]"
        core.if %starts_number {
          %message = core.call intrinsic.string.format("Field name \"{}\" cannot start with a number", %name)
          %error = core.call intrinsic.error.signature(%message)
          core.raise %error
        } else {
          %message = core.call intrinsic.string.format("Invalid field name: \"{}\"", %name)
          %error = core.call intrinsic.error.signature(%message)
          core.raise %error
        }
      }
      %typ = core.get %field["type"]
      %type_name = core.get %typ["name"]
      %valid_types = core.list
      core.append %valid_types, "audio"
      core.append %valid_types, "boolean"
      core.append %valid_types, "class"
      core.append %valid_types, "code"
      core.append %valid_types, "date"
      core.append %valid_types, "dateRange"
      core.append %valid_types, "datetime"
      core.append %valid_types, "datetimeRange"
      core.append %valid_types, "file"
      core.append %valid_types, "image"
      core.append %valid_types, "json"
      core.append %valid_types, "number"
      core.append %valid_types, "object"
      core.append %valid_types, "string"
      core.append %valid_types, "url"
      %known_type = core.call intrinsic.contains(%valid_types, %type_name)
      %unknown_type = core.call intrinsic.not(%known_type)
      core.if %unknown_type {
        %message = core.call intrinsic.string.format("Invalid type \"{}\"", %type_name)
        %error = core.call intrinsic.error.signature(%message)
        core.raise %error
      }
      %media_types = core.list
      core.append %media_types, "image"
      core.append %media_types, "audio"
      core.append %media_types, "file"
      %is_media = core.call intrinsic.contains(%media_types, %type_name)
      %nested_media = core.call intrinsic.and(%nested, %is_media)
      core.if %nested_media {
        %message = core.call intrinsic.string.format("Media type '{}' is not allowed in nested object fields", %type_name)
        %error = core.call intrinsic.error.signature(%message)
        core.raise %error
      }
      %is_class = core.call intrinsic.eq(%type_name, "class")
      %is_input = core.call intrinsic.not(%output)
      %input_class = core.call intrinsic.and(%is_class, %is_input)
      core.if %input_class {
        %error = core.call intrinsic.error.signature("Input field cannot use the \"class\" type")
        core.raise %error
      }
      %class_options = core.get %typ["options"]
      %has_class_options = core.call intrinsic.truthy(%class_options)
      %missing_class_options = core.call intrinsic.not(%has_class_options)
      %class_without_options = core.call intrinsic.and(%is_class, %missing_class_options)
      core.if %class_without_options {
        %error = core.call intrinsic.error.signature("Missing class options after \"class\" type")
        core.raise %error
      }
      %is_internal = core.get %field["is_internal"] default false
      %internal_input = core.call intrinsic.and(%is_internal, %is_input)
      core.if %internal_input {
        %error = core.call intrinsic.error.signature("Input field cannot use the internal marker")
        core.raise %error
      }
      %is_image = core.call intrinsic.eq(%type_name, "image")
      %output_image = core.call intrinsic.and(%output, %is_image)
      core.if %output_image {
        %error = core.call intrinsic.error.signature("Image type is not supported in output fields")
        core.raise %error
      }
      %is_file = core.call intrinsic.eq(%type_name, "file")
      %output_file = core.call intrinsic.and(%output, %is_file)
      core.if %output_file {
        %error = core.call intrinsic.error.signature("File type is not supported in output fields")
        core.raise %error
      }
      %is_audio = core.call intrinsic.eq(%type_name, "audio")
      %is_array = core.get %typ["is_array"] default false
      %output_audio = core.call intrinsic.and(%output, %is_audio)
      %output_audio_array = core.call intrinsic.and(%output_audio, %is_array)
      core.if %output_audio_array {
        %error = core.call intrinsic.error.signature("Arrays of audio are not supported in output fields")
        core.raise %error
      }
      %nested_map = core.get %typ["fields"]
      %has_nested = core.call intrinsic.truthy(%nested_map)
      core.if %has_nested {
        %nested_fields = core.call intrinsic.fields.from_map(%nested_map)
        core.for %nested_field in %nested_fields {
          core.call @signature_validate_field_shape_impl(%nested_field, %output, true)
        }
      }
      core.return
    }
  }

  op ax.signature.semantic @signature_validate_impl {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "signature"
    attr private = true
    tag "signature-validation-core-helper"
    type signature = "(AxSignature) -> void throws"
    body @entry(%signature: AxSignature) {
      %inputs = core.get %signature["input_fields"]
      %outputs = core.get %signature["output_fields"]
      %input_count = core.call intrinsic.len(%inputs)
      %no_inputs = core.call intrinsic.eq(%input_count, 0)
      core.if %no_inputs {
        %error = core.call intrinsic.error.signature("No input fields specified")
        core.raise %error
      }
      %output_count = core.call intrinsic.len(%outputs)
      %no_outputs = core.call intrinsic.eq(%output_count, 0)
      core.if %no_outputs {
        %error = core.call intrinsic.error.signature("No output fields specified")
        core.raise %error
      }
      %seen_inputs = core.list
      core.for %field in %inputs {
        core.call @signature_validate_field_shape_impl(%field, false, false)
        %field_name = core.get %field["name"]
        %duplicate = core.call intrinsic.contains(%seen_inputs, %field_name)
        core.if %duplicate {
          %message = core.call intrinsic.string.format("Duplicate input field name: \"{}\"", %field_name)
          %error = core.call intrinsic.error.signature(%message)
          core.raise %error
        }
        core.append %seen_inputs, %field_name
      }
      %seen_outputs = core.list
      core.for %field in %outputs {
        core.call @signature_validate_field_shape_impl(%field, true, false)
        %field_name = core.get %field["name"]
        %collision = core.call intrinsic.contains(%seen_inputs, %field_name)
        core.if %collision {
          %message = core.call intrinsic.string.format("Field name \"{}\" appears in both inputs and outputs", %field_name)
          %error = core.call intrinsic.error.signature(%message)
          core.raise %error
        }
        %duplicate = core.call intrinsic.contains(%seen_outputs, %field_name)
        core.if %duplicate {
          %message = core.call intrinsic.string.format("Duplicate output field name: \"{}\"", %field_name)
          %error = core.call intrinsic.error.signature(%message)
          core.raise %error
        }
        core.append %seen_outputs, %field_name
      }
      core.return
    }
  }
}
