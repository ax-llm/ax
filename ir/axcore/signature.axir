          attr callee = "intrinsic.not"
          attr result = %is_input
        }
        op core.call {
          attr args = [%is_class, %is_input]
          attr callee = "intrinsic.and"
          attr result = %input_class
        }
        op core.if {
          attr condition = %input_class
          region @then {
            block @then {
              op core.call {
                attr args = ["Input field cannot use the \"class\" type"]
                attr callee = "intrinsic.error.signature"
                attr result = %error
              }
              op core.raise {
                attr error = %error
              }
            }
          }
          region @else {
            block @else {
            }
          }
        }
        op core.get {
          attr key = "options"
          attr result = %class_options
          attr target = %typ
        }
        op core.call {
          attr args = [%class_options]
          attr callee = "intrinsic.truthy"
          attr result = %has_class_options
        }
        op core.call {
          attr args = [%has_class_options]
          attr callee = "intrinsic.not"
          attr result = %missing_class_options
        }
        op core.call {
          attr args = [%is_class, %missing_class_options]
          attr callee = "intrinsic.and"
          attr result = %class_without_options
        }
        op core.if {
          attr condition = %class_without_options
          region @then {
            block @then {
              op core.call {
                attr args = ["Missing class options after \"class\" type"]
                attr callee = "intrinsic.error.signature"
                attr result = %error
              }
              op core.raise {
                attr error = %error
              }
            }
          }
          region @else {
            block @else {
            }
          }
        }
        op core.get {
          attr default = false
          attr key = "is_internal"
          attr result = %is_internal
          attr target = %field
        }
        op core.call {
          attr args = [%is_internal, %is_input]
          attr callee = "intrinsic.and"
          attr result = %internal_input
        }
        op core.if {
          attr condition = %internal_input
          region @then {
            block @then {
              op core.call {
                attr args = ["Input field cannot use the internal marker"]
                attr callee = "intrinsic.error.signature"
                attr result = %error
              }
              op core.raise {
                attr error = %error
              }
            }
          }
          region @else {
            block @else {
            }
          }
        }
        op core.call {
          attr args = [%type_name, "image"]
          attr callee = "intrinsic.eq"
          attr result = %is_image
        }
        op core.call {
          attr args = [%output, %is_image]
          attr callee = "intrinsic.and"
          attr result = %output_image
        }
        op core.if {
          attr condition = %output_image
          region @then {
            block @then {
              op core.call {
                attr args = ["Image type is not supported in output fields"]
                attr callee = "intrinsic.error.signature"
                attr result = %error
              }
              op core.raise {
                attr error = %error
              }
            }
          }
          region @else {
            block @else {
            }
          }
        }
        op core.call {
          attr args = [%type_name, "file"]
          attr callee = "intrinsic.eq"
          attr result = %is_file
        }
        op core.call {
          attr args = [%output, %is_file]
          attr callee = "intrinsic.and"
          attr result = %output_file
        }
        op core.if {
          attr condition = %output_file
          region @then {
            block @then {
              op core.call {
                attr args = ["File type is not supported in output fields"]
                attr callee = "intrinsic.error.signature"
                attr result = %error
              }
              op core.raise {
                attr error = %error
              }
            }
          }
          region @else {
            block @else {
            }
          }
        }
        op core.call {
          attr args = [%type_name, "audio"]
          attr callee = "intrinsic.eq"
          attr result = %is_audio
        }
        op core.get {
          attr default = false
          attr key = "is_array"
          attr result = %is_array
          attr target = %typ
        }
        op core.call {
          attr args = [%output, %is_audio]
          attr callee = "intrinsic.and"
          attr result = %output_audio
        }
        op core.call {
          attr args = [%output_audio, %is_array]
          attr callee = "intrinsic.and"
          attr result = %output_audio_array
        }
        op core.if {
          attr condition = %output_audio_array
          region @then {
            block @then {
              op core.call {
                attr args = ["Arrays of audio are not supported in output fields"]
                attr callee = "intrinsic.error.signature"
                attr result = %error
              }
              op core.raise {
                attr error = %error
              }
            }
          }
          region @else {
            block @else {
            }
          }
        }
        op core.get {
          attr key = "fields"
          attr result = %nested_map
          attr target = %typ
