        op core.call {
          attr args = [%nested_map]
          attr callee = "intrinsic.truthy"
          attr result = %has_nested
        }
        op core.if {
          attr condition = %has_nested
          region @then {
            block @then {
              op core.call {
                attr args = [%nested_map]
                attr callee = "intrinsic.fields.from_map"
                attr result = %nested_fields
              }
              op core.for {
                attr in = %nested_fields
                attr item = %nested_field
                region @body {
                  block @each {
                    op core.call {
                      attr args = [%nested_field, %output, true]
                      attr callee = @signature_validate_field_shape_impl
                    }
                  }
                }
              }
            }
          }
          region @else {
            block @else {
            }
          }
        }
        op core.return {
        }
      }
    }
  }

  op ax.signature.semantic @signature_validate_impl {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "signature"
    attr private = true
    tag "signature-validation-core-helper"
    type signature = "(AxSignature) -> void throws"
    region @body {
      block @entry(%signature: AxSignature) {
        op core.get {
          attr key = "input_fields"
          attr result = %inputs
          attr target = %signature
        }
        op core.get {
          attr key = "output_fields"
          attr result = %outputs
          attr target = %signature
        }
        op core.call {
          attr args = [%inputs]
          attr callee = "intrinsic.len"
          attr result = %input_count
        }
        op core.call {
          attr args = [%input_count, 0]
          attr callee = "intrinsic.eq"
          attr result = %no_inputs
        }
        op core.if {
          attr condition = %no_inputs
          region @then {
            block @then {
              op core.call {
                attr args = ["No input fields specified"]
                attr callee = "intrinsic.error.signature"
                attr result = %error
              }
              op core.raise {
                attr error = %error
              }
            }
          }
          region @else {
            block @else {
            }
          }
        }
        op core.call {
          attr args = [%outputs]
          attr callee = "intrinsic.len"
          attr result = %output_count
        }
        op core.call {
          attr args = [%output_count, 0]
          attr callee = "intrinsic.eq"
          attr result = %no_outputs
        }
        op core.if {
          attr condition = %no_outputs
          region @then {
            block @then {
              op core.call {
                attr args = ["No output fields specified"]
                attr callee = "intrinsic.error.signature"
                attr result = %error
              }
              op core.raise {
                attr error = %error
              }
            }
          }
          region @else {
            block @else {
            }
          }
        }
        op core.list {
          attr result = %seen_inputs
        }
        op core.for {
          attr in = %inputs
          attr item = %field
          region @body {
            block @each {
              op core.call {
                attr args = [%field, false, false]
                attr callee = @signature_validate_field_shape_impl
              }
              op core.get {
                attr key = "name"
                attr result = %field_name
                attr target = %field
              }
              op core.call {
                attr args = [%seen_inputs, %field_name]
                attr callee = "intrinsic.contains"
                attr result = %duplicate
              }
              op core.if {
                attr condition = %duplicate
                region @then {
                  block @then {
                    op core.call {
                      attr args = ["Duplicate input field name: \"{}\"", %field_name]
                      attr callee = "intrinsic.string.format"
                      attr result = %message
                    }
                    op core.call {
                      attr args = [%message]
                      attr callee = "intrinsic.error.signature"
                      attr result = %error
                    }
                    op core.raise {
                      attr error = %error
                    }
                  }
                }
                region @else {
                  block @else {
                  }
                }
              }
              op core.append {
                attr target = %seen_inputs
                attr value = %field_name
              }
            }
          }
        }
        op core.list {
          attr result = %seen_outputs
        }
        op core.for {
          attr in = %outputs
          attr item = %field
          region @body {
            block @each {
              op core.call {
                attr args = [%field, true, false]
                attr callee = @signature_validate_field_shape_impl
              }
              op core.get {
                attr key = "name"
                attr result = %field_name
                attr target = %field
              }
              op core.call {
                attr args = [%seen_inputs, %field_name]
                attr callee = "intrinsic.contains"
                attr result = %collision
              }
              op core.if {
                attr condition = %collision
                region @then {
                  block @then {
                    op core.call {
                      attr args = ["Field name \"{}\" appears in both inputs and outputs", %field_name]
                      attr callee = "intrinsic.string.format"
                      attr result = %message
                    }
                    op core.call {
                      attr args = [%message]
                      attr callee = "intrinsic.error.signature"
                      attr result = %error
                    }
                    op core.raise {
                      attr error = %error
                    }
                  }
                }
                region @else {
                  block @else {
                  }
                }
              }
              op core.call {
                attr args = [%seen_outputs, %field_name]
                attr callee = "intrinsic.contains"
                attr result = %duplicate
              }
              op core.if {
                attr condition = %duplicate
                region @then {
                  block @then {
                    op core.call {
                      attr args = ["Duplicate output field name: \"{}\"", %field_name]
                      attr callee = "intrinsic.string.format"
                      attr result = %message
                    }
                    op core.call {
                      attr args = [%message]
                      attr callee = "intrinsic.error.signature"
                      attr result = %error
                    }
                    op core.raise {
                      attr error = %error
                    }
                  }
                }
                region @else {
                  block @else {
                  }
                }
              }
              op core.append {
                attr target = %seen_outputs
                attr value = %field_name
              }
            }
          }
        }
        op core.return {
        }
      }
    }
  }
}
