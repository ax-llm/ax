module @ax.program version "0.1" {
  dialect @ax.program version "0.1"

  op ax.program.interface @AxProgram {
    attr core_kind = "interface"
    attr public = "true"
    attr contract = "program"
    tag "ax-program"
  }

  op ax.program.semantic @program_descriptor {
    attr core_kind = "func"
    attr emit_module = "program"
    attr private = true
    type signature = "(kind:string, id:string, metadata:json) -> json"
    body @entry(%kind: string, %id: string, %metadata: json) {
      %empty_map = core.map
      %meta_missing = core.call intrinsic.is_none(%metadata)
      %meta = core.let %metadata
      core.if %meta_missing {
        %meta = core.let %empty_map
      } else {
      }
      %out = core.map
      core.set %out["kind"] = %kind
      core.set %out["id"] = %id
      core.set %out["metadata"] = %meta
      core.return %out
    }
  }

  op ax.program.semantic @program_trace_event {
    attr core_kind = "func"
    attr emit_module = "program"
    attr private = true
    type signature = "(program_id:string, kind:string, payload:json) -> json"
    body @entry(%program_id: string, %kind: string, %payload: json) {
      %empty_map = core.map
      %payload_missing = core.call intrinsic.is_none(%payload)
      %data = core.let %payload
      core.if %payload_missing {
        %data = core.let %empty_map
      } else {
      }
      %event = core.map
      core.set %event["programId"] = %program_id
      core.set %event["kind"] = %kind
      core.set %event["payload"] = %data
      core.return %event
    }
  }

  op ax.program.semantic @program_child_component_prefix {
    attr core_kind = "func"
    attr emit_module = "program"
    attr private = true
    type signature = "(owner:string, node:string) -> string"
    body @entry(%owner: string, %node: string) {
      %path = core.call intrinsic.string.format("{}.{}::", %owner, %node)
      core.return %path
    }
  }

  op ax.program.semantic @program_prefix_component {
    attr core_kind = "func"
    attr emit_module = "program"
    attr private = true
    type signature = "(component:json, owner:string, node:string) -> json"
    body @entry(%component: json, %owner: string, %node: string) {
      %empty_map = core.map
      %child = core.call intrinsic.map.merge(%empty_map, %component)
      %child_owner = core.call intrinsic.string.format("{}.{}", %owner, %node)
      %child_id = core.get %component["id"] default ""
      %prefixed_id = core.call intrinsic.string.format("{}::{}", %child_owner, %child_id)
      core.set %child["owner"] = %child_owner
      core.set %child["id"] = %prefixed_id
      core.return %child
    }
  }

  op ax.program.semantic @program_slice_component_map {
    attr core_kind = "func"
    attr emit_module = "program"
    attr private = true
    type signature = "(component_map:json, prefix:string) -> json"
    body @entry(%component_map: json, %prefix: string) {
      %out = core.map
      %keys = core.call intrinsic.map.keys(%component_map)
      core.for %key in %keys {
        %matches = core.call intrinsic.string.starts_with(%key, %prefix)
      core.if %matches {
          %prefix_len = core.call intrinsic.len(%prefix)
          %short_key = core.call intrinsic.string.slice(%key, %prefix_len)
          %value = core.get %component_map[%key]
          core.set %out[%short_key] = %value
        } else {
        }
      }
      core.return %out
    }
  }
}
