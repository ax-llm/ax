      %code_field_title = core.get %contract["code_field_title"] default "Javascript Code"
      %code_fence_language = core.get %contract["code_fence_language"] default "js"
      %is_javascript = core.get %contract["is_javascript"] default true
      %usage_instructions = core.get %contract["usage_instructions"] default ""
      %discovery_mode = core.get %flags["discoveryMode"] default false
      %skills_mode = core.get %flags["skillsMode"] default false
      %has_skills = core.get %flags["hasSkills"] default %skills_mode
      %memories_mode = core.get %flags["memoriesMode"] default false
      %status_callback = core.get %flags["hasAgentStatusCallback"] default false
      %relevance_hints_mode = core.get %flags["relevanceHintsEnabled"] default false
      %memory_usage_camel = core.get %options["memoryUsageMode"] default false
      %memory_usage_mode = core.get %options["memory_usage_mode"] default %memory_usage_camel
      %skill_usage_camel = core.get %options["skillUsageMode"] default false
      %skill_usage_mode = core.get %options["skill_usage_mode"] default %skill_usage_camel
      %callable_split = core.get %state["callable_split"] default %empty_map
      %functions_list = core.call @render_agent_inline_functions_list(%callable_split)
      %modules_list = core.call @render_agent_modules_list(%callable_split)
      %has_modules = core.call intrinsic.ne(%modules_list, "")
      %skills_catalog = core.get %state["skills_catalog"] default null
      %skills_catalog_is_list = core.type_is %skills_catalog type "list"
      core.if %skills_catalog_is_list {
      } else {
        %skills_catalog = core.list
      }
      %skills_catalog_list = core.call @render_agent_skills_catalog_list(%skills_catalog)
      %has_skills_catalog = core.call intrinsic.ne(%skills_catalog_list, "")
      %vars = core.map
      core.set %vars["runtimeLanguageName"] = %language
      core.set %vars["runtimeCodeFieldTitle"] = %code_field_title
      core.set %vars["runtimeCodeFenceLanguage"] = %code_fence_language
      core.set %vars["isJavaScriptRuntime"] = %is_javascript
      core.set %vars["runtimeUsageInstructions"] = %usage_instructions
      core.set %vars["primitivesList"] = %primitives_list
      core.set %vars["functionsList"] = %functions_list
      core.set %vars["modulesList"] = %modules_list
      core.set %vars["discoveryMode"] = %discovery_mode
      core.set %vars["hasModules"] = %has_modules
      core.set %vars["hasDiscoveredDocs"] = %discovery_mode
      core.set %vars["hasRelevanceHints"] = %relevance_hints_mode
      core.set %vars["hasSkills"] = %has_skills
      core.set %vars["hasSkillsCatalog"] = %has_skills_catalog
      core.set %vars["skillsCatalogList"] = %skills_catalog_list
      core.set %vars["skillUsageMode"] = %skill_usage_mode
      core.set %vars["memoriesMode"] = %memories_mode
      core.set %vars["memoryUsageMode"] = %memory_usage_mode
      core.set %vars["hasAgentStatusCallback"] = %status_callback
      %data = core.call intrinsic.json.parse(file "data/rlm-prompts.json")
      %template = core.get %data["executor_template"] default ""
      %out = core.call @rlm_render_template(%template, %vars, "rlm/executor.md")
      core.return %out
    }
  }

  op ax.agent.runtime @render_rlm_responder_description {
