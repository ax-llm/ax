      %has_expected_kinds = core.type_is %expected_kinds type "list"
      core.if %has_expected_kinds {
        %actual_text = core.call intrinsic.json.stringify(%event_kinds)
        %expected_text = core.call intrinsic.json.stringify(%expected_kinds)
        %matches = core.call intrinsic.eq(%actual_text, %expected_text)
        %mismatch = core.call intrinsic.not(%matches)
        core.if %mismatch {
          %message = core.call intrinsic.string.format("agent replay event sequence mismatch: expected {} got {}", %expected_text, %actual_text)
          %error = core.call intrinsic.error.runtime(%message)
          core.raise %error
        } else {
        }
      } else {
      }
      %output = core.get %trace["final_output"] default null
      %expected_output = core.get %fixtures["expected_output"] default null
      %has_expected_output = core.call intrinsic.is_not_none(%expected_output)
      core.if %has_expected_output {
        %actual_output_text = core.call intrinsic.json.stringify(%output)
        %expected_output_text = core.call intrinsic.json.stringify(%expected_output)
        %output_matches = core.call intrinsic.eq(%actual_output_text, %expected_output_text)
        %output_mismatch = core.call intrinsic.not(%output_matches)
        core.if %output_mismatch {
          %message = core.call intrinsic.string.format("agent replay output mismatch: expected {} got {}", %expected_output_text, %actual_output_text)
          %error = core.call intrinsic.error.runtime(%message)
          core.raise %error
        } else {
        }
      } else {
      }
      %event_count = core.call intrinsic.len(%events)
      %status = core.get %trace["status"] default "unknown"
      %action_log = core.get %trace["action_log"] default %empty_list
      %chat_log = core.get %trace["chat_log"] default %empty_list
      %out = core.map
      core.set %out["ok"] = true
      core.set %out["status"] = "replayed"
      core.set %out["original_status"] = %status
      core.set %out["output"] = %output
      core.set %out["event_kinds"] = %event_kinds
      core.set %out["event_count"] = %event_count
      core.set %out["action_log"] = %action_log
      core.set %out["chat_log"] = %chat_log
      core.set %out["trace"] = %trace
      core.return %out
    }
  }

