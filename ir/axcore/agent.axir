  op ax.agent.runtime @agent_runtime_build_globals {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> json throws"
    body @entry(%state: json, %values: json) {
      %empty_list = core.list
      %empty_map = core.map
      %reserved = core.call @agent_reserved_runtime_names()
      %globals = core.map
      %primitives = core.list
      %callable_inventory = core.get %state["callable_inventory"] default %empty_list
      %discovery_catalog = core.get %state["discovery_catalog"] default %empty_list
      %registry = core.get %state["policy_registry"] default %empty_map
      %runtime_input_names = core.get %state["runtime_input_names"] default %empty_list
      core.for %input_name in %values {
        %input_name_known = core.call intrinsic.contains(%runtime_input_names, %input_name)
        core.if %input_name_known {
        } else {
          core.append %runtime_input_names, %input_name
        }
      }
      core.set %state["runtime_input_names"] = %runtime_input_names
      %selected_primitives = core.call @select_actor_primitives(%registry, "executor")
      core.set %globals["inputs"] = %values
      core.set %globals["context"] = %values
      core.set %globals["callables"] = %callable_inventory
      core.set %globals["discovery_catalog"] = %discovery_catalog
      core.for %primitive_meta in %selected_primitives {
        %name = core.get %primitive_meta["id"]
        %primitive = core.map
        core.set %primitive["name"] = %name
        core.set %primitive["kind"] = "runtime_primitive"
        core.set %primitive["metadata"] = %primitive_meta
        core.append %primitives, %primitive
      }
      core.set %globals["runtime_primitives"] = %primitives
      core.for %key in %values {
        %conflict = core.call intrinsic.contains(%reserved, %key)
        core.if %conflict {
          %message = core.call intrinsic.string.format("agent runtime global conflicts with reserved name: {}", %key)
          %error = core.call intrinsic.error.runtime(%message)
          core.raise %error
        } else {
          %value = core.get %values[%key]
          core.set %globals[%key] = %value
        }
      }
      %runtime_contract = core.get %state["runtime_contract"] default %empty_map
      core.set %globals["runtime"] = %runtime_contract
      core.set %state["runtime_globals"] = %globals
      core.return %globals
    }
  }

  op ax.agent.runtime @agent_runtime_sanitize_bindings {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> json"
    body @entry(%state: json, %bindings: json) {
      %reserved = core.call @agent_runtime_reserved_names_for_state(%state)
      %out = core.map
      %bindings_is_map = core.type_is %bindings type "object"
      core.if %bindings_is_map {
        core.for %key in %bindings {
          %conflict = core.call intrinsic.contains(%reserved, %key)
          core.if %conflict {
          } else {
            %value = core.get %bindings[%key]
            core.set %out[%key] = %value
          }
        }
      }
      core.return %out
    }
  }

  op ax.agent.runtime @normalize_agent_runtime_snapshot {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> json throws"
    body @entry(%state: json, %snapshot: json) {
      %empty_list = core.list
      %snapshot_is_map = core.type_is %snapshot type "object"
      core.if %snapshot_is_map {
      } else {
        %error = core.call intrinsic.error.runtime("runtime session snapshot must be an object")
        core.raise %error
      }
      %raw_globals = core.get %snapshot["globals"] default null
      %raw_bindings = core.get %snapshot["bindings"] default null
      %has_globals = core.type_is %raw_globals type "object"
      %has_bindings = core.type_is %raw_bindings type "object"
      %has_any = core.call intrinsic.or(%has_globals, %has_bindings)
      core.if %has_any {
      } else {
        %error2 = core.call intrinsic.error.runtime("runtime session snapshot globals must be an object")
        core.raise %error2
      }
      %bindings = core.let %raw_globals
      core.if %has_bindings {
        %bindings = core.let %raw_bindings
      }
      %reserved = core.call @agent_runtime_reserved_names_for_state(%state)
      %clean_bindings = core.call @agent_runtime_sanitize_bindings(%state, %bindings)
      %entries = core.get %snapshot["entries"] default %empty_list
      %entries_is_list = core.type_is %entries type "list"
      core.if %entries_is_list {
      } else {
        %entries = core.let %empty_list
      }
      %clean_entries = core.list
      core.for %entry in %entries {
        %entry_name = core.get %entry["name"] default ""
        %entry_reserved = core.call intrinsic.contains(%reserved, %entry_name)
        core.if %entry_reserved {
        } else {
          core.append %clean_entries, %entry
        }
      }
      %closed = core.get %snapshot["closed"] default false
      %version = core.get %snapshot["version"] default 1
      %out = core.map
      core.set %out["version"] = %version
      core.set %out["entries"] = %clean_entries
      core.set %out["bindings"] = %clean_bindings
      core.set %out["globals"] = %clean_bindings
      core.set %out["closed"] = %closed
      core.return %out
    }
  }

  op ax.agent.runtime @agent_runtime_append_action_log {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> json"
    body @entry(%state: json, %entry: json) {
      %empty_list = core.list
      %log = core.get %state["action_log"] default %empty_list
      %entry_is_map = core.type_is %entry type "object"
      core.if %entry_is_map {
        %has_turn = core.call intrinsic.map.contains(%entry, "turn")
        core.if %has_turn {
        } else {
          %count = core.call intrinsic.len(%log)
          %turn = core.call intrinsic.add(%count, 1)
          core.set %entry["turn"] = %turn
        }
        %has_tags = core.call intrinsic.map.contains(%entry, "tags")
        core.if %has_tags {
        } else {
          %tags = core.list
          %is_error = core.get %entry["is_error"] default false
          core.if %is_error {
            core.append %tags, "error"
          }
          core.set %entry["tags"] = %tags
        }
      }
      core.append %log, %entry
      core.set %state["action_log"] = %log
      core.return %entry
    }
  }

  op ax.agent.runtime @normalize_agent_runtime_step_result {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, string) -> json throws"
    body @entry(%raw: json, %code: string) {
      %empty_map = core.map
      %none = core.call intrinsic.none()
      %out = core.map
      %raw_is_map = core.type_is %raw type "object"
      %kind = core.let "result"
      %is_error = core.let false
      %result = core.let %raw
      %output = core.let ""
      %error_message = core.let ""
      %error_category = core.let ""
      %completion_payload = core.let %none
      %discover_request = core.let %none
      %recall_request = core.let %none
      %used_request = core.let %none
      %callable_request = core.let %none
      %guidance_payload = core.let %none
      %status = core.let %none
      core.if %raw_is_map {
        %raw_type = core.get %raw["type"] default ""
        %kind = core.get %raw["kind"] default %raw_type
        %missing_kind = core.call intrinsic.eq(%kind, "")
        core.if %missing_kind {
          %kind = core.let "result"
        }
        %is_error = core.get %raw["is_error"] default false
        %result = core.get %raw["result"] default %raw
        %output = core.get %raw["output"] default ""
        %output_is_empty = core.call intrinsic.eq(%output, "")
        core.if %output_is_empty {
          %raw_logs = core.get %raw["logs"] default null
          %raw_logs_is_list = core.type_is %raw_logs type "list"
          core.if %raw_logs_is_list {
            %joined_logs = core.call intrinsic.string.join("\n", %raw_logs)
            %output = core.let %joined_logs
          }
        }
        %error_message = core.get %raw["error"] default ""
        %error_category = core.get %raw["error_category"] default ""
        %completion_payload = core.get %raw["completion_payload"] default null
        %discover_request = core.get %raw["discover"] default null
        %recall_request = core.get %raw["recall"] default null
        %used_request = core.get %raw["used"] default null
        %callable_request = core.get %raw["callable"] default null
        %guidance_payload = core.get %raw["guidance"] default null
        %status = core.get %raw["status"] default null
      }
      %completion_is_map = core.type_is %completion_payload type "object"
      core.if %completion_is_map {
      } else {
        %is_final_kind = core.call intrinsic.eq(%kind, "final")
        %is_respond_kind = core.call intrinsic.eq(%kind, "respond")
        %is_clarification_kind = core.call intrinsic.eq(%kind, "askClarification")
        %is_completion_kind = core.call intrinsic.or(%is_final_kind, %is_respond_kind)
        %is_protocol_kind = core.call intrinsic.or(%is_completion_kind, %is_clarification_kind)
        core.if %is_protocol_kind {
          %completion_payload = core.let %raw
        }
      }
      %completion_is_map2 = core.type_is %completion_payload type "object"
      core.if %completion_is_map2 {
        %completion_type = core.get %completion_payload["type"] default %kind
        %is_final = core.call intrinsic.eq(%completion_type, "final")
        core.if %is_final {
          %completion_payload = core.call @normalize_agent_final_payload(%completion_payload)
          %kind = core.let "final"
        } else {
          %is_respond = core.call intrinsic.eq(%completion_type, "respond")
          core.if %is_respond {
            %completion_payload = core.call @normalize_agent_respond_payload(%completion_payload)
            %kind = core.let "respond"
          } else {
            %is_clarification = core.call intrinsic.eq(%completion_type, "askClarification")
            core.if %is_clarification {
              %completion_payload = core.call @normalize_agent_clarification_payload(%completion_payload)
              %kind = core.let "askClarification"
            }
          }
        }
      }
      %is_guide_kind = core.call intrinsic.eq(%kind, "guide_agent")
      core.if %is_guide_kind {
        %guidance_payload = core.call @normalize_agent_guidance_payload(%raw, "")
      }
      core.set %out["type"] = "runtime_step"
      core.set %out["kind"] = %kind
      core.set %out["code"] = %code
      core.set %out["result"] = %result
      core.set %out["output"] = %output
      core.set %out["is_error"] = %is_error
      core.set %out["error"] = %error_message
      core.set %out["error_category"] = %error_category
      core.set %out["completion_payload"] = %completion_payload
      core.set %out["discover_request"] = %discover_request
      core.set %out["recall_request"] = %recall_request
      core.set %out["used_request"] = %used_request
      core.set %out["callable_request"] = %callable_request
      core.set %out["guidance_payload"] = %guidance_payload
      core.set %out["status"] = %status
      %is_closed = core.call intrinsic.eq(%error_category, "session_closed")
      core.if %is_closed {
        core.set %out["restart_notice"] = "runtime session closed; restarting fresh session"
      }
      %is_abort = core.call intrinsic.eq(%error_category, "abort")
      %is_aborted = core.call intrinsic.eq(%error_category, "aborted")
      %is_user_error = core.call intrinsic.eq(%error_category, "user_error")
      %abort_like = core.call intrinsic.or(%is_abort, %is_aborted)
      %should_escape = core.call intrinsic.or(%abort_like, %is_user_error)
      core.if %should_escape {
        %escape_message = core.call intrinsic.string.format("runtime host boundary escaped {}: {}", %error_category, %error_message)
        %escape_error = core.call intrinsic.error.runtime(%escape_message)
        core.raise %escape_error
      }
      core.return %out
    }
  }

  op ax.agent.runtime @agent_runtime_execution_options {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> json"
    body @entry(%state: json, %options: json) {
      %empty_map = core.map
      %reserved_names = core.call @agent_runtime_reserved_names_for_state(%state)
      %runtime_options = core.call intrinsic.map.merge(%empty_map, %options)
      core.call intrinsic.map.delete(%runtime_options, "runtime")
      core.set %runtime_options["reservedNames"] = %reserved_names
      %timeout_ms = core.get %options["timeout_ms"] default null
      %timeout = core.get %options["timeout"] default %timeout_ms
      %has_timeout = core.call intrinsic.is_not_none(%timeout)
      core.if %has_timeout {
        core.set %runtime_options["timeout"] = %timeout
      }
      %abort_snake = core.get %options["abort"] default false
      %aborted = core.get %options["aborted"] default %abort_snake
      %abort_signal = core.get %options["abortSignal"] default %aborted
      %has_abort = core.call intrinsic.truthy(%abort_signal)
      core.if %has_abort {
        core.set %runtime_options["abort"] = true
      }
      %session_id_snake = core.get %options["session_id"] default null
      %session_id = core.get %options["sessionId"] default %session_id_snake
      %has_session_id = core.call intrinsic.is_not_none(%session_id)
      core.if %has_session_id {
        core.set %runtime_options["sessionId"] = %session_id
      }
      %trace_id_snake = core.get %options["trace_id"] default null
      %trace_id = core.get %options["traceId"] default %trace_id_snake
      %has_trace_id = core.call intrinsic.is_not_none(%trace_id)
      core.if %has_trace_id {
        core.set %runtime_options["traceId"] = %trace_id
      }
      core.return %runtime_options
    }
  }

  op ax.agent.runtime @agent_runtime_lifecycle_event {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, string, json) -> json"
    body @entry(%state: json, %action: string, %details: json) {
      %empty_map = core.map
      %entry = core.call intrinsic.map.merge(%empty_map, %details)
      core.set %entry["type"] = "runtime_session"
      core.set %entry["action"] = %action
      core.call @agent_runtime_append_action_log(%state, %entry)
      core.call @agent_record_trace_event(%state, "runtime_lifecycle", %entry)
      core.return %entry
    }
  }

  op ax.agent.runtime @agent_runtime_create_session {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json, json, json) -> json"
    body @entry(%state: json, %runtime: json, %globals: json, %options: json) {
      %runtime_options = core.call @agent_runtime_execution_options(%state, %options)
      %session = core.call intrinsic.agent.runtime.create_session(%runtime, %globals, %runtime_options)
      core.set %state["runtime_session"] = %session
      core.set %state["runtime_globals"] = %globals
      %entry = core.map
      core.set %entry["globals"] = %globals
      core.set %entry["options"] = %runtime_options
      core.call @agent_runtime_lifecycle_event(%state, "create_session", %entry)
      core.return %session
    }
  }

  op ax.agent.runtime @agent_runtime_execute_step {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json, json, string, json) -> json throws"
    body @entry(%state: json, %runtime: json, %session: json, %code: string, %options: json) {
      %runtime_options = core.call @agent_runtime_execution_options(%state, %options)
      %empty_map = core.map
      %globals = core.get %state["runtime_globals"] default %empty_map
      %missing_session = core.call intrinsic.is_none(%session)
      core.if %missing_session {
        %session = core.call @agent_runtime_create_session(%state, %runtime, %globals, %runtime_options)
      }
      %raw = core.call intrinsic.agent.runtime.execute(%session, %code, %runtime_options)
      %normalized = core.call @normalize_agent_runtime_step_result(%raw, %code)
      %closed = core.get %normalized["error_category"] default ""
      %is_closed = core.call intrinsic.eq(%closed, "session_closed")
      core.if %is_closed {
        %notice = core.map
        core.set %notice["reason"] = "session_closed"
        core.call @agent_runtime_lifecycle_event(%state, "restart", %notice)
        %session = core.call @agent_runtime_create_session(%state, %runtime, %globals, %runtime_options)
        %raw = core.call intrinsic.agent.runtime.execute(%session, %code, %runtime_options)
        %normalized = core.call @normalize_agent_runtime_step_result(%raw, %code)
      }
      core.call @agent_runtime_append_action_log(%state, %normalized)
      core.call @agent_record_trace_event(%state, "runtime_execute", %normalized)
      %step_error = core.get %normalized["is_error"] default false
      core.if %step_error {
        core.call @agent_record_trace_event(%state, "error", %normalized)
      }
      %discover_request = core.get %normalized["discover_request"] default null
      %has_discover = core.type_is %discover_request type "object"
      core.if %has_discover {
        core.call @agent_discover(%state, %discover_request)
      }
      %recall_request = core.get %normalized["recall_request"] default null
      %has_recall = core.call intrinsic.is_not_none(%recall_request)
      core.if %has_recall {
        core.call @agent_recall(%state, %recall_request)
        %memory_globals = core.get %state["runtime_globals"] default %empty_map
        %memory_inputs = core.get %memory_globals["inputs"] default %empty_map
        %memory_context = core.get %memory_globals["context"] default %empty_map
        %current_memories = core.get %state["loaded_memories"] default null
        core.set %memory_inputs["memories"] = %current_memories
        core.set %memory_context["memories"] = %current_memories
        core.set %memory_globals["inputs"] = %memory_inputs
        core.set %memory_globals["context"] = %memory_context
        core.set %memory_globals["memories"] = %current_memories
        core.set %state["runtime_globals"] = %memory_globals
        %memory_patch = core.map
        core.set %memory_patch["globals"] = %memory_globals
        core.call @agent_runtime_restore_session_state(%state, %session, %memory_patch, %runtime_options)
      }
      %used_request = core.get %normalized["used_request"] default null
      %has_used = core.call intrinsic.is_not_none(%used_request)
      core.if %has_used {
        %active_stage = core.get %state["active_stage"] default "executor"
        core.call @agent_used(%state, %used_request, %active_stage)
      }
      %callable_request = core.get %normalized["callable_request"] default null
      %has_callable = core.call intrinsic.is_not_none(%callable_request)
      core.if %has_callable {
        %callable_result = core.call @agent_execute_callable(%state, %callable_request, %options)
        core.set %normalized["callable_result"] = %callable_result
      }
      %guidance_payload = core.get %normalized["guidance_payload"] default null
      %has_guidance = core.type_is %guidance_payload type "object"
      core.if %has_guidance {
        core.call @agent_append_guidance(%state, %guidance_payload)
      }
      %completion_payload = core.get %normalized["completion_payload"] default null
      %has_completion = core.type_is %completion_payload type "object"
      core.if %has_completion {
        core.set %state["last_runtime_completion"] = %completion_payload
        %completion_type = core.get %completion_payload["type"] default ""
        %is_final_completion = core.call intrinsic.eq(%completion_type, "final")
        core.if %is_final_completion {
          core.call @agent_record_trace_event(%state, "final", %completion_payload)
        } else {
          %is_clarification_completion = core.call intrinsic.eq(%completion_type, "askClarification")
          core.if %is_clarification_completion {
            core.call @agent_record_trace_event(%state, "clarification", %completion_payload)
          }
        }
      }
      %status = core.get %normalized["status"] default null
      %has_status = core.type_is %status type "object"
      core.if %has_status {
        %empty_list = core.list
        %status_log = core.get %state["status_log"] default %empty_list
        core.append %status_log, %status
        core.set %state["status_log"] = %status_log
        core.call @agent_record_trace_event(%state, "status", %status)
      }
      core.return %normalized
    }
  }

  op ax.agent.runtime @agent_runtime_inspect_state {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json, json) -> json"
    body @entry(%state: json, %session: json, %options: json) {
      %inspection = core.call intrinsic.agent.runtime.inspect(%session, %options)
      core.set %state["runtime_inspection"] = %inspection
      %entry = core.map
      core.set %entry["type"] = "runtime_session"
      core.set %entry["action"] = "inspect_globals"
      core.set %entry["result"] = %inspection
      core.call @agent_runtime_append_action_log(%state, %entry)
      core.return %inspection
    }
  }

  op ax.agent.runtime @agent_runtime_export_session_state {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json, json) -> json throws"
    body @entry(%state: json, %session: json, %options: json) {
      %raw_snapshot = core.call intrinsic.agent.runtime.export_state(%session, %options)
      %snapshot = core.call @normalize_agent_runtime_snapshot(%state, %raw_snapshot)
      core.set %state["runtime_session_state"] = %snapshot
      %log_entry = core.map
      core.set %log_entry["type"] = "runtime_session"
      core.set %log_entry["action"] = "snapshot_globals"
      core.set %log_entry["snapshot"] = %snapshot
      core.call @agent_runtime_append_action_log(%state, %log_entry)
      %event = core.map
      core.set %event["snapshot"] = %snapshot
      core.call @agent_record_trace_event(%state, "state_export", %event)
      core.return %snapshot
    }
  }

  op ax.agent.runtime @agent_runtime_refresh_state_summary {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json, json) -> json throws"
    body @entry(%state: json, %session: json, %options: json) {
      %empty_map = core.map
      %none = core.call intrinsic.none()
      %policy = core.get %state["context_policy"] default null
      %state_summary = core.get %policy["stateSummary"] default %empty_map
      %enabled = core.get %state_summary["enabled"] default false
      core.if %enabled {
        %runtime_options = core.call @agent_runtime_execution_options(%state, %options)
        %raw_snapshot = core.call intrinsic.agent.runtime.export_state(%session, %runtime_options)
        %snapshot = core.call @normalize_agent_runtime_snapshot(%state, %raw_snapshot)
        core.set %state["runtime_session_state"] = %snapshot
        core.return %snapshot
      }
      core.return %none
    }
  }

  op ax.agent.runtime @agent_runtime_restore_session_state {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json, json, json) -> json throws"
    body @entry(%state: json, %session: json, %snapshot: json, %options: json) {
      %normalized_snapshot = core.call @normalize_agent_runtime_snapshot(%state, %snapshot)
      %raw_restored = core.call intrinsic.agent.runtime.restore_state(%session, %normalized_snapshot, %options)
      %restored = core.call @normalize_agent_runtime_snapshot(%state, %raw_restored)
      core.set %state["runtime_session_state"] = %restored
      %log_entry = core.map
      core.set %log_entry["type"] = "runtime_session"
      core.set %log_entry["action"] = "patch_globals"
      core.set %log_entry["snapshot"] = %restored
      core.call @agent_runtime_append_action_log(%state, %log_entry)
      %event = core.map
      core.set %event["snapshot"] = %restored
      core.call @agent_record_trace_event(%state, "state_restore", %event)
      core.return %restored
    }
  }

  op ax.agent.runtime @agent_runtime_close_session {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> json"
    body @entry(%state: json, %session: json) {
      %closed = core.call intrinsic.agent.runtime.close(%session)
      core.set %state["runtime_session_closed"] = true
      %entry = core.map
      core.set %entry["result"] = %closed
      core.call @agent_runtime_lifecycle_event(%state, "close_session", %entry)
      core.return %closed
    }
  }

  op ax.agent.semantic @agent_reserved_auto_promotion_fields {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "() -> list<string>"
    body @entry {
      %fields = core.list
      core.append %fields, "executorRequest"
      core.append %fields, "distilledContextSummary"
      core.append %fields, "contextMetadata"
      core.append %fields, "memories"
      core.append %fields, "contextMap"
      core.append %fields, "discoveredToolDocs"
      core.append %fields, "loadedSkills"
      core.append %fields, "relevanceHints"
      core.append %fields, "summarizedActorLog"
      core.append %fields, "guidanceLog"
      core.append %fields, "actionLog"
      core.append %fields, "liveRuntimeState"
      core.append %fields, "contextPressure"
      core.append %fields, "contextData"
      core.return %fields
    }
  }

  op ax.agent.semantic @agent_value_kind {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> string"
    body @entry(%value: json) {
      %is_none = core.call intrinsic.is_none(%value)
      core.if %is_none {
        core.return "null"
      }
      %is_string = core.type_is %value type "string"
      core.if %is_string {
        core.return "string"
      }
      %is_number = core.type_is %value type "number"
      core.if %is_number {
        core.return "number"
      }
      %is_bool = core.type_is %value type "bool"
      core.if %is_bool {
        core.return "boolean"
      }
      %is_list = core.type_is %value type "list"
      core.if %is_list {
        core.return "array"
      }
      %is_object = core.type_is %value type "object"
      core.if %is_object {
        core.return "object"
      }
      core.return "value"
    }
  }

  op ax.agent.semantic @agent_take_strings {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, number) -> list<string>"
    body @entry(%items: json, %limit: number) {
      %out = core.list
      %index = core.let 0
      core.for %item in %items {
        %under = core.call intrinsic.lt(%index, %limit)
        core.if %under {
          %item_text = core.call intrinsic.string.format("{}", %item)
          core.append %out, %item_text
        }
        %index = core.call intrinsic.add(%index, 1)
      }
      core.return %out
    }
  }

  op ax.agent.semantic @agent_object_keys_sample {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, number) -> list<string>"
    body @entry(%value: json, %limit: number) {
      %empty = core.list
      %is_object = core.type_is %value type "object"
      core.if %is_object {
        %keys = core.call intrinsic.map.keys(%value)
        %out = core.call @agent_take_strings(%keys, %limit)
        core.return %out
      }
      core.return %empty
    }
  }

  op ax.agent.semantic @agent_evidence_entry_descriptor {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(string, json) -> json"
    body @entry(%key: string, %value: json) {
      %text = core.call intrinsic.json.stringify(%value)
      %size = core.call intrinsic.len(%text)
      %kind = core.call @agent_value_kind(%value)
      %entry = core.map
      core.set %entry["key"] = %key
      core.set %entry["type"] = %kind
      core.set %entry["size"] = %size
      %is_list = core.type_is %value type "list"
      core.if %is_list {
        %length = core.call intrinsic.len(%value)
        core.set %entry["length"] = %length
        %first = core.call intrinsic.list.get(%value, 0, null)
        %item_keys = core.call @agent_object_keys_sample(%first, 12)
        %item_key_count = core.call intrinsic.len(%item_keys)
        %has_item_keys = core.call intrinsic.gt(%item_key_count, 0)
        core.if %has_item_keys {
          core.set %entry["itemKeys"] = %item_keys
        }
      }
      %is_object = core.type_is %value type "object"
      core.if %is_object {
        %keys = core.call @agent_object_keys_sample(%value, 12)
        %key_count = core.call intrinsic.len(%keys)
        %has_keys = core.call intrinsic.gt(%key_count, 0)
        core.if %has_keys {
          core.set %entry["keys"] = %keys
        }
      }
      core.return %entry
    }
  }

  op ax.agent.semantic @agent_build_evidence_descriptor {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json"
    body @entry(%evidence: json) {
      %empty_map = core.map
      %payload = core.let %evidence
      %is_object = core.type_is %payload type "object"
      core.if %is_object {
      } else {
        %payload = core.let %empty_map
      }
      %text = core.call intrinsic.json.stringify(%payload)
      %total = core.call intrinsic.len(%text)
      %entries = core.list
      %keys = core.call intrinsic.map.keys(%payload)
      core.for %key in %keys {
        %value = core.get %payload[%key]
        %entry = core.call @agent_evidence_entry_descriptor(%key, %value)
        core.append %entries, %entry
      }
      %out = core.map
      core.set %out["kind"] = "axEvidenceDescriptor"
      core.set %out["totalChars"] = %total
      core.set %out["entries"] = %entries
      core.return %out
    }
  }

  op ax.agent.semantic @agent_render_evidence_descriptor {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> string"
    body @entry(%descriptor: json) {
      %empty_list = core.list
      %kind = core.get %descriptor["kind"] default ""
      %is_descriptor = core.call intrinsic.eq(%kind, "axEvidenceDescriptor")
      core.if %is_descriptor {
      } else {
        %descriptor = core.call @agent_build_evidence_descriptor(%descriptor)
      }
      %total = core.get %descriptor["totalChars"] default 0
      %entries = core.get %descriptor["entries"] default %empty_list
      %entry_count = core.call intrinsic.len(%entries)
      %empty = core.call intrinsic.eq(%entry_count, 0)
      core.if %empty {
        core.return "Evidence object is available in the runtime as `inputs.distilledContext` (empty)."
      }
      %lines = core.list
      %header = core.call intrinsic.string.format("Evidence keys available in the runtime as `inputs.distilledContext` (~{} chars total):", %total)
      core.append %lines, %header
      core.for %entry in %entries {
        %key = core.get %entry["key"] default ""
        %type = core.get %entry["type"] default "value"
        %size = core.get %entry["size"] default 0
        %line = core.call intrinsic.string.format("- `{}`: {} ({} chars)", %key, %type, %size)
        %length = core.get %entry["length"] default null
        %has_length = core.call intrinsic.is_not_none(%length)
        core.if %has_length {
          %line = core.call intrinsic.string.format("{}; length {}", %line, %length)
        }
        %keys = core.get %entry["keys"] default %empty_list
        %keys_count = core.call intrinsic.len(%keys)
        %has_keys = core.call intrinsic.gt(%keys_count, 0)
        core.if %has_keys {
          %keys_text = core.call intrinsic.string.join(", ", %keys)
          %line = core.call intrinsic.string.format("{}; keys: {}", %line, %keys_text)
        }
        %item_keys = core.get %entry["itemKeys"] default %empty_list
        %item_keys_count = core.call intrinsic.len(%item_keys)
        %has_item_keys = core.call intrinsic.gt(%item_keys_count, 0)
        core.if %has_item_keys {
          %item_keys_text = core.call intrinsic.string.join(", ", %item_keys)
          %line = core.call intrinsic.string.format("{}; item keys: {}", %line, %item_keys_text)
        }
        core.append %lines, %line
      }
      %out = core.call intrinsic.string.join("\n", %lines)
      core.return %out
    }
  }

  op ax.agent.semantic @agent_identifier_tokens {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(string) -> list<string>"
    body @entry(%text: string) {
      %acronyms = core.call intrinsic.regex.replace("([A-Z]+)([A-Z][a-z])", "$1 $2", %text)
      %camel = core.call intrinsic.regex.replace("([a-z0-9])([A-Z])", "$1 $2", %acronyms)
      %spaced = core.call intrinsic.regex.replace("[^A-Za-z0-9]+", " ", %camel)
      %lower = core.call intrinsic.string.lower(%spaced)
      %parts = core.call intrinsic.string.split_trim_nonempty(%lower, " ")
      %out = core.list
      core.for %part in %parts {
        %len = core.call intrinsic.len(%part)
        %long_enough = core.call intrinsic.gt(%len, 1)
        %without_digits = core.call intrinsic.regex.replace("^[0-9]+$", "", %part)
        %not_numeric = core.call intrinsic.ne(%without_digits, "")
        %keep = core.call intrinsic.and(%long_enough, %not_numeric)
        core.if %keep {
          core.append %out, %part
        }
      }
      core.return %out
    }
  }

  op ax.agent.semantic @agent_relevance_tokens {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(string) -> list<string>"
    body @entry(%text: string) {
      %stopwords = core.call intrinsic.json.parse(file "data/agent-stopwords.json")
      %lower = core.call intrinsic.string.lower(%text)
      %clean = core.call intrinsic.regex.replace("[-!\"#$%&'()*+,./:;<=>?@\\[\\]^_`{|}~]", " ", %lower)
      %parts = core.call intrinsic.string.split_trim_nonempty(%clean, " ")
      %out = core.list
      core.for %part in %parts {
        %len = core.call intrinsic.len(%part)
        %long_enough = core.call intrinsic.gt(%len, 1)
        %without_digits = core.call intrinsic.regex.replace("^[0-9]+$", "", %part)
        %not_numeric = core.call intrinsic.ne(%without_digits, "")
        %is_stop = core.call intrinsic.contains(%stopwords, %part)
        %not_stop = core.call intrinsic.not(%is_stop)
        %base_ok = core.call intrinsic.and(%long_enough, %not_numeric)
        %ok = core.call intrinsic.and(%base_ok, %not_stop)
        core.if %ok {
          core.append %out, %part
        }
      }
      core.return %out
    }
  }

  op ax.agent.semantic @agent_document_term_frequency {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json"
    body @entry(%fields: json) {
      %tf = core.map
      core.for %field in %fields {
        %text = core.get %field["text"] default ""
        %weight = core.get %field["weight"] default 1
        %identifier = core.get %field["identifier"] default false
        %terms = core.call @agent_relevance_tokens(%text)
        core.if %identifier {
          %terms = core.call @agent_identifier_tokens(%text)
        }
        core.for %term in %terms {
          %current = core.get %tf[%term] default 0
          %next = core.call intrinsic.add(%current, %weight)
          core.set %tf[%term] = %next
        }
      }
      core.return %tf
    }
  }

  op ax.agent.semantic @agent_rank_documents {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(string, json, json) -> json"
    body @entry(%query: string, %docs: json, %options: json) {
      %empty = core.list
      %top_k = core.get %options["topK"] default 3
      %min_score = core.get %options["minScore"] default 0.08
      %margin_ratio = core.get %options["marginRatio"] default 0.15
      %min_docs = core.get %options["minDocs"] default 2
      %doc_count = core.call intrinsic.len(%docs)
      %too_few = core.call intrinsic.lt(%doc_count, %min_docs)
      core.if %too_few {
        core.return %empty
      }
      %indexed = core.list
      %df = core.map
      core.for %doc in %docs {
        %fields = core.get %doc["fields"] default %empty
        %tf = core.call @agent_document_term_frequency(%fields)
        %doc_id = core.get %doc["id"] default ""
        %indexed_doc = core.map
        core.set %indexed_doc["id"] = %doc_id
        core.set %indexed_doc["tf"] = %tf
        core.append %indexed, %indexed_doc
        %terms = core.call intrinsic.map.keys(%tf)
        core.for %term in %terms {
          %count = core.get %df[%term] default 0
          %count = core.call intrinsic.add(%count, 1)
          core.set %df[%term] = %count
        }
      }
      %query_terms = core.call @agent_relevance_tokens(%query)
      %effective = core.list
      core.for %query_term in %query_terms {
        %appears = core.call intrinsic.map.contains(%df, %query_term)
        %already_effective = core.call intrinsic.contains(%effective, %query_term)
        %fresh_effective = core.call intrinsic.not(%already_effective)
        %include_effective = core.call intrinsic.and(%appears, %fresh_effective)
        core.if %include_effective {
          core.append %effective, %query_term
        }
      }
      %effective_count = core.call intrinsic.len(%effective)
      %no_effective = core.call intrinsic.eq(%effective_count, 0)
      core.if %no_effective {
        core.return %empty
      }
      %idf = core.map
      %total_idf = core.let 0
      core.for %term2 in %effective {
        %frequency = core.get %df[%term2] default 1
        %ratio = core.call intrinsic.div(%doc_count, %frequency)
        %ratio_plus_one = core.call intrinsic.add(1, %ratio)
        %weight = core.call intrinsic.math.log(%ratio_plus_one)
        core.set %idf[%term2] = %weight
        %total_idf = core.call intrinsic.add(%total_idf, %weight)
      }
      %scored = core.list
      core.for %indexed_doc2 in %indexed {
        %id = core.get %indexed_doc2["id"] default ""
        %tf2 = core.get %indexed_doc2["tf"] default null
        %raw = core.let 0
        %coverage_weight = core.let 0
        %matched = core.list
        core.for %term3 in %effective {
          %frequency2 = core.get %tf2[%term3] default 0
          %matched_frequency = core.call intrinsic.gt(%frequency2, 0)
          core.if %matched_frequency {
            %idf_weight = core.get %idf[%term3] default 0
            %saturated_denominator = core.call intrinsic.add(%frequency2, 1)
            %saturated = core.call intrinsic.div(%frequency2, %saturated_denominator)
            %weighted = core.call intrinsic.mul(%idf_weight, %saturated)
            %raw = core.call intrinsic.add(%raw, %weighted)
            %coverage_weight = core.call intrinsic.add(%coverage_weight, %idf_weight)
            core.append %matched, %term3
          }
        }
        %coverage = core.call intrinsic.div(%coverage_weight, %total_idf)
        %score_entry = core.map
        core.set %score_entry["id"] = %id
        core.set %score_entry["raw"] = %raw
        core.set %score_entry["coverage"] = %coverage
        core.set %score_entry["matchedTerms"] = %matched
        core.append %scored, %score_entry
      }
      %scored_ids = core.list
      core.for %scored_for_id in %scored {
        %scored_id = core.get %scored_for_id["id"] default ""
        core.append %scored_ids, %scored_id
      }
      %sorted_scored_ids = core.call intrinsic.list.sorted_strings(%scored_ids)
      %scored_by_id = core.list
      core.for %sorted_scored_id in %sorted_scored_ids {
        core.for %scored_for_sort in %scored {
          %scored_for_sort_id = core.get %scored_for_sort["id"] default ""
          %same_scored_id = core.call intrinsic.eq(%scored_for_sort_id, %sorted_scored_id)
          core.if %same_scored_id {
            core.append %scored_by_id, %scored_for_sort
          }
        }
      }
      %scored = core.let %scored_by_id
      %sorted = core.list
      core.loop {
        %sorted_count = core.call intrinsic.len(%sorted)
        %all_sorted = core.call intrinsic.gte(%sorted_count, %doc_count)
        core.if %all_sorted {
          core.break
        }
        %best = core.call intrinsic.none()
        %best_raw = core.let -1
        %best_id = core.let ""
        %found = core.let false
        core.for %candidate in %scored {
          %candidate_id = core.get %candidate["id"] default ""
          %already = core.call @agent_relevance_has_id(%sorted, "id", %candidate_id)
          %fresh = core.call intrinsic.not(%already)
          core.if %fresh {
            %candidate_raw = core.get %candidate["raw"] default 0
            %greater = core.call intrinsic.gt(%candidate_raw, %best_raw)
            %better = core.let %greater
            core.if %better {
              %best = core.let %candidate
              %best_raw = core.let %candidate_raw
              %best_id = core.let %candidate_id
              %found = core.let true
            }
          }
        }
        core.if %found {
          core.append %sorted, %best
        } else {
          core.break
        }
      }
      %top = core.call intrinsic.list.get(%sorted, 0, null)
      %top_raw = core.get %top["raw"] default 0
      %top_coverage = core.get %top["coverage"] default 0
      %no_match = core.call intrinsic.lte(%top_raw, 0)
      %below_floor = core.call intrinsic.lt(%top_coverage, %min_score)
      %rejected = core.call intrinsic.or(%no_match, %below_floor)
      core.if %rejected {
        core.return %empty
      }
      %use_margin = core.call intrinsic.gt(%margin_ratio, 0)
      core.if %use_margin {
        %near_top = core.let 0
        core.for %scored_entry in %sorted {
          %entry_raw = core.get %scored_entry["raw"] default 0
          %positive = core.call intrinsic.gt(%entry_raw, 0)
          core.if %positive {
            %negative_entry_raw = core.call intrinsic.mul(%entry_raw, -1)
            %difference = core.call intrinsic.add(%top_raw, %negative_entry_raw)
            %relative = core.call intrinsic.div(%difference, %top_raw)
            %near = core.call intrinsic.lt(%relative, %margin_ratio)
            core.if %near {
              %near_top = core.call intrinsic.add(%near_top, 1)
            }
          }
        }
        %multiple_docs = core.call intrinsic.gte(%doc_count, 2)
        %all_near = core.call intrinsic.gte(%near_top, %doc_count)
        %suppress = core.call intrinsic.and(%multiple_docs, %all_near)
        core.if %suppress {
          core.return %empty
        }
      }
      %out = core.list
      core.for %scored_entry2 in %sorted {
        %out_count = core.call intrinsic.len(%out)
        %under_limit = core.call intrinsic.lt(%out_count, %top_k)
        %entry_raw2 = core.get %scored_entry2["raw"] default 0
        %positive2 = core.call intrinsic.gt(%entry_raw2, 0)
        %include = core.call intrinsic.and(%under_limit, %positive2)
        core.if %include {
          %normalized_score = core.call intrinsic.div(%entry_raw2, %top_raw)
          %ranked_id = core.get %scored_entry2["id"] default ""
          %ranked_terms = core.get %scored_entry2["matchedTerms"] default %empty
          %ranked = core.map
          core.set %ranked["id"] = %ranked_id
          core.set %ranked["score"] = %normalized_score
          core.set %ranked["matchedTerms"] = %ranked_terms
          core.append %out, %ranked
        }
      }
      core.return %out
    }
  }

  op ax.agent.semantic @agent_relevance_has_id {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, string, string) -> bool"
    body @entry(%items: json, %field: string, %id: string) {
      core.for %item in %items {
        %existing = core.get %item[%field] default ""
        %matches = core.call intrinsic.eq(%existing, %id)
        core.if %matches {
          core.return true
        }
      }
      core.return false
    }
  }

  op ax.agent.semantic @agent_rank_relevance_modules {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, string) -> json"
    body @entry(%state: json, %task: string) {
      %empty_list = core.list
      %split = core.get %state["callable_split"] default null
      %discoverable = core.get %split["discoverable"] default %empty_list
      %docs = core.list
      core.for %group in %discoverable {
        %namespace = core.get %group["namespace"] default ""
        %title = core.get %group["title"] default ""
        %description = core.get %group["description"] default ""
        %selection = core.get %group["selection_criteria"] default ""
        %fields = core.list
        %namespace_field = core.map
        core.set %namespace_field["text"] = %namespace
        core.set %namespace_field["identifier"] = true
        core.append %fields, %namespace_field
        %has_title = core.call intrinsic.ne(%title, "")
        core.if %has_title {
          %title_field = core.map
          core.set %title_field["text"] = %title
          core.append %fields, %title_field
        }
        %has_description = core.call intrinsic.ne(%description, "")
        core.if %has_description {
          %description_field = core.map
          core.set %description_field["text"] = %description
          core.append %fields, %description_field
        }
        %has_selection = core.call intrinsic.ne(%selection, "")
        core.if %has_selection {
          %selection_field = core.map
          core.set %selection_field["text"] = %selection
          core.set %selection_field["weight"] = 2
          core.append %fields, %selection_field
        }
        %callables = core.get %group["callables"] default %empty_list
        core.for %callable in %callables {
          %name = core.get %callable["name"] default ""
          %name_field = core.map
          core.set %name_field["text"] = %name
          core.set %name_field["identifier"] = true
          core.append %fields, %name_field
          %params = core.get %callable["parameters"] default null
          %properties = core.get %params["properties"] default null
          %props_is_object = core.type_is %properties type "object"
          core.if %props_is_object {
            %prop_keys = core.call intrinsic.map.keys(%properties)
            core.for %prop_key in %prop_keys {
              %prop_field = core.map
              core.set %prop_field["text"] = %prop_key
              core.set %prop_field["identifier"] = true
              core.append %fields, %prop_field
            }
          }
        }
        %doc = core.map
        core.set %doc["id"] = %namespace
        core.set %doc["fields"] = %fields
        core.append %docs, %doc
      }
      %ranking_options = core.get %state["relevance_ranking_options"] default null
      %ranked = core.call @agent_rank_documents(%task, %docs, %ranking_options)
      %out = core.list
      core.for %ranked_entry in %ranked {
        %entry = core.map
        %namespace2 = core.get %ranked_entry["id"] default ""
        %score = core.get %ranked_entry["score"] default 0
        %matched = core.get %ranked_entry["matchedTerms"] default %empty_list
        core.set %entry["namespace"] = %namespace2
        core.set %entry["score"] = %score
        core.set %entry["matchedTerms"] = %matched
        core.append %out, %entry
      }
      core.return %out
    }
  }

  op ax.agent.semantic @agent_rank_relevance_skills {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, string) -> json"
    body @entry(%state: json, %task: string) {
      %empty_list = core.list
      %catalog = core.get %state["skills_catalog"] default %empty_list
      %docs = core.list
      core.for %skill in %catalog {
        %id = core.get %skill["id"] default ""
        %name = core.get %skill["name"] default %id
        %description = core.get %skill["description"] default ""
        %content = core.get %skill["content"] default ""
        %content_head = core.call intrinsic.string.slice(%content, 0, 600)
        %fields = core.list
        %id_field = core.map
        core.set %id_field["text"] = %id
        core.set %id_field["identifier"] = true
        core.append %fields, %id_field
        %name_field = core.map
        core.set %name_field["text"] = %name
        core.set %name_field["weight"] = 2
        core.append %fields, %name_field
        %has_description = core.call intrinsic.ne(%description, "")
        core.if %has_description {
          %description_field = core.map
          core.set %description_field["text"] = %description
          core.set %description_field["weight"] = 2
          core.append %fields, %description_field
        }
        %content_field = core.map
        core.set %content_field["text"] = %content_head
        core.append %fields, %content_field
        %doc = core.map
        core.set %doc["id"] = %id
        core.set %doc["fields"] = %fields
        core.append %docs, %doc
      }
      %ranking_options = core.get %state["relevance_ranking_options"] default null
      %ranked = core.call @agent_rank_documents(%task, %docs, %ranking_options)
      %out = core.list
      core.for %ranked_entry in %ranked {
        %ranked_id = core.get %ranked_entry["id"] default ""
        %ranked_score = core.get %ranked_entry["score"] default 0
        %ranked_name = core.let %ranked_id
        core.for %catalog_skill in %catalog {
          %catalog_id = core.get %catalog_skill["id"] default ""
          %id_match = core.call intrinsic.eq(%catalog_id, %ranked_id)
          core.if %id_match {
            %ranked_name = core.get %catalog_skill["name"] default %ranked_id
          }
        }
        %entry = core.map
        core.set %entry["id"] = %ranked_id
        core.set %entry["name"] = %ranked_name
        core.set %entry["score"] = %ranked_score
        core.append %out, %entry
      }
      core.return %out
    }
  }

  op ax.agent.semantic @agent_rank_relevance_memories {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, string) -> json"
    body @entry(%state: json, %task: string) {
      %empty_list = core.list
      %catalog = core.get %state["memories_catalog"] default %empty_list
      %loaded = core.get %state["loaded_memories"] default %empty_list
      %candidates = core.list
      %docs = core.list
      core.for %memory in %catalog {
        %id = core.get %memory["id"] default ""
        %already_loaded = core.call @agent_relevance_has_id(%loaded, "id", %id)
        %fresh = core.call intrinsic.not(%already_loaded)
        core.if %fresh {
          core.append %candidates, %memory
          %content = core.get %memory["content"] default ""
          %content_head = core.call intrinsic.string.slice(%content, 0, 600)
          %fields = core.list
          %id_field = core.map
          core.set %id_field["text"] = %id
          core.set %id_field["identifier"] = true
          core.append %fields, %id_field
          %content_field = core.map
          core.set %content_field["text"] = %content_head
          core.append %fields, %content_field
          %doc = core.map
          core.set %doc["id"] = %id
          core.set %doc["fields"] = %fields
          core.append %docs, %doc
        }
      }
      %ranking_options = core.get %state["relevance_ranking_options"] default null
      %ranked = core.call @agent_rank_documents(%task, %docs, %ranking_options)
      %out = core.list
      core.for %ranked_entry in %ranked {
        %ranked_id = core.get %ranked_entry["id"] default ""
        %ranked_score = core.get %ranked_entry["score"] default 0
        %snippet = core.let ""
        core.for %candidate in %candidates {
          %candidate_id = core.get %candidate["id"] default ""
          %id_match = core.call intrinsic.eq(%candidate_id, %ranked_id)
          core.if %id_match {
            %candidate_content = core.get %candidate["content"] default ""
            %single_line = core.call intrinsic.regex.replace("\\s+", " ", %candidate_content)
            %trimmed = core.string_trim %single_line
            %snippet = core.call intrinsic.string.slice(%trimmed, 0, 80)
          }
        }
        %entry = core.map
        core.set %entry["id"] = %ranked_id
        core.set %entry["snippet"] = %snippet
        core.set %entry["score"] = %ranked_score
        core.append %out, %entry
      }
      core.return %out
    }
  }

  op ax.agent.semantic @agent_render_relevance_hints {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> string"
    body @entry(%hints: json) {
      %empty_list = core.list
      %sections = core.list
      %modules = core.get %hints["modules"] default %empty_list
      %module_count = core.call intrinsic.len(%modules)
      %has_modules = core.call intrinsic.gt(%module_count, 0)
      core.if %has_modules {
        %lines = core.list
        core.for %module in %modules {
          %namespace = core.get %module["namespace"] default ""
          %line = core.call intrinsic.string.format("- `{}`", %namespace)
          core.append %lines, %line
        }
        %body = core.call intrinsic.string.join("\n", %lines)
        %section = core.call intrinsic.string.format("Modules:\n{}", %body)
        core.append %sections, %section
      }
      %skills = core.get %hints["skills"] default %empty_list
      %skill_count = core.call intrinsic.len(%skills)
      %has_skills = core.call intrinsic.gt(%skill_count, 0)
      core.if %has_skills {
        %skill_lines = core.list
        core.for %skill in %skills {
          %id = core.get %skill["id"] default ""
          %name = core.get %skill["name"] default %id
          %line = core.call intrinsic.string.format("- `{}` — {}", %id, %name)
          core.append %skill_lines, %line
        }
        %skill_body = core.call intrinsic.string.join("\n", %skill_lines)
        %skill_section = core.call intrinsic.string.format("Skills:\n{}", %skill_body)
        core.append %sections, %skill_section
      }
      %memories = core.get %hints["memories"] default %empty_list
      %memory_count = core.call intrinsic.len(%memories)
      %has_memories = core.call intrinsic.gt(%memory_count, 0)
      core.if %has_memories {
        %memory_lines = core.list
        core.for %memory in %memories {
          %id2 = core.get %memory["id"] default ""
          %snippet = core.get %memory["snippet"] default ""
          %line2 = core.call intrinsic.string.format("- `{}`", %id2)
          %has_snippet = core.call intrinsic.ne(%snippet, "")
          core.if %has_snippet {
            %line2 = core.call intrinsic.string.format("{} — {}", %line2, %snippet)
          }
          core.append %memory_lines, %line2
        }
        %memory_body = core.call intrinsic.string.join("\n", %memory_lines)
        %memory_section = core.call intrinsic.string.format("Memories:\n{}", %memory_body)
        core.append %sections, %memory_section
      }
      %out = core.call intrinsic.string.join("\n", %sections)
      core.return %out
    }
  }

  op ax.agent.semantic @agent_rank_task_text {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, string) -> string"
    body @entry(%values: json, %executor_request: string) {
      %reserved = core.call @agent_reserved_auto_promotion_fields()
      %parts = core.list
      core.for %key in %values {
        %is_reserved = core.call intrinsic.contains(%reserved, %key)
        %not_reserved = core.call intrinsic.not(%is_reserved)
        core.if %not_reserved {
          %value = core.get %values[%key]
          %is_string = core.type_is %value type "string"
          core.if %is_string {
            core.append %parts, %value
          }
        }
      }
      core.append %parts, %executor_request
      %out = core.call intrinsic.string.join(" ", %parts)
      core.return %out
    }
  }

  op ax.agent.semantic @agent_build_relevance_hints {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json, string) -> json"
    body @entry(%state: json, %values: json, %executor_request: string) {
      %empty_list = core.list
      %empty_map = core.map
      %flags = core.get %state["policy_flags"] default %empty_map
      %enabled = core.get %flags["relevanceHintsEnabled"] default false
      core.if %enabled {
      } else {
        core.return %empty_map
      }
      %task = core.call @agent_rank_task_text(%values, %executor_request)
      %out = core.map
      %module_enabled = core.get %flags["moduleHintEnabled"] default false
      core.if %module_enabled {
        %modules = core.call @agent_rank_relevance_modules(%state, %task)
        core.set %out["modules"] = %modules
      } else {
        core.set %out["modules"] = %empty_list
      }
      %skills_enabled = core.get %flags["skillsHintEnabled"] default false
      core.if %skills_enabled {
        %skills = core.call @agent_rank_relevance_skills(%state, %task)
        core.set %out["skills"] = %skills
      } else {
        core.set %out["skills"] = %empty_list
      }
      %memories_enabled = core.get %flags["memoriesHintEnabled"] default false
      core.if %memories_enabled {
        %memories = core.call @agent_rank_relevance_memories(%state, %task)
        core.set %out["memories"] = %memories
      } else {
        core.set %out["memories"] = %empty_list
      }
      core.return %out
    }
  }

  op ax.agent.runtime @agent_runtime_test {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json, string, json, json) -> json throws"
    body @entry(%state: json, %runtime: json, %code: string, %values: json, %options: json) {
      %globals = core.call @agent_runtime_build_globals(%state, %values)
      %runtime_options = core.call @agent_runtime_execution_options(%state, %options)
      %session = core.call @agent_runtime_create_session(%state, %runtime, %globals, %runtime_options)
      %result = core.map
      core.try {
        %result = core.call @agent_runtime_execute_step(%state, %runtime, %session, %code, %runtime_options)
      } catch %runtime_test_error {
        %error_session = core.get %state["runtime_session"] default %session
        core.call @agent_runtime_close_session(%state, %error_session)
        core.raise %runtime_test_error
      }
      %active_session = core.get %state["runtime_session"] default %session
      core.call @agent_runtime_close_session(%state, %active_session)
      core.return %result
    }
  }

  op ax.agent.semantic @split_context_values {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> json"
    body @entry(%state: json, %values: json) {
      %empty_list = core.list
      %context_fields = core.get %state["context_fields"] default %empty_list
      %auto_upgrade = core.get %state["auto_upgrade"] default null
      %auto_context = core.get %auto_upgrade["contextFields"] default null
      %auto_enabled = core.get %auto_context["enabled"] default false
      %promote_above = core.get %auto_context["promoteAboveChars"] default 8000
      %preview_chars = core.get %auto_context["previewChars"] default 1200
      %reserved = core.call @agent_reserved_auto_promotion_fields()
      %ctx_values = core.map
      %non_ctx_values = core.map
      core.for %key in %values {
        %value = core.get %values[%key]
        %is_context = core.call intrinsic.contains(%context_fields, %key)
        core.if %is_context {
          core.set %ctx_values[%key] = %value
        } else {
          %promoted = core.let false
          %is_reserved = core.call intrinsic.contains(%reserved, %key)
          %not_reserved = core.call intrinsic.not(%is_reserved)
          %can_auto = core.call intrinsic.and(%auto_enabled, %not_reserved)
          core.if %can_auto {
            %value_text = core.call intrinsic.json.stringify(%value)
            %value_len = core.call intrinsic.len(%value_text)
            %too_large = core.call intrinsic.gt(%value_len, %promote_above)
            core.if %too_large {
              %promoted = core.let true
              core.set %ctx_values[%key] = %value
              %is_string = core.type_is %value type "string"
              %preview_source = core.let %value_text
              core.if %is_string {
                %preview_source = core.let %value
              }
              %preview = core.call intrinsic.string.slice(%preview_source, 0, %preview_chars)
              %preview_value = core.call intrinsic.string.format("[runtime-only context: {} chars available as inputs.{}; preview]\n{}", %value_len, %key, %preview)
              core.set %non_ctx_values[%key] = %preview_value
              %event = core.map
              core.set %event["kind"] = "field_auto_promoted"
              core.set %event["fieldName"] = %key
              core.set %event["originalChars"] = %value_len
              core.set %event["promptPreviewChars"] = %preview_chars
              %events = core.get %state["context_events"] default %empty_list
              core.append %events, %event
              core.set %state["context_events"] = %events
            }
          }
          %not_promoted = core.call intrinsic.not(%promoted)
          core.if %not_promoted {
            core.set %non_ctx_values[%key] = %value
          }
        }
      }
      %out = core.map
      core.set %out["context"] = %ctx_values
      core.set %out["values"] = %non_ctx_values
      core.return %out
    }
  }

  op ax.agent.semantic @agent_render_context_metadata {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> string"
    body @entry(%context: json) {
      %lines = core.list
      core.for %ck in %context {
        %cv = core.get %context[%ck]
        %cv_str = core.call intrinsic.json.stringify(%cv)
        %cv_len = core.call intrinsic.len(%cv_str)
        %cv_type = core.call @agent_value_kind(%cv)
        %runtime_ref = core.call intrinsic.string.format("inputs.{} ({} chars)", %ck, %cv_len)
        %line = core.call intrinsic.string.format("- {}: {} loaded in the runtime as {} — read and narrow it with code; never retype its contents", %ck, %cv_type, %runtime_ref)
        %keys = core.call @agent_object_keys_sample(%cv, 12)
        %key_count = core.call intrinsic.len(%keys)
        %has_keys = core.call intrinsic.gt(%key_count, 0)
        core.if %has_keys {
          %keys_text = core.call intrinsic.string.join(", ", %keys)
          %line = core.call intrinsic.string.format("{}; keys: {}", %line, %keys_text)
        }
        %is_list = core.type_is %cv type "list"
        core.if %is_list {
          %length = core.call intrinsic.len(%cv)
          %line = core.call intrinsic.string.format("{}; length {}", %line, %length)
          %first = core.call intrinsic.list.get(%cv, 0, null)
          %item_keys = core.call @agent_object_keys_sample(%first, 12)
          %item_key_count = core.call intrinsic.len(%item_keys)
          %has_item_keys = core.call intrinsic.gt(%item_key_count, 0)
          core.if %has_item_keys {
            %item_keys_text = core.call intrinsic.string.join(", ", %item_keys)
            %line = core.call intrinsic.string.format("{}; item keys: {}", %line, %item_keys_text)
          }
        }
        core.append %lines, %line
      }
      %out = core.call intrinsic.string.join("\n", %lines)
      core.return %out
    }
  }

  op ax.agent.semantic @build_distiller_inputs {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> json"
    body @entry(%state: json, %values: json) {
      %empty_list = core.list
      %empty_map = core.map
      %split = core.call @split_context_values(%state, %values)
      %context = core.get %split["context"] default %empty_map
      %non_ctx = core.get %split["values"] default %empty_map
      %cm_state = core.get %state["context_map"] default null
      %cm_text = core.get %cm_state["text"] default ""
      %cm_has = core.call intrinsic.ne(%cm_text, "")
      %ctx_out = core.map
      %distiller_runtime_enabled = core.get %state["runtime_enabled"] default false
      core.for %ck in %context {
        %cv = core.get %context[%ck]
        core.if %distiller_runtime_enabled {
          %cv_str = core.call intrinsic.string.format("{}", %cv)
          %cv_len = core.call intrinsic.len(%cv_str)
          %meta_note = core.call intrinsic.string.format("loaded in the runtime as inputs.{} ({} chars) — read and narrow it with code; never retype its contents", %ck, %cv_len)
          core.set %ctx_out[%ck] = %meta_note
        } else {
          core.set %ctx_out[%ck] = %cv
        }
      }
      core.if %cm_has {
        core.set %ctx_out["contextMap"] = %cm_text
      }
      %out = core.map
      core.set %out["input"] = %non_ctx
      core.set %out["context"] = %ctx_out
      %actor_context = core.call @agent_prepare_actor_context(%state)
      %guidance_text = core.get %actor_context["guidanceLog"] default "[]"
      %action_text = core.get %actor_context["actionLog"] default "(no actions yet)"
      %summary_text = core.get %actor_context["summarizedActorLog"] default ""
      %runtime_text = core.get %actor_context["liveRuntimeState"] default ""
      %pressure_text = core.get %actor_context["contextPressure"] default ""
      %discovered_docs = core.get %state["discovered_tool_docs"] default %empty_list
      %loaded_skills = core.get %state["distiller_loaded_skill_docs"] default %empty_list
      %loaded_memories = core.get %state["loaded_memories"] default %empty_list
      %discovered_text = core.call @agent_render_discovered_tool_docs(%discovered_docs)
      %skills_text = core.call @agent_render_loaded_skills(%loaded_skills)
      %memories_text = core.call @agent_render_loaded_memories(%loaded_memories)
      core.set %out["discoveredToolDocs"] = %discovered_text
      core.set %out["loadedSkills"] = %skills_text
      core.set %out["memories"] = %memories_text
      core.set %out["summarizedActorLog"] = %summary_text
      core.set %out["guidanceLog"] = %guidance_text
      core.set %out["actionLog"] = %action_text
      core.set %out["liveRuntimeState"] = %runtime_text
      core.set %out["contextPressure"] = %pressure_text
      core.return %out
    }
  }

  op ax.agent.semantic @build_executor_inputs {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json, json) -> json"
    body @entry(%state: json, %values: json, %distiller_payload: json) {
      %empty_list = core.list
      %empty_map = core.map
      %split = core.call @split_context_values(%state, %values)
      %context = core.get %split["context"] default %empty_map
      %non_ctx = core.get %split["values"] default %empty_map
      %empty = core.map
      %out = core.call intrinsic.map.merge(%non_ctx, %empty)
      %args = core.get %distiller_payload["args"] default %empty_list
      %fallback_request = core.call intrinsic.json.stringify(%non_ctx)
      %executor_request_raw = core.call intrinsic.list.get(%args, 0, %fallback_request)
      %request_is_string = core.type_is %executor_request_raw type "string"
      %executor_request = core.let %executor_request_raw
      core.if %request_is_string {
      } else {
        %executor_request_coerced = core.call intrinsic.string.format("{}", %executor_request_raw)
        %executor_request = core.let %executor_request_coerced
      }
      %distilled_context = core.call intrinsic.list.get(%args, 1, %empty_map)
      %distilled_context_summary = core.call @agent_render_evidence_descriptor(%distilled_context)
      core.set %out["input"] = %non_ctx
      core.set %out["executorRequest"] = %executor_request
      core.set %out["distilledContextSummary"] = %distilled_context_summary
      %state_runtime_enabled = core.get %state["runtime_enabled"] default false
      %state_runtime_disabled = core.call intrinsic.not(%state_runtime_enabled)
      core.if %state_runtime_disabled {
        core.set %out["distilledContext"] = %distilled_context
      }
      %context_metadata = core.call @agent_render_context_metadata(%context)
      %has_context_metadata = core.call intrinsic.ne(%context_metadata, "")
      core.if %has_context_metadata {
        core.set %out["contextMetadata"] = %context_metadata
      }
      %hints = core.get %state["relevance_hints_for_turn"] default null
      %hints_is_object = core.type_is %hints type "object"
      core.if %hints_is_object {
      } else {
        %hints = core.call @agent_build_relevance_hints(%state, %non_ctx, %executor_request)
        core.set %state["relevance_hints_for_turn"] = %hints
      }
      %hints_text = core.call @agent_render_relevance_hints(%hints)
      %has_hints = core.call intrinsic.ne(%hints_text, "")
      core.if %has_hints {
        core.set %out["relevanceHints"] = %hints_text
      }
      %discovered_docs = core.get %state["discovered_tool_docs"] default %empty_list
      %loaded_skills = core.get %state["loaded_skill_docs"] default %empty_list
      %loaded_memories = core.get %state["loaded_memories"] default %empty_list
      %discovered_text = core.call @agent_render_discovered_tool_docs(%discovered_docs)
      %skills_text = core.call @agent_render_loaded_skills(%loaded_skills)
      %memories_text = core.call @agent_render_loaded_memories(%loaded_memories)
      %actor_context = core.call @agent_prepare_actor_context(%state)
      %guidance_text = core.get %actor_context["guidanceLog"] default "[]"
      %action_text = core.get %actor_context["actionLog"] default "(no actions yet)"
      %summary_text = core.get %actor_context["summarizedActorLog"] default ""
      %runtime_text = core.get %actor_context["liveRuntimeState"] default ""
      %pressure_text = core.get %actor_context["contextPressure"] default ""
      core.set %out["discoveredToolDocs"] = %discovered_text
      core.set %out["loadedSkills"] = %skills_text
      core.set %out["memories"] = %memories_text
      core.set %out["summarizedActorLog"] = %summary_text
      core.set %out["guidanceLog"] = %guidance_text
      core.set %out["actionLog"] = %action_text
      core.set %out["liveRuntimeState"] = %runtime_text
      core.set %out["contextPressure"] = %pressure_text
      %exclude = core.get %state["executor_exclude_fields"] default %empty_list
      core.for %key in %exclude {
        core.call intrinsic.map.delete(%out, %key)
        core.call intrinsic.map.delete(%non_ctx, %key)
      }
      core.return %out
    }
  }

  op ax.agent.semantic @build_responder_inputs {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json, json) -> json"
    body @entry(%state: json, %values: json, %executor_payload: json) {
      %empty_list = core.list
      %empty_map = core.map
      %split = core.call @split_context_values(%state, %values)
      %non_ctx = core.get %split["values"] default %empty_map
      %empty = core.map
      %out = core.call intrinsic.map.merge(%values, %empty)
      %args = core.get %executor_payload["args"] default %empty_list
      %task = core.call intrinsic.list.get(%args, 0, "")
      %context = core.call intrinsic.list.get(%args, 1, %empty_map)
      %args_count = core.call intrinsic.len(%args)
      %has_evidence_arg = core.call intrinsic.gt(%args_count, 1)
      %context_is_object = core.type_is %context type "object"
      %evidence_present = core.call intrinsic.and(%has_evidence_arg, %context_is_object)
      core.set %state["responder_evidence_present"] = %evidence_present
      core.set %state["responder_evidence"] = %context
      %context_data = core.map
      core.set %context_data["task"] = %task
      core.set %context_data["evidence"] = %context
      core.set %out["contextData"] = %context_data
      core.set %out["agentTask"] = %task
      core.set %out["agentContext"] = %context
      core.set %out["executorResult"] = %executor_payload
      %exclude = core.get %state["responder_exclude_fields"] default %empty_list
      core.for %key in %exclude {
        core.call intrinsic.map.delete(%out, %key)
        core.call intrinsic.map.delete(%non_ctx, %key)
      }
      core.return %out
    }
  }

  op ax.agent.semantic @agent_render_field_token {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> string"
    body @entry(%field: json) {
      %empty_list = core.list
      %name = core.get %field["name"] default ""
      %parts = core.list
      core.append %parts, %name
      %is_optional = core.get %field["is_optional"] default false
      core.if %is_optional {
        core.append %parts, "?"
      }
      %is_internal = core.get %field["is_internal"] default false
      core.if %is_internal {
        core.append %parts, "!"
      }
      %ftype = core.get %field["type"] default null
      %tname = core.let ""
      %has_type = core.call intrinsic.is_not_none(%ftype)
      core.if %has_type {
        %tname = core.get %ftype["name"] default ""
        core.append %parts, ":"
        core.append %parts, %tname
        %is_array = core.get %ftype["is_array"] default false
        core.if %is_array {
          core.append %parts, "[]"
        }
        %is_class = core.call intrinsic.eq(%tname, "class")
        core.if %is_class {
          %options = core.get %ftype["options"] default %empty_list
          %opt_count = core.call intrinsic.len(%options)
          %has_opts = core.call intrinsic.ne(%opt_count, 0)
          core.if %has_opts {
            %opts_joined = core.call intrinsic.string.join(" | ", %options)
            core.append %parts, " \""
            core.append %parts, %opts_joined
            core.append %parts, "\""
          }
        }
      }
      %description = core.get %field["description"] default ""
      %desc_none = core.call intrinsic.is_none(%description)
      core.if %desc_none {
        %description = core.let ""
      }
      %has_desc = core.call intrinsic.ne(%description, "")
      %is_class_desc = core.call intrinsic.eq(%tname, "class")
      %not_class = core.call intrinsic.not(%is_class_desc)
      %render_desc = core.call intrinsic.and(%has_desc, %not_class)
      core.if %render_desc {
        core.append %parts, " \""
        core.append %parts, %description
        core.append %parts, "\""
      }
      %result = core.call intrinsic.string.join("", %parts)
      core.return %result
    }
  }

  op ax.agent.semantic @build_responder_signature {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json, json) -> string"
    body @entry(%sig: json, %context_fields: json, %citations: json) {
      %empty_list = core.list
      %input_fields = core.get %sig["input_fields"] default %empty_list
      %output_fields = core.get %sig["output_fields"] default %empty_list
      %description = core.get %sig["description"] default ""
      %desc_none = core.call intrinsic.is_none(%description)
      core.if %desc_none {
        %description = core.let ""
      }
      %input_tokens = core.list
      core.for %field in %input_fields {
        %fname = core.get %field["name"] default ""
        %is_context = core.call intrinsic.contains(%context_fields, %fname)
        %not_context = core.call intrinsic.not(%is_context)
        core.if %not_context {
          %tok = core.call @agent_render_field_token(%field)
          core.append %input_tokens, %tok
        }
      }
      %ctx_field = core.map
      core.set %ctx_field["name"] = "contextData"
      %ctx_type = core.map
      core.set %ctx_type["name"] = "json"
      core.set %ctx_field["type"] = %ctx_type
      %ctx_tok = core.call @agent_render_field_token(%ctx_field)
      core.append %input_tokens, %ctx_tok
      %output_tokens = core.list
      core.for %ofield in %output_fields {
        %otok = core.call @agent_render_field_token(%ofield)
        core.append %output_tokens, %otok
      }
      %citations_enabled = core.get %citations["enabled"] default false
      core.if %citations_enabled {
        %citations_field = core.map
        %citations_name = core.get %citations["field"] default "evidenceCitations"
        core.set %citations_field["name"] = %citations_name
        core.set %citations_field["title"] = "Evidence Citations"
        %include_memory_ids = core.get %citations["includeMemoryIds"] default true
        %citations_description = core.let "IDs of the evidence entries that directly support the answer: use the exact top-level keys of the contextData.evidence object. Cite only entries actually used. Leave empty when contextData.evidence is absent or was not needed."
        core.if %include_memory_ids {
          %citations_description = core.let "IDs of the evidence entries that directly support the answer: use the exact top-level keys of the contextData.evidence object, plus the id of any records inside it that were relied on (e.g. loaded memories). Cite only entries actually used. Leave empty when contextData.evidence is absent or was not needed."
        }
        core.set %citations_field["description"] = %citations_description
        %citations_type = core.map
        core.set %citations_type["name"] = "string"
        core.set %citations_type["is_array"] = true
        core.set %citations_field["type"] = %citations_type
        core.set %citations_field["is_optional"] = true
        %citations_token = core.call @agent_render_field_token(%citations_field)
        core.append %output_tokens, %citations_token
      }
      %inputs_joined = core.call intrinsic.string.join(", ", %input_tokens)
      %outputs_joined = core.call intrinsic.string.join(", ", %output_tokens)
      %body_parts = core.list
      %has_desc = core.call intrinsic.ne(%description, "")
      core.if %has_desc {
        core.append %body_parts, "\""
        core.append %body_parts, %description
        core.append %body_parts, "\" "
      }
      core.append %body_parts, %inputs_joined
      core.append %body_parts, " -> "
      core.append %body_parts, %outputs_joined
      %sig_string = core.call intrinsic.string.join("", %body_parts)
      core.return %sig_string
    }
  }

  op ax.agent.semantic @resolve_agent_citations {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> json throws"
    body @entry(%options: json, %sig: json) {
      %out = core.map
      %raw = core.get %options["citations"] default false
      %enabled = core.let false
      %field = core.let "evidenceCitations"
      %surface = core.let "output"
      %include_memory_ids = core.let true
      %raw_is_bool = core.type_is %raw type "boolean"
      core.if %raw_is_bool {
        %enabled = core.let %raw
      }
      %raw_is_object = core.type_is %raw type "object"
      core.if %raw_is_object {
        %enabled = core.let true
        %field = core.get %raw["field"] default "evidenceCitations"
        %surface = core.get %raw["surface"] default "output"
        %include_memory_ids = core.get %raw["includeMemoryIds"] default true
      }
      core.if %enabled {
        %valid_field = core.regex_match %field pattern "^[A-Za-z][A-Za-z0-9_]*$"
        %bad_field = core.call intrinsic.not(%valid_field)
        core.if %bad_field {
          %message = core.call intrinsic.string.format("citations.field must be a valid field name, got {}", %field)
          %error = core.call intrinsic.error.runtime(%message)
          core.raise %error
        }
        %is_context_data = core.call intrinsic.eq(%field, "contextData")
        core.if %is_context_data {
          %error = core.call intrinsic.error.runtime("AxAgent: citations.field cannot be contextData; it is the reserved responder evidence input")
          core.raise %error
        }
        %is_output = core.call intrinsic.eq(%surface, "output")
        %is_hidden = core.call intrinsic.eq(%surface, "hidden")
        %valid_surface = core.call intrinsic.or(%is_output, %is_hidden)
        %bad_surface = core.call intrinsic.not(%valid_surface)
        core.if %bad_surface {
          %error = core.call intrinsic.error.runtime("citations.surface must be output or hidden")
          core.raise %error
        }
        %empty_list = core.list
        %outputs = core.get %sig["output_fields"] default %empty_list
        core.for %output_field in %outputs {
          %output_name = core.get %output_field["name"] default ""
          %collision = core.call intrinsic.eq(%output_name, %field)
          core.if %collision {
            %message = core.call intrinsic.string.format("AxAgent: citations.field {} collides with an output field of the agent signature", %field)
            %error = core.call intrinsic.error.runtime(%message)
            core.raise %error
          }
        }
      }
      core.set %out["enabled"] = %enabled
      core.set %out["field"] = %field
      core.set %out["surface"] = %surface
      core.set %out["includeMemoryIds"] = %include_memory_ids
      core.return %out
    }
  }

  op ax.agent.semantic @agent_collect_citation_ids {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json, i64) -> json"
    body @entry(%ids: json, %node: json, %depth: i64) {
      %has_depth = core.call intrinsic.gte(%depth, 0)
      core.if %has_depth {
        %is_object = core.type_is %node type "object"
        core.if %is_object {
          %id = core.get %node["id"] default null
          %id_is_string = core.type_is %id type "string"
          %id_is_number = core.type_is %id type "number"
          %valid_id = core.call intrinsic.or(%id_is_string, %id_is_number)
          core.if %valid_id {
            %id_text = core.call intrinsic.string.format("{}", %id)
            core.set %ids[%id_text] = true
          }
          %next_depth = core.call intrinsic.add(%depth, -1)
          %children = core.call intrinsic.map.values(%node)
          core.for %child in %children {
            %ids = core.call @agent_collect_citation_ids(%ids, %child, %next_depth)
          }
        } else {
          %is_list = core.type_is %node type "list"
          core.if %is_list {
            %next_depth = core.call intrinsic.add(%depth, -1)
            core.for %child in %node {
              %ids = core.call @agent_collect_citation_ids(%ids, %child, %next_depth)
            }
          }
        }
      }
      core.return %ids
    }
  }

  op ax.agent.semantic @agent_validate_citations {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> bool"
    body @entry(%state: json, %output: json) {
      %empty_map = core.map
      %citations = core.get %state["citations"] default %empty_map
      %enabled = core.get %citations["enabled"] default false
      %disabled = core.call intrinsic.not(%enabled)
      core.if %disabled {
        core.return true
      }
      %evidence_present = core.get %state["responder_evidence_present"] default false
      %no_evidence_contract = core.call intrinsic.not(%evidence_present)
      core.if %no_evidence_contract {
        core.return true
      }
      %field = core.get %citations["field"] default "evidenceCitations"
      %raw = core.get %output[%field] default null
      %missing = core.call intrinsic.is_none(%raw)
      core.if %missing {
        core.return true
      }
      %ids = core.map
      %evidence = core.get %state["responder_evidence"] default %empty_map
      %keys = core.call intrinsic.map.keys(%evidence)
      core.for %key in %keys {
        core.set %ids[%key] = true
      }
      %include_memory_ids = core.get %citations["includeMemoryIds"] default true
      core.if %include_memory_ids {
        %values = core.call intrinsic.map.values(%evidence)
        core.for %value in %values {
          %ids = core.call @agent_collect_citation_ids(%ids, %value, 2)
        }
      }
      %empty_list = core.list
      %cited = core.let %empty_list
      %raw_is_list = core.type_is %raw type "list"
      core.if %raw_is_list {
        %cited = core.let %raw
      } else {
        core.append %cited, %raw
      }
      %valid = core.let true
      core.for %raw_id in %cited {
        %id_text = core.call intrinsic.string.format("{}", %raw_id)
        %known = core.call intrinsic.map.contains(%ids, %id_text)
        %unknown = core.call intrinsic.not(%known)
        core.if %unknown {
          %valid = core.let false
        }
      }
      core.return %valid
    }
  }

  op ax.agent.semantic @agent_finalize_citations {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> json"
    body @entry(%state: json, %output: json) {
      %empty_map = core.map
      %empty_list = core.list
      %citations = core.get %state["citations"] default %empty_map
      %enabled = core.get %citations["enabled"] default false
      core.if %enabled {
        %field = core.get %citations["field"] default "evidenceCitations"
        %raw = core.get %output[%field] default %empty_list
        core.set %state["last_citations"] = %raw
        %surface = core.get %citations["surface"] default "output"
        %hidden = core.call intrinsic.eq(%surface, "hidden")
        core.if %hidden {
          core.call intrinsic.map.delete(%output, %field)
        }
      }
      core.return %output
    }
  }

  op ax.agent.semantic @agent_collect_covered_failure_signatures {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    tag "source:src/ax/agent/playbookConfig.ts#collectCoveredFailureSignatures"
    type signature = "(snapshot:json) -> list<string>"
    body @entry(%snapshot: json) {
      %empty_map = core.map
      %empty_list = core.list
      %live_ids = core.map
      %playbook = core.get %snapshot["playbook"] default %empty_map
      %sections = core.get %playbook["sections"] default %empty_map
      %section_names = core.call intrinsic.map.keys(%sections)
      core.for %section_name in %section_names {
        %bullets = core.get %sections[%section_name] default %empty_list
        core.for %bullet in %bullets {
          %bullet_id = core.get %bullet["id"] default null
          %has_bullet_id = core.call intrinsic.is_not_none(%bullet_id)
          core.if %has_bullet_id {
            %bullet_id_text = core.call intrinsic.string.format("{}", %bullet_id)
            core.set %live_ids[%bullet_id_text] = true
          }
        }
      }
      %artifact = core.get %snapshot["artifact"] default %empty_map
      %feedback = core.get %artifact["feedback"] default %empty_list
      %history = core.get %artifact["history"] default %empty_list
      %covered_ids = core.map
      %covered = core.list
      %event_index = core.let 0
      core.for %event in %feedback {
        %example = core.get %event["example"] default %empty_map
        %signatures_raw = core.get %example["failureSignatures"] default %empty_list
        %signatures_is_list = core.type_is %signatures_raw type "list"
        %signatures = core.list
        core.if %signatures_is_list {
          %signatures = core.let %signatures_raw
        }
        %signature_count = core.call intrinsic.len(%signatures)
        %has_signatures = core.call intrinsic.gt(%signature_count, 0)
        core.if %has_signatures {
          %deltas = core.list
          core.for %entry in %history {
            %source = core.get %entry["source"] default ""
            %is_online = core.call intrinsic.eq(%source, "online")
            %entry_index = core.get %entry["exampleIndex"] default -2
            %index_lte = core.call intrinsic.lte(%entry_index, %event_index)
            %index_gte = core.call intrinsic.gte(%entry_index, %event_index)
            %same_index = core.call intrinsic.and(%index_lte, %index_gte)
            %matching_delta = core.call intrinsic.and(%is_online, %same_index)
            core.if %matching_delta {
              core.append %deltas, %entry
            }
          }
          %delta_count = core.call intrinsic.len(%deltas)
          %has_deltas = core.call intrinsic.gt(%delta_count, 0)
          %alive = core.let false
          core.if %has_deltas {
            core.for %delta in %deltas {
              %has_updated_ids = core.call intrinsic.map.contains(%delta, "updatedBulletIds")
              %legacy_delta = core.call intrinsic.not(%has_updated_ids)
              core.if %legacy_delta {
                %alive = core.let true
              } else {
                %updated_ids = core.get %delta["updatedBulletIds"] default %empty_list
                core.for %updated_id in %updated_ids {
                  %updated_id_text = core.call intrinsic.string.format("{}", %updated_id)
                  %still_live = core.call intrinsic.map.contains(%live_ids, %updated_id_text)
                  core.if %still_live {
                    %alive = core.let true
                  }
                }
              }
            }
          } else {
            %curator = core.get %event["curator"] default null
            %curator_ran = core.call intrinsic.is_not_none(%curator)
            %alive = core.let %curator_ran
          }
          core.if %alive {
            core.for %signature in %signatures {
              %signature_text = core.call intrinsic.string.format("{}", %signature)
              %already_covered = core.call intrinsic.map.contains(%covered_ids, %signature_text)
              %newly_covered = core.call intrinsic.not(%already_covered)
              core.if %newly_covered {
                core.set %covered_ids[%signature_text] = true
                core.append %covered, %signature_text
              }
            }
          }
        }
        %next_event_index = core.call intrinsic.add(%event_index, 1)
        %event_index = core.let %next_event_index
      }
      core.return %covered
    }
  }

  op ax.agent.semantic @agent_build_failure_signals {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(state:json) -> list<json>"
    body @entry(%state: json) {
      %empty_list = core.list
      %signals = core.list
      %action_log = core.get %state["action_log"] default %empty_list
      %previous_signature = core.let ""
      core.for %entry in %action_log {
        %is_error = core.call @agent_entry_is_error(%entry)
        core.if %is_error {
          %detail = core.get %entry["error"] default ""
          %detail_empty = core.call intrinsic.eq(%detail, "")
          core.if %detail_empty {
            %detail = core.get %entry["output"] default ""
          }
          %detail_empty = core.call intrinsic.eq(%detail, "")
          core.if %detail_empty {
            %detail = core.get %entry["error_category"] default "runtime error"
          }
          %detail_preview = core.call intrinsic.string.slice(%detail, 0, 200)
          %category = core.get %entry["error_category"] default "runtime_error"
          %signature_detail = core.call intrinsic.string.slice(%detail, 0, 96)
          %signature = core.call intrinsic.string.format("{}:{}", %category, %signature_detail)
          %kind = core.let "error_turn"
          %repeated = core.call intrinsic.eq(%signature, %previous_signature)
          core.if %repeated {
            %kind = core.let "dead_end"
          }
          %signal = core.map
          core.set %signal["kind"] = %kind
          %turn = core.get %entry["turn"] default 0
          core.set %signal["turn"] = %turn
          core.set %signal["signature"] = %signature
          core.set %signal["detail"] = %detail_preview
          %code = core.get %entry["code"] default ""
          %has_code = core.call intrinsic.ne(%code, "")
          core.if %has_code {
            %code_preview = core.call intrinsic.string.slice(%code, 0, 240)
            core.set %signal["code"] = %code_preview
          }
          core.set %signal["occurrences"] = 1
          core.append %signals, %signal
          %previous_signature = core.let %signature
        }
      }
      %function_traces = core.get %state["function_call_traces"] default %empty_list
      core.for %call in %function_traces {
        %status = core.get %call["status"] default "ok"
        %failed = core.call intrinsic.eq(%status, "error")
        core.if %failed {
          %result = core.get %call["result"] default null
          %error_text = core.get %result["error"] default "tool call failed"
          %error_preview = core.call intrinsic.string.slice(%error_text, 0, 120)
          %qualified_name = core.get %call["qualified_name"] default "tool"
          %signature_error = core.call intrinsic.string.slice(%error_text, 0, 60)
          %signature = core.call intrinsic.string.format("{}:{}", %qualified_name, %signature_error)
          %detail = core.call intrinsic.string.format("{} failed: {}", %qualified_name, %error_preview)
          %signal = core.map
          core.set %signal["kind"] = "tool_error"
          core.set %signal["turn"] = 0
          core.set %signal["signature"] = %signature
          core.set %signal["detail"] = %detail
          %arguments = core.get %call["arguments"] default null
          %has_arguments = core.call intrinsic.is_not_none(%arguments)
          core.if %has_arguments {
            %arguments_text = core.call intrinsic.string.format("{}", %arguments)
            %arguments_preview = core.call intrinsic.string.slice(%arguments_text, 0, 240)
            core.set %signal["code"] = %arguments_preview
          }
          core.set %signal["occurrences"] = 1
          core.append %signals, %signal
        }
      }
      core.set %state["failure_signals"] = %signals
      core.return %signals
    }
  }

  op ax.agent.semantic @normalize_agent_completion_payload {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json throws"
    body @entry(%output: json) {
      %completion = core.get %output["completion"] default %output
      %payload = core.get %completion["executorResult"] default %completion
      %type = core.get %payload["type"]
      %is_final = core.call intrinsic.eq(%type, "final")
      %is_respond = core.call intrinsic.eq(%type, "respond")
      %is_clarification = core.call intrinsic.eq(%type, "askClarification")
      %is_completion = core.call intrinsic.or(%is_final, %is_respond)
      %valid = core.call intrinsic.or(%is_completion, %is_clarification)
      %invalid = core.call intrinsic.not(%valid)
      core.if %invalid {
        %message = core.call intrinsic.string.format("agent stage did not return a completion payload (a live model returns prose, but this stage expects a structured completion): pass options.runtime with a code engine so the executor runs model-generated code that calls final(...), or use a client that returns a structured final/askClarification completion. got: {}", %payload)
        %error = core.call intrinsic.error.runtime(%message)
        core.raise %error
      }
      core.return %payload
    }
  }

  op ax.agent.semantic @throw_agent_clarification {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> void throws"
    body @entry(%payload: json, %state: json) {
      %type = core.get %payload["type"]
      %is_clarification = core.call intrinsic.eq(%type, "askClarification")
      core.if %is_clarification {
        %error = core.call intrinsic.agent.clarification_error(%payload, %state)
        core.raise %error
      }
      %none = core.call intrinsic.none()
      core.return %none
    }
  }

  op ax.agent.semantic @merge_agent_chat_log {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json, json, json) -> list<json>"
    body @entry(%state: json, %distiller: json, %executor: json, %responder: json) {
      %logs = core.list
      %distiller_logs = core.call intrinsic.agent.stage_chat_log(%distiller)
      core.for %entry in %distiller_logs {
        core.set %entry["name"] = "distiller"
        core.set %entry["stage"] = "ctx"
        core.append %logs, %entry
      }
      %executor_logs = core.call intrinsic.agent.stage_chat_log(%executor)
      core.for %entry in %executor_logs {
        core.set %entry["name"] = "executor"
        core.set %entry["stage"] = "task"
        core.append %logs, %entry
      }
      %responder_logs = core.call intrinsic.agent.stage_chat_log(%responder)
      core.for %entry in %responder_logs {
        core.set %entry["name"] = "responder"
        core.set %entry["stage"] = "task"
        core.append %logs, %entry
      }
      core.set %state["chat_log"] = %logs
      core.return %logs
    }
  }

  op ax.agent.semantic @merge_agent_usage {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json"
    body @entry(%state: json) {
      %empty_list = core.list
      %chat_log = core.get %state["chat_log"] default %empty_list
      %count = core.call intrinsic.len(%chat_log)
      %usage = core.map
      core.set %usage["chat_log_entries"] = %count
      core.set %state["usage"] = %usage
      core.return %usage
    }
  }

  op ax.agent.semantic @agent_get_state {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json"
    body @entry(%state: json) {
      %empty_map = core.map
      %runtime_state = core.get %state["runtime_state"] default %empty_map
      core.return %runtime_state
    }
  }

  op ax.agent.semantic @agent_set_state {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> json"
    body @entry(%state: json, %runtime_state: json) {
      core.set %state["runtime_state"] = %runtime_state
      core.return %runtime_state
    }
  }

  op ax.agent.semantic @agent_stage_options {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, string, json) -> json"
    body @entry(%state: json, %stage: string, %forward_options: json) {
      %empty_map = core.map
      %base_options = core.get %state["options"] default %empty_map
      %stage_options = core.map
      %is_distiller = core.call intrinsic.eq(%stage, "distiller")
      %is_executor = core.call intrinsic.eq(%stage, "executor")
      %is_responder = core.call intrinsic.eq(%stage, "responder")
      core.if %is_distiller {
        %context_opts_camel = core.get %base_options["contextOptions"] default %empty_map
        %stage_options = core.get %base_options["context_options"] default %context_opts_camel
      }
      core.if %is_executor {
        %executor_opts_camel = core.get %base_options["executorOptions"] default %empty_map
        %stage_options = core.get %base_options["executor_options"] default %executor_opts_camel
      }
      core.if %is_responder {
        %responder_opts_camel = core.get %base_options["responderOptions"] default %empty_map
        %stage_options = core.get %base_options["responder_options"] default %responder_opts_camel
      }
      %out = core.call intrinsic.map.merge(%stage_options, %forward_options)
      %top_cache_snake = core.get %base_options["context_cache"] default null
      %top_cache = core.get %base_options["contextCache"] default %top_cache_snake
      %stage_cache_snake = core.get %stage_options["context_cache"] default null
      %stage_cache = core.get %stage_options["contextCache"] default %stage_cache_snake
      %call_cache_snake = core.get %forward_options["context_cache"] default null
      %call_cache = core.get %forward_options["contextCache"] default %call_cache_snake
      %cache = core.let %top_cache
      %has_stage_cache = core.call intrinsic.is_not_none(%stage_cache)
      core.if %has_stage_cache {
        %cache = core.let %stage_cache
      }
      %has_call_cache = core.call intrinsic.is_not_none(%call_cache)
      core.if %has_call_cache {
        %cache = core.let %call_cache
      }
      %has_cache = core.call intrinsic.is_not_none(%cache)
      core.if %has_cache {
        core.set %out["context_cache"] = %cache
        core.set %out["contextCache"] = %cache
      }
      core.return %out
    }
  }

  op ax.agent.semantic @extract_agent_runtime_code {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> string throws"
    body @entry(%state: json, %executor_output: json) {
      %runtime_contract = core.get %state["runtime_contract"]
      %code_field_name = core.get %runtime_contract["code_field_name"] default "javascriptCode"
      %code = core.get %executor_output[%code_field_name] default ""
      %completion = core.get %executor_output["completion"] default %executor_output
      %completion_code = core.get %completion[%code_field_name] default %code
      %code = core.let %completion_code
      %missing = core.call intrinsic.eq(%code, "")
      core.if %missing {
        %message = core.call intrinsic.string.format("agent executor did not return runtime code field: {}", %code_field_name)
        %error = core.call intrinsic.error.runtime(%message)
        core.raise %error
      }
      core.return %code
    }
  }

  op ax.agent.semantic @agent_apply_llm_checkpoint_summary {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json, json) -> json throws"
    body @entry(%state: json, %client: json, %options: json) {
      %empty_map = core.map
      %checkpoint = core.get %state["checkpoint_state"] default null
      %has_checkpoint = core.call intrinsic.is_not_none(%checkpoint)
      core.if %has_checkpoint {
        %pending = core.get %checkpoint["llm_pending"] default false
        core.if %pending {
          %llm_input = core.get %checkpoint["llm_input"] default ""
          %instruction = core.let "You are an internal AxAgent trajectory summarizer. Compress the execution history into a concise ledger with exactly these labels in order: Objective:, Current state and artifacts:, Exact callables and formats:, Evidence:, User constraints and preferences:, Failures to avoid:, Next step:. Use 'none' when a section is empty. Be concise and factual."
          %messages = core.list
          %sys = core.map
          core.set %sys["role"] = "system"
          core.set %sys["content"] = %instruction
          core.append %messages, %sys
          %usr = core.map
          core.set %usr["role"] = "user"
          core.set %usr["content"] = %llm_input
          core.append %messages, %usr
          %request = core.map
          core.set %request["chat_prompt"] = %messages
          %response = core.call intrinsic.ai.complete_once(%client, %request, %options)
          %text = core.get %response["content"] default ""
          %has_text = core.call intrinsic.ne(%text, "")
          core.if %has_text {
            %updated = core.call intrinsic.map.merge(%empty_map, %checkpoint)
            core.set %updated["summary"] = %text
            core.set %updated["summary_source"] = "model"
            core.set %updated["llm_pending"] = false
            core.set %state["checkpoint_state"] = %updated
          }
        }
      }
      core.return %state
    }
  }

  op ax.agent.semantic @context_map_sections {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "() -> json"
    body @entry {
      %sections = core.list
      %s1 = core.map
      core.set %s1["name"] = "context_roadmap"
      core.set %s1["title"] = "CONTEXT ROADMAP"
      core.set %s1["slug"] = "cr"
      core.append %sections, %s1
      %s2 = core.map
      core.set %s2["name"] = "context_understanding"
      core.set %s2["title"] = "CONTEXT UNDERSTANDING"
      core.set %s2["slug"] = "cu"
      core.append %sections, %s2
      %s3 = core.map
      core.set %s3["name"] = "domain_constants"
      core.set %s3["title"] = "DOMAIN CONSTANTS"
      core.set %s3["slug"] = "dc"
      core.append %sections, %s3
      %s4 = core.map
      core.set %s4["name"] = "parsing_schema"
      core.set %s4["title"] = "PARSING SCHEMA"
      core.set %s4["slug"] = "ps"
      core.append %sections, %s4
      %s5 = core.map
      core.set %s5["name"] = "reusable_results"
      core.set %s5["title"] = "REUSABLE RESULTS"
      core.set %s5["slug"] = "rr"
      core.append %sections, %s5
      %s6 = core.map
      core.set %s6["name"] = "error_patterns"
      core.set %s6["title"] = "ERROR PATTERNS"
      core.set %s6["slug"] = "ep"
      core.append %sections, %s6
      core.return %sections
    }
  }

  op ax.agent.semantic @context_map_parse_items {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json"
    body @entry(%text: json) {
      %sections = core.call @context_map_sections()
      %items = core.list
      %lines = core.call intrinsic.string.split_trim_nonempty(%text, "\n")
      %current = core.let "context_understanding"
      core.for %line in %lines {
        %is_header = core.call intrinsic.string.starts_with(%line, "##")
        core.if %is_header {
          %title_raw = core.call intrinsic.string.replace(%line, "#", "")
          %title = core.string_trim %title_raw
          core.for %sec in %sections {
            %sec_title = core.get %sec["title"]
            %match = core.call intrinsic.eq(%sec_title, %title)
            core.if %match {
              %sec_name = core.get %sec["name"]
              %current = core.let %sec_name
            }
          }
        } else {
          %is_item = core.call intrinsic.string.starts_with(%line, "[")
          core.if %is_item {
            %parts = core.call intrinsic.string.split_once(%line, "]")
            %left = core.get %parts["left"] default ""
            %right = core.get %parts["right"] default ""
            %id_raw = core.call intrinsic.string.replace(%left, "[", "")
            %id = core.string_trim %id_raw
            %content = core.string_trim %right
            %id_ok = core.call intrinsic.ne(%id, "")
            %content_ok = core.call intrinsic.ne(%content, "")
            %valid = core.call intrinsic.and(%id_ok, %content_ok)
            core.if %valid {
              %item = core.map
              core.set %item["id"] = %id
              core.set %item["section"] = %current
              core.set %item["content"] = %content
              core.append %items, %item
            }
          }
        }
      }
      core.return %items
    }
  }

  op ax.agent.semantic @context_map_render_items {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json"
    body @entry(%items: json) {
      %sections = core.call @context_map_sections()
      %parts = core.list
      core.for %sec in %sections {
        %sec_name = core.get %sec["name"]
        %sec_title = core.get %sec["title"]
        %header = core.call intrinsic.string.format("## {}", %sec_title)
        core.append %parts, %header
        core.for %item in %items {
          %item_sec = core.get %item["section"]
          %in_sec = core.call intrinsic.eq(%item_sec, %sec_name)
          core.if %in_sec {
            %id = core.get %item["id"]
            %content = core.get %item["content"]
            %line = core.call intrinsic.string.format("[{}] {}", %id, %content)
            core.append %parts, %line
          }
        }
      }
      %text = core.call intrinsic.string.join("\n", %parts)
      core.return %text
    }
  }

  op ax.agent.semantic @context_map_update_scores {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> json"
    body @entry(%scores: json, %item_tags: json) {
      %empty_map = core.map
      %out = core.call intrinsic.map.merge(%empty_map, %scores)
      %is_obj = core.type_is %item_tags type "object"
      core.if %is_obj {
        core.for %id in %item_tags {
          %tag = core.get %item_tags[%id]
          %cur = core.get %out[%id] default 0
          %is_helpful = core.call intrinsic.eq(%tag, "helpful")
          core.if %is_helpful {
            %up = core.call intrinsic.add(%cur, 1)
            core.set %out[%id] = %up
          }
          %is_harmful = core.call intrinsic.eq(%tag, "harmful")
          core.if %is_harmful {
            %down = core.call intrinsic.add(%cur, -1)
            core.set %out[%id] = %down
          }
          %is_stale = core.call intrinsic.eq(%tag, "stale")
          core.if %is_stale {
            %down2 = core.call intrinsic.add(%cur, -1)
            core.set %out[%id] = %down2
          }
        }
      }
      core.return %out
    }
  }

  op ax.agent.semantic @context_map_apply_operations {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json, json) -> json"
    body @entry(%items: json, %operations: json, %next_id: json) {
      %sections = core.call @context_map_sections()
      %deletes = core.map
      %replaces = core.map
      %raw_adds = core.list
      %is_list = core.type_is %operations type "list"
      core.if %is_list {
        core.for %op in %operations {
          %type = core.get %op["type"] default ""
          %is_delete = core.call intrinsic.eq(%type, "DELETE")
          core.if %is_delete {
            %del_a = core.get %op["item_id"] default ""
            %del_id = core.get %op["itemId"] default %del_a
            core.set %deletes[%del_id] = true
          }
          %is_replace = core.call intrinsic.eq(%type, "REPLACE")
          core.if %is_replace {
            %rep_a = core.get %op["item_id"] default ""
            %rep_id = core.get %op["itemId"] default %rep_a
            %rep_content = core.get %op["content"] default ""
            core.set %replaces[%rep_id] = %rep_content
          }
          %is_add = core.call intrinsic.eq(%type, "ADD")
          core.if %is_add {
            %add_section = core.get %op["section"] default "context_understanding"
            %add_content = core.get %op["content"] default ""
            %content_ok = core.call intrinsic.ne(%add_content, "")
            core.if %content_ok {
              %raw = core.map
              core.set %raw["section"] = %add_section
              core.set %raw["content"] = %add_content
              core.append %raw_adds, %raw
            }
          }
        }
      }
      %result_items = core.list
      core.for %item in %items {
        %id = core.get %item["id"]
        %deleted = core.get %deletes[%id] default false
        %keep = core.call intrinsic.not(%deleted)
        core.if %keep {
          %kept = core.map
          core.set %kept["id"] = %id
          %sec = core.get %item["section"]
          core.set %kept["section"] = %sec
          %new_content = core.get %replaces[%id] default null
          %has_replace = core.call intrinsic.is_not_none(%new_content)
          core.if %has_replace {
            core.set %kept["content"] = %new_content
          } else {
            %old_content = core.get %item["content"]
            core.set %kept["content"] = %old_content
          }
          core.append %result_items, %kept
        }
      }
      %counter = core.let %next_id
      core.for %radd in %raw_adds {
        %radd_section = core.get %radd["section"]
        %radd_content = core.get %radd["content"]
        %slug = core.let "cu"
        core.for %sec in %sections {
          %sname = core.get %sec["name"]
          %smatch = core.call intrinsic.eq(%sname, %radd_section)
          core.if %smatch {
            %sslug = core.get %sec["slug"]
            %slug = core.let %sslug
          }
        }
        %new_id = core.call intrinsic.string.format("{}-{}", %slug, %counter)
        %inc = core.call intrinsic.add(%counter, 1)
        %counter = core.let %inc
        %add_item = core.map
        core.set %add_item["id"] = %new_id
        core.set %add_item["section"] = %radd_section
        core.set %add_item["content"] = %radd_content
        core.append %result_items, %add_item
      }
      %out = core.map
      core.set %out["items"] = %result_items
      core.set %out["next_id"] = %counter
      core.return %out
    }
  }

  op ax.agent.semantic @context_map_evict_to_budget {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json, json) -> json"
    body @entry(%items: json, %scores: json, %max_chars: json) {
      %current = core.let %items
      core.loop {
        %text = core.call @context_map_render_items(%current)
        %len = core.call intrinsic.len(%text)
        %over = core.call intrinsic.gt(%len, %max_chars)
        %not_over = core.call intrinsic.not(%over)
        core.if %not_over {
          core.break
        }
        %count = core.call intrinsic.len(%current)
        %empty = core.call intrinsic.eq(%count, 0)
        core.if %empty {
          core.break
        }
        %min_id = core.let ""
        %min_score = core.let 0
        %have_min = core.let false
        core.for %item in %current {
          %iid = core.get %item["id"]
          %iscore = core.get %scores[%iid] default 0
          %first = core.call intrinsic.not(%have_min)
          %lower = core.call intrinsic.lt(%iscore, %min_score)
          %take = core.call intrinsic.or(%first, %lower)
          core.if %take {
            %min_id = core.let %iid
            %min_score = core.let %iscore
            %have_min = core.let true
          }
        }
        %next_items = core.list
        core.for %item in %current {
          %iid = core.get %item["id"]
          %is_min = core.call intrinsic.eq(%iid, %min_id)
          %keep = core.call intrinsic.not(%is_min)
          core.if %keep {
            core.append %next_items, %item
          }
        }
        %current = core.let %next_items
      }
      core.return %current
    }
  }

  op ax.agent.semantic @format_context_map_trajectory {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json"
    body @entry(%state: json) {
      %empty_list = core.list
      %action_log = core.get %state["action_log"] default %empty_list
      %action_text = core.call intrinsic.json.stable_stringify(%action_log)
      %status_log = core.get %state["status_log"] default %empty_list
      %status_text = core.call intrinsic.json.stable_stringify(%status_log)
      %out = core.call intrinsic.string.format("## Executor Action Log\n{}\n\n## Status Log\n{}", %action_text, %status_text)
      core.return %out
    }
  }

  op ax.agent.semantic @context_map_complete {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json, json, json) -> json throws"
    body @entry(%client: json, %system: json, %user: json, %options: json) {
      %messages = core.list
      %sys = core.map
      core.set %sys["role"] = "system"
      core.set %sys["content"] = %system
      core.append %messages, %sys
      %usr = core.map
      core.set %usr["role"] = "user"
      core.set %usr["content"] = %user
      core.append %messages, %usr
      %request = core.map
      core.set %request["chat_prompt"] = %messages
      %response = core.call intrinsic.ai.complete_once(%client, %request, %options)
      %content = core.get %response["content"] default ""
      core.return %content
    }
  }

  op ax.agent.semantic @context_map_parse_json {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json throws"
    body @entry(%content: json) {
      %empty_map = core.map
      %trimmed = core.string_trim %content
      %is_empty = core.call intrinsic.eq(%trimmed, "")
      core.if %is_empty {
        core.return %empty_map
      }
      %looks_object = core.call intrinsic.string.starts_with(%trimmed, "{")
      %not_object = core.call intrinsic.not(%looks_object)
      core.if %not_object {
        core.return %empty_map
      }
      %parsed = core.call intrinsic.json.parse(%trimmed)
      %is_obj = core.type_is %parsed type "object"
      core.if %is_obj {
        core.return %parsed
      }
      core.return %empty_map
    }
  }

  op ax.agent.semantic @agent_evolve_context_map {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json, json) -> json throws"
    body @entry(%state: json, %client: json, %options: json) {
      %empty_map = core.map
      %empty_list = core.list
      %cm = core.get %state["context_map"] default null
      %has_cm = core.call intrinsic.is_not_none(%cm)
      %infinite = core.get %cm["infiniteEvolve"] default false
      %steps = core.get %cm["steps"] default 0
      %evolve_steps = core.get %cm["evolveSteps"] default 0
      %under_budget = core.call intrinsic.lt(%steps, %evolve_steps)
      %evolve_ok = core.call intrinsic.or(%infinite, %under_budget)
      %should_evolve = core.call intrinsic.and(%has_cm, %evolve_ok)
      core.if %should_evolve {
        %current_text = core.get %cm["text"] default ""
        %scores = core.get %cm["scores"] default %empty_map
        %max_chars = core.get %cm["maxChars"] default 4000
        %next_id = core.get %cm["next_id"] default 1
        %task = core.get %state["task_description"] default ""
        %trajectory = core.call @format_context_map_trajectory(%state)
        %distiller_sys = core.let "You are the context-map Distiller for a recurring external context used by an AxAgent RLM loop.\n\nYour job is to read the completed trajectory and identify reusable orientation knowledge about the external context. The context map is a persistent cache of understanding, not a transcript summary, task playbook, or answer cache.\n\nCache only orientation work: would a future agent asking a completely different question about the same context benefit from knowing this?\n\nReview every existing context-map item before proposing new knowledge. Tag each existing item ID as exactly one of helpful, harmful, neutral, or stale. Treat unused-but-correct domain knowledge as neutral, not harmful.\n\nReturn:\n- diagnosis: concise analysis of orientation work vs. question-specific work.\n- itemTags: object mapping existing context-map item IDs to helpful, harmful, neutral, or stale.\n- cacheCandidates: JSON array of objects with section, value, transferability, and rationale."
        %distiller_user = core.call intrinsic.string.format("task: {}\n\ncontextMap:\n{}\n\ntrajectory:\n{}", %task, %current_text, %trajectory)
        %distiller_resp = core.call @context_map_complete(%client, %distiller_sys, %distiller_user, %options)
        %distiller_parsed = core.call @context_map_parse_json(%distiller_resp)
        %item_tags = core.get %distiller_parsed["itemTags"] default %empty_map
        %reflection = core.call intrinsic.json.stringify(%distiller_parsed)
        %current_chars = core.call intrinsic.len(%current_text)
        %carto_sys = core.let "You are the context-map Cartographer for a recurring external context used by an AxAgent RLM loop.\n\nTranslate the Distiller reflection into a small set of concrete context-map edits. Maintain a concise, high-value context map that stores shared understanding of the external context, not answers to individual questions.\n\nPrefer REPLACE over ADD when an existing item can be made more correct, compact, or general. DELETE stale, misleading, redundant, low-value, verbose, or question-specific items. ADD only transferable context understanding. When the map is near or over budget, remove or rewrite low-value entries first. If nothing is worth keeping, return an empty operations list.\n\nReturn operations as JSON objects under the key operations:\n- {\"type\":\"ADD\",\"section\":\"context_understanding\",\"content\":\"...\"}\n- {\"type\":\"DELETE\",\"item_id\":\"cu-1\"}\n- {\"type\":\"REPLACE\",\"item_id\":\"cu-1\",\"content\":\"...\"}"
        %carto_user_head = core.call intrinsic.string.format("task: {}\n\ncontextMap:\n{}\n\ndistillerReflection:\n{}", %task, %current_text, %reflection)
        %carto_user = core.call intrinsic.string.format("{}\n\ncurrentChars: {}\nmaxChars: {}", %carto_user_head, %current_chars, %max_chars)
        %carto_resp = core.call @context_map_complete(%client, %carto_sys, %carto_user, %options)
        %carto_parsed = core.call @context_map_parse_json(%carto_resp)
        %operations = core.get %carto_parsed["operations"] default %empty_list
        %items = core.call @context_map_parse_items(%current_text)
        %new_scores = core.call @context_map_update_scores(%scores, %item_tags)
        %applied = core.call @context_map_apply_operations(%items, %operations, %next_id)
        %new_items = core.get %applied["items"] default %empty_list
        %new_next_id = core.get %applied["next_id"] default %next_id
        %evicted = core.call @context_map_evict_to_budget(%new_items, %new_scores, %max_chars)
        %new_text = core.call @context_map_render_items(%evicted)
        %new_steps = core.call intrinsic.add(%steps, 1)
        %updated = core.call intrinsic.map.merge(%empty_map, %cm)
        core.set %updated["text"] = %new_text
        core.set %updated["scores"] = %new_scores
        core.set %updated["steps"] = %new_steps
        core.set %updated["next_id"] = %new_next_id
        core.set %state["context_map"] = %updated
      }
      core.return %state
    }
  }

  op ax.agent.semantic @agent_transcribe_one_audio {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json, json, json) -> json throws"
    body @entry(%client: json, %audio: json, %transcribe_opts: json, %options: json) {
      %empty_map = core.map
      %is_object = core.type_is %audio type "object"
      core.if %is_object {
        %has_data = core.call intrinsic.map.contains(%audio, "data")
        core.if %has_data {
          %request = core.call intrinsic.map.merge(%empty_map, %transcribe_opts)
          core.set %request["audio"] = %audio
          %response = core.call intrinsic.agent.transcribe(%client, %request, %options)
          %text = core.get %response["text"] default ""
          core.return %text
        }
      }
      core.return %audio
    }
  }

  op ax.agent.semantic @agent_transcribe_audio_inputs {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json, json, json) -> json throws"
    body @entry(%state: json, %client: json, %values: json, %options: json) {
      %empty_list = core.list
      %empty_map = core.map
      %sig = core.get %state["signature"] default %empty_map
      %input_fields = core.get %sig["input_fields"] default %empty_list
      %speech = core.get %options["speech"] default %empty_map
      %transcribe_opts = core.get %speech["transcribe"] default %empty_map
      %result = core.call intrinsic.map.merge(%empty_map, %values)
      core.for %field in %input_fields {
        %ftype = core.get %field["type"] default %empty_map
        %tname = core.get %ftype["name"] default ""
        %is_audio = core.call intrinsic.eq(%tname, "audio")
        core.if %is_audio {
          %fname = core.get %field["name"]
          %has = core.call intrinsic.map.contains(%result, %fname)
          core.if %has {
            %value = core.get %result[%fname]
            %is_string = core.type_is %value type "string"
            %is_list = core.type_is %value type "list"
            core.if %is_list {
              %transcribed = core.list
              core.for %item in %value {
                %item_text = core.call @agent_transcribe_one_audio(%client, %item, %transcribe_opts, %options)
                core.append %transcribed, %item_text
              }
              core.set %result[%fname] = %transcribed
            } else {
              %do_single = core.call intrinsic.not(%is_string)
              core.if %do_single {
                %text = core.call @agent_transcribe_one_audio(%client, %value, %transcribe_opts, %options)
                core.set %result[%fname] = %text
              }
            }
          }
        }
      }
      core.return %result
    }
  }

  op ax.agent.semantic @agent_run_llm_query_one {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json, json) -> string throws"
    body @entry(%sub_gen: json, %client: json, %item: json) {
      %empty_map = core.map
      %query = core.let ""
      %context = core.let %empty_map
      %item_is_string = core.type_is %item type "string"
      core.if %item_is_string {
        %query = core.let %item
      } else {
        %query = core.get %item["query"] default ""
        %context = core.get %item["context"] default %empty_map
      }
      %values = core.map
      core.set %values["task"] = %query
      core.set %values["context"] = %context
      %sub_options = core.map
      %output = core.call intrinsic.agent.stage_forward(%sub_gen, %client, %values, %sub_options)
      %answer = core.get %output["answer"] default ""
      core.return %answer
    }
  }

  op ax.agent.semantic @agent_run_llm_query {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json, json) -> json throws"
    body @entry(%sub_gen: json, %client: json, %params: json) {
      %params_is_list = core.type_is %params type "list"
      core.if %params_is_list {
        %answers = core.list
        core.for %item in %params {
          %one = core.call @agent_run_llm_query_one(%sub_gen, %client, %item)
          core.append %answers, %one
        }
        core.return %answers
      }
      %single = core.call @agent_run_llm_query_one(%sub_gen, %client, %params)
      core.return %single
    }
  }

  op ax.agent.semantic @agent_forward {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json, json, json, json, json, json) -> json throws"
    body @entry(%state: json, %distiller: json, %executor: json, %responder: json, %client: json, %values: json, %options: json) {
      %empty_list = core.list
      %empty_map = core.map
      %loaded_memories = core.list
      %used_memories = core.list
      %used_skills = core.list
      %relevance_hints_for_turn = core.call intrinsic.none()
      core.set %state["loaded_memories"] = %loaded_memories
      core.set %state["used_memories"] = %used_memories
      core.set %state["used_skills"] = %used_skills
      core.set %state["relevance_hints_for_turn"] = %relevance_hints_for_turn
      %preset_memories = core.get %values["memories"] default %empty_list
      %loaded_memories = core.call @agent_merge_memory_results(%loaded_memories, %preset_memories)
      core.set %state["loaded_memories"] = %loaded_memories
      %loaded_skills = core.get %state["loaded_skill_docs"] default %empty_list
      %forward_skills = core.get %options["skills"] default %empty_list
      %loaded_skills = core.call @agent_merge_skill_results(%loaded_skills, %forward_skills)
      core.set %state["loaded_skill_docs"] = %loaded_skills
      %flags = core.get %state["policy_flags"] default %empty_map
      %forward_used_memories = core.get %options["onUsedMemories"] default null
      %forward_used_memories_snake = core.get %options["on_used_memories"] default %forward_used_memories
      %forward_used_skills = core.get %options["onUsedSkills"] default null
      %forward_used_skills_snake = core.get %options["on_used_skills"] default %forward_used_skills
      %has_forward_used_memories = core.call intrinsic.is_not_none(%forward_used_memories_snake)
      %has_forward_used_skills = core.call intrinsic.is_not_none(%forward_used_skills_snake)
      %has_forward_used_observer = core.call intrinsic.or(%has_forward_used_memories, %has_forward_used_skills)
      core.if %has_forward_used_observer {
        core.set %flags["usageTrackingMode"] = true
        core.set %state["policy_flags"] = %flags
      }
      %direct_respond_only = core.get %flags["directRespondOnly"] default false
      core.if %direct_respond_only {
        %distiller_skills = core.get %state["distiller_loaded_skill_docs"] default %empty_list
        %distiller_skills = core.call @agent_merge_skill_results(%distiller_skills, %forward_skills)
        core.set %state["distiller_loaded_skill_docs"] = %distiller_skills
      }
      core.set %state["active_stage"] = "distiller"
      %transcribed_values = core.call @agent_transcribe_audio_inputs(%state, %client, %values, %options)
      %values = core.let %transcribed_values
      %runtime_input_names = core.list
      core.for %runtime_input_name in %values {
        core.append %runtime_input_names, %runtime_input_name
      }
      core.set %state["runtime_input_names"] = %runtime_input_names
      %previous_runtime_session_state = core.get %state["runtime_session_state"] default null
      %previous_runtime_session_state_is_map = core.type_is %previous_runtime_session_state type "object"
      core.if %previous_runtime_session_state_is_map {
        %previous_runtime_globals = core.get %previous_runtime_session_state["globals"] default null
        %previous_runtime_bindings = core.get %previous_runtime_session_state["bindings"] default null
        %previous_runtime_globals_is_map = core.type_is %previous_runtime_globals type "object"
        %previous_runtime_bindings_is_map = core.type_is %previous_runtime_bindings type "object"
        %previous_runtime_state_has_bindings = core.call intrinsic.or(%previous_runtime_globals_is_map, %previous_runtime_bindings_is_map)
        core.if %previous_runtime_state_has_bindings {
          %clean_previous_runtime_state = core.call @normalize_agent_runtime_snapshot(%state, %previous_runtime_session_state)
          core.set %state["runtime_session_state"] = %clean_previous_runtime_state
        }
      }
      core.call @agent_begin_trace(%state, %values)
      core.call @agent_apply_llm_checkpoint_summary(%state, %client, %options)
      %state_options = core.get %state["options"]
      %runtime_from_state = core.get %state_options["runtime"] default null
      %runtime_from_options = core.get %options["runtime"] default %runtime_from_state
      %runtime_enabled = core.call intrinsic.is_not_none(%runtime_from_options)
      %distiller_options = core.call @agent_stage_options(%state, "distiller", %options)
      %executor_options = core.call @agent_stage_options(%state, "executor", %options)
      %responder_options = core.call @agent_stage_options(%state, "responder", %options)
      %distiller_payload = core.call intrinsic.none()
      core.if %runtime_enabled {
        %distiller_empty_log = core.list
        %distiller_saved_action_log = core.get %state["action_log"] default %distiller_empty_log
        %distiller_globals = core.call @agent_runtime_build_globals(%state, %values)
        %distiller_session = core.call intrinsic.none()
        %distiller_max_steps = core.get %options["max_actor_steps"] default 4
        %distiller_step = core.let 0
        core.loop {
          %distiller_too_many = core.call intrinsic.gte(%distiller_step, %distiller_max_steps)
          core.if %distiller_too_many {
            %distiller_error_event = core.map
            core.set %distiller_error_event["error"] = "agent distiller loop exceeded max steps"
            core.set %distiller_error_event["stage"] = "distiller"
            core.call @agent_record_trace_event(%state, "error", %distiller_error_event)
            %distiller_error = core.call intrinsic.error.runtime("agent distiller loop exceeded max steps")
            core.raise %distiller_error
          }
          %distiller_values = core.call @build_distiller_inputs(%state, %values)
          %distiller_request_event = core.map
          core.set %distiller_request_event["stage"] = "distiller"
          core.set %distiller_request_event["step"] = %distiller_step
          core.set %distiller_request_event["values"] = %distiller_values
          core.set %distiller_request_event["component_id"] = "agent.stage.distiller"
          core.call @agent_record_trace_event(%state, "stage_request", %distiller_request_event)
          %distiller_output = core.call intrinsic.agent.stage_forward(%distiller, %client, %distiller_values, %distiller_options)
          %distiller_response_event = core.map
          core.set %distiller_response_event["stage"] = "distiller"
          core.set %distiller_response_event["step"] = %distiller_step
          core.set %distiller_response_event["output"] = %distiller_output
          core.set %distiller_response_event["component_id"] = "agent.stage.distiller"
          core.call @agent_record_trace_event(%state, "stage_response", %distiller_response_event)
          %distiller_code = core.call @extract_agent_runtime_code(%state, %distiller_output)
          %distiller_runtime_step = core.call @agent_runtime_execute_step(%state, %runtime_from_options, %distiller_session, %distiller_code, %options)
          %distiller_session = core.get %state["runtime_session"] default %distiller_session
          %distiller_step_error = core.get %distiller_runtime_step["is_error"] default false
          %distiller_step_ok = core.call intrinsic.not(%distiller_step_error)
          core.if %distiller_step_ok {
            core.call @agent_runtime_refresh_state_summary(%state, %distiller_session, %options)
          }
          %distiller_completion = core.get %distiller_runtime_step["completion_payload"] default null
          %distiller_has_completion = core.type_is %distiller_completion type "object"
          core.if %distiller_has_completion {
            %distiller_payload = core.let %distiller_completion
            core.break
          }
          %distiller_step = core.call intrinsic.add(%distiller_step, 1)
        }
        %shared_contract = core.get %state["runtime_contract"] default null
        %shared_js = core.get %shared_contract["is_javascript"] default true
        core.if %shared_js {
          core.set %state["runtime_session"] = %distiller_session
        } else {
          %distiller_session_reset = core.call intrinsic.none()
          core.set %state["runtime_session"] = %distiller_session_reset
          %distiller_state_reset = core.map
          core.set %state["runtime_session_state"] = %distiller_state_reset
        }
        core.set %state["action_log"] = %distiller_saved_action_log
      } else {
        %distiller_values = core.call @build_distiller_inputs(%state, %values)
        %distiller_request_event = core.map
        core.set %distiller_request_event["stage"] = "distiller"
        core.set %distiller_request_event["values"] = %distiller_values
        core.set %distiller_request_event["component_id"] = "agent.stage.distiller"
        core.call @agent_record_trace_event(%state, "stage_request", %distiller_request_event)
        %distiller_output = core.call intrinsic.agent.stage_forward(%distiller, %client, %distiller_values, %distiller_options)
        %distiller_response_event = core.map
        core.set %distiller_response_event["stage"] = "distiller"
        core.set %distiller_response_event["output"] = %distiller_output
        core.set %distiller_response_event["component_id"] = "agent.stage.distiller"
        core.call @agent_record_trace_event(%state, "stage_response", %distiller_response_event)
        %distiller_payload = core.call @normalize_agent_completion_payload(%distiller_output)
      }
      core.call @throw_agent_clarification(%distiller_payload, %state)
      %distiller_skills_after = core.get %state["distiller_loaded_skill_docs"] default %empty_list
      %executor_skills_after = core.get %state["loaded_skill_docs"] default %empty_list
      %executor_skills_after = core.call @agent_merge_skill_results(%executor_skills_after, %distiller_skills_after)
      core.set %state["loaded_skill_docs"] = %executor_skills_after
      core.set %state["active_stage"] = "executor"
      %executor_payload = core.call intrinsic.none()
      %distiller_payload_type = core.get %distiller_payload["type"] default ""
      %distiller_is_respond = core.call intrinsic.eq(%distiller_payload_type, "respond")
      core.if %distiller_is_respond {
        %skip_empty_map = core.map
        %skip_policy_flags = core.get %state["policy_flags"] default %skip_empty_map
        %skip_enabled = core.get %skip_policy_flags["directRespondEnabled"] default true
        %skip_disabled = core.call intrinsic.not(%skip_enabled)
        core.if %skip_disabled {
          %skip_error = core.call intrinsic.error.runtime("agent distiller produced a respond() payload while directResponse is 'off'")
          core.raise %skip_error
        }
        %skip_args_empty = core.list
        %skip_args = core.get %distiller_payload["args"] default %skip_args_empty
        %skip_payload = core.map
        core.set %skip_payload["type"] = "final"
        core.set %skip_payload["args"] = %skip_args
        %executor_payload = core.let %skip_payload
        %skip_event = core.map
        core.set %skip_event["stage"] = "executor"
        core.set %skip_event["reason"] = "direct_respond"
        core.set %skip_event["component_id"] = "agent.stage.executor"
        core.call @agent_record_trace_event(%state, "stage_skipped", %skip_event)
      }
      %run_executor = core.call intrinsic.not(%distiller_is_respond)
      %runtime_executor_enabled = core.call intrinsic.and(%run_executor, %runtime_enabled)
      core.if %runtime_executor_enabled {
        %exec_empty_map = core.map
        %exec_empty_list = core.list
        %exec_args = core.get %distiller_payload["args"] default %exec_empty_list
        %exec_non_ctx_split = core.call @split_context_values(%state, %values)
        %exec_non_ctx = core.get %exec_non_ctx_split["values"] default %exec_empty_map
        %exec_fallback_req = core.call intrinsic.json.stringify(%exec_non_ctx)
        %exec_req_raw = core.call intrinsic.list.get(%exec_args, 0, %exec_fallback_req)
        %exec_req_is_string = core.type_is %exec_req_raw type "string"
        %exec_req = core.let %exec_req_raw
        core.if %exec_req_is_string {
        } else {
          %exec_req_coerced = core.call intrinsic.string.format("{}", %exec_req_raw)
          %exec_req = core.let %exec_req_coerced
        }
        %exec_distilled = core.call intrinsic.list.get(%exec_args, 1, %exec_empty_map)
        %exec_extras = core.map
        core.set %exec_extras["executorRequest"] = %exec_req
        core.set %exec_extras["distilledContext"] = %exec_distilled
        %exec_runtime_values = core.call intrinsic.map.merge(%values, %exec_extras)
        %globals = core.call @agent_runtime_build_globals(%state, %exec_runtime_values)
        %session = core.get %state["runtime_session"] default null
        %has_shared_session = core.call intrinsic.is_not_none(%session)
        core.if %has_shared_session {
          %patch_snapshot = core.map
          core.set %patch_snapshot["globals"] = %globals
          core.call @agent_runtime_restore_session_state(%state, %session, %patch_snapshot, %options)
        }
        %max_steps = core.get %options["max_actor_steps"] default 4
        %step = core.let 0
        core.loop {
          %too_many = core.call intrinsic.gte(%step, %max_steps)
          core.if %too_many {
            %error_event = core.map
            core.set %error_event["error"] = "agent actor loop exceeded max steps"
            core.set %error_event["stage"] = "executor"
            core.call @agent_record_trace_event(%state, "error", %error_event)
            %error = core.call intrinsic.error.runtime("agent actor loop exceeded max steps")
            core.raise %error
          }
          %executor_values = core.call @build_executor_inputs(%state, %values, %distiller_payload)
          %executor_request_event = core.map
          core.set %executor_request_event["stage"] = "executor"
          core.set %executor_request_event["step"] = %step
          core.set %executor_request_event["values"] = %executor_values
          core.set %executor_request_event["component_id"] = "agent.stage.executor"
          core.call @agent_record_trace_event(%state, "stage_request", %executor_request_event)
          %executor_output = core.call intrinsic.agent.stage_forward(%executor, %client, %executor_values, %executor_options)
          %executor_response_event = core.map
          core.set %executor_response_event["stage"] = "executor"
          core.set %executor_response_event["step"] = %step
          core.set %executor_response_event["output"] = %executor_output
          core.set %executor_response_event["component_id"] = "agent.stage.executor"
          core.call @agent_record_trace_event(%state, "stage_response", %executor_response_event)
          %code = core.call @extract_agent_runtime_code(%state, %executor_output)
          %runtime_step = core.call @agent_runtime_execute_step(%state, %runtime_from_options, %session, %code, %options)
          %session = core.get %state["runtime_session"] default %session
          %exec_step_error = core.get %runtime_step["is_error"] default false
          %exec_step_ok = core.call intrinsic.not(%exec_step_error)
          core.if %exec_step_ok {
            core.call @agent_runtime_refresh_state_summary(%state, %session, %options)
          }
          %completion_payload = core.get %runtime_step["completion_payload"] default null
          %has_completion = core.type_is %completion_payload type "object"
          core.if %has_completion {
            %executor_completion_type = core.get %completion_payload["type"] default ""
            %executor_completion_is_respond = core.call intrinsic.eq(%executor_completion_type, "respond")
            core.if %executor_completion_is_respond {
              core.set %completion_payload["type"] = "final"
            }
            core.call @throw_agent_clarification(%completion_payload, %state)
            %executor_payload = core.let %completion_payload
            core.break
          }
          %step = core.call intrinsic.add(%step, 1)
        }
      }
      %runtime_disabled = core.call intrinsic.not(%runtime_enabled)
      %non_runtime_executor = core.call intrinsic.and(%run_executor, %runtime_disabled)
      core.if %non_runtime_executor {
        %executor_values = core.call @build_executor_inputs(%state, %values, %distiller_payload)
        %executor_request_event = core.map
        core.set %executor_request_event["stage"] = "executor"
        core.set %executor_request_event["values"] = %executor_values
        core.set %executor_request_event["component_id"] = "agent.stage.executor"
        core.call @agent_record_trace_event(%state, "stage_request", %executor_request_event)
        %executor_output = core.call intrinsic.agent.stage_forward(%executor, %client, %executor_values, %executor_options)
        %executor_response_event = core.map
        core.set %executor_response_event["stage"] = "executor"
        core.set %executor_response_event["output"] = %executor_output
        core.set %executor_response_event["component_id"] = "agent.stage.executor"
        core.call @agent_record_trace_event(%state, "stage_response", %executor_response_event)
        %executor_payload = core.call @normalize_agent_completion_payload(%executor_output)
        core.call @throw_agent_clarification(%executor_payload, %state)
        %executor_payload_type = core.get %executor_payload["type"] default ""
        %executor_payload_is_respond = core.call intrinsic.eq(%executor_payload_type, "respond")
        core.if %executor_payload_is_respond {
          core.set %executor_payload["type"] = "final"
        }
      }
      core.call @agent_apply_llm_checkpoint_summary(%state, %client, %options)
      core.call @agent_apply_context_management(%state)
      core.call @agent_apply_llm_tombstone_summary(%state, %client, %options)
      core.call @agent_evolve_context_map(%state, %client, %options)
      %responder_values = core.call @build_responder_inputs(%state, %values, %executor_payload)
      %responder_request_event = core.map
      core.set %responder_request_event["stage"] = "responder"
      core.set %responder_request_event["values"] = %responder_values
      core.set %responder_request_event["component_id"] = "agent.stage.responder"
      core.call @agent_record_trace_event(%state, "stage_request", %responder_request_event)
      %responder_output = core.call intrinsic.agent.stage_forward(%responder, %client, %responder_values, %responder_options)
      %citation_retry_options = core.map
      %citation_retry_options = core.call intrinsic.map.merge(%citation_retry_options, %responder_options)
      %citations_valid = core.call @agent_validate_citations(%state, %responder_output)
      %citations_invalid = core.call intrinsic.not(%citations_valid)
      core.if %citations_invalid {
        %invalid_citations_output = core.call intrinsic.json.stringify(%responder_output)
        %citation_retry_feedback = core.call intrinsic.string.format("The previous responder output failed evidence-citation validation: {}. Cite only exact top-level evidence keys or permitted nested record ids present in contextData.evidence, or leave citations empty. Return only corrected JSON.", %invalid_citations_output)
        core.set %citation_retry_options["validation_feedback"] = %citation_retry_feedback
        %responder_output = core.call intrinsic.agent.stage_forward(%responder, %client, %responder_values, %citation_retry_options)
        %citations_valid = core.call @agent_validate_citations(%state, %responder_output)
      }
      %citations_invalid = core.call intrinsic.not(%citations_valid)
      core.if %citations_invalid {
        %invalid_citations_output = core.call intrinsic.json.stringify(%responder_output)
        %citation_retry_feedback = core.call intrinsic.string.format("The previous responder output failed evidence-citation validation: {}. Cite only exact top-level evidence keys or permitted nested record ids present in contextData.evidence, or leave citations empty. Return only corrected JSON.", %invalid_citations_output)
        core.set %citation_retry_options["validation_feedback"] = %citation_retry_feedback
        %responder_output = core.call intrinsic.agent.stage_forward(%responder, %client, %responder_values, %citation_retry_options)
        %citations_valid = core.call @agent_validate_citations(%state, %responder_output)
      }
      %citations_invalid = core.call intrinsic.not(%citations_valid)
      core.if %citations_invalid {
        %error = core.call intrinsic.error.runtime("AxAgent responder returned citations that do not exist in the run evidence")
        core.raise %error
      }
      %responder_output = core.call @agent_finalize_citations(%state, %responder_output)
      %responder_response_event = core.map
      core.set %responder_response_event["stage"] = "responder"
      core.set %responder_response_event["output"] = %responder_output
      core.set %responder_response_event["component_id"] = "agent.stage.responder"
      core.call @agent_record_trace_event(%state, "stage_response", %responder_response_event)
      %logs = core.call @merge_agent_chat_log(%state, %distiller, %executor, %responder)
      %usage = core.call @merge_agent_usage(%state)
      core.set %state["last_output"] = %responder_output
      core.set %state["chat_log"] = %logs
      core.set %state["usage"] = %usage
      %forward_used_memories = core.get %state["used_memories"] default %empty_list
      %forward_used_skills = core.get %state["used_skills"] default %empty_list
      core.call intrinsic.agent.observer.notify(%state, %options, "used_memories", %forward_used_memories)
      core.call intrinsic.agent.observer.notify(%state, %options, "used_skills", %forward_used_skills)
      core.call @agent_build_failure_signals(%state)
      core.call @agent_finalize_trace(%state, "completed", %responder_output)
      core.return %responder_output
    }
  }
}
