  op ax.agent.policy @record_policy_event {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, string, json) -> void"
    body @entry(%state: json, %action: string, %payload: json) {
      %empty_list = core.list
      %trace = core.get %state["policy_trace"] default %empty_list
      %event = core.map
      core.set %event["type"] = "policy_event"
      core.set %event["action"] = %action
      core.set %event["payload"] = %payload
      core.append %trace, %event
      core.set %state["policy_trace"] = %trace
      %none = core.call intrinsic.none()
      core.return %none
    }
  }

  op ax.agent.policy @normalize_policy_action_result {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(string, json) -> json"
    body @entry(%action: string, %payload: json) {
      %out = core.map
      %null_value = core.call intrinsic.none()
      %vocabulary = core.call @agent_policy_vocabulary_registry()
      %empty_list = core.list
      %effect_only_actions = core.get %vocabulary["effect_only_actions"] default %empty_list
      core.set %out["action"] = %action
      core.set %out["payload"] = %payload
      %is_effect = core.call intrinsic.contains(%effect_only_actions, %action)
      core.if %is_effect {
        core.set %out["returns"] = %null_value
        core.set %out["effect_only"] = true
      } else {
        core.set %out["returns"] = %payload
        core.set %out["effect_only"] = false
      }
      core.return %out
    }
  }

  op ax.agent.policy @build_agent_actor_prompt_policy {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json"
    body @entry(%state: json) {
      %runtime_contract = core.get %state["runtime_contract"]
      %code_field_name = core.get %runtime_contract["code_field_name"] default "javascriptCode"
      %code_field_title = core.get %runtime_contract["code_field_title"] default "Javascript Code"
      %code_fence_language = core.get %runtime_contract["code_fence_language"] default "js"
      %empty_map = core.map
      %flags = core.get %state["policy_flags"] default %empty_map
      %relevance_hints_enabled = core.get %flags["relevanceHintsEnabled"] default false
      %stable = core.list
      core.append %stable, "input"
      core.append %stable, "executorRequest"
      core.append %stable, "distilledContextSummary"
      core.append %stable, "contextMetadata"
      core.append %stable, "contextMap"
      core.append %stable, "memories"
      core.append %stable, "discoveredToolDocs"
      core.append %stable, "loadedSkills"
      core.append %stable, "summarizedActorLog"
      %dynamic = core.list
      core.append %dynamic, "guidanceLog"
      core.append %dynamic, "actionLog"
      core.if %relevance_hints_enabled {
        core.append %dynamic, "relevanceHints"
      }
      core.append %dynamic, "liveRuntimeState"
      core.append %dynamic, "contextPressure"
      %out = core.map
      core.set %out["stable_cached_fields"] = %stable
      core.set %out["dynamic_uncached_fields"] = %dynamic
      core.set %out["code_field_name"] = %code_field_name
      core.set %out["code_field_title"] = %code_field_title
      core.set %out["code_fence_language"] = %code_fence_language
      core.set %out["cache_order"] = "stable_before_dynamic"
      core.return %out
    }
  }

  op ax.agent.semantic @resolve_agent_context_policy {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json throws"
    body @entry(%options: json) {
      %empty_map = core.map
      %context_registry = core.call @agent_context_policy_registry()
      %option_keys = core.get %context_registry["option_keys"] default %empty_map
      %policy_camel_key = core.get %option_keys["camel"] default "contextPolicy"
      %policy_snake_key = core.get %option_keys["snake"] default "context_policy"
      %preset_key = core.get %option_keys["preset"] default "preset"
      %budget_key = core.get %option_keys["budget"] default "budget"
      %summarizer_camel_key = core.get %option_keys["summarizer_camel"] default "summarizerOptions"
      %summarizer_snake_key = core.get %option_keys["summarizer_snake"] default "summarizer_options"
      %max_runtime_camel_key = core.get %option_keys["max_runtime_camel"] default "maxRuntimeChars"
      %max_runtime_snake_key = core.get %option_keys["max_runtime_snake"] default "max_runtime_chars"
      %policy_camel = core.get %options[%policy_camel_key] default %empty_map
      %policy = core.get %options[%policy_snake_key] default %policy_camel
      %policy_is_map = core.type_is %policy type "object"
      core.if %policy_is_map {
      } else {
        %policy = core.let %empty_map
      }
      %allowed_keys = core.get %context_registry["allowed_keys"] default null
      %allowed_is_list = core.type_is %allowed_keys type "list"
      core.if %allowed_is_list {
      } else {
        %allowed_keys = core.list
      }
      core.for %key in %policy {
        %allowed = core.call intrinsic.contains(%allowed_keys, %key)
        %disallowed = core.call intrinsic.not(%allowed)
        core.if %disallowed {
          %error_message = core.call @agent_context_policy_migration_error(%key)
          %error_policy = core.call intrinsic.error.runtime(%error_message)
          core.raise %error_policy
        }
      }
      %default_preset = core.get %context_registry["default_preset"] default "checkpointed"
      %default_budget = core.get %context_registry["default_budget"] default "balanced"
      %preset = core.get %policy[%preset_key] default %default_preset
      %budget = core.get %policy[%budget_key] default %default_budget
      %budget_profile = core.call @agent_context_budget_profile(%budget)
      %preset_profile = core.call @agent_context_preset_profile(%preset)
      %target_prompt_chars = core.get %budget_profile["targetPromptChars"] default 16000
      %inspect_threshold = core.get %budget_profile["inspectThreshold"] default 13600
      %action_replay = core.get %preset_profile["actionReplay"] default "full"
      %recent_by_budget = core.get %preset_profile["recentFullActionsByBudget"] default %empty_map
      %recent_default = core.get %preset_profile["recentFullActions"] default 1
      %recent_full_actions = core.get %recent_by_budget[%budget] default %recent_default
      %error_pruning = core.get %preset_profile["errorPruning"] default false
      %hindsight = core.get %preset_profile["hindsight"] default false
      %prune_rank = core.get %preset_profile["pruneRank"] default 2
      %state_summary_enabled = core.get %preset_profile["stateSummary"] default false
      %inspect_enabled = core.get %preset_profile["inspect"] default false
      %max_entries = core.get %preset_profile["maxEntries"] default null
      %hygiene_default = core.get %preset_profile["defaultHygieneMode"] default "none"
      %hygiene_pressure = core.get %preset_profile["pressureHygieneMode"] default null
      %checkpoints_enabled = core.get %preset_profile["checkpointsEnabled"] default false
      %checkpoint_trigger = core.call intrinsic.none()
      core.if %checkpoints_enabled {
        %checkpoint_ratio = core.get %preset_profile["checkpointTriggerRatio"] default null
        %has_checkpoint_ratio = core.call intrinsic.is_not_none(%checkpoint_ratio)
        core.if %has_checkpoint_ratio {
          %checkpoint_trigger = core.call intrinsic.mul(%target_prompt_chars, %checkpoint_ratio)
        }
      }
      %summarizer_camel = core.get %options[%summarizer_camel_key] default %empty_map
      %summarizer_options = core.get %options[%summarizer_snake_key] default %summarizer_camel
      %max_runtime_snake = core.get %options[%max_runtime_snake_key] default null
      %max_runtime_chars = core.get %options[%max_runtime_camel_key] default %max_runtime_snake
      %has_max_runtime = core.call intrinsic.is_not_none(%max_runtime_chars)
      core.if %has_max_runtime {
      } else {
        %max_runtime_chars = core.get %context_registry["default_max_runtime_chars"] default 3000
      }
      %context_hygiene = core.map
      core.set %context_hygiene["defaultMode"] = %hygiene_default
      %has_pressure = core.call intrinsic.is_not_none(%hygiene_pressure)
      core.if %has_pressure {
        core.set %context_hygiene["pressureMode"] = %hygiene_pressure
      }
      %state_summary = core.map
      core.set %state_summary["enabled"] = %state_summary_enabled
      core.set %state_summary["maxEntries"] = %max_entries
      %state_summary_max_chars = core.get %context_registry["state_summary_max_chars"] default 1200
      core.set %state_summary["maxChars"] = %state_summary_max_chars
      %state_inspection = core.map
      core.set %state_inspection["enabled"] = %inspect_enabled
      core.set %state_inspection["contextThreshold"] = %inspect_threshold
      %checkpoints = core.map
      core.set %checkpoints["enabled"] = %checkpoints_enabled
      core.set %checkpoints["triggerChars"] = %checkpoint_trigger
      %out = core.map
      %none_value = core.call intrinsic.none()
      core.set %out["preset"] = %preset
      core.set %out["budget"] = %budget
      core.set %out["summarizerOptions"] = %summarizer_options
      core.set %out["actionReplay"] = %action_replay
      core.set %out["recentFullActions"] = %recent_full_actions
      core.set %out["contextHygiene"] = %context_hygiene
      core.set %out["errorPruning"] = %error_pruning
      core.set %out["hindsightEvaluation"] = %hindsight
      core.set %out["pruneRank"] = %prune_rank
      core.set %out["rankPruneGraceTurns"] = 2
      %tombstoning_opt = core.get %options["tombstoning"] default %none_value
      core.set %out["tombstoning"] = %tombstoning_opt
      core.set %out["stateSummary"] = %state_summary
      core.set %out["stateInspection"] = %state_inspection
      core.set %out["checkpoints"] = %checkpoints
      core.set %out["targetPromptChars"] = %target_prompt_chars
      core.set %out["maxRuntimeChars"] = %max_runtime_chars
      core.return %out
    }
  }

  op ax.agent.semantic @resolve_agent_executor_model_policy {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json throws"
    body @entry(%options: json) {
      %empty_list = core.list
      %context_registry = core.call @agent_context_policy_registry()
      %empty_map = core.map
      %executor_registry = core.get %context_registry["executor_model_policy"] default %empty_map
      %migration_error = core.get %executor_registry["migration_error"] default "executorModelPolicy now expects an ordered array of { model, namespaces?, aboveErrorTurns? } entries. Manage prompt pressure with contextPolicy.budget instead of abovePromptChars."
      %legacy_keys = core.get %executor_registry["legacy_keys"] default %empty_list
      %policy_snake = core.get %options["executor_model_policy"] default null
      %policy = core.get %options["executorModelPolicy"] default %policy_snake
      %missing = core.call intrinsic.is_none(%policy)
      core.if %missing {
        %none = core.call intrinsic.none()
        core.return %none
      }
      %is_list = core.type_is %policy type "list"
      core.if %is_list {
      } else {
        %error_shape = core.call intrinsic.error.runtime(%migration_error)
        core.raise %error_shape
      }
      %out = core.list
      %index = core.let 0
      core.for %entry in %policy {
        %entry_is_map = core.type_is %entry type "object"
        core.if %entry_is_map {
        } else {
          %message_entry = core.call intrinsic.string.format("executorModelPolicy[{}] must be an object", %index)
          %error_entry = core.call intrinsic.error.runtime(%message_entry)
          core.raise %error_entry
        }
        %legacy_any = core.let false
        core.for %legacy_key in %legacy_keys {
          %has_legacy_key = core.call intrinsic.map.contains(%entry, %legacy_key)
          core.if %has_legacy_key {
            %legacy_any = core.let true
          }
        }
        core.if %legacy_any {
          %error_legacy = core.call intrinsic.error.runtime(%migration_error)
          core.raise %error_legacy
        }
        %model = core.get %entry["model"] default ""
        %model_missing = core.call intrinsic.eq(%model, "")
        core.if %model_missing {
          %message_model = core.call intrinsic.string.format("executorModelPolicy[{}].model must be a non-empty string", %index)
          %error_model = core.call intrinsic.error.runtime(%message_model)
          core.raise %error_model
        }
        %above = core.get %entry["aboveErrorTurns"] default null
        %namespaces = core.get %entry["namespaces"] default null
        %has_above = core.call intrinsic.is_not_none(%above)
        %has_namespaces = core.type_is %namespaces type "list"
        core.if %has_above {
          %above_is_number = core.type_is %above type "number"
          %above_negative = core.call intrinsic.lt(%above, 0)
          %above_invalid = core.call intrinsic.not(%above_is_number)
          %above_invalid = core.call intrinsic.or(%above_invalid, %above_negative)
          core.if %above_invalid {
            %message_above = core.call intrinsic.string.format("executorModelPolicy[{}].aboveErrorTurns must be a finite number >= 0", %index)
            %error_above = core.call intrinsic.error.runtime(%message_above)
            core.raise %error_above
          }
        }
        core.if %has_namespaces {
          %valid_namespace_count = core.let 0
          core.for %namespace in %namespaces {
            %namespace_is_string = core.type_is %namespace type "string"
            core.if %namespace_is_string {
              %trimmed_namespace = core.string_trim %namespace
              %namespace_nonempty = core.call intrinsic.ne(%trimmed_namespace, "")
              core.if %namespace_nonempty {
                %valid_namespace_count = core.call intrinsic.add(%valid_namespace_count, 1)
              }
            }
          }
          %no_valid_namespaces = core.call intrinsic.eq(%valid_namespace_count, 0)
          core.if %no_valid_namespaces {
            %message_namespaces = core.call intrinsic.string.format("executorModelPolicy[{}].namespaces must contain at least one non-empty string", %index)
            %error_namespaces = core.call intrinsic.error.runtime(%message_namespaces)
            core.raise %error_namespaces
          }
        }
        %has_trigger = core.call intrinsic.or(%has_above, %has_namespaces)
        core.if %has_trigger {
        } else {
          %message_trigger = core.call intrinsic.string.format("executorModelPolicy[{}] must define at least one of aboveErrorTurns or namespaces", %index)
          %error_trigger = core.call intrinsic.error.runtime(%message_trigger)
          core.raise %error_trigger
        }
        %normalized = core.map
        core.set %normalized["model"] = %model
        core.if %has_above {
          core.set %normalized["aboveErrorTurns"] = %above
        }
        core.if %has_namespaces {
          core.set %normalized["namespaces"] = %namespaces
        }
        core.append %out, %normalized
        %index = core.call intrinsic.add(%index, 1)
      }
      %count = core.call intrinsic.len(%out)
      %empty = core.call intrinsic.eq(%count, 0)
      core.if %empty {
        %error_empty = core.call intrinsic.error.runtime("executorModelPolicy must contain at least one entry")
        core.raise %error_empty
      }
      core.return %out
    }
  }

  op ax.agent.semantic @select_agent_executor_model {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> json"
    body @entry(%policy: json, %actor_model_state: json) {
      %none = core.call intrinsic.none()
      %is_list = core.type_is %policy type "list"
      core.if %is_list {
      } else {
        core.return %none
      }
      %errors = core.get %actor_model_state["consecutiveErrorTurns"] default 0
      %matched = core.get %actor_model_state["matchedNamespaces"] default null
      %matched_is_list = core.type_is %matched type "list"
      core.if %matched_is_list {
      } else {
        %matched = core.list
      }
      %selected = core.call intrinsic.none()
      core.for %entry in %policy {
        %model = core.get %entry["model"] default ""
        %above = core.get %entry["aboveErrorTurns"] default null
        %namespaces = core.get %entry["namespaces"] default null
        %trigger = core.let false
        %has_above = core.call intrinsic.is_not_none(%above)
        core.if %has_above {
          %error_trigger = core.call intrinsic.gte(%errors, %above)
          core.if %error_trigger {
            %trigger = core.let true
          }
        }
        %namespaces_is_list = core.type_is %namespaces type "list"
        core.if %namespaces_is_list {
          core.for %namespace in %namespaces {
            %namespace_match = core.call intrinsic.contains(%matched, %namespace)
            core.if %namespace_match {
              %trigger = core.let true
            }
          }
        }
        core.if %trigger {
          %selected = core.let %model
        }
      }
      core.return %selected
    }
  }

  op ax.agent.semantic @agent_compute_effective_chat_budget {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(number, number) -> number"
    body @entry(%base_budget: json, %fixed_overhead_chars: json) {
      %context_registry = core.call @agent_context_policy_registry()
      %empty_map = core.map
      %budget_math = core.get %context_registry["budget_math"] default %empty_map
      %ratio = core.let 1
      %max_system = core.get %budget_math["maxSystemPromptChars"] default 30000
      %min_ratio = core.get %budget_math["minEffectiveBudgetRatio"] default 0.25
      %overhead_ratio = core.call intrinsic.div(%fixed_overhead_chars, %max_system)
      %negative_overhead = core.call intrinsic.mul(-1, %overhead_ratio)
      %ratio = core.call intrinsic.add(1, %negative_overhead)
      %too_low = core.call intrinsic.lt(%ratio, %min_ratio)
      core.if %too_low {
        %ratio = core.let %min_ratio
      }
      %too_high = core.call intrinsic.gt(%ratio, 1)
      core.if %too_high {
        %ratio = core.let 1
      }
      %budget = core.call intrinsic.mul(%base_budget, %ratio)
      core.return %budget
    }
  }

  op ax.agent.semantic @agent_action_log_char_count {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(list<json>) -> number"
    body @entry(%entries: json) {
      %total = core.let 0
      core.for %entry in %entries {
        %code = core.get %entry["code"] default ""
        %output = core.get %entry["output"] default ""
        %code_len = core.call intrinsic.len(%code)
        %output_len = core.call intrinsic.len(%output)
        %entry_len = core.call intrinsic.add(%code_len, %output_len)
        %total = core.call intrinsic.add(%total, %entry_len)
      }
      core.return %total
    }
  }

  op ax.agent.semantic @agent_compute_dynamic_runtime_chars {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(list<json>, number, number) -> number"
    body @entry(%entries: json, %target_prompt_chars: json, %max_runtime_chars: json) {
      %context_registry = core.call @agent_context_policy_registry()
      %empty_map = core.map
      %runtime_budget = core.get %context_registry["runtime_output_budget"] default %empty_map
      %floor_ratio = core.get %runtime_budget["floorRatio"] default 0.15
      %min_runtime_chars = core.get %runtime_budget["minRuntimeChars"] default 400
      %current_chars = core.call @agent_action_log_char_count(%entries)
      %usage_ratio = core.call intrinsic.div(%current_chars, %target_prompt_chars)
      %negative_usage_ratio = core.call intrinsic.mul(-1, %usage_ratio)
      %remaining_ratio = core.call intrinsic.add(1, %negative_usage_ratio)
      %too_low = core.call intrinsic.lt(%remaining_ratio, %floor_ratio)
      core.if %too_low {
        %remaining_ratio = core.let %floor_ratio
      }
      %too_high = core.call intrinsic.gt(%remaining_ratio, 1)
      core.if %too_high {
        %remaining_ratio = core.let 1
      }
      %effective_min = core.let %min_runtime_chars
      %max_below_min = core.call intrinsic.lt(%max_runtime_chars, %effective_min)
      core.if %max_below_min {
        %effective_min = core.let %max_runtime_chars
      }
      %candidate = core.call intrinsic.mul(%max_runtime_chars, %remaining_ratio)
      %above_max = core.call intrinsic.gt(%candidate, %max_runtime_chars)
      core.if %above_max {
        %candidate = core.let %max_runtime_chars
      }
      %below_min = core.call intrinsic.lt(%candidate, %effective_min)
      core.if %below_min {
        %candidate = core.let %effective_min
      }
      core.return %candidate
    }
  }

  op ax.agent.semantic @agent_context_pressure {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(number, number, bool) -> string"
    body @entry(%mutable_prompt_chars: json, %effective_budget_chars: json, %checkpoint_active: json) {
      %context_registry = core.call @agent_context_policy_registry()
      %empty_map = core.map
      %pressure_levels = core.get %context_registry["pressure_levels"] default %empty_map
      %ok_level = core.get %pressure_levels["ok"] default %empty_map
      %watch_level = core.get %pressure_levels["watch"] default %empty_map
      %critical_level = core.get %pressure_levels["critical"] default %empty_map
      %ok_id = core.get %ok_level["id"] default "ok"
      %watch_id = core.get %watch_level["id"] default "watch"
      %critical_id = core.get %critical_level["id"] default "critical"
      %watch_threshold = core.get %watch_level["threshold"] default 0.7
      %critical_threshold = core.get %critical_level["threshold"] default 0.9
      core.if %checkpoint_active {
        core.return %critical_id
      }
      %invalid_budget = core.call intrinsic.lte(%effective_budget_chars, 0)
      core.if %invalid_budget {
        core.return %ok_id
      }
      %ratio = core.call intrinsic.div(%mutable_prompt_chars, %effective_budget_chars)
      %critical = core.call intrinsic.gte(%ratio, %critical_threshold)
      core.if %critical {
        core.return %critical_id
      }
      %watch = core.call intrinsic.gte(%ratio, %watch_threshold)
      core.if %watch {
        core.return %watch_id
      }
      core.return %ok_id
    }
  }

  op ax.agent.semantic @agent_render_context_pressure {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(string) -> string"
    body @entry(%pressure: string) {
      %context_registry = core.call @agent_context_policy_registry()
      %empty_map = core.map
      %pressure_levels = core.get %context_registry["pressure_levels"] default %empty_map
      %level = core.get %pressure_levels[%pressure] default %empty_map
      %text = core.get %level["text"] default ""
      %empty_text = core.call intrinsic.eq(%text, "")
      core.if %empty_text {
        %ok_level = core.get %pressure_levels["ok"] default %empty_map
        %text = core.get %ok_level["text"] default "ok - normal context pressure; continue with focused, useful inspections."
      }
      core.return %text
    }
  }

  op ax.agent.semantic @agent_smart_stringify {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, number) -> string"
    body @entry(%value: json, %max_chars: json) {
      %context_registry = core.call @agent_context_policy_registry()
      %empty_map = core.map
      %settings = core.get %context_registry["smart_stringify"] default %empty_map
      %array_threshold = core.get %settings["arrayThreshold"] default 10
      %array_head_items = core.get %settings["arrayHeadItems"] default 3
      %array_tail_items = core.get %settings["arrayTailItems"] default 2
      %is_list = core.type_is %value type "list"
      core.if %is_list {
        %count = core.call intrinsic.len(%value)
        %large = core.call intrinsic.gt(%count, %array_threshold)
        core.if %large {
          %head = core.list
          %tail = core.list
          %negative_tail_items = core.call intrinsic.mul(-1, %array_tail_items)
          %tail_start = core.call intrinsic.add(%count, %negative_tail_items)
          %index = core.let 0
          core.for %item in %value {
            %item_text = core.call intrinsic.json.stringify(%item)
            %in_head = core.call intrinsic.lt(%index, %array_head_items)
            core.if %in_head {
              core.append %head, %item_text
            }
            %in_tail = core.call intrinsic.gte(%index, %tail_start)
            core.if %in_tail {
              core.append %tail, %item_text
            }
            %index = core.call intrinsic.add(%index, 1)
          }
          %head_text = core.call intrinsic.string.join(",\n  ", %head)
          %tail_text = core.call intrinsic.string.join(",\n  ", %tail)
          %hidden = core.call intrinsic.add(%count, -5)
          %out = core.call intrinsic.string.format("[\n  {},\n  ... [{} hidden items],\n  {}\n]", %head_text, %hidden, %tail_text)
          core.return %out
        }
      }
      %json = core.call intrinsic.json.pretty(%value)
      core.return %json
    }
  }

  op ax.agent.semantic @agent_record_context_event {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> json"
    body @entry(%state: json, %event: json) {
      %empty_list = core.list
      %events = core.get %state["context_events"] default %empty_list
      core.append %events, %event
      core.set %state["context_events"] = %events
      core.return %event
    }
  }

  op ax.agent.semantic @agent_entry_turn {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, number) -> number"
    body @entry(%entry: json, %fallback: json) {
      %turn = core.get %entry["turn"] default %fallback
      core.return %turn
    }
  }

  op ax.agent.semantic @agent_entry_is_error {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> bool"
    body @entry(%entry: json) {
      %tags = core.get %entry["tags"] default null
      %tags_is_list = core.type_is %tags type "list"
      core.if %tags_is_list {
      } else {
        %tags = core.list
      }
      %tag_error = core.call intrinsic.contains(%tags, "error")
      %is_error = core.get %entry["is_error"] default %tag_error
      core.return %is_error
    }
  }

  op ax.agent.semantic @agent_entry_summary {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, number) -> string"
    body @entry(%entry: json, %fallback_turn: json) {
      %tombstone = core.get %entry["tombstone"] default ""
      %has_tombstone = core.call intrinsic.ne(%tombstone, "")
      core.if %has_tombstone {
        core.return %tombstone
      }
      %turn = core.call @agent_entry_turn(%entry, %fallback_turn)
      %summary = core.get %entry["summary"] default ""
      %has_summary = core.call intrinsic.ne(%summary, "")
      core.if %has_summary {
        core.return %summary
      }
      %kind = core.get %entry["kind"] default "result"
      %output = core.get %entry["output"] default ""
      %preview = core.call intrinsic.string.slice(%output, 0, 180)
      %text = core.call intrinsic.string.format("{} turn result: {}", %kind, %preview)
      %is_error = core.call @agent_entry_is_error(%entry)
      core.if %is_error {
        %text = core.call intrinsic.string.format("error turn {}: {}", %turn, %preview)
      }
      core.return %text
    }
  }

  op ax.agent.semantic @agent_entry_callables_text {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> string"
    body @entry(%entry: json) {
      %empty_list = core.list
      %calls = core.get %entry["_functionCalls"] default %empty_list
      %names = core.list
      %calls_is_list = core.type_is %calls type "list"
      core.if %calls_is_list {
        core.for %call in %calls {
          %qualified = core.get %call["qualifiedName"] default ""
          %has_qualified = core.call intrinsic.ne(%qualified, "")
          core.if %has_qualified {
            %known = core.call intrinsic.contains(%names, %qualified)
            %new_name = core.call intrinsic.not(%known)
            core.if %new_name {
              core.append %names, %qualified
            }
          }
        }
      }
      %direct = core.get %entry["_directQualifiedCalls"] default %empty_list
      %direct_is_list = core.type_is %direct type "list"
      core.if %direct_is_list {
        core.for %direct_name in %direct {
          %has_direct = core.call intrinsic.ne(%direct_name, "")
          core.if %has_direct {
            %known_direct = core.call intrinsic.contains(%names, %direct_name)
            %new_direct = core.call intrinsic.not(%known_direct)
            core.if %new_direct {
              core.append %names, %direct_name
            }
          }
        }
      }
      %count = core.call intrinsic.len(%names)
      %empty = core.call intrinsic.eq(%count, 0)
      core.if %empty {
        core.return "none"
      }
      %text = core.call intrinsic.string.join(", ", %names)
      core.return %text
    }
  }

  op ax.agent.semantic @agent_distill_structured_action_output {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(string) -> string"
    body @entry(%output: string) {
      %has_failed_line = core.call intrinsic.contains(%output, "FAILED ")
      %has_passed = core.call intrinsic.contains(%output, " passed")
      %has_failed_count = core.call intrinsic.contains(%output, " failed")
      %looks_test = core.call intrinsic.and(%has_failed_line, %has_passed)
      %looks_test = core.call intrinsic.and(%looks_test, %has_failed_count)
      core.if %looks_test {
        %lines = core.call intrinsic.string.split_trim_nonempty(%output, "\n")
        %failure = core.let ""
        %counts = core.let ""
        core.for %line in %lines {
          %line_is_failure = core.call intrinsic.string.starts_with(%line, "FAILED ")
          %no_failure_yet = core.call intrinsic.eq(%failure, "")
          %take_failure = core.call intrinsic.and(%line_is_failure, %no_failure_yet)
          core.if %take_failure {
            %failure = core.let %line
          }
          %line_has_passed = core.call intrinsic.contains(%line, " passed")
          %line_has_failed = core.call intrinsic.contains(%line, " failed")
          %line_counts = core.call intrinsic.and(%line_has_passed, %line_has_failed)
          core.if %line_counts {
            %counts = core.let %line
          }
        }
        %clean_counts = core.call intrinsic.regex.replace("^=+\\s*", "", %counts)
        %clean_counts = core.call intrinsic.regex.replace("\\s*=+$", "", %clean_counts)
        %clean_counts = core.call intrinsic.regex.replace("\\s+in\\s+.*$", "", %clean_counts)
        %test_name = core.call intrinsic.regex.replace("^FAILED\\s+", "", %failure)
        %test_name = core.call intrinsic.regex.replace("\\s+-\\s+.*$", "", %test_name)
        %detail = core.call intrinsic.string.slice(%failure, 0, 180)
        %out = core.call intrinsic.string.format("[DISTILLED:test-output]: {}\nFailures: {}\nError details: {}", %clean_counts, %test_name, %detail)
        core.return %out
      }
      %looks_json_array = core.call intrinsic.string.starts_with(%output, "[")
      %output_len = core.call intrinsic.len(%output)
      %long_output = core.call intrinsic.gt(%output_len, 220)
      %json_distill = core.call intrinsic.and(%looks_json_array, %long_output)
      core.if %json_distill {
        %preview = core.call intrinsic.string.slice(%output, 0, 180)
        %out_json = core.call intrinsic.string.format("[DISTILLED:json]: array\nPreview: {}", %preview)
        core.return %out_json
      }
      core.return ""
    }
  }

  op ax.agent.semantic @agent_render_full_action_entry {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> string"
    body @entry(%state: json, %entry: json) {
      %tombstone = core.get %entry["tombstone"] default ""
      %has_tombstone = core.call intrinsic.ne(%tombstone, "")
      core.if %has_tombstone {
        core.return %tombstone
      }
      %runtime_contract = core.get %state["runtime_contract"] default null
      %fence = core.get %runtime_contract["code_fence_language"] default "javascript"
      %js_fence = core.call intrinsic.eq(%fence, "js")
      core.if %js_fence {
        %fence = core.let "javascript"
      }
      %code = core.get %entry["code"] default ""
      %output = core.get %entry["output"] default ""
      %kind = core.get %entry["kind"] default ""
      %is_final_action = core.call intrinsic.eq(%kind, "final")
      core.if %is_final_action {
        %code = core.let "// final() completed; evidence omitted from actor prompt"
      }
      %full_is_error = core.get %entry["is_error"] default false
      core.if %full_is_error {
        %full_error = core.get %entry["error"] default ""
        %full_err_text = core.call intrinsic.string.format("[runtime error] {}", %full_error)
        %full_output_has = core.call intrinsic.ne(%output, "")
        core.if %full_output_has {
          %output = core.call intrinsic.string.format("{}\n{}", %output, %full_err_text)
        } else {
          %output = core.let %full_err_text
        }
      }
      %text = core.call intrinsic.string.format("```{}\n{}\n```\nResult:\n{}", %fence, %code, %output)
      core.return %text
    }
  }

  op ax.agent.semantic @agent_render_compact_action_entry {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, number, string) -> string"
    body @entry(%entry: json, %turn: json, %reason: string) {
      %kind = core.get %entry["kind"] default "result"
      %state_delta = core.get %entry["stateDelta"] default "No durable runtime state update"
      %output = core.get %entry["output"] default ""
      %compact_is_error = core.get %entry["is_error"] default false
      core.if %compact_is_error {
        %compact_error = core.get %entry["error"] default ""
        %output = core.call intrinsic.string.format("[runtime error] {}", %compact_error)
      }
      %callables = core.call @agent_entry_callables_text(%entry)
      %distilled = core.call @agent_distill_structured_action_output(%output)
      %has_distilled = core.call intrinsic.ne(%distilled, "")
      %preview = core.call intrinsic.string.slice(%output, 0, 180)
      core.if %has_distilled {
        %preview = core.let %distilled
      }
      %head = core.call intrinsic.string.format("[COMPACT:{}]: Turn {}. {} step.", %reason, %turn, %kind)
      %tail = core.call intrinsic.string.format(" State: {}. Callables: {}. Result: {}.", %state_delta, %callables, %preview)
      %text = core.call intrinsic.add(%head, %tail)
      core.return %text
    }
  }

  op ax.agent.semantic @agent_fallback_checkpoint_summary {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(list<json>, list<number>) -> string"
    body @entry(%entries: json, %turns: json) {
      %empty_list = core.list
      %evidence = core.list
      %failures = core.list
      %artifacts = core.list
      %objective = core.let "explore"
      %fallback = core.let 1
      core.for %entry in %entries {
        %turn = core.call @agent_entry_turn(%entry, %fallback)
        %covered = core.call intrinsic.contains(%turns, %turn)
        core.if %covered {
          %kind = core.get %entry["kind"] default "result"
          %objective = core.let %kind
          %output = core.get %entry["output"] default ""
          %preview = core.call intrinsic.string.slice(%output, 0, 200)
          %line = core.call intrinsic.string.format("Turn {}: {}", %turn, %preview)
          core.append %evidence, %line
          %state_delta = core.get %entry["stateDelta"] default ""
          %has_state = core.call intrinsic.ne(%state_delta, "")
          core.if %has_state {
            %artifact = core.call intrinsic.string.format("Turn {}: {}", %turn, %state_delta)
            core.append %artifacts, %artifact
          }
          %is_error = core.call @agent_entry_is_error(%entry)
          core.if %is_error {
            core.append %failures, %line
          }
        }
        %fallback = core.call intrinsic.add(%fallback, 1)
      }
      %artifact_text = core.call intrinsic.string.join(" | ", %artifacts)
      %evidence_text = core.call intrinsic.string.join(" | ", %evidence)
      %failure_text = core.call intrinsic.string.join(" | ", %failures)
      %empty_artifact = core.call intrinsic.eq(%artifact_text, "")
      core.if %empty_artifact {
        %artifact_text = core.let "Continue from liveRuntimeState and recent full action replay."
      }
      %empty_evidence = core.call intrinsic.eq(%evidence_text, "")
      core.if %empty_evidence {
        %evidence_text = core.let "none"
      }
      %empty_failures = core.call intrinsic.eq(%failure_text, "")
      core.if %empty_failures {
        %failure_text = core.let "none"
      }
      %head_summary = core.call intrinsic.string.format("Objective: {}\nCurrent state and artifacts: {}\nExact callables and formats: none\nEvidence: {}", %objective, %artifact_text, %evidence_text)
      %tail_summary = core.call intrinsic.string.format("\nUser constraints and preferences: none\nFailures to avoid: {}\nNext step: Continue from the latest live runtime state.", %failure_text)
      %summary = core.call intrinsic.add(%head_summary, %tail_summary)
      %working = core.call @agent_working_code_state(%entries, %turns)
      %working_text = core.get %working["text"] default ""
      %working_turns = core.get %working["turns"] default %empty_list
      %working_count = core.call intrinsic.len(%working_turns)
      %turn_count = core.call intrinsic.len(%turns)
      %has_working = core.call intrinsic.ne(%working_text, "")
      %all_working = core.call intrinsic.eq(%working_count, %turn_count)
      core.if %has_working {
        core.if %all_working {
          %summary = core.let %working_text
        } else {
          %summary = core.call intrinsic.string.format("{}\n\n{}", %working_text, %summary)
        }
      }
      core.return %summary
    }
  }

  op ax.agent.semantic @agent_build_deterministic_tombstone {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> string"
    body @entry(%error_entry: json, %resolution_entry: json) {
      %output = core.get %error_entry["output"] default ""
      %signature = core.call intrinsic.string.slice(%output, 0, 96)
      %empty_signature = core.call intrinsic.eq(%signature, "")
      core.if %empty_signature {
        %signature = core.let "runtime error"
      }
      %resolved_turn = core.call @agent_entry_turn(%resolution_entry, 0)
      %text = core.call intrinsic.string.format("[TOMBSTONE]: Resolved {} in turn {}.", %signature, %resolved_turn)
      core.return %text
    }
  }

  op ax.agent.semantic @agent_apply_context_management {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json"
    body @entry(%state: json) {
      %empty_list = core.list
      %entries = core.get %state["action_log"] default %empty_list
      %policy = core.get %state["context_policy"] default null
      %error_pruning = core.get %policy["errorPruning"] default false
      %tombstoning = core.get %policy["tombstoning"] default false
      %enabled = core.call intrinsic.or(%error_pruning, %tombstoning)
      core.if %enabled {
      } else {
        core.return %entries
      }
      %count = core.call intrinsic.len(%entries)
      %has_pairs = core.call intrinsic.gt(%count, 1)
      core.if %has_pairs {
      } else {
        core.return %entries
      }
      %prev = core.call intrinsic.none()
      %has_prev = core.let false
      core.for %entry in %entries {
        core.if %has_prev {
          %prev_is_error = core.call @agent_entry_is_error(%prev)
          %current_is_error = core.call @agent_entry_is_error(%entry)
          %current_success = core.call intrinsic.not(%current_is_error)
          %resolved = core.call intrinsic.and(%prev_is_error, %current_success)
          core.if %resolved {
            %existing = core.get %prev["tombstone"] default ""
            %missing = core.call intrinsic.eq(%existing, "")
            core.if %missing {
              %tombstone = core.call @agent_build_deterministic_tombstone(%prev, %entry)
              core.set %prev["tombstone"] = %tombstone
              %event = core.map
              %kind = core.call @agent_context_event_name("tombstone_created")
              core.set %event["kind"] = %kind
              core.set %event["stage"] = "executor"
              %turn = core.call @agent_entry_turn(%prev, 0)
              %resolved_turn = core.call @agent_entry_turn(%entry, 0)
              core.set %event["turn"] = %turn
              core.set %event["resolvedByTurn"] = %resolved_turn
              core.set %event["source"] = "deterministic"
              %summary_chars = core.call intrinsic.len(%tombstone)
              core.set %event["summaryChars"] = %summary_chars
              core.call @agent_record_context_event(%state, %event)
              %tomb_is_true = core.call intrinsic.eq(%tombstoning, true)
              %tomb_is_obj = core.type_is %tombstoning type "object"
              %want_llm = core.call intrinsic.or(%tomb_is_true, %tomb_is_obj)
              core.if %want_llm {
                core.set %prev["tombstone_llm_pending"] = true
                %err_code = core.get %prev["code"] default ""
                %err_output = core.get %prev["output"] default ""
                %res_code = core.get %entry["code"] default ""
                %llm_input = core.call intrinsic.string.format("errorCode:\n{}\n\nerrorOutput:\n{}\n\nresolutionCode:\n{}", %err_code, %err_output, %res_code)
                core.set %prev["tombstone_llm_input"] = %llm_input
              }
            }
          }
        }
        %prev = core.let %entry
        %has_prev = core.let true
      }
      core.set %state["action_log"] = %entries
      core.return %entries
    }
  }

  op ax.agent.semantic @agent_apply_llm_tombstone_summary {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json, json) -> json throws"
    body @entry(%state: json, %client: json, %options: json) {
      %empty_list = core.list
      %entries = core.get %state["action_log"] default %empty_list
      core.for %entry in %entries {
        %pending = core.get %entry["tombstone_llm_pending"] default false
        core.if %pending {
          %llm_input = core.get %entry["tombstone_llm_input"] default ""
          %instruction = core.let "You are an internal AxAgent tombstone summarizer.\n\nWrite the output as exactly one concise line.\n- Start with [TOMBSTONE]:\n- Summarize the resolved error and the successful fix.\n- Mention one failed approach to avoid when possible.\n- Do not include code fences, bullet points, or extra prose.\n- Keep it roughly 20-40 tokens."
          %tombstone = core.call @context_map_complete(%client, %instruction, %llm_input, %options)
          %has_text = core.call intrinsic.ne(%tombstone, "")
          core.if %has_text {
            core.set %entry["tombstone"] = %tombstone
            core.set %entry["tombstone_source"] = "model"
            core.set %entry["tombstone_llm_pending"] = false
            %event = core.map
            %kind = core.call @agent_context_event_name("tombstone_created")
            core.set %event["kind"] = %kind
            core.set %event["stage"] = "executor"
            core.set %event["source"] = "model"
            %summary_chars = core.call intrinsic.len(%tombstone)
            core.set %event["summaryChars"] = %summary_chars
            core.call @agent_record_context_event(%state, %event)
          }
        }
      }
      core.set %state["action_log"] = %entries
      core.return %state
    }
  }

  op ax.agent.semantic @agent_working_code_state {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(list<json>, list<number>) -> json"
    body @entry(%entries: json, %turns: json) {
      %empty_list = core.list
      %working_turns = core.list
      %coverable_count = core.let 0
      %fallback = core.let 1
      core.for %entry in %entries {
        %turn = core.call @agent_entry_turn(%entry, %fallback)
        %covered = core.call intrinsic.contains(%turns, %turn)
        %is_error = core.call @agent_entry_is_error(%entry)
        %not_error = core.call intrinsic.not(%is_error)
        %tombstone = core.get %entry["tombstone"] default ""
        %has_tombstone = core.call intrinsic.ne(%tombstone, "")
        %not_tombstone = core.call intrinsic.not(%has_tombstone)
        %include = core.call intrinsic.and(%covered, %not_error)
        %include = core.call intrinsic.and(%include, %not_tombstone)
        core.if %include {
          %coverable_count = core.call intrinsic.add(%coverable_count, 1)
        }
        %fallback = core.call intrinsic.add(%fallback, 1)
      }
      %start = core.let 0
      %more_than_two = core.call intrinsic.gt(%coverable_count, 2)
      core.if %more_than_two {
        %start = core.call intrinsic.add(%coverable_count, -2)
      }
      %blocks = core.list
      %index = core.let 0
      %fallback2 = core.let 1
      core.for %entry2 in %entries {
        %turn2 = core.call @agent_entry_turn(%entry2, %fallback2)
        %covered2 = core.call intrinsic.contains(%turns, %turn2)
        %is_error2 = core.call @agent_entry_is_error(%entry2)
        %not_error2 = core.call intrinsic.not(%is_error2)
        %tombstone2 = core.get %entry2["tombstone"] default ""
        %has_tombstone2 = core.call intrinsic.ne(%tombstone2, "")
        %not_tombstone2 = core.call intrinsic.not(%has_tombstone2)
        %coverable2 = core.call intrinsic.and(%covered2, %not_error2)
        %coverable2 = core.call intrinsic.and(%coverable2, %not_tombstone2)
        core.if %coverable2 {
          %include_working = core.call intrinsic.gte(%index, %start)
          core.if %include_working {
            core.append %working_turns, %turn2
            %code = core.get %entry2["code"] default "(no code)"
            %code_len = core.call intrinsic.len(%code)
            %code_too_long = core.call intrinsic.gt(%code_len, 2000)
            core.if %code_too_long {
              %code_head = core.call intrinsic.string.slice(%code, 0, 2000)
              %code = core.call intrinsic.string.format("{}\n// ... (truncated)", %code_head)
            }
            %produced = core.get %entry2["producedVars"] default %empty_list
            %produced_text = core.call intrinsic.string.join(", ", %produced)
            %produced_empty = core.call intrinsic.eq(%produced_text, "")
            core.if %produced_empty {
              %produced_text = core.let "none"
            }
            %reads = core.get %entry2["_durableReads"] default null
            %reads_is_list = core.type_is %reads type "list"
            core.if %reads_is_list {
            } else {
              %reads = core.get %entry2["referencedVars"] default %empty_list
            }
            %read_text = core.call intrinsic.string.join(", ", %reads)
            %read_empty = core.call intrinsic.eq(%read_text, "")
            core.if %read_empty {
              %read_text = core.let "none"
            }
            %callables = core.call @agent_entry_callables_text(%entry2)
            %state_delta = core.get %entry2["stateDelta"] default "none"
            %output = core.get %entry2["output"] default "(no output)"
            %output_preview = core.call intrinsic.string.slice(%output, 0, 800)
            %block_head = core.call intrinsic.string.format("Code:\n{}\nProduced: {}\nRead: {}", %code, %produced_text, %read_text)
            %block_tail = core.call intrinsic.string.format("\nDirect callables: {}\nState delta: {}\nOutput: {}", %callables, %state_delta, %output_preview)
            %block = core.call intrinsic.add(%block_head, %block_tail)
            core.append %blocks, %block
          }
          %index = core.call intrinsic.add(%index, 1)
        }
        %fallback2 = core.call intrinsic.add(%fallback2, 1)
      }
      %body = core.call intrinsic.string.join("\n\n", %blocks)
      %out = core.map
      core.set %out["turns"] = %working_turns
      %has_body = core.call intrinsic.ne(%body, "")
      core.if %has_body {
        %text = core.call intrinsic.string.format("=== Working Code State (verbatim) ===\n{}", %body)
        core.set %out["text"] = %text
      } else {
        core.set %out["text"] = ""
      }
      core.return %out
    }
  }

  op ax.agent.semantic @agent_refresh_checkpoint_state {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json"
    body @entry(%state: json) {
      %empty_list = core.list
      %context_registry = core.call @agent_context_policy_registry()
      %empty_map = core.map
      %pressure_levels = core.get %context_registry["pressure_levels"] default %empty_map
      %ok_level = core.get %pressure_levels["ok"] default %empty_map
      %ok_pressure = core.get %ok_level["id"] default "ok"
      %policy = core.get %state["context_policy"] default null
      %checkpoints = core.get %policy["checkpoints"] default null
      %enabled = core.get %checkpoints["enabled"] default false
      core.if %enabled {
      } else {
        %existing = core.get %state["checkpoint_state"] default null
        %has_existing = core.type_is %existing type "object"
        core.if %has_existing {
          %cleared = core.map
          %cleared_kind = core.call @agent_context_event_name("checkpoint_cleared")
          %disabled_reason = core.call @agent_context_event_reason("disabled")
          core.set %cleared["kind"] = %cleared_kind
          core.set %cleared["stage"] = "executor"
          core.set %cleared["turn"] = 0
          core.set %cleared["coveredTurns"] = %empty_list
          core.set %cleared["reason"] = %disabled_reason
          core.call @agent_record_context_event(%state, %cleared)
        }
        %none_checkpoint = core.call intrinsic.none()
        core.set %state["checkpoint_state"] = %none_checkpoint
        %none = core.call intrinsic.none()
        core.return %none
      }
      %entries = core.get %state["action_log"] default %empty_list
      %count = core.call intrinsic.len(%entries)
      %has_entries = core.call intrinsic.gt(%count, 0)
      core.if %has_entries {
      } else {
        %none_empty = core.call intrinsic.none()
        core.return %none_empty
      }
      %chars = core.call @agent_action_log_char_count(%entries)
      %trigger = core.get %checkpoints["triggerChars"] default 16000
      %over = core.call intrinsic.gte(%chars, %trigger)
      core.if %over {
      } else {
        %current = core.get %state["checkpoint_state"] default null
        core.return %current
      }
      %recent = core.get %policy["recentFullActions"] default 1
      %recent_start = core.let 0
      %too_many = core.call intrinsic.gt(%count, %recent)
      core.if %too_many {
        %negative_recent = core.call intrinsic.mul(-1, %recent)
        %recent_start = core.call intrinsic.add(%count, %negative_recent)
      }
      %covered_turns = core.list
      %index = core.let 0
      %fallback_turn = core.let 1
      core.for %entry in %entries {
        %turn = core.call @agent_entry_turn(%entry, %fallback_turn)
        %is_error = core.call @agent_entry_is_error(%entry)
        %is_recent = core.call intrinsic.gte(%index, %recent_start)
        %coverable = core.call intrinsic.not(%is_error)
        %not_recent = core.call intrinsic.not(%is_recent)
        %coverable = core.call intrinsic.and(%coverable, %not_recent)
        core.if %coverable {
          core.append %covered_turns, %turn
        }
        %index = core.call intrinsic.add(%index, 1)
        %fallback_turn = core.call intrinsic.add(%fallback_turn, 1)
      }
      %covered_count = core.call intrinsic.len(%covered_turns)
      %has_covered = core.call intrinsic.gt(%covered_count, 0)
      core.if %has_covered {
      } else {
        %none_no_covered = core.call intrinsic.none()
        core.return %none_no_covered
      }
      %summary = core.call @agent_fallback_checkpoint_summary(%entries, %covered_turns)
      %checkpoint = core.map
      %fingerprint = core.call intrinsic.json.stable_stringify(%covered_turns)
      core.set %checkpoint["fingerprint"] = %fingerprint
      core.set %checkpoint["summary"] = %summary
      core.set %checkpoint["turns"] = %covered_turns
      %cp_empty = core.map
      %cp_context_policy = core.get %state["context_policy"] default %cp_empty
      %cp_summarizer_opts = core.get %cp_context_policy["summarizerOptions"] default null
      %cp_want_llm = core.call intrinsic.is_not_none(%cp_summarizer_opts)
      core.if %cp_want_llm {
        core.set %checkpoint["llm_pending"] = true
        core.set %checkpoint["llm_input"] = %summary
      }
      core.set %state["checkpoint_state"] = %checkpoint
      %event = core.map
      %created_kind = core.call @agent_context_event_name("checkpoint_created")
      %over_budget_reason = core.call @agent_context_event_reason("over_budget")
      core.set %event["kind"] = %created_kind
      core.set %event["stage"] = "executor"
      core.set %event["turn"] = %count
      core.set %event["coveredTurns"] = %covered_turns
      %summary_len = core.call intrinsic.len(%summary)
      core.set %event["summaryChars"] = %summary_len
      core.set %event["reason"] = %over_budget_reason
      core.call @agent_record_context_event(%state, %event)
      core.return %checkpoint
    }
  }

  op ax.agent.semantic @agent_build_action_log_parts {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, string) -> json"
    body @entry(%state: json, %hygiene_mode: string) {
      %empty_list = core.list
      %context_registry = core.call @agent_context_policy_registry()
      %empty_map = core.map
      %hygiene_modes = core.get %context_registry["hygiene_modes"] default %empty_map
      %pressure_hygiene_mode = core.get %hygiene_modes["pressure"] default "pressure"
      %aggressive_hygiene_mode = core.get %hygiene_modes["aggressive"] default "aggressive"
      %entries = core.get %state["action_log"] default %empty_list
      %policy = core.get %state["context_policy"] default null
      %action_replay = core.get %policy["actionReplay"] default "full"
      %recent = core.get %policy["recentFullActions"] default 1
      %checkpoint_state = core.get %state["checkpoint_state"] default null
      %checkpoint_summary = core.get %checkpoint_state["summary"] default ""
      %checkpoint_turns = core.get %checkpoint_state["turns"] default %empty_list
      %restore_notice = core.get %state["restore_notice"] default ""
      %delegated_summary = core.get %state["delegated_context_summary"] default ""
      %summary_parts = core.list
      %has_restore = core.call intrinsic.ne(%restore_notice, "")
      core.if %has_restore {
        core.append %summary_parts, %restore_notice
      }
      %has_delegated = core.call intrinsic.ne(%delegated_summary, "")
      core.if %has_delegated {
        %delegated_text = core.call intrinsic.string.format("Delegated Context (runtime-only - explore with code):\n{}", %delegated_summary)
        core.append %summary_parts, %delegated_text
      }
      %has_checkpoint_summary = core.call intrinsic.ne(%checkpoint_summary, "")
      core.if %has_checkpoint_summary {
        %checkpoint_text = core.call intrinsic.string.format("Checkpoint Summary:\n{}", %checkpoint_summary)
        core.append %summary_parts, %checkpoint_text
      }
      %summary = core.call intrinsic.string.join("\n\n", %summary_parts)
      %history_parts = core.list
      %compactions = core.list
      %count = core.call intrinsic.len(%entries)
      %recent_start = core.let 0
      %too_many = core.call intrinsic.gt(%count, %recent)
      core.if %too_many {
        %negative_recent = core.call intrinsic.mul(-1, %recent)
        %recent_start = core.call intrinsic.add(%count, %negative_recent)
      }
      %full_replay = core.call intrinsic.eq(%action_replay, "full")
      %checkpointed = core.call intrinsic.eq(%action_replay, "checkpointed")
      %index = core.let 0
      %fallback_turn = core.let 1
      core.for %entry in %entries {
        %turn = core.call @agent_entry_turn(%entry, %fallback_turn)
        %is_error = core.call @agent_entry_is_error(%entry)
        %tombstone = core.get %entry["tombstone"] default ""
        %has_tombstone = core.call intrinsic.ne(%tombstone, "")
        %is_recent = core.call intrinsic.gte(%index, %recent_start)
        %checkpoint_covered = core.call intrinsic.contains(%checkpoint_turns, %turn)
        %not_error = core.call intrinsic.not(%is_error)
        %replay_mode = core.get %entry["replayMode"] default ""
        %replay_full = core.call intrinsic.eq(%replay_mode, "full")
        %replay_distill = core.call intrinsic.eq(%replay_mode, "distill")
        %replay_compact = core.call intrinsic.eq(%replay_mode, "compact")
        %replay_omit = core.call intrinsic.eq(%replay_mode, "omit")
        %covered_success = core.call intrinsic.and(%checkpoint_covered, %not_error)
        %not_replay_full = core.call intrinsic.not(%replay_full)
        %covered_success = core.call intrinsic.and(%covered_success, %not_replay_full)
        %rendered = core.let ""
        core.if %covered_success {
          %rendered = core.let ""
        } else {
          %render_full = core.let false
          core.if %replay_full {
            %render_full = core.let true
          }
          core.if %full_replay {
            %render_full = core.let true
          }
          core.if %is_recent {
            %render_full = core.let true
          }
          core.if %is_error {
            %render_full = core.let true
          }
          %pressure_pre = core.call intrinsic.eq(%hygiene_mode, %pressure_hygiene_mode)
          %aggressive_pre = core.call intrinsic.eq(%hygiene_mode, %aggressive_hygiene_mode)
          %pressure_compaction = core.call intrinsic.or(%pressure_pre, %aggressive_pre)
          %old_success = core.call intrinsic.not(%is_recent)
          %old_success = core.call intrinsic.and(%old_success, %not_error)
          %pressure_can_compact = core.call intrinsic.and(%pressure_compaction, %old_success)
          core.if %pressure_can_compact {
            %render_full = core.let false
          }
          core.if %has_tombstone {
            %rendered = core.let %tombstone
          }
          %has_rendered_pre = core.call intrinsic.ne(%rendered, "")
          core.if %has_rendered_pre {
          } else {
            core.if %render_full {
              %rendered = core.call @agent_render_full_action_entry(%state, %entry)
            } else {
              %pressure = core.call intrinsic.eq(%hygiene_mode, %pressure_hygiene_mode)
              %aggressive = core.call intrinsic.eq(%hygiene_mode, %aggressive_hygiene_mode)
              %should_compact = core.call intrinsic.or(%pressure, %aggressive)
              %should_compact = core.call intrinsic.or(%should_compact, %replay_compact)
              %should_distill = core.let %replay_distill
              core.if %should_distill {
                %distilled_output = core.get %entry["distilledOutput"] default ""
                %has_distilled_output = core.call intrinsic.ne(%distilled_output, "")
                core.if %has_distilled_output {
                } else {
                  %raw_output_for_distill = core.get %entry["output"] default ""
                  %distilled_output = core.call @agent_distill_structured_action_output(%raw_output_for_distill)
                }
                %has_distill = core.call intrinsic.ne(%distilled_output, "")
                core.if %has_distill {
                  %full_text_distill = core.call @agent_render_full_action_entry(%state, %entry)
                  %runtime_contract_distill = core.get %state["runtime_contract"] default null
                  %fence_distill = core.get %runtime_contract_distill["code_fence_language"] default "javascript"
                  %js_fence_distill = core.call intrinsic.eq(%fence_distill, "js")
                  core.if %js_fence_distill {
                    %fence_distill = core.let "javascript"
                  }
                  %code_distill = core.get %entry["code"] default ""
                  %rendered = core.call intrinsic.string.format("```{}\n{}\n```\nResult:\n{}", %fence_distill, %code_distill, %distilled_output)
                  %compaction_distill = core.map
                  core.set %compaction_distill["turn"] = %turn
                  core.set %compaction_distill["mode"] = "distill"
                  core.set %compaction_distill["reason"] = "structured_output"
                  %original_chars_distill = core.call intrinsic.len(%full_text_distill)
                  %rendered_chars_distill = core.call intrinsic.len(%rendered)
                  core.set %compaction_distill["originalChars"] = %original_chars_distill
                  core.set %compaction_distill["renderedChars"] = %rendered_chars_distill
                  core.append %compactions, %compaction_distill
                }
              }
              %rendered_after_distill = core.call intrinsic.ne(%rendered, "")
              core.if %rendered_after_distill {
              } else {
                core.if %should_compact {
                  %reason = core.call @agent_context_event_reason("pressure")
                  core.if %aggressive {
                    %reason = core.call @agent_context_event_reason("lean")
                  }
                  %full_text = core.call @agent_render_full_action_entry(%state, %entry)
                  %rendered = core.call @agent_render_compact_action_entry(%entry, %turn, %reason)
                  %compaction = core.map
                  core.set %compaction["turn"] = %turn
                  core.set %compaction["mode"] = "compact"
                  core.set %compaction["reason"] = %reason
                  %original_chars = core.call intrinsic.len(%full_text)
                  %rendered_chars = core.call intrinsic.len(%rendered)
                  core.set %compaction["originalChars"] = %original_chars
                  core.set %compaction["renderedChars"] = %rendered_chars
                  core.append %compactions, %compaction
                } else {
                  core.if %replay_omit {
                    %rendered = core.call @agent_entry_summary(%entry, %turn)
                  } else {
                    %entry_summary = core.call @agent_entry_summary(%entry, %turn)
                    %rendered = core.call intrinsic.string.format("- Action {}: {}", %turn, %entry_summary)
                  }
                }
              }
            }
          }
        }
        %has_rendered = core.call intrinsic.ne(%rendered, "")
        core.if %has_rendered {
          core.append %history_parts, %rendered
        }
        %index = core.call intrinsic.add(%index, 1)
        %fallback_turn = core.call intrinsic.add(%fallback_turn, 1)
      }
      %history = core.call intrinsic.string.join("\n\n", %history_parts)
      %out = core.map
      core.set %out["summary"] = %summary
      core.set %out["history"] = %history
      core.set %out["compactions"] = %compactions
      core.return %out
    }
  }

  op ax.agent.semantic @agent_render_runtime_state_summary {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> string"
    body @entry(%state: json, %policy: json) {
      %empty_map = core.map
      %empty_list = core.list
      %auto_promoted_fields = core.call @agent_auto_promoted_fields(%state)
      %session_state = core.get %state["runtime_session_state"] default %empty_map
      %state_summary = core.get %policy["stateSummary"] default %empty_map
      %enabled = core.get %state_summary["enabled"] default false
      core.if %enabled {
      } else {
        core.return ""
      }
      %max_entries = core.get %state_summary["maxEntries"] default 8
      %entries = core.get %session_state["entries"] default %empty_list
      %entries_is_list = core.type_is %entries type "list"
      core.if %entries_is_list {
        %entry_count = core.call intrinsic.len(%entries)
        %has_entries = core.call intrinsic.gt(%entry_count, 0)
        core.if %has_entries {
          %provenance = core.get %state["provenance"] default %empty_map
          %lines_structured = core.list
          %structured_count = core.let 0
          core.for %entry in %entries {
            %under_structured_limit = core.call intrinsic.lt(%structured_count, %max_entries)
            core.if %under_structured_limit {
              %name = core.get %entry["name"] default ""
              %type = core.get %entry["type"] default "unknown"
              %size = core.get %entry["size"] default ""
              %preview = core.get %entry["preview"] default ""
              %ctor = core.get %entry["ctor"] default ""
              %is_promoted_name = core.call intrinsic.contains(%auto_promoted_fields, %name)
              %is_context_name = core.call intrinsic.eq(%name, "context")
              %is_distilled_name = core.call intrinsic.eq(%name, "distilledContext")
              %type_label = core.let %type
              %object_type = core.call intrinsic.eq(%type, "object")
              %has_ctor = core.call intrinsic.ne(%ctor, "")
              %object_with_ctor = core.call intrinsic.and(%object_type, %has_ctor)
              core.if %object_with_ctor {
                %type_label = core.call intrinsic.string.format("object<{}>", %ctor)
              }
              %has_size = core.call intrinsic.ne(%size, "")
              core.if %has_size {
                %type_label = core.call intrinsic.string.format("{} ({})", %type_label, %size)
              }
              %preview_text = core.let ""
              %has_preview = core.call intrinsic.ne(%preview, "")
              core.if %has_preview {
                %preview_text = core.call intrinsic.string.format(" = {}", %preview)
              }
              core.if %is_promoted_name {
                %preview_text = core.call intrinsic.string.format(" = [runtime-only context available as inputs.{}]", %name)
              }
              core.if %is_context_name {
                %preview_text = core.let " = [runtime context map; values omitted from prompt]"
              }
              core.if %is_distilled_name {
                %preview_text = core.let " = [distilled evidence object; values omitted from prompt]"
              }
              %prov = core.get %provenance[%name] default null
              %prov_text = core.let ""
              %has_prov = core.type_is %prov type "object"
              core.if %has_prov {
                %created_turn = core.get %prov["createdTurn"] default 0
                %source = core.get %prov["source"] default ""
                %last_read = core.get %prov["lastReadTurn"] default 0
                %has_source = core.call intrinsic.ne(%source, "")
                core.if %has_source {
                  %prov_text = core.call intrinsic.string.format(" [from t{} via {}", %created_turn, %source)
                } else {
                  %prov_text = core.call intrinsic.string.format(" [from t{}", %created_turn)
                }
                %read_after = core.call intrinsic.gt(%last_read, %created_turn)
                core.if %read_after {
                  %prov_text = core.call intrinsic.string.format("{}; read t{}", %prov_text, %last_read)
                }
                %prov_text = core.call intrinsic.add(%prov_text, "]")
              }
              %restorable = core.get %entry["restorable"] default true
              %snapshot_only = core.call intrinsic.eq(%restorable, false)
              %restore_text = core.let ""
              core.if %snapshot_only {
                %restore_text = core.let " [snapshot only]"
              }
              %line_base = core.call intrinsic.string.format("{}: {}{}", %name, %type_label, %preview_text)
              %line_with_prov = core.call intrinsic.add(%line_base, %prov_text)
              %line = core.call intrinsic.add(%line_with_prov, %restore_text)
              core.append %lines_structured, %line
              %structured_count = core.call intrinsic.add(%structured_count, 1)
            }
          }
          %body_structured = core.call intrinsic.string.join("\n", %lines_structured)
          %empty_structured = core.call intrinsic.eq(%body_structured, "")
          core.if %empty_structured {
            %body_structured = core.let "(no user variables)"
          }
          %out_structured = core.call intrinsic.string.format("Current runtime state:\n{}", %body_structured)
          core.set %state["runtime_state_summary"] = %out_structured
          core.return %out_structured
        }
      }
      %globals = core.get %session_state["globals"] default null
      %bindings = core.get %session_state["bindings"] default %globals
      %bindings_is_map = core.type_is %bindings type "object"
      core.if %bindings_is_map {
      } else {
        core.return ""
      }
      %reserved = core.call @agent_reserved_runtime_names()
      %parts = core.list
      %count = core.let 0
      core.for %key in %bindings {
        %reserved_key = core.call intrinsic.contains(%reserved, %key)
        %allowed_key = core.call intrinsic.not(%reserved_key)
        %under_limit = core.call intrinsic.lt(%count, %max_entries)
        %include_key = core.call intrinsic.and(%allowed_key, %under_limit)
        core.if %include_key {
          %value = core.get %bindings[%key]
          %text = core.call intrinsic.json.stringify(%value)
          %is_promoted_binding = core.call intrinsic.contains(%auto_promoted_fields, %key)
          core.if %is_promoted_binding {
            %text = core.call intrinsic.string.format("[runtime-only context available as inputs.{}]", %key)
          }
          %is_context_binding = core.call intrinsic.eq(%key, "context")
          core.if %is_context_binding {
            %text = core.let "[runtime context map; values omitted from prompt]"
          }
          %is_distilled_binding = core.call intrinsic.eq(%key, "distilledContext")
          core.if %is_distilled_binding {
            %text = core.let "[distilled evidence object; values omitted from prompt]"
          }
          %line = core.call intrinsic.string.format("- {}: {}", %key, %text)
          core.append %parts, %line
          %count = core.call intrinsic.add(%count, 1)
        }
      }
      %body = core.call intrinsic.string.join("\n", %parts)
      %empty = core.call intrinsic.eq(%body, "")
      core.if %empty {
        core.return ""
      }
      %out = core.call intrinsic.string.format("Current runtime state:\n{}", %body)
      core.set %state["runtime_state_summary"] = %out
      core.return %out
    }
  }

  op ax.agent.semantic @agent_auto_promoted_fields {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> list<string>"
    body @entry(%state: json) {
      %empty_list = core.list
      %events = core.get %state["context_events"] default %empty_list
      %out = core.list
      core.for %event in %events {
        %kind = core.get %event["kind"] default ""
        %is_auto = core.call intrinsic.eq(%kind, "field_auto_promoted")
        core.if %is_auto {
          %field = core.get %event["fieldName"] default ""
          %has_field = core.call intrinsic.ne(%field, "")
          %already = core.call intrinsic.contains(%out, %field)
          %fresh = core.call intrinsic.not(%already)
          %take = core.call intrinsic.and(%has_field, %fresh)
          core.if %take {
            core.append %out, %field
          }
        }
      }
      core.return %out
    }
  }

  op ax.agent.semantic @agent_prepare_actor_context {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json"
    body @entry(%state: json) {
      %empty_list = core.list
      %context_registry = core.call @agent_context_policy_registry()
      %empty_map = core.map
      %pressure_levels = core.get %context_registry["pressure_levels"] default %empty_map
      %ok_level = core.get %pressure_levels["ok"] default %empty_map
      %ok_pressure = core.get %ok_level["id"] default "ok"
      %policy = core.get %state["context_policy"] default null
      %hygiene = core.get %policy["contextHygiene"] default null
      %default_hygiene = core.get %hygiene["defaultMode"] default "none"
      %pressure_hygiene = core.get %hygiene["pressureMode"] default %default_hygiene
      %checkpoint = core.call @agent_refresh_checkpoint_state(%state)
      %parts = core.call @agent_build_action_log_parts(%state, %default_hygiene)
      %summary = core.get %parts["summary"] default ""
      %history = core.get %parts["history"] default ""
      %history_empty = core.call intrinsic.eq(%history, "")
      core.if %history_empty {
        %history = core.let "(no actions yet)"
      }
      %runtime_state_summary = core.call @agent_render_runtime_state_summary(%state, %policy)
      %guidance_log = core.get %state["guidance_log"] default %empty_list
      %guidance_text = core.call intrinsic.json.stringify(%guidance_log)
      %history_chars = core.call intrinsic.len(%history)
      %guidance_chars = core.call intrinsic.len(%guidance_text)
      %runtime_chars = core.call intrinsic.len(%runtime_state_summary)
      %summary_chars = core.call intrinsic.len(%summary)
      %mutable_chars = core.call intrinsic.add(%history_chars, %guidance_chars)
      %mutable_chars = core.call intrinsic.add(%mutable_chars, %runtime_chars)
      %mutable_chars = core.call intrinsic.add(%mutable_chars, %summary_chars)
      %target = core.get %policy["targetPromptChars"] default 16000
      %fixed = core.get %state["fixed_prompt_chars"] default 0
      %effective_budget = core.call @agent_compute_effective_chat_budget(%target, %fixed)
      %checkpoint_is_map = core.type_is %checkpoint type "object"
      %pressure = core.call @agent_context_pressure(%mutable_chars, %effective_budget, %checkpoint_is_map)
      %pressure_is_ok = core.call intrinsic.eq(%pressure, %ok_pressure)
      %hygiene_changes = core.call intrinsic.ne(%pressure_hygiene, %default_hygiene)
      %pressure_not_ok = core.call intrinsic.not(%pressure_is_ok)
      %should_pressure = core.call intrinsic.and(%pressure_not_ok, %hygiene_changes)
      core.if %should_pressure {
        %pressure_parts = core.call @agent_build_action_log_parts(%state, %pressure_hygiene)
        %pressure_history = core.get %pressure_parts["history"] default ""
        %pressure_history_empty = core.call intrinsic.eq(%pressure_history, "")
        core.if %pressure_history_empty {
          %pressure_history = core.let "(no actions yet)"
        }
        %pressure_len = core.call intrinsic.len(%pressure_history)
        %history_len = core.call intrinsic.len(%history)
        %shorter = core.call intrinsic.lt(%pressure_len, %history_len)
        core.if %shorter {
          %parts = core.let %pressure_parts
          %summary = core.get %pressure_parts["summary"] default %summary
          %history = core.let %pressure_history
        }
      }
      %compactions = core.get %parts["compactions"] default %empty_list
      core.for %compaction in %compactions {
        %event = core.map
        %action_compacted_kind = core.call @agent_context_event_name("action_compacted")
        core.set %event["kind"] = %action_compacted_kind
        core.set %event["stage"] = "executor"
        %turn = core.get %compaction["turn"] default 0
        %mode = core.get %compaction["mode"] default "compact"
        %default_reason = core.call @agent_context_event_reason("pressure")
        %reason = core.get %compaction["reason"] default %default_reason
        %original_chars = core.get %compaction["originalChars"] default 0
        %rendered_chars = core.get %compaction["renderedChars"] default 0
        core.set %event["turn"] = %turn
        core.set %event["mode"] = %mode
        core.set %event["reason"] = %reason
        core.set %event["originalChars"] = %original_chars
        core.set %event["renderedChars"] = %rendered_chars
        core.call @agent_record_context_event(%state, %event)
      }
      %action_log = core.get %state["action_log"] default %empty_list
      %guidance_count = core.call intrinsic.len(%guidance_log)
      %action_count = core.call intrinsic.len(%action_log)
      %budget_event = core.map
      %budget_check_kind = core.call @agent_context_event_name("budget_check")
      core.set %budget_event["kind"] = %budget_check_kind
      core.set %budget_event["stage"] = "executor"
      %turn = core.call intrinsic.add(%action_count, 1)
      core.set %budget_event["turn"] = %turn
      core.set %budget_event["pressure"] = %pressure
      core.set %budget_event["mutablePromptChars"] = %mutable_chars
      core.set %budget_event["fixedPromptChars"] = %fixed
      core.set %budget_event["effectiveBudgetChars"] = %effective_budget
      core.set %budget_event["targetPromptChars"] = %target
      core.set %budget_event["checkpointActive"] = %checkpoint_is_map
      core.set %budget_event["actionLogEntryCount"] = %action_count
      core.set %budget_event["guidanceLogEntryCount"] = %guidance_count
      core.call @agent_record_context_event(%state, %budget_event)
      %pressure_text = core.let ""
      %default_preset = core.get %context_registry["default_preset"] default "checkpointed"
      %full_preset = core.get %context_registry["full_preset"] default "full"
      %preset = core.get %policy["preset"] default %default_preset
      %is_full = core.call intrinsic.eq(%preset, %full_preset)
      core.if %is_full {
        %pressure_text = core.let ""
      } else {
        %pressure_text = core.call @agent_render_context_pressure(%pressure)
      }
      %max_runtime = core.get %policy["maxRuntimeChars"] default 3000
      %dynamic_runtime_chars = core.call @agent_compute_dynamic_runtime_chars(%action_log, %target, %max_runtime)
      %out = core.map
      core.set %out["summarizedActorLog"] = %summary
      core.set %out["actionLog"] = %history
      core.set %out["guidanceLog"] = %guidance_text
      core.set %out["liveRuntimeState"] = %runtime_state_summary
      core.set %out["contextPressure"] = %pressure_text
      core.set %out["pressure"] = %pressure
      core.set %out["effectiveBudgetChars"] = %effective_budget
      core.set %out["mutablePromptChars"] = %mutable_chars
      core.set %out["dynamicRuntimeChars"] = %dynamic_runtime_chars
      core.set %state["last_actor_context"] = %out
      core.return %out
    }
  }

  op ax.agent.semantic @agent_build_action_evidence_summary {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> string"
    body @entry(%state: json) {
      %empty_list = core.list
      %entries = core.get %state["action_log"] default %empty_list
      %checkpoint = core.get %state["checkpoint_state"] default null
      %checkpoint_summary = core.get %checkpoint["summary"] default ""
      %checkpoint_turns = core.get %checkpoint["turns"] default %empty_list
      %runtime_summary = core.get %state["runtime_state_summary"] default ""
      %parts = core.list
      core.append %parts, "Actor stopped without calling final(...). Evidence summary:"
      %has_checkpoint = core.call intrinsic.ne(%checkpoint_summary, "")
      core.if %has_checkpoint {
        %checkpoint_text = core.call intrinsic.string.format("Checkpoint summary:\n{}", %checkpoint_summary)
        core.append %parts, %checkpoint_text
      }
      %lines = core.list
      %fallback = core.let 1
      core.for %entry in %entries {
        %turn = core.call @agent_entry_turn(%entry, %fallback)
        %covered = core.call intrinsic.contains(%checkpoint_turns, %turn)
        %is_error = core.call @agent_entry_is_error(%entry)
        %not_error_skip = core.call intrinsic.not(%is_error)
        %skip = core.call intrinsic.and(%covered, %not_error_skip)
        core.if %skip {
        } else {
          %summary = core.call @agent_entry_summary(%entry, %turn)
          %line = core.call intrinsic.string.format("- Action {}: {}", %turn, %summary)
          core.append %lines, %line
        }
        %fallback = core.call intrinsic.add(%fallback, 1)
      }
      %line_text = core.call intrinsic.string.join("\n", %lines)
      %has_lines = core.call intrinsic.ne(%line_text, "")
      core.if %has_lines {
        core.append %parts, %line_text
      } else {
        %no_checkpoint = core.call intrinsic.not(%has_checkpoint)
        core.if %no_checkpoint {
          core.append %parts, "- No actions were taken."
        }
      }
      %has_runtime = core.call intrinsic.ne(%runtime_summary, "")
      core.if %has_runtime {
        %runtime_text = core.call intrinsic.string.format("Current runtime state:\n{}", %runtime_summary)
        core.append %parts, %runtime_text
      }
      %out = core.call intrinsic.string.join("\n", %parts)
      core.return %out
    }
  }

  op ax.agent.runtime @agent_sanitize_action_log_entries {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(list<json>) -> list<json>"
    body @entry(%entries: json) {
      %out = core.list
      core.for %entry in %entries {
        %clean = core.map
        %public_type = core.get %entry["type"] default ""
        %has_public_type = core.call intrinsic.ne(%public_type, "")
        core.if %has_public_type {
          core.set %clean["type"] = %public_type
        }
        %public_kind = core.get %entry["kind"] default ""
        %has_public_kind = core.call intrinsic.ne(%public_kind, "")
        core.if %has_public_kind {
          core.set %clean["kind"] = %public_kind
        }
        %public_action = core.get %entry["action"] default ""
        %has_public_action = core.call intrinsic.ne(%public_action, "")
        core.if %has_public_action {
          core.set %clean["action"] = %public_action
        }
        %public_reason = core.get %entry["reason"] default ""
        %has_public_reason = core.call intrinsic.ne(%public_reason, "")
        core.if %has_public_reason {
          core.set %clean["reason"] = %public_reason
        }
        %public_status = core.get %entry["status"] default ""
        %has_public_status = core.call intrinsic.ne(%public_status, "")
        core.if %has_public_status {
          core.set %clean["status"] = %public_status
        }
        %qualified_name = core.get %entry["qualified_name"] default ""
        %has_qualified_name = core.call intrinsic.ne(%qualified_name, "")
        core.if %has_qualified_name {
          core.set %clean["qualified_name"] = %qualified_name
        }
        %entry_name = core.get %entry["name"] default ""
        %has_entry_name = core.call intrinsic.ne(%entry_name, "")
        core.if %has_entry_name {
          core.set %clean["name"] = %entry_name
        }
        %entry_namespace = core.get %entry["namespace"] default ""
        %has_entry_namespace = core.call intrinsic.ne(%entry_namespace, "")
        core.if %has_entry_namespace {
          core.set %clean["namespace"] = %entry_namespace
        }
        %entry_error = core.get %entry["error"] default ""
        %has_entry_error = core.call intrinsic.ne(%entry_error, "")
        core.if %has_entry_error {
          core.set %clean["error"] = %entry_error
        }
        %error_category = core.get %entry["error_category"] default ""
        %has_error_category = core.call intrinsic.ne(%error_category, "")
        core.if %has_error_category {
          core.set %clean["error_category"] = %error_category
        }
        %entry_message = core.get %entry["message"] default ""
        %has_entry_message = core.call intrinsic.ne(%entry_message, "")
        core.if %has_entry_message {
          core.set %clean["message"] = %entry_message
        }
        %guidance = core.get %entry["guidance"] default ""
        %has_guidance = core.call intrinsic.ne(%guidance, "")
        core.if %has_guidance {
          core.set %clean["guidance"] = %guidance
        }
        %triggered_by = core.get %entry["triggered_by"] default ""
        %has_triggered_by = core.call intrinsic.ne(%triggered_by, "")
        core.if %has_triggered_by {
          core.set %clean["triggered_by"] = %triggered_by
        }
        %searches = core.get %entry["searches"] default null
        %searches_is_list = core.type_is %searches type "list"
        core.if %searches_is_list {
          core.set %clean["searches"] = %searches
        }
        %tools = core.get %entry["tools"] default null
        %tools_is_list = core.type_is %tools type "list"
        core.if %tools_is_list {
          core.set %clean["tools"] = %tools
        }
        %skills = core.get %entry["skills"] default null
        %skills_is_list = core.type_is %skills type "list"
        core.if %skills_is_list {
          core.set %clean["skills"] = %skills
        }
        %request = core.get %entry["request"] default null
        %request_is_object = core.type_is %request type "object"
        core.if %request_is_object {
          core.set %clean["request"] = %request
