  op ax.agent.policy @agent_policy_registry {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> json"
    body @entry(%policy: json, %flags: json) {
      %vocabulary = core.call @agent_policy_vocabulary_registry()
      %empty_map = core.map
      %primitive_names = core.get %vocabulary["actor_primitive_names"] default %empty_map
      %llm_query_name = core.get %primitive_names["llm_query"] default "llmQuery"
      %final_name = core.get %primitive_names["final"] default "final"
      %ask_clarification_name = core.get %primitive_names["ask_clarification"] default "askClarification"
      %report_success_name = core.get %primitive_names["report_success"] default "reportSuccess"
      %report_failure_name = core.get %primitive_names["report_failure"] default "reportFailure"
      %inspect_runtime_name = core.get %primitive_names["inspect_runtime"] default "inspectRuntime"
      %discover_name = core.get %primitive_names["discover"] default "discover"
      %recall_name = core.get %primitive_names["recall"] default "recall"
      %used_name = core.get %primitive_names["used"] default "used"
      %guide_agent_name = core.get %primitive_names["guide_agent"] default "guideAgent"
      %inputs_name = core.get %primitive_names["inputs"] default "inputs"
      %distiller_executor = core.list
      core.append %distiller_executor, "distiller"
      core.append %distiller_executor, "executor"
      %executor_only = core.list
      core.append %executor_only, "executor"
      %all_actor = core.list
      core.append %all_actor, "distiller"
      core.append %all_actor, "executor"
      %actor_primitives = core.list
      %llm = core.call @agent_policy_action(%llm_query_name, "actor_primitive", "sub_agent_query", %distiller_executor, "always", "returns string or string[]", "sub_agent_llm_query", true)
      core.append %actor_primitives, %llm
      %final_action = core.call @agent_policy_action(%final_name, "actor_primitive", "completion", %distiller_executor, "always", "ends actor turn with final payload", "runtime_completion_signal", true)
      core.append %actor_primitives, %final_action
      %clarify = core.call @agent_policy_action(%ask_clarification_name, "actor_primitive", "completion", %distiller_executor, "always", "throws clarification payload", "runtime_completion_signal", true)
      core.append %actor_primitives, %clarify
      %success = core.call @agent_policy_action(%report_success_name, "actor_primitive", "status", %executor_only, "hasAgentStatusCallback", "records successful progress status", "status_callback", true)
      core.append %actor_primitives, %success
      %failure = core.call @agent_policy_action(%report_failure_name, "actor_primitive", "status", %executor_only, "hasAgentStatusCallback", "records failed progress status", "status_callback", true)
      core.append %actor_primitives, %failure
      %inspect = core.call @agent_policy_action(%inspect_runtime_name, "actor_primitive", "runtime_inspection", %distiller_executor, "hasInspectRuntime", "returns compact runtime state", "runtime_inspection", true)
      core.append %actor_primitives, %inspect
      %discover = core.call @agent_policy_action(%discover_name, "actor_primitive", "discovery", %executor_only, "discoveryMode|skillsMode", "loads tool docs or skill guides for next turn", "tool_or_skill_discovery", true)
      core.append %actor_primitives, %discover
      %recall = core.call @agent_policy_action(%recall_name, "actor_primitive", "memory", %distiller_executor, "memoriesMode", "loads memories for next turn", "memory_search", true)
      core.append %actor_primitives, %recall
      %used = core.call @agent_policy_action(%used_name, "actor_primitive", "usage_tracking", %distiller_executor, "usageTrackingMode", "records loaded memory or skill usage", "usage_tracking_callback", true)
      core.append %actor_primitives, %used
      %protocol_actions = core.list
      %protocol_final_action = core.call @agent_policy_action(%final_name, "protocol_action", "completion", %all_actor, "always", "normalizes final protocol payload", "completion_protocol", false)
      core.append %protocol_actions, %protocol_final_action
      %protocol_clarify = core.call @agent_policy_action(%ask_clarification_name, "protocol_action", "completion", %all_actor, "always", "normalizes clarification protocol payload", "completion_protocol", false)
      core.append %protocol_actions, %protocol_clarify
      %guide = core.call @agent_policy_action(%guide_agent_name, "protocol_action", "guidance", %executor_only, "host_protocol_only", "adds trusted guidance and continues actor loop", "host_function_protocol", false)
      core.append %protocol_actions, %guide
      %protocol_success = core.call @agent_policy_action("success", "protocol_action", "status", %executor_only, "hasAgentStatusCallback", "reports successful status", "status_callback", false)
      core.append %protocol_actions, %protocol_success
      %protocol_failed = core.call @agent_policy_action("failed", "protocol_action", "status", %executor_only, "hasAgentStatusCallback", "reports failed status", "status_callback", false)
      core.append %protocol_actions, %protocol_failed
      %runtime_globals = core.list
      %inputs = core.call @agent_policy_action(%inputs_name, "runtime_global", "data", %all_actor, "always", "contains current actor inputs", "runtime_global", false)
      core.append %runtime_globals, %inputs
      %callables = core.call @agent_policy_action("callable_namespaces", "runtime_global", "callable_namespace", %executor_only, "has_callables", "namespaced tools and child agents", "tool_or_child_agent_handler", false)
      core.append %runtime_globals, %callables
      %bootstrap = core.call @agent_policy_action("safe_bootstrap_globals", "runtime_global", "bootstrap", %all_actor, "has_bootstrap_context", "safe context aliases only", "runtime_session_bootstrap", false)
      core.append %runtime_globals, %bootstrap
      %host_boundaries = core.list
      %tool_boundary = core.call @agent_policy_action("tool_handler", "host_boundary", "callback", %executor_only, "has_callables", "invokes target-native tool handler", "tool_handler", false)
      core.append %host_boundaries, %tool_boundary
      %child_boundary = core.call @agent_policy_action("child_agent", "host_boundary", "callback", %executor_only, "has_child_agents", "invokes child agent as callable", "child_agent_forward", false)
      core.append %host_boundaries, %child_boundary
      %memory_boundary = core.call @agent_policy_action("memory_search", "host_boundary", "callback", %distiller_executor, "memoriesMode", "loads host memory results", "memory_search_callback", false)
      core.append %host_boundaries, %memory_boundary
      %skill_boundary = core.call @agent_policy_action("skill_search", "host_boundary", "callback", %executor_only, "skillsMode", "loads host skill docs", "skill_search_callback", false)
      core.append %host_boundaries, %skill_boundary
      %status_boundary = core.call @agent_policy_action("status_callback", "host_boundary", "callback", %executor_only, "hasAgentStatusCallback", "reports progress status", "status_callback", false)
      core.append %host_boundaries, %status_boundary
      %runtime_boundary = core.call @agent_policy_action("runtime_execution", "host_boundary", "runtime", %all_actor, "has_runtime", "executes opaque runtime code", "code_runtime_session", false)
      core.append %host_boundaries, %runtime_boundary
      %inspect_boundary = core.call @agent_policy_action("runtime_inspection", "host_boundary", "runtime", %all_actor, "hasInspectRuntime", "inspects runtime state", "code_runtime_inspection", false)
      core.append %host_boundaries, %inspect_boundary
      %subquery_boundary = core.call @agent_policy_action("sub_agent_llm_query", "host_boundary", "ai", %distiller_executor, "always", "runs focused AxGen sub-query", "axgen_sub_agent", false)
      core.append %host_boundaries, %subquery_boundary
      %out = core.map
      %policy_version = core.get %policy["policy_version"] default "agent-runtime-decision-v1"
      %schema_version = core.get %policy["policy_schema_version"] default "axir-agent-policy-v1"
      core.set %out["policy_version"] = %policy_version
      core.set %out["policy_schema_version"] = %schema_version
      core.set %out["flags"] = %flags
      core.set %out["actor_primitives"] = %actor_primitives
      core.set %out["protocol_actions"] = %protocol_actions
      core.set %out["runtime_globals"] = %runtime_globals
      core.set %out["host_boundaries"] = %host_boundaries
      core.set %out["vocabulary"] = %vocabulary
      core.return %out
    }
  }

  op ax.agent.policy @policy_flag_enabled {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, string) -> bool"
    body @entry(%flags: json, %condition: string) {
      %out = core.let false
      %always = core.call intrinsic.eq(%condition, "always")
      core.if %always {
        %out = core.let true
      } else {
        %discovery_or_skills = core.call intrinsic.eq(%condition, "discoveryMode|skillsMode")
        core.if %discovery_or_skills {
          %discovery = core.get %flags["discoveryMode"] default false
          %skills = core.get %flags["skillsMode"] default false
          %out = core.call intrinsic.or(%discovery, %skills)
        } else {
          %host_only = core.call intrinsic.eq(%condition, "host_protocol_only")
          core.if %host_only {
            %out = core.let true
          } else {
            %value = core.get %flags[%condition] default false
            %out = core.let %value
          }
        }
      }
      core.return %out
    }
  }

  op ax.agent.policy @select_actor_primitives {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, string) -> json"
    body @entry(%registry: json, %stage: string) {
      %empty_list = core.list
      %out = core.list
      %flags = core.get %registry["flags"] default %empty_list
      %primitives = core.get %registry["actor_primitives"] default %empty_list
      core.for %primitive in %primitives {
        %stages = core.get %primitive["stages"] default %empty_list
        %in_stage = core.call intrinsic.contains(%stages, %stage)
        %condition = core.get %primitive["availability_condition"] default "always"
        %enabled = core.call @policy_flag_enabled(%flags, %condition)
        %include = core.call intrinsic.and(%in_stage, %enabled)
        core.if %include {
          core.append %out, %primitive
        } else {
        }
      }
      core.return %out
    }
  }

  op ax.agent.policy @select_protocol_actions {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json"
    body @entry(%registry: json) {
      %empty_list = core.list
      %actions = core.get %registry["protocol_actions"] default %empty_list
      core.return %actions
    }
  }

  op ax.agent.policy @select_runtime_globals {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json"
    body @entry(%registry: json) {
      %empty_list = core.list
      %globals = core.get %registry["runtime_globals"] default %empty_list
      core.return %globals
    }
  }

  op ax.agent.policy @validate_policy_reserved_names {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, string) -> void throws"
    body @entry(%registry: json, %name: string) {
      %reserved = core.call @agent_reserved_runtime_names()
      %conflicts = core.call intrinsic.contains(%reserved, %name)
      core.if %conflicts {
        %message = core.call intrinsic.string.format("agent callable namespace conflicts with reserved runtime name: {}", %name)
        %error = core.call intrinsic.error.runtime(%message)
        core.raise %error
      } else {
      }
      %none = core.call intrinsic.none()
      core.return %none
    }
  }

  op ax.agent.policy @render_actor_primitive_guidance {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, string) -> string"
    body @entry(%registry: json, %stage: string) {
      %primitives = core.call @select_actor_primitives(%registry, %stage)
      %lines = core.list
      core.for %primitive in %primitives {
        %id = core.get %primitive["id"]
        %effect = core.get %primitive["effect"] default ""
        %line = core.call intrinsic.string.format("- {}: {}", %id, %effect)
        core.append %lines, %line
      }
      %out = core.call intrinsic.string.join("\n", %lines)
      core.return %out
    }
  }

  op ax.agent.policy @record_policy_event {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, string, json) -> void"
    body @entry(%state: json, %action: string, %payload: json) {
      %empty_list = core.list
      %trace = core.get %state["policy_trace"] default %empty_list
      %event = core.map
      core.set %event["type"] = "policy_event"
      core.set %event["action"] = %action
      core.set %event["payload"] = %payload
      core.append %trace, %event
      core.set %state["policy_trace"] = %trace
      %none = core.call intrinsic.none()
      core.return %none
    }
  }

  op ax.agent.policy @normalize_policy_action_result {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(string, json) -> json"
    body @entry(%action: string, %payload: json) {
      %out = core.map
      %null_value = core.call intrinsic.none()
      %vocabulary = core.call @agent_policy_vocabulary_registry()
      %empty_list = core.list
      %effect_only_actions = core.get %vocabulary["effect_only_actions"] default %empty_list
      core.set %out["action"] = %action
      core.set %out["payload"] = %payload
      %is_effect = core.call intrinsic.contains(%effect_only_actions, %action)
      core.if %is_effect {
        core.set %out["returns"] = %null_value
        core.set %out["effect_only"] = true
      } else {
        core.set %out["returns"] = %payload
        core.set %out["effect_only"] = false
      }
      core.return %out
    }
  }

  op ax.agent.policy @build_agent_actor_prompt_policy {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json"
    body @entry(%state: json) {
