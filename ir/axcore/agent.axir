module @ax.agent version "0.1" {
  dialect @ax.agent version "0.1"

  op ax.agent.semantic @agent_factory {
    attr core_kind = "func"
    attr emit_module = "agent"
    ref parse = @parse_signature
    type signature = "(string|AxSignature, options?:json) -> json throws"
    body @entry(%signature: json, %options: json) {
      %empty_list = core.list
      %empty_map = core.map
      %sig = core.let %signature
      %is_string = core.type_is %signature type "string"
      core.if %is_string {
        %parsed_sig = core.call @parse_signature(%signature)
        %sig = core.let %parsed_sig
      } else {
        %sig = core.let %signature
      }
      %context_camel = core.get %options["contextFields"] default %empty_list
      %context_fields = core.get %options["context_fields"] default %context_camel
      %executor_options = core.get %options["executor_options"] default %empty_map
      %executor_options_camel = core.get %options["executorOptions"] default %executor_options
      %responder_options = core.get %options["responder_options"] default %empty_map
      %responder_options_camel = core.get %options["responderOptions"] default %responder_options
      %executor_exclude_camel = core.get %executor_options_camel["excludeFields"] default %empty_list
      %executor_exclude = core.get %executor_options_camel["exclude_fields"] default %executor_exclude_camel
      %responder_exclude_camel = core.get %responder_options_camel["excludeFields"] default %empty_list
      %responder_exclude = core.get %responder_options_camel["exclude_fields"] default %responder_exclude_camel
      %input_fields = core.get %sig["input_fields"] default %empty_list
      core.for %ctx in %context_fields {
        %found = core.let false
        core.for %field in %input_fields {
          %field_name = core.get %field["name"]
          %matches = core.call intrinsic.eq(%field_name, %ctx)
          core.if %matches {
            %found = core.let true
          } else {
          }
        }
        %missing = core.call intrinsic.not(%found)
        core.if %missing {
          %message = core.call intrinsic.string.format("context field not found: {}", %ctx)
          %error = core.call intrinsic.error.runtime(%message)
          core.raise %error
        } else {
        }
      }
      %chat_log = core.list
      %usage = core.map
      %state_alpha = core.map
      %action_log = core.list
      %status_log = core.list
      %state = core.map
      %runtime_contract = core.call @normalize_agent_runtime(%options)
      %policy = core.call @normalize_agent_policy(%options)
      %callable_inventory = core.call @normalize_agent_callable_inventory(%options)
      %callable_split = core.call @split_agent_callable_inventory(%callable_inventory)
      %discovery_catalog = core.call @render_agent_discovery_catalog(%callable_split)
      %discovered_tool_docs = core.list
      %loaded_skill_docs = core.list
      %policy_trace = core.list
      core.set %state["signature"] = %sig
      core.set %state["options"] = %options
      core.set %state["context_fields"] = %context_fields
      core.set %state["executor_exclude_fields"] = %executor_exclude
      core.set %state["responder_exclude_fields"] = %responder_exclude
      core.set %state["distiller_signature"] = "input:json, context:json -> completion:json"
      core.set %state["executor_signature"] = "input:json, executorRequest:string, distilledContext:json -> completion:json"
      core.set %state["chat_log"] = %chat_log
      core.set %state["usage"] = %usage
      core.set %state["runtime_state"] = %state_alpha
      core.set %state["action_log"] = %action_log
      core.set %state["status_log"] = %status_log
      core.set %state["runtime_contract"] = %runtime_contract
      core.set %state["policy"] = %policy
      core.set %state["callable_inventory"] = %callable_inventory
      core.set %state["callable_split"] = %callable_split
      core.set %state["discovery_catalog"] = %discovery_catalog
      core.set %state["discovered_tool_docs"] = %discovered_tool_docs
      core.set %state["loaded_skill_docs"] = %loaded_skill_docs
      core.set %state["policy_trace"] = %policy_trace
      %optimizer_metadata = core.call @agent_optimizer_metadata(%state)
      core.set %state["optimizer_metadata"] = %optimizer_metadata
      core.return %state
    }
  }

  op ax.agent.runtime @agent_reserved_runtime_names {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "() -> list<string>"
    body @entry {
      %names = core.list
      core.append %names, "inputs"
      core.append %names, "final"
      core.append %names, "askClarification"
      core.append %names, "discover"
      core.append %names, "recall"
      core.append %names, "llmQuery"
      core.append %names, "inspectRuntime"
      core.append %names, "reportSuccess"
      core.append %names, "reportFailure"
      core.return %names
    }
  }

  op ax.agent.runtime @normalize_agent_runtime {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json) -> json"
    body @entry(%options: json) {
      %empty_map = core.map
      %runtime_camel = core.get %options["runtimeConfig"] default %empty_map
      %runtime = core.get %options["runtime"] default %runtime_camel
      %language = core.get %runtime["language"] default "javascript"
      %is_js = core.call intrinsic.eq(%language, "javascript")
      %code_field_camel = core.get %runtime["codeFieldName"] default ""
      %code_field_name = core.get %runtime["code_field_name"] default %code_field_camel
      %missing_code_field = core.call intrinsic.eq(%code_field_name, "")
      core.if %missing_code_field {
        core.if %is_js {
          %code_field_name = core.let "javascriptCode"
        } else {
          %code_field_name = core.call intrinsic.string.format("{}Code", %language)
        }
      } else {
      }
      %code_title_camel = core.get %runtime["codeFieldTitle"] default ""
      %code_field_title = core.get %runtime["code_field_title"] default %code_title_camel
      %missing_title = core.call intrinsic.eq(%code_field_title, "")
      core.if %missing_title {
        core.if %is_js {
          %code_field_title = core.let "Javascript Code"
        } else {
          %code_field_title = core.call intrinsic.string.format("{} Code", %language)
        }
      } else {
      }
      %code_fence_camel = core.get %runtime["codeFenceLanguage"] default ""
      %code_fence_language = core.get %runtime["code_fence_language"] default %code_fence_camel
      %missing_fence = core.call intrinsic.eq(%code_fence_language, "")
      core.if %missing_fence {
        %code_fence_language = core.let %language
      } else {
      }
      %usage_camel = core.get %runtime["usageInstructions"] default ""
      %usage_instructions = core.get %runtime["usage_instructions"] default %usage_camel
      %missing_usage = core.call intrinsic.eq(%usage_instructions, "")
      core.if %missing_usage {
        %usage_instructions = core.let "Use the active runtime language. Read inputs, call namespaced tools or child agents, use discover(...) before unknown callables, final(...) when complete, and askClarification(...) when blocked."
      } else {
      }
      %primitives = core.call @agent_reserved_runtime_names()
      %state_hooks = core.list
      core.append %state_hooks, "create_session"
      core.append %state_hooks, "execute_code"
      core.append %state_hooks, "inspect_globals"
      core.append %state_hooks, "export_state"
      core.append %state_hooks, "restore_state"
      core.append %state_hooks, "close_session"
      %out = core.map
      core.set %out["language"] = %language
      core.set %out["code_field_name"] = %code_field_name
      core.set %out["code_field_title"] = %code_field_title
      core.set %out["code_fence_language"] = %code_fence_language
      core.set %out["usage_instructions"] = %usage_instructions
      core.set %out["callable_format"] = "namespaced_runtime_call"
      core.set %out["primitives"] = %primitives
      core.set %out["state_hooks"] = %state_hooks
      core.return %out
    }
  }

  op ax.agent.policy @normalize_agent_policy {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json) -> json"
    body @entry(%options: json) {
      %empty_map = core.map
      %policy_camel = core.get %options["agentPolicy"] default %empty_map
      %policy_in = core.get %options["agent_policy"] default %policy_camel
      %discovery_default = core.get %policy_in["discovery_default"] default "compact_catalog_prompt_full_docs_runtime_discover"
      %delegation_default = core.get %policy_in["delegation_default"] default "child_agents_as_namespaced_tools"
      %skills_default = core.get %policy_in["skills_default"] default "host_callback_loads_skill_docs_next_executor_prompt"
      %prompt_placement = core.get %policy_in["prompt_placement"] default "runtime_usage_catalog_in_actor_prompt_loaded_docs_next_turn"
      %out = core.map
      core.set %out["policy_version"] = "agent-runtime-decision-v1"
      core.set %out["discovery_default"] = %discovery_default
      core.set %out["delegation_default"] = %delegation_default
      core.set %out["skills_default"] = %skills_default
      core.set %out["prompt_placement"] = %prompt_placement
      core.set %out["discover_returns"] = "void"
      core.return %out
    }
  }

  op ax.agent.policy @normalize_agent_callable {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, string) -> json throws"
    body @entry(%raw: json, %namespace: string) {
      %name = core.get %raw["name"] default ""
      %missing_name = core.call intrinsic.eq(%name, "")
      core.if %missing_name {
        %error = core.call intrinsic.error.runtime("agent callable name is required")
        core.raise %error
      } else {
      }
      %kind = core.get %raw["kind"] default "tool"
      %description = core.get %raw["description"] default ""
      %qualified = core.call intrinsic.string.format("{}.{}", %namespace, %name)
      %parameters = core.get %raw["parameters"] default null
      %always_camel = core.get %raw["alwaysInclude"] default false
      %always_include = core.get %raw["always_include"] default %always_camel
      %out = core.map
      core.set %out["name"] = %name
      core.set %out["namespace"] = %namespace
      core.set %out["qualified_name"] = %qualified
      core.set %out["kind"] = %kind
      core.set %out["description"] = %description
      core.set %out["parameters"] = %parameters
      core.set %out["always_include"] = %always_include
      core.return %out
    }
  }

  op ax.agent.policy @normalize_agent_group {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json) -> json throws"
    body @entry(%raw: json) {
      %empty_list = core.list
      %name = core.get %raw["name"] default "tools"
      %namespace = core.get %raw["namespace"] default %name
      %reserved = core.call @agent_reserved_runtime_names()
      %conflicts = core.call intrinsic.contains(%reserved, %namespace)
      core.if %conflicts {
        %message = core.call intrinsic.string.format("agent callable namespace conflicts with reserved runtime name: {}", %namespace)
        %error = core.call intrinsic.error.runtime(%message)
        core.raise %error
      } else {
      }
      %title = core.get %raw["title"] default %namespace
      %description = core.get %raw["description"] default ""
      %selection_camel = core.get %raw["selectionCriteria"] default ""
      %selection_criteria = core.get %raw["selection_criteria"] default %selection_camel
      %always_camel = core.get %raw["alwaysInclude"] default false
      %always_include = core.get %raw["always_include"] default %always_camel
      %functions = core.get %raw["functions"] default %empty_list
      %callables = core.list
      core.for %fn in %functions {
        %callable = core.call @normalize_agent_callable(%fn, %namespace)
        core.append %callables, %callable
      }
      %out = core.map
      core.set %out["namespace"] = %namespace
      core.set %out["title"] = %title
      core.set %out["description"] = %description
      core.set %out["selection_criteria"] = %selection_criteria
      core.set %out["always_include"] = %always_include
      core.set %out["callables"] = %callables
      core.return %out
    }
  }

  op ax.agent.policy @normalize_agent_callable_inventory {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json) -> json throws"
    body @entry(%options: json) {
      %empty_list = core.list
      %functions = core.get %options["functions"] default %empty_list
      %groups = core.list
      %flat_callables = core.list
      %has_flat = core.let false
      %has_group = core.let false
      core.for %item in %functions {
        %group_functions = core.get %item["functions"] default null
        %is_group = core.type_is %group_functions type "list"
        core.if %is_group {
          %has_group = core.let true
          core.if %has_flat {
            %error = core.call intrinsic.error.runtime("agent functions cannot mix grouped modules and flat functions")
            core.raise %error
          } else {
          }
          %group = core.call @normalize_agent_group(%item)
          core.append %groups, %group
        } else {
          %has_flat = core.let true
          core.if %has_group {
            %error = core.call intrinsic.error.runtime("agent functions cannot mix grouped modules and flat functions")
            core.raise %error
          } else {
          }
          %callable = core.call @normalize_agent_callable(%item, "tools")
          core.append %flat_callables, %callable
        }
      }
      %flat_count = core.call intrinsic.len(%flat_callables)
      %has_any_flat = core.call intrinsic.gt(%flat_count, 0)
      core.if %has_any_flat {
        %flat_group = core.map
        core.set %flat_group["namespace"] = "tools"
        core.set %flat_group["title"] = "Tools"
        core.set %flat_group["description"] = ""
        core.set %flat_group["selection_criteria"] = ""
        core.set %flat_group["always_include"] = true
        core.set %flat_group["callables"] = %flat_callables
        core.append %groups, %flat_group
      } else {
      }
      core.return %groups
    }
  }

  op ax.agent.policy @split_agent_callable_inventory {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json) -> json"
    body @entry(%inventory: json) {
      %inline = core.list
      %discoverable = core.list
      core.for %group in %inventory {
        %always = core.get %group["always_include"] default false
        core.if %always {
          core.append %inline, %group
        } else {
          core.append %discoverable, %group
        }
      }
      %out = core.map
      core.set %out["inline"] = %inline
      core.set %out["discoverable"] = %discoverable
      core.return %out
    }
  }

  op ax.agent.policy @render_agent_discovery_catalog {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json) -> json"
    body @entry(%split: json) {
      %empty_list = core.list
      %catalog = core.list
      %inline = core.get %split["inline"] default %empty_list
      %discoverable = core.get %split["discoverable"] default %empty_list
      core.for %group in %inline {
        %callable_names = core.list
        %callables = core.get %group["callables"] default %empty_list
        core.for %callable in %callables {
          %qualified = core.get %callable["qualified_name"]
          core.append %callable_names, %qualified
        }
        %namespace = core.get %group["namespace"]
        %entry = core.map
        core.set %entry["namespace"] = %namespace
        core.set %entry["placement"] = "actor_prompt"
        core.set %entry["callables"] = %callable_names
        core.append %catalog, %entry
      }
      core.for %group in %discoverable {
        %namespace = core.get %group["namespace"]
        %hint = core.call intrinsic.string.format("discover tools {}", %namespace)
        %entry = core.map
        core.set %entry["namespace"] = %namespace
        core.set %entry["placement"] = "discover"
        core.set %entry["hint"] = %hint
        core.append %catalog, %entry
      }
      core.return %catalog
    }
  }

  op ax.agent.policy @agent_discover {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, json) -> void"
    body @entry(%state: json, %request: json) {
      %empty_list = core.list
      %inventory = core.get %state["callable_inventory"] default %empty_list
      %docs = core.get %state["discovered_tool_docs"] default %empty_list
      %skill_docs = core.get %state["loaded_skill_docs"] default %empty_list
      %trace = core.get %state["policy_trace"] default %empty_list
      %tools = core.get %request["tools"] default %empty_list
      %skills = core.get %request["skills"] default %empty_list
      core.for %wanted in %tools {
        core.for %group in %inventory {
          %namespace = core.get %group["namespace"]
          %namespace_match = core.call intrinsic.eq(%namespace, %wanted)
          %callables = core.get %group["callables"] default %empty_list
          core.if %namespace_match {
            core.for %callable in %callables {
              %doc_name = core.get %callable["name"]
              %doc_qualified = core.get %callable["qualified_name"]
              %doc_kind = core.get %callable["kind"]
              %doc_description = core.get %callable["description"] default ""
              %doc = core.map
              core.set %doc["namespace"] = %namespace
              core.set %doc["name"] = %doc_name
              core.set %doc["qualified_name"] = %doc_qualified
              core.set %doc["kind"] = %doc_kind
              core.set %doc["description"] = %doc_description
              core.append %docs, %doc
            }
          } else {
            core.for %callable in %callables {
              %qualified = core.get %callable["qualified_name"]
              %name = core.get %callable["name"]
              %qualified_match = core.call intrinsic.eq(%qualified, %wanted)
              %name_match = core.call intrinsic.eq(%name, %wanted)
              %matches = core.call intrinsic.or(%qualified_match, %name_match)
              core.if %matches {
                %kind = core.get %callable["kind"]
                %description = core.get %callable["description"] default ""
                %doc = core.map
                core.set %doc["namespace"] = %namespace
                core.set %doc["name"] = %name
                core.set %doc["qualified_name"] = %qualified
                core.set %doc["kind"] = %kind
                core.set %doc["description"] = %description
                core.append %docs, %doc
              } else {
              }
            }
          }
        }
      }
      core.for %skill in %skills {
        %doc = core.map
        core.set %doc["name"] = %skill
        %content = core.call intrinsic.string.format("Skill docs loaded for {}", %skill)
        core.set %doc["content"] = %content
        core.append %skill_docs, %doc
      }
      %event = core.map
      core.set %event["type"] = "discover"
      core.set %event["tools"] = %tools
      core.set %event["skills"] = %skills
      core.append %trace, %event
      core.set %state["discovered_tool_docs"] = %docs
      core.set %state["loaded_skill_docs"] = %skill_docs
      core.set %state["policy_trace"] = %trace
      %none = core.call intrinsic.none()
      core.return %none
    }
  }

  op ax.agent.runtime @normalize_agent_final_payload {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json) -> json"
    body @entry(%value: json) {
      %is_map = core.type_is %value type "object"
      core.if %is_map {
        %type = core.get %value["type"] default ""
        %is_final = core.call intrinsic.eq(%type, "final")
        core.if %is_final {
          core.return %value
        } else {
        }
      } else {
      }
      %args = core.list
      core.append %args, %value
      %out = core.map
      core.set %out["type"] = "final"
      core.set %out["args"] = %args
      core.return %out
    }
  }

  op ax.agent.runtime @normalize_agent_clarification_payload {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json) -> json throws"
    body @entry(%value: json) {
      %is_map = core.type_is %value type "object"
      %question = core.let ""
      %payload = core.map
      core.if %is_map {
        %type = core.get %value["type"] default ""
        %is_clarification = core.call intrinsic.eq(%type, "askClarification")
        core.if %is_clarification {
          core.return %value
        } else {
        }
        %message = core.get %value["message"] default ""
        %question = core.get %value["question"] default %message
        %payload = core.let %value
      } else {
        %question = core.let %value
        core.set %payload["question"] = %question
      }
      %missing = core.call intrinsic.eq(%question, "")
      core.if %missing {
        %error = core.call intrinsic.error.runtime("agent clarification question is required")
        core.raise %error
      } else {
      }
      %args = core.list
      core.append %args, %payload
      %out = core.map
      core.set %out["type"] = "askClarification"
      core.set %out["args"] = %args
      core.return %out
    }
  }

  op ax.agent.policy @agent_optimizer_metadata {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json) -> json"
    body @entry(%state: json) {
      %policy = core.get %state["policy"] default null
      %policy_version = core.get %policy["policy_version"] default "agent-runtime-decision-v1"
      %stage_ids = core.list
      core.append %stage_ids, "distiller"
      core.append %stage_ids, "executor"
      core.append %stage_ids, "responder"
      %components = core.list
      %runtime_component = core.map
      core.set %runtime_component["id"] = "agent.actor.runtime_instructions"
      core.set %runtime_component["kind"] = "runtime_instruction"
      core.append %components, %runtime_component
      %discovery_component = core.map
      core.set %discovery_component["id"] = "agent.actor.discovery_policy"
      core.set %discovery_component["kind"] = "policy"
      core.append %components, %discovery_component
      %delegation_component = core.map
      core.set %delegation_component["id"] = "agent.actor.delegation_policy"
      core.set %delegation_component["kind"] = "policy"
      core.append %components, %delegation_component
      %responder_component = core.map
      core.set %responder_component["id"] = "agent.responder.signature"
      core.set %responder_component["kind"] = "stage"
      core.append %components, %responder_component
      %out = core.map
      core.set %out["policy_version"] = %policy_version
      core.set %out["stage_ids"] = %stage_ids
      core.set %out["optimizable_components"] = %components
      core.return %out
    }
  }

  op ax.agent.runtime @agent_export_runtime_state {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json) -> json"
    body @entry(%state: json) {
      %empty_map = core.map
      %empty_list = core.list
      %out = core.map
      %runtime_state = core.get %state["runtime_state"] default %empty_map
      %discovered = core.get %state["discovered_tool_docs"] default %empty_list
      %skills = core.get %state["loaded_skill_docs"] default %empty_list
      %trace = core.get %state["policy_trace"] default %empty_list
      %action_log = core.get %state["action_log"] default %empty_list
      %status_log = core.get %state["status_log"] default %empty_list
      %runtime_session_state = core.get %state["runtime_session_state"] default %empty_map
      %runtime_globals = core.get %state["runtime_globals"] default %empty_map
      core.set %out["runtime_state"] = %runtime_state
      core.set %out["discovered_tool_docs"] = %discovered
      core.set %out["loaded_skill_docs"] = %skills
      core.set %out["policy_trace"] = %trace
      core.set %out["action_log"] = %action_log
      core.set %out["status_log"] = %status_log
      core.set %out["runtime_session_state"] = %runtime_session_state
      core.set %out["runtime_globals"] = %runtime_globals
      core.return %out
    }
  }

  op ax.agent.runtime @agent_restore_runtime_state {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, json) -> json"
    body @entry(%state: json, %snapshot: json) {
      %empty_map = core.map
      %empty_list = core.list
      %runtime_state = core.get %snapshot["runtime_state"] default %empty_map
      %discovered = core.get %snapshot["discovered_tool_docs"] default %empty_list
      %skills = core.get %snapshot["loaded_skill_docs"] default %empty_list
      %trace = core.get %snapshot["policy_trace"] default %empty_list
      %action_log = core.get %snapshot["action_log"] default %empty_list
      %status_log = core.get %snapshot["status_log"] default %empty_list
      %runtime_session_state = core.get %snapshot["runtime_session_state"] default %empty_map
      %runtime_globals = core.get %snapshot["runtime_globals"] default %empty_map
      core.set %state["runtime_state"] = %runtime_state
      core.set %state["discovered_tool_docs"] = %discovered
      core.set %state["loaded_skill_docs"] = %skills
      core.set %state["policy_trace"] = %trace
      core.set %state["action_log"] = %action_log
      core.set %state["status_log"] = %status_log
      core.set %state["runtime_session_state"] = %runtime_session_state
      core.set %state["runtime_globals"] = %runtime_globals
      %out = core.call @agent_export_runtime_state(%state)
      core.return %out
    }
  }

  op ax.agent.runtime @agent_runtime_build_globals {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, json) -> json throws"
    body @entry(%state: json, %values: json) {
      %empty_list = core.list
      %empty_map = core.map
      %reserved = core.call @agent_reserved_runtime_names()
      %globals = core.map
      %primitives = core.list
      %callable_inventory = core.get %state["callable_inventory"] default %empty_list
      %discovery_catalog = core.get %state["discovery_catalog"] default %empty_list
      core.set %globals["inputs"] = %values
      core.set %globals["context"] = %values
      core.set %globals["callables"] = %callable_inventory
      core.set %globals["discovery_catalog"] = %discovery_catalog
      core.for %name in %reserved {
        %primitive = core.map
        core.set %primitive["name"] = %name
        core.set %primitive["kind"] = "runtime_primitive"
        core.append %primitives, %primitive
      }
      core.set %globals["runtime_primitives"] = %primitives
      core.for %key in %values {
        %conflict = core.call intrinsic.contains(%reserved, %key)
        core.if %conflict {
          %message = core.call intrinsic.string.format("agent runtime global conflicts with reserved name: {}", %key)
          %error = core.call intrinsic.error.runtime(%message)
          core.raise %error
        } else {
          %value = core.get %values[%key]
          core.set %globals[%key] = %value
        }
      }
      %runtime_contract = core.get %state["runtime_contract"] default %empty_map
      core.set %globals["runtime"] = %runtime_contract
      core.set %state["runtime_globals"] = %globals
      core.return %globals
    }
  }

  op ax.agent.runtime @agent_runtime_append_action_log {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, json) -> json"
    body @entry(%state: json, %entry: json) {
      %empty_list = core.list
      %log = core.get %state["action_log"] default %empty_list
      core.append %log, %entry
      core.set %state["action_log"] = %log
      core.return %entry
    }
  }

  op ax.agent.runtime @normalize_agent_runtime_step_result {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, string) -> json throws"
    body @entry(%raw: json, %code: string) {
      %empty_map = core.map
      %none = core.call intrinsic.none()
      %out = core.map
      %raw_is_map = core.type_is %raw type "object"
      %kind = core.let "result"
      %is_error = core.let false
      %result = core.let %raw
      %output = core.let ""
      %error_message = core.let ""
      %error_category = core.let ""
      %completion_payload = core.let %none
      %discover_request = core.let %none
      %status = core.let %none
      core.if %raw_is_map {
        %raw_type = core.get %raw["type"] default ""
        %kind = core.get %raw["kind"] default %raw_type
        %missing_kind = core.call intrinsic.eq(%kind, "")
        core.if %missing_kind {
          %kind = core.let "result"
        } else {
        }
        %is_error = core.get %raw["is_error"] default false
        %result = core.get %raw["result"] default %raw
        %output = core.get %raw["output"] default ""
        %error_message = core.get %raw["error"] default ""
        %error_category = core.get %raw["error_category"] default ""
        %completion_payload = core.get %raw["completion_payload"] default null
        %discover_request = core.get %raw["discover"] default null
        %status = core.get %raw["status"] default null
      } else {
      }
      %completion_is_map = core.type_is %completion_payload type "object"
      core.if %completion_is_map {
      } else {
        %is_final_kind = core.call intrinsic.eq(%kind, "final")
        %is_clarification_kind = core.call intrinsic.eq(%kind, "askClarification")
        %is_protocol_kind = core.call intrinsic.or(%is_final_kind, %is_clarification_kind)
        core.if %is_protocol_kind {
          %completion_payload = core.let %raw
        } else {
        }
      }
      %completion_is_map2 = core.type_is %completion_payload type "object"
      core.if %completion_is_map2 {
        %completion_type = core.get %completion_payload["type"] default %kind
        %is_final = core.call intrinsic.eq(%completion_type, "final")
        core.if %is_final {
          %completion_payload = core.call @normalize_agent_final_payload(%completion_payload)
          %kind = core.let "final"
        } else {
          %is_clarification = core.call intrinsic.eq(%completion_type, "askClarification")
          core.if %is_clarification {
            %completion_payload = core.call @normalize_agent_clarification_payload(%completion_payload)
            %kind = core.let "askClarification"
          } else {
          }
        }
      } else {
      }
      core.set %out["type"] = "runtime_step"
      core.set %out["kind"] = %kind
      core.set %out["code"] = %code
      core.set %out["result"] = %result
      core.set %out["output"] = %output
      core.set %out["is_error"] = %is_error
      core.set %out["error"] = %error_message
      core.set %out["error_category"] = %error_category
      core.set %out["completion_payload"] = %completion_payload
      core.set %out["discover_request"] = %discover_request
      core.set %out["status"] = %status
      %is_closed = core.call intrinsic.eq(%error_category, "session_closed")
      core.if %is_closed {
        core.set %out["restart_notice"] = "runtime session closed; restarting fresh session"
      } else {
      }
      core.return %out
    }
  }

  op ax.agent.runtime @agent_runtime_create_session {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, json, json, json) -> json"
    body @entry(%state: json, %runtime: json, %globals: json, %options: json) {
      %session = core.call intrinsic.agent.runtime.create_session(%runtime, %globals, %options)
      core.set %state["runtime_session"] = %session
      core.set %state["runtime_globals"] = %globals
      %entry = core.map
      core.set %entry["type"] = "runtime_session"
      core.set %entry["action"] = "create_session"
      core.set %entry["globals"] = %globals
      core.call @agent_runtime_append_action_log(%state, %entry)
      core.return %session
    }
  }

  op ax.agent.runtime @agent_runtime_execute_step {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, json, json, string, json) -> json"
    body @entry(%state: json, %runtime: json, %session: json, %code: string, %options: json) {
      %empty_map = core.map
      %globals = core.get %state["runtime_globals"] default %empty_map
      %missing_session = core.call intrinsic.is_none(%session)
      core.if %missing_session {
        %session = core.call @agent_runtime_create_session(%state, %runtime, %globals, %options)
      } else {
      }
      %raw = core.call intrinsic.agent.runtime.execute(%session, %code, %options)
      %normalized = core.call @normalize_agent_runtime_step_result(%raw, %code)
      %closed = core.get %normalized["error_category"] default ""
      %is_closed = core.call intrinsic.eq(%closed, "session_closed")
      core.if %is_closed {
        %notice = core.map
        core.set %notice["type"] = "runtime_session"
        core.set %notice["action"] = "restart"
        core.set %notice["reason"] = "session_closed"
        core.call @agent_runtime_append_action_log(%state, %notice)
        %session = core.call @agent_runtime_create_session(%state, %runtime, %globals, %options)
        %raw = core.call intrinsic.agent.runtime.execute(%session, %code, %options)
        %normalized = core.call @normalize_agent_runtime_step_result(%raw, %code)
      } else {
      }
      core.call @agent_runtime_append_action_log(%state, %normalized)
      %discover_request = core.get %normalized["discover_request"] default null
      %has_discover = core.type_is %discover_request type "object"
      core.if %has_discover {
        core.call @agent_discover(%state, %discover_request)
      } else {
      }
      %completion_payload = core.get %normalized["completion_payload"] default null
      %has_completion = core.type_is %completion_payload type "object"
      core.if %has_completion {
        core.set %state["last_runtime_completion"] = %completion_payload
      } else {
      }
      %status = core.get %normalized["status"] default null
      %has_status = core.type_is %status type "object"
      core.if %has_status {
        %empty_list = core.list
        %status_log = core.get %state["status_log"] default %empty_list
        core.append %status_log, %status
        core.set %state["status_log"] = %status_log
      } else {
      }
      core.return %normalized
    }
  }

  op ax.agent.runtime @agent_runtime_inspect_state {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, json, json) -> json"
    body @entry(%state: json, %session: json, %options: json) {
      %inspection = core.call intrinsic.agent.runtime.inspect(%session, %options)
      core.set %state["runtime_inspection"] = %inspection
      core.return %inspection
    }
  }

  op ax.agent.runtime @agent_runtime_export_session_state {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, json, json) -> json"
    body @entry(%state: json, %session: json, %options: json) {
      %snapshot = core.call intrinsic.agent.runtime.export_state(%session, %options)
      core.set %state["runtime_session_state"] = %snapshot
      core.return %snapshot
    }
  }

  op ax.agent.runtime @agent_runtime_restore_session_state {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, json, json, json) -> json"
    body @entry(%state: json, %session: json, %snapshot: json, %options: json) {
      %restored = core.call intrinsic.agent.runtime.restore_state(%session, %snapshot, %options)
      core.set %state["runtime_session_state"] = %restored
      core.return %restored
    }
  }

  op ax.agent.runtime @agent_runtime_close_session {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, json) -> json"
    body @entry(%state: json, %session: json) {
      %closed = core.call intrinsic.agent.runtime.close(%session)
      core.set %state["runtime_session_closed"] = true
      %entry = core.map
      core.set %entry["type"] = "runtime_session"
      core.set %entry["action"] = "close_session"
      core.call @agent_runtime_append_action_log(%state, %entry)
      core.return %closed
    }
  }

  op ax.agent.runtime @agent_runtime_test {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, json, string, json, json) -> json throws"
    body @entry(%state: json, %runtime: json, %code: string, %values: json, %options: json) {
      %globals = core.call @agent_runtime_build_globals(%state, %values)
      %session = core.call @agent_runtime_create_session(%state, %runtime, %globals, %options)
      %result = core.call @agent_runtime_execute_step(%state, %runtime, %session, %code, %options)
      core.call @agent_runtime_close_session(%state, %session)
      core.return %result
    }
  }

  op ax.agent.semantic @split_context_values {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, json) -> json"
    body @entry(%state: json, %values: json) {
      %empty_list = core.list
      %context_fields = core.get %state["context_fields"] default %empty_list
      %ctx_values = core.map
      %non_ctx_values = core.map
      core.for %key in %values {
        %value = core.get %values[%key]
        %is_context = core.call intrinsic.contains(%context_fields, %key)
        core.if %is_context {
          core.set %ctx_values[%key] = %value
        } else {
          core.set %non_ctx_values[%key] = %value
        }
      }
      %out = core.map
      core.set %out["context"] = %ctx_values
      core.set %out["values"] = %non_ctx_values
      core.return %out
    }
  }

  op ax.agent.semantic @build_distiller_inputs {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, json) -> json"
    body @entry(%state: json, %values: json) {
      %empty_map = core.map
      %split = core.call @split_context_values(%state, %values)
      %context = core.get %split["context"] default %empty_map
      %out = core.map
      core.set %out["input"] = %values
      core.set %out["context"] = %context
      core.return %out
    }
  }

  op ax.agent.semantic @build_executor_inputs {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, json, json) -> json"
    body @entry(%state: json, %values: json, %distiller_payload: json) {
      %empty_list = core.list
      %empty_map = core.map
      %split = core.call @split_context_values(%state, %values)
      %non_ctx = core.get %split["values"] default %empty_map
      %empty = core.map
      %out = core.call intrinsic.map.merge(%non_ctx, %empty)
      %args = core.get %distiller_payload["args"] default %empty_list
      %fallback_request = core.call intrinsic.json.stringify(%non_ctx)
      %executor_request = core.call intrinsic.list.get(%args, 0, %fallback_request)
      %distilled_context = core.call intrinsic.list.get(%args, 1, %empty_map)
      core.set %out["input"] = %non_ctx
      core.set %out["executorRequest"] = %executor_request
      core.set %out["distilledContext"] = %distilled_context
      %exclude = core.get %state["executor_exclude_fields"] default %empty_list
      core.for %key in %exclude {
        core.call intrinsic.map.delete(%out, %key)
        core.call intrinsic.map.delete(%non_ctx, %key)
      }
      core.return %out
    }
  }

  op ax.agent.semantic @build_responder_inputs {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, json, json) -> json"
    body @entry(%state: json, %values: json, %executor_payload: json) {
      %empty_list = core.list
      %empty_map = core.map
      %split = core.call @split_context_values(%state, %values)
      %non_ctx = core.get %split["values"] default %empty_map
      %empty = core.map
      %out = core.call intrinsic.map.merge(%values, %empty)
      %args = core.get %executor_payload["args"] default %empty_list
      %task = core.call intrinsic.list.get(%args, 0, "")
      %context = core.call intrinsic.list.get(%args, 1, %empty_map)
      core.set %out["agentTask"] = %task
      core.set %out["agentContext"] = %context
      core.set %out["executorResult"] = %executor_payload
      %exclude = core.get %state["responder_exclude_fields"] default %empty_list
      core.for %key in %exclude {
        core.call intrinsic.map.delete(%out, %key)
        core.call intrinsic.map.delete(%non_ctx, %key)
      }
      core.return %out
    }
  }

  op ax.agent.semantic @normalize_agent_completion_payload {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json) -> json throws"
    body @entry(%output: json) {
      %completion = core.get %output["completion"] default %output
      %payload = core.get %completion["executorResult"] default %completion
      %type = core.get %payload["type"]
      %is_final = core.call intrinsic.eq(%type, "final")
      %is_clarification = core.call intrinsic.eq(%type, "askClarification")
      %valid = core.call intrinsic.or(%is_final, %is_clarification)
      %invalid = core.call intrinsic.not(%valid)
      core.if %invalid {
        %message = core.call intrinsic.string.format("agent stage did not return a completion payload: {}", %payload)
        %error = core.call intrinsic.error.runtime(%message)
        core.raise %error
      } else {
      }
      core.return %payload
    }
  }

  op ax.agent.semantic @throw_agent_clarification {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, json) -> void throws"
    body @entry(%payload: json, %state: json) {
      %type = core.get %payload["type"]
      %is_clarification = core.call intrinsic.eq(%type, "askClarification")
      core.if %is_clarification {
        %error = core.call intrinsic.agent.clarification_error(%payload, %state)
        core.raise %error
      } else {
      }
      %none = core.call intrinsic.none()
      core.return %none
    }
  }

  op ax.agent.semantic @merge_agent_chat_log {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, json, json, json) -> list<json>"
    body @entry(%state: json, %distiller: json, %executor: json, %responder: json) {
      %logs = core.list
      %distiller_logs = core.call intrinsic.agent.stage_chat_log(%distiller)
      core.for %entry in %distiller_logs {
        core.set %entry["name"] = "distiller"
        core.set %entry["stage"] = "ctx"
        core.append %logs, %entry
      }
      %executor_logs = core.call intrinsic.agent.stage_chat_log(%executor)
      core.for %entry in %executor_logs {
        core.set %entry["name"] = "executor"
        core.set %entry["stage"] = "task"
        core.append %logs, %entry
      }
      %responder_logs = core.call intrinsic.agent.stage_chat_log(%responder)
      core.for %entry in %responder_logs {
        core.set %entry["name"] = "responder"
        core.set %entry["stage"] = "task"
        core.append %logs, %entry
      }
      core.set %state["chat_log"] = %logs
      core.return %logs
    }
  }

  op ax.agent.semantic @merge_agent_usage {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json) -> json"
    body @entry(%state: json) {
      %empty_list = core.list
      %chat_log = core.get %state["chat_log"] default %empty_list
      %count = core.call intrinsic.len(%chat_log)
      %usage = core.map
      core.set %usage["chat_log_entries"] = %count
      core.set %state["usage"] = %usage
      core.return %usage
    }
  }

  op ax.agent.semantic @agent_get_state {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json) -> json"
    body @entry(%state: json) {
      %empty_map = core.map
      %runtime_state = core.get %state["runtime_state"] default %empty_map
      core.return %runtime_state
    }
  }

  op ax.agent.semantic @agent_set_state {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, json) -> json"
    body @entry(%state: json, %runtime_state: json) {
      core.set %state["runtime_state"] = %runtime_state
      core.return %runtime_state
    }
  }

  op ax.agent.semantic @agent_forward {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, json, json, json, json, json, json) -> json throws"
    body @entry(%state: json, %distiller: json, %executor: json, %responder: json, %client: json, %values: json, %options: json) {
      %distiller_values = core.call @build_distiller_inputs(%state, %values)
      %distiller_output = core.call intrinsic.agent.stage_forward(%distiller, %client, %distiller_values, %options)
      %distiller_payload = core.call @normalize_agent_completion_payload(%distiller_output)
      core.call @throw_agent_clarification(%distiller_payload, %state)
      %executor_values = core.call @build_executor_inputs(%state, %values, %distiller_payload)
      %executor_output = core.call intrinsic.agent.stage_forward(%executor, %client, %executor_values, %options)
      %executor_payload = core.call @normalize_agent_completion_payload(%executor_output)
      core.call @throw_agent_clarification(%executor_payload, %state)
      %responder_values = core.call @build_responder_inputs(%state, %values, %executor_payload)
      %responder_output = core.call intrinsic.agent.stage_forward(%responder, %client, %responder_values, %options)
      %logs = core.call @merge_agent_chat_log(%state, %distiller, %executor, %responder)
      %usage = core.call @merge_agent_usage(%state)
      core.set %state["last_output"] = %responder_output
      core.set %state["chat_log"] = %logs
      core.set %state["usage"] = %usage
      core.return %responder_output
    }
  }
}
