      %snapshot = core.call @normalize_agent_runtime_snapshot(%raw_snapshot)
      core.set %state["runtime_session_state"] = %snapshot
      %log_entry = core.map
      core.set %log_entry["type"] = "runtime_session"
      core.set %log_entry["action"] = "snapshot_globals"
