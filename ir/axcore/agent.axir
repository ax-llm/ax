      %chat_log = core.get %state["chat_log"] default %empty_list
      %action_log = core.get %state["action_log"] default %empty_list
      %policy_trace = core.get %state["policy_trace"] default %empty_list
      %function_traces = core.get %state["function_call_traces"] default %empty_list
      %failure_signals = core.get %state["failure_signals"] default %empty_list
