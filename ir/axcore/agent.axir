module @ax.agent version "0.1" {
  dialect @ax.agent version "0.1"

  op ax.agent.semantic @agent_factory {
    attr core_kind = "func"
    attr emit_module = "agent"
    ref parse = @parse_signature
    type signature = "(string|AxSignature, options?:json) -> json throws"
    body @entry(%signature: json, %options: json) {
      %empty_list = core.list
      %empty_map = core.map
      %sig = core.let %signature
      %is_string = core.type_is %signature type "string"
      core.if %is_string {
        %parsed_sig = core.call @parse_signature(%signature)
        %sig = core.let %parsed_sig
      } else {
        %sig = core.let %signature
      }
      %context_camel = core.get %options["contextFields"] default %empty_list
      %context_fields = core.get %options["context_fields"] default %context_camel
      %executor_options = core.get %options["executor_options"] default %empty_map
      %executor_options_camel = core.get %options["executorOptions"] default %executor_options
      %responder_options = core.get %options["responder_options"] default %empty_map
      %responder_options_camel = core.get %options["responderOptions"] default %responder_options
      %executor_exclude_camel = core.get %executor_options_camel["excludeFields"] default %empty_list
      %executor_exclude = core.get %executor_options_camel["exclude_fields"] default %executor_exclude_camel
      %responder_exclude_camel = core.get %responder_options_camel["excludeFields"] default %empty_list
      %responder_exclude = core.get %responder_options_camel["exclude_fields"] default %responder_exclude_camel
      %input_fields = core.get %sig["input_fields"] default %empty_list
      core.for %ctx in %context_fields {
        %found = core.let false
        core.for %field in %input_fields {
          %field_name = core.get %field["name"]
          %matches = core.call intrinsic.eq(%field_name, %ctx)
          core.if %matches {
            %found = core.let true
          } else {
          }
        }
        %missing = core.call intrinsic.not(%found)
        core.if %missing {
          %message = core.call intrinsic.string.format("context field not found: {}", %ctx)
          %error = core.call intrinsic.error.runtime(%message)
          core.raise %error
        } else {
        }
      }
      %chat_log = core.list
      %usage = core.map
      %state_alpha = core.map
      %action_log = core.list
      %status_log = core.list
      %state = core.map
      %runtime_contract = core.call @normalize_agent_runtime(%options)
      %has_runtime_direct = core.call intrinsic.map.contains(%options, "runtime")
      %has_runtime_config = core.call intrinsic.map.contains(%options, "runtimeConfig")
      %has_runtime_config_snake = core.call intrinsic.map.contains(%options, "runtime_config")
      %has_any_runtime_config = core.call intrinsic.or(%has_runtime_config, %has_runtime_config_snake)
      %runtime_enabled = core.call intrinsic.or(%has_runtime_direct, %has_any_runtime_config)
      %policy = core.call @normalize_agent_policy(%options)
      %policy_flags = core.call @agent_policy_flags(%options)
      %policy_registry = core.call @agent_policy_registry(%policy, %policy_flags)
      %callable_inventory = core.call @normalize_agent_callable_inventory(%options)
      %callable_split = core.call @split_agent_callable_inventory(%callable_inventory)
      %discovery_catalog = core.call @render_agent_discovery_catalog(%callable_split)
      %discovered_tool_docs = core.list
      %loaded_skill_docs = core.list
      %loaded_memories = core.list
      %used_memories = core.list
      %used_skills = core.list
      %guidance_log = core.list
      %function_call_traces = core.list
      %policy_trace = core.list
      %trace_events = core.list
      %trace = core.map
      core.set %trace["schema_version"] = "axir-agent-trace-v1"
      core.set %trace["kind"] = "agent_run"
      core.set %trace["status"] = "idle"
      core.set %trace["events"] = %trace_events
      core.set %state["signature"] = %sig
      core.set %state["options"] = %options
      core.set %state["context_fields"] = %context_fields
      core.set %state["executor_exclude_fields"] = %executor_exclude
      core.set %state["responder_exclude_fields"] = %responder_exclude
      core.set %state["distiller_signature"] = "input:json, context:json -> completion:json"
      %code_field_name = core.get %runtime_contract["code_field_name"] default "javascriptCode"
      %runtime_executor_signature = core.call intrinsic.string.format("input:json, executorRequest:string, distilledContext:json, discoveredToolDocs?:string, loadedSkills?:string, summarizedActorLog?:string, guidanceLog?:string, actionLog:string -> {}:code", %code_field_name)
      %executor_signature = core.let "input:json, executorRequest:string, distilledContext:json -> completion:json"
      core.if %runtime_enabled {
        %executor_signature = core.let %runtime_executor_signature
      } else {
      }
      core.set %state["executor_signature"] = %executor_signature
      core.set %state["chat_log"] = %chat_log
      core.set %state["usage"] = %usage
      core.set %state["runtime_state"] = %state_alpha
      core.set %state["action_log"] = %action_log
      core.set %state["status_log"] = %status_log
      core.set %state["runtime_contract"] = %runtime_contract
      core.set %state["runtime_enabled"] = %runtime_enabled
      core.set %state["policy"] = %policy
      core.set %state["policy_flags"] = %policy_flags
      core.set %state["policy_registry"] = %policy_registry
      core.set %state["callable_inventory"] = %callable_inventory
      core.set %state["callable_split"] = %callable_split
      core.set %state["discovery_catalog"] = %discovery_catalog
      core.set %state["discovered_tool_docs"] = %discovered_tool_docs
      core.set %state["loaded_skill_docs"] = %loaded_skill_docs
      core.set %state["loaded_memories"] = %loaded_memories
      core.set %state["used_memories"] = %used_memories
      core.set %state["used_skills"] = %used_skills
      core.set %state["guidance_log"] = %guidance_log
      core.set %state["function_call_traces"] = %function_call_traces
      core.set %state["policy_trace"] = %policy_trace
      core.set %state["trace"] = %trace
      %optimizer_metadata = core.call @agent_optimizer_metadata(%state)
      core.set %state["optimizer_metadata"] = %optimizer_metadata
      %actor_prompt_policy = core.call @build_agent_actor_prompt_policy(%state)
      core.set %state["actor_prompt_policy"] = %actor_prompt_policy
      core.return %state
    }
  }

  op ax.agent.runtime @agent_reserved_runtime_names {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "() -> list<string>"
    body @entry {
      %names = core.list
      core.append %names, "inputs"
      core.append %names, "final"
      core.append %names, "askClarification"
      core.append %names, "discover"
      core.append %names, "recall"
      core.append %names, "llmQuery"
      core.append %names, "inspectRuntime"
      core.append %names, "reportSuccess"
      core.append %names, "reportFailure"
      core.return %names
    }
  }

  op ax.agent.runtime @agent_runtime_language_tokens {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(string) -> list<string>"
    body @entry(%language: string) {
      %trimmed = core.string_trim %language
      %sharp_spaced = core.call intrinsic.regex.replace("#", " Sharp ", %trimmed)
      %plus_spaced = core.call intrinsic.regex.replace("\\+", " Plus ", %sharp_spaced)
      %word_spaced = core.call intrinsic.regex.replace("[^A-Za-z0-9]+", " ", %plus_spaced)
      %tokens = core.call intrinsic.string.words(%word_spaced)
      core.return %tokens
    }
  }

  op ax.agent.runtime @agent_runtime_language_alias_key {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(list<string>) -> string"
    body @entry(%tokens: json) {
      %joined = core.call intrinsic.string.join("", %tokens)
      %alias_key = core.call intrinsic.string.lower(%joined)
      core.return %alias_key
    }
  }

  op ax.agent.runtime @agent_runtime_is_javascript_alias {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(string) -> bool"
    body @entry(%alias_key: string) {
      %is_javascript = core.call intrinsic.eq(%alias_key, "javascript")
      %is_js = core.call intrinsic.eq(%alias_key, "js")
      %is_ecmascript = core.call intrinsic.eq(%alias_key, "ecmascript")
      %is_js_or_javascript = core.call intrinsic.or(%is_javascript, %is_js)
      %out = core.call intrinsic.or(%is_js_or_javascript, %is_ecmascript)
      core.return %out
    }
  }

  op ax.agent.runtime @agent_runtime_code_field_name {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(list<string>, bool) -> string"
    body @entry(%tokens: json, %is_javascript: bool) {
      %out = core.let "javascriptCode"
      core.if %is_javascript {
        %out = core.let "javascriptCode"
      } else {
        %count = core.call intrinsic.len(%tokens)
        %has_tokens = core.call intrinsic.gt(%count, 0)
        core.if %has_tokens {
          %prefix = core.call intrinsic.string.lower_camel(%tokens)
          %out = core.call intrinsic.string.format("{}Code", %prefix)
        } else {
          %out = core.let "runtimeCode"
        }
      }
      core.return %out
    }
  }

  op ax.agent.runtime @agent_runtime_code_fence_language {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(list<string>, string, bool) -> string"
    body @entry(%tokens: json, %alias_key: string, %is_javascript: bool) {
      %out = core.let "js"
      core.if %is_javascript {
        %out = core.let "js"
      } else {
        %count = core.call intrinsic.len(%tokens)
        %has_tokens = core.call intrinsic.gt(%count, 0)
        core.if %has_tokens {
          %out = core.let %alias_key
        } else {
          %out = core.let "text"
        }
      }
      core.return %out
    }
  }

  op ax.agent.runtime @normalize_agent_runtime {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json) -> json"
    body @entry(%options: json) {
      %empty_map = core.map
      %runtime_camel = core.get %options["runtimeConfig"] default %empty_map
      %runtime = core.get %options["runtime"] default %runtime_camel
      %raw_language = core.get %runtime["language"] default "JavaScript"
      %trimmed_language = core.string_trim %raw_language
      %language_missing = core.call intrinsic.eq(%trimmed_language, "")
      %language = core.let %trimmed_language
      core.if %language_missing {
        %language = core.let "JavaScript"
      } else {
      }
      %language_tokens = core.call @agent_runtime_language_tokens(%language)
      %alias_key = core.call @agent_runtime_language_alias_key(%language_tokens)
      %is_js = core.call @agent_runtime_is_javascript_alias(%alias_key)
      %code_field_camel = core.get %runtime["codeFieldName"] default ""
      %code_field_name = core.get %runtime["code_field_name"] default %code_field_camel
      %missing_code_field = core.call intrinsic.eq(%code_field_name, "")
      core.if %missing_code_field {
        %code_field_name = core.call @agent_runtime_code_field_name(%language_tokens, %is_js)
      } else {
      }
      %code_title_camel = core.get %runtime["codeFieldTitle"] default ""
      %code_field_title = core.get %runtime["code_field_title"] default %code_title_camel
      %missing_title = core.call intrinsic.eq(%code_field_title, "")
      core.if %missing_title {
        %code_field_title = core.call intrinsic.string.title_from_camel(%code_field_name)
      } else {
      }
      %code_fence_camel = core.get %runtime["codeFenceLanguage"] default ""
      %code_fence_language = core.get %runtime["code_fence_language"] default %code_fence_camel
      %missing_fence = core.call intrinsic.eq(%code_fence_language, "")
      core.if %missing_fence {
        %code_fence_language = core.call @agent_runtime_code_fence_language(%language_tokens, %alias_key, %is_js)
      } else {
      }
      %usage_camel = core.get %runtime["usageInstructions"] default ""
      %usage_instructions = core.get %runtime["usage_instructions"] default %usage_camel
      %missing_usage = core.call intrinsic.eq(%usage_instructions, "")
      core.if %missing_usage {
        %usage_instructions = core.let "Use the active runtime language. Read inputs, call namespaced tools or child agents, use discover(...) before unknown callables, final(...) when complete, and askClarification(...) when blocked."
      } else {
      }
      %primitives = core.call @agent_reserved_runtime_names()
      %state_hooks = core.list
      core.append %state_hooks, "create_session"
      core.append %state_hooks, "execute_code"
      core.append %state_hooks, "inspect_globals"
      core.append %state_hooks, "export_state"
      core.append %state_hooks, "restore_state"
      core.append %state_hooks, "close_session"
      %out = core.map
      core.set %out["language"] = %language
      core.set %out["code_field_name"] = %code_field_name
      core.set %out["code_field_title"] = %code_field_title
      core.set %out["code_fence_language"] = %code_fence_language
      core.set %out["is_javascript"] = %is_js
      core.set %out["usage_instructions"] = %usage_instructions
      core.set %out["callable_format"] = "namespaced_runtime_call"
      core.set %out["primitives"] = %primitives
      core.set %out["state_hooks"] = %state_hooks
      core.return %out
    }
  }

  op ax.agent.policy @normalize_agent_policy {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json) -> json"
    body @entry(%options: json) {
      %empty_map = core.map
      %policy_camel = core.get %options["agentPolicy"] default %empty_map
      %policy_in = core.get %options["agent_policy"] default %policy_camel
      %discovery_default = core.get %policy_in["discovery_default"] default "compact_catalog_prompt_full_docs_runtime_discover"
      %delegation_default = core.get %policy_in["delegation_default"] default "child_agents_as_namespaced_tools"
      %skills_default = core.get %policy_in["skills_default"] default "host_callback_loads_skill_docs_next_executor_prompt"
      %prompt_placement = core.get %policy_in["prompt_placement"] default "runtime_usage_catalog_in_actor_prompt_loaded_docs_next_turn"
      %out = core.map
      core.set %out["policy_version"] = "agent-runtime-decision-v1"
      core.set %out["policy_schema_version"] = "axir-agent-policy-v1"
      core.set %out["discovery_default"] = %discovery_default
      core.set %out["delegation_default"] = %delegation_default
      core.set %out["skills_default"] = %skills_default
      core.set %out["prompt_placement"] = %prompt_placement
      core.set %out["discover_returns"] = "void"
      core.return %out
    }
  }

  op ax.agent.policy @agent_policy_flags {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json) -> json"
    body @entry(%options: json) {
      %function_discovery_camel = core.get %options["functionDiscovery"] default false
      %function_discovery = core.get %options["function_discovery"] default %function_discovery_camel
      %skills_camel = core.get %options["skillsMode"] default false
      %skills_direct = core.get %options["skills_mode"] default %skills_camel
      %has_skills_callback = core.call intrinsic.map.contains(%options, "onSkillsSearch")
      %skills_mode = core.call intrinsic.or(%skills_direct, %has_skills_callback)
      %memories_camel = core.get %options["memoriesMode"] default false
      %memories_direct = core.get %options["memories_mode"] default %memories_camel
      %has_memories_callback = core.call intrinsic.map.contains(%options, "onMemoriesSearch")
      %memories_mode = core.call intrinsic.or(%memories_direct, %has_memories_callback)
      %usage_camel = core.get %options["usageTrackingMode"] default false
      %usage_enabled = core.get %options["usage_tracking_mode"] default %usage_camel
      %status_camel = core.get %options["hasAgentStatusCallback"] default false
      %status_direct = core.get %options["has_agent_status_callback"] default %status_camel
      %has_status_callback = core.call intrinsic.map.contains(%options, "agentStatusCallback")
      %status_mode = core.call intrinsic.or(%status_direct, %has_status_callback)
      %inspect_camel = core.get %options["hasInspectRuntime"] default false
      %inspect_direct = core.get %options["has_inspect_runtime"] default %inspect_camel
      %context_config = core.get %options["context"] default null
      %has_context_config = core.type_is %context_config type "object"
      %inspect_mode = core.call intrinsic.or(%inspect_direct, %has_context_config)
      %out = core.map
      core.set %out["discoveryMode"] = %function_discovery
      core.set %out["skillsMode"] = %skills_mode
      core.set %out["memoriesMode"] = %memories_mode
      core.set %out["usageTrackingMode"] = %usage_enabled
      core.set %out["hasAgentStatusCallback"] = %status_mode
      core.set %out["hasInspectRuntime"] = %inspect_mode
      core.return %out
    }
  }

  op ax.agent.policy @agent_policy_action {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(string, string, string, json, string, string, string, bool) -> json"
    body @entry(%id: string, %category: string, %kind: string, %stages: json, %availability: string, %effect: string, %host_boundary: string, %actor_visible: bool) {
      %entry = core.map
      core.set %entry["id"] = %id
      core.set %entry["category"] = %category
      core.set %entry["kind"] = %kind
      core.set %entry["stages"] = %stages
      core.set %entry["availability_condition"] = %availability
      core.set %entry["effect"] = %effect
      core.set %entry["host_boundary"] = %host_boundary
      core.set %entry["actor_visible"] = %actor_visible
      core.set %entry["trace_event"] = %id
      core.return %entry
    }
  }

  op ax.agent.policy @agent_policy_registry {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, json) -> json"
    body @entry(%policy: json, %flags: json) {
      %distiller_executor = core.list
      core.append %distiller_executor, "distiller"
      core.append %distiller_executor, "executor"
      %executor_only = core.list
      core.append %executor_only, "executor"
      %all_actor = core.list
      core.append %all_actor, "distiller"
      core.append %all_actor, "executor"
      %actor_primitives = core.list
      %llm = core.call @agent_policy_action("llmQuery", "actor_primitive", "sub_agent_query", %distiller_executor, "always", "returns string or string[]", "sub_agent_llm_query", true)
      core.append %actor_primitives, %llm
      %final_action = core.call @agent_policy_action("final", "actor_primitive", "completion", %distiller_executor, "always", "ends actor turn with final payload", "runtime_completion_signal", true)
      core.append %actor_primitives, %final_action
      %clarify = core.call @agent_policy_action("askClarification", "actor_primitive", "completion", %distiller_executor, "always", "throws clarification payload", "runtime_completion_signal", true)
      core.append %actor_primitives, %clarify
      %success = core.call @agent_policy_action("reportSuccess", "actor_primitive", "status", %executor_only, "hasAgentStatusCallback", "records successful progress status", "status_callback", true)
      core.append %actor_primitives, %success
      %failure = core.call @agent_policy_action("reportFailure", "actor_primitive", "status", %executor_only, "hasAgentStatusCallback", "records failed progress status", "status_callback", true)
      core.append %actor_primitives, %failure
      %inspect = core.call @agent_policy_action("inspectRuntime", "actor_primitive", "runtime_inspection", %distiller_executor, "hasInspectRuntime", "returns compact runtime state", "runtime_inspection", true)
      core.append %actor_primitives, %inspect
      %discover = core.call @agent_policy_action("discover", "actor_primitive", "discovery", %executor_only, "discoveryMode|skillsMode", "loads tool docs or skill guides for next turn", "tool_or_skill_discovery", true)
      core.append %actor_primitives, %discover
      %recall = core.call @agent_policy_action("recall", "actor_primitive", "memory", %distiller_executor, "memoriesMode", "loads memories for next turn", "memory_search", true)
      core.append %actor_primitives, %recall
      %used = core.call @agent_policy_action("used", "actor_primitive", "usage_tracking", %distiller_executor, "usageTrackingMode", "records loaded memory or skill usage", "usage_tracking_callback", true)
      core.append %actor_primitives, %used
      %protocol_actions = core.list
      %protocol_final_action = core.call @agent_policy_action("final", "protocol_action", "completion", %all_actor, "always", "normalizes final protocol payload", "completion_protocol", false)
      core.append %protocol_actions, %protocol_final_action
      %protocol_clarify = core.call @agent_policy_action("askClarification", "protocol_action", "completion", %all_actor, "always", "normalizes clarification protocol payload", "completion_protocol", false)
      core.append %protocol_actions, %protocol_clarify
      %guide = core.call @agent_policy_action("guideAgent", "protocol_action", "guidance", %executor_only, "host_protocol_only", "adds trusted guidance and continues actor loop", "host_function_protocol", false)
      core.append %protocol_actions, %guide
      %protocol_success = core.call @agent_policy_action("success", "protocol_action", "status", %executor_only, "hasAgentStatusCallback", "reports successful status", "status_callback", false)
      core.append %protocol_actions, %protocol_success
      %protocol_failed = core.call @agent_policy_action("failed", "protocol_action", "status", %executor_only, "hasAgentStatusCallback", "reports failed status", "status_callback", false)
      core.append %protocol_actions, %protocol_failed
      %runtime_globals = core.list
      %inputs = core.call @agent_policy_action("inputs", "runtime_global", "data", %all_actor, "always", "contains current actor inputs", "runtime_global", false)
      core.append %runtime_globals, %inputs
      %callables = core.call @agent_policy_action("callable_namespaces", "runtime_global", "callable_namespace", %executor_only, "has_callables", "namespaced tools and child agents", "tool_or_child_agent_handler", false)
      core.append %runtime_globals, %callables
      %bootstrap = core.call @agent_policy_action("safe_bootstrap_globals", "runtime_global", "bootstrap", %all_actor, "has_bootstrap_context", "safe context aliases only", "runtime_session_bootstrap", false)
      core.append %runtime_globals, %bootstrap
      %host_boundaries = core.list
      %tool_boundary = core.call @agent_policy_action("tool_handler", "host_boundary", "callback", %executor_only, "has_callables", "invokes target-native tool handler", "tool_handler", false)
      core.append %host_boundaries, %tool_boundary
      %child_boundary = core.call @agent_policy_action("child_agent", "host_boundary", "callback", %executor_only, "has_child_agents", "invokes child agent as callable", "child_agent_forward", false)
      core.append %host_boundaries, %child_boundary
      %memory_boundary = core.call @agent_policy_action("memory_search", "host_boundary", "callback", %distiller_executor, "memoriesMode", "loads host memory results", "memory_search_callback", false)
      core.append %host_boundaries, %memory_boundary
      %skill_boundary = core.call @agent_policy_action("skill_search", "host_boundary", "callback", %executor_only, "skillsMode", "loads host skill docs", "skill_search_callback", false)
      core.append %host_boundaries, %skill_boundary
      %status_boundary = core.call @agent_policy_action("status_callback", "host_boundary", "callback", %executor_only, "hasAgentStatusCallback", "reports progress status", "status_callback", false)
      core.append %host_boundaries, %status_boundary
      %runtime_boundary = core.call @agent_policy_action("runtime_execution", "host_boundary", "runtime", %all_actor, "has_runtime", "executes opaque runtime code", "code_runtime_session", false)
      core.append %host_boundaries, %runtime_boundary
      %inspect_boundary = core.call @agent_policy_action("runtime_inspection", "host_boundary", "runtime", %all_actor, "hasInspectRuntime", "inspects runtime state", "code_runtime_inspection", false)
      core.append %host_boundaries, %inspect_boundary
      %subquery_boundary = core.call @agent_policy_action("sub_agent_llm_query", "host_boundary", "ai", %distiller_executor, "always", "runs focused AxGen sub-query", "axgen_sub_agent", false)
      core.append %host_boundaries, %subquery_boundary
      %out = core.map
      %policy_version = core.get %policy["policy_version"] default "agent-runtime-decision-v1"
      %schema_version = core.get %policy["policy_schema_version"] default "axir-agent-policy-v1"
      core.set %out["policy_version"] = %policy_version
      core.set %out["policy_schema_version"] = %schema_version
      core.set %out["flags"] = %flags
      core.set %out["actor_primitives"] = %actor_primitives
      core.set %out["protocol_actions"] = %protocol_actions
      core.set %out["runtime_globals"] = %runtime_globals
      core.set %out["host_boundaries"] = %host_boundaries
      core.return %out
    }
  }

  op ax.agent.policy @policy_flag_enabled {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, string) -> bool"
    body @entry(%flags: json, %condition: string) {
      %out = core.let false
      %always = core.call intrinsic.eq(%condition, "always")
      core.if %always {
        %out = core.let true
      } else {
        %discovery_or_skills = core.call intrinsic.eq(%condition, "discoveryMode|skillsMode")
        core.if %discovery_or_skills {
          %discovery = core.get %flags["discoveryMode"] default false
          %skills = core.get %flags["skillsMode"] default false
          %out = core.call intrinsic.or(%discovery, %skills)
        } else {
          %host_only = core.call intrinsic.eq(%condition, "host_protocol_only")
          core.if %host_only {
            %out = core.let true
          } else {
            %value = core.get %flags[%condition] default false
            %out = core.let %value
          }
        }
      }
      core.return %out
    }
  }

  op ax.agent.policy @select_actor_primitives {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, string) -> json"
    body @entry(%registry: json, %stage: string) {
      %empty_list = core.list
      %out = core.list
      %flags = core.get %registry["flags"] default %empty_list
      %primitives = core.get %registry["actor_primitives"] default %empty_list
      core.for %primitive in %primitives {
        %stages = core.get %primitive["stages"] default %empty_list
        %in_stage = core.call intrinsic.contains(%stages, %stage)
        %condition = core.get %primitive["availability_condition"] default "always"
        %enabled = core.call @policy_flag_enabled(%flags, %condition)
        %include = core.call intrinsic.and(%in_stage, %enabled)
        core.if %include {
          core.append %out, %primitive
        } else {
        }
      }
      core.return %out
    }
  }

  op ax.agent.policy @select_protocol_actions {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json) -> json"
    body @entry(%registry: json) {
      %empty_list = core.list
      %actions = core.get %registry["protocol_actions"] default %empty_list
      core.return %actions
    }
  }

  op ax.agent.policy @select_runtime_globals {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json) -> json"
    body @entry(%registry: json) {
      %empty_list = core.list
      %globals = core.get %registry["runtime_globals"] default %empty_list
      core.return %globals
    }
  }

  op ax.agent.policy @validate_policy_reserved_names {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, string) -> void throws"
    body @entry(%registry: json, %name: string) {
      %reserved = core.call @agent_reserved_runtime_names()
      %conflicts = core.call intrinsic.contains(%reserved, %name)
      core.if %conflicts {
        %message = core.call intrinsic.string.format("agent callable namespace conflicts with reserved runtime name: {}", %name)
        %error = core.call intrinsic.error.runtime(%message)
        core.raise %error
      } else {
      }
      %none = core.call intrinsic.none()
      core.return %none
    }
  }

  op ax.agent.policy @render_actor_primitive_guidance {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, string) -> string"
    body @entry(%registry: json, %stage: string) {
      %primitives = core.call @select_actor_primitives(%registry, %stage)
      %lines = core.list
      core.for %primitive in %primitives {
        %id = core.get %primitive["id"]
        %effect = core.get %primitive["effect"] default ""
        %line = core.call intrinsic.string.format("- {}: {}", %id, %effect)
        core.append %lines, %line
      }
      %out = core.call intrinsic.string.join("\n", %lines)
      core.return %out
    }
  }

  op ax.agent.policy @record_policy_event {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, string, json) -> void"
    body @entry(%state: json, %action: string, %payload: json) {
      %empty_list = core.list
      %trace = core.get %state["policy_trace"] default %empty_list
      %event = core.map
      core.set %event["type"] = "policy_event"
      core.set %event["action"] = %action
      core.set %event["payload"] = %payload
      core.append %trace, %event
      core.set %state["policy_trace"] = %trace
      %none = core.call intrinsic.none()
      core.return %none
    }
  }

  op ax.agent.policy @normalize_policy_action_result {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(string, json) -> json"
    body @entry(%action: string, %payload: json) {
      %out = core.map
      %null_value = core.call intrinsic.none()
      core.set %out["action"] = %action
      core.set %out["payload"] = %payload
      %is_discover = core.call intrinsic.eq(%action, "discover")
      %is_recall = core.call intrinsic.eq(%action, "recall")
      %is_used = core.call intrinsic.eq(%action, "used")
      %is_effect = core.call intrinsic.or(%is_discover, %is_recall)
      %is_effect = core.call intrinsic.or(%is_effect, %is_used)
      core.if %is_effect {
        core.set %out["returns"] = %null_value
        core.set %out["effect_only"] = true
      } else {
        core.set %out["returns"] = %payload
        core.set %out["effect_only"] = false
      }
      core.return %out
    }
  }

  op ax.agent.policy @build_agent_actor_prompt_policy {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json) -> json"
    body @entry(%state: json) {
      %runtime_contract = core.get %state["runtime_contract"]
      %code_field_name = core.get %runtime_contract["code_field_name"] default "javascriptCode"
      %code_field_title = core.get %runtime_contract["code_field_title"] default "Javascript Code"
      %code_fence_language = core.get %runtime_contract["code_fence_language"] default "js"
      %stable = core.list
      core.append %stable, "input"
      core.append %stable, "executorRequest"
      core.append %stable, "distilledContext"
      core.append %stable, "contextMetadata"
      core.append %stable, "contextMap"
      core.append %stable, "memories"
      core.append %stable, "discoveredToolDocs"
      core.append %stable, "loadedSkills"
      core.append %stable, "summarizedActorLog"
      %dynamic = core.list
      core.append %dynamic, "guidanceLog"
      core.append %dynamic, "actionLog"
      core.append %dynamic, "liveRuntimeState"
      core.append %dynamic, "contextPressure"
      %out = core.map
      core.set %out["stable_cached_fields"] = %stable
      core.set %out["dynamic_uncached_fields"] = %dynamic
      core.set %out["code_field_name"] = %code_field_name
      core.set %out["code_field_title"] = %code_field_title
      core.set %out["code_fence_language"] = %code_fence_language
      core.set %out["cache_order"] = "stable_before_dynamic"
      core.return %out
    }
  }

  op ax.agent.policy @normalize_agent_callable {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, string) -> json throws"
    body @entry(%raw: json, %namespace: string) {
      %name = core.get %raw["name"] default ""
      %missing_name = core.call intrinsic.eq(%name, "")
      core.if %missing_name {
        %error = core.call intrinsic.error.runtime("agent callable name is required")
        core.raise %error
      } else {
      }
      %kind = core.get %raw["kind"] default "tool"
      %description = core.get %raw["description"] default ""
      %qualified = core.call intrinsic.string.format("{}.{}", %namespace, %name)
      %parameters = core.get %raw["parameters"] default null
      %always_camel = core.get %raw["alwaysInclude"] default false
      %always_include = core.get %raw["always_include"] default %always_camel
      %out = core.map
      core.set %out["name"] = %name
      core.set %out["namespace"] = %namespace
      core.set %out["qualified_name"] = %qualified
      core.set %out["kind"] = %kind
      core.set %out["description"] = %description
      core.set %out["parameters"] = %parameters
      core.set %out["always_include"] = %always_include
      core.return %out
    }
  }

  op ax.agent.policy @normalize_agent_group {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json) -> json throws"
    body @entry(%raw: json) {
      %empty_list = core.list
      %name = core.get %raw["name"] default "tools"
      %namespace = core.get %raw["namespace"] default %name
      %reserved = core.call @agent_reserved_runtime_names()
      %conflicts = core.call intrinsic.contains(%reserved, %namespace)
      core.if %conflicts {
        %message = core.call intrinsic.string.format("agent callable namespace conflicts with reserved runtime name: {}", %namespace)
        %error = core.call intrinsic.error.runtime(%message)
        core.raise %error
      } else {
      }
      %title = core.get %raw["title"] default %namespace
      %description = core.get %raw["description"] default ""
      %selection_camel = core.get %raw["selectionCriteria"] default ""
      %selection_criteria = core.get %raw["selection_criteria"] default %selection_camel
      %always_camel = core.get %raw["alwaysInclude"] default false
      %always_include = core.get %raw["always_include"] default %always_camel
      %functions = core.get %raw["functions"] default %empty_list
      %callables = core.list
      core.for %fn in %functions {
        %callable = core.call @normalize_agent_callable(%fn, %namespace)
        core.append %callables, %callable
      }
      %out = core.map
      core.set %out["namespace"] = %namespace
      core.set %out["title"] = %title
      core.set %out["description"] = %description
      core.set %out["selection_criteria"] = %selection_criteria
      core.set %out["always_include"] = %always_include
      core.set %out["callables"] = %callables
      core.return %out
    }
  }

  op ax.agent.policy @normalize_agent_callable_inventory {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json) -> json throws"
    body @entry(%options: json) {
      %empty_list = core.list
      %functions = core.get %options["functions"] default %empty_list
      %groups = core.list
      %flat_callables = core.list
      %has_flat = core.let false
      %has_group = core.let false
      core.for %item in %functions {
        %group_functions = core.get %item["functions"] default null
        %is_group = core.type_is %group_functions type "list"
        core.if %is_group {
          %has_group = core.let true
          core.if %has_flat {
            %error = core.call intrinsic.error.runtime("agent functions cannot mix grouped modules and flat functions")
            core.raise %error
          } else {
          }
          %group = core.call @normalize_agent_group(%item)
          core.append %groups, %group
        } else {
          %has_flat = core.let true
          core.if %has_group {
            %error = core.call intrinsic.error.runtime("agent functions cannot mix grouped modules and flat functions")
            core.raise %error
          } else {
          }
          %callable = core.call @normalize_agent_callable(%item, "tools")
          core.append %flat_callables, %callable
        }
      }
      %flat_count = core.call intrinsic.len(%flat_callables)
      %has_any_flat = core.call intrinsic.gt(%flat_count, 0)
      core.if %has_any_flat {
        %flat_group = core.map
        core.set %flat_group["namespace"] = "tools"
        core.set %flat_group["title"] = "Tools"
        core.set %flat_group["description"] = ""
        core.set %flat_group["selection_criteria"] = ""
        core.set %flat_group["always_include"] = true
        core.set %flat_group["callables"] = %flat_callables
        core.append %groups, %flat_group
      } else {
      }
      core.return %groups
    }
  }

  op ax.agent.policy @split_agent_callable_inventory {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json) -> json"
    body @entry(%inventory: json) {
      %inline = core.list
      %discoverable = core.list
      core.for %group in %inventory {
        %always = core.get %group["always_include"] default false
        core.if %always {
          core.append %inline, %group
        } else {
          core.append %discoverable, %group
        }
      }
      %out = core.map
      core.set %out["inline"] = %inline
      core.set %out["discoverable"] = %discoverable
      core.return %out
    }
  }

  op ax.agent.policy @render_agent_discovery_catalog {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json) -> json"
    body @entry(%split: json) {
      %empty_list = core.list
      %catalog = core.list
      %inline = core.get %split["inline"] default %empty_list
      %discoverable = core.get %split["discoverable"] default %empty_list
      core.for %group in %inline {
        %callable_names = core.list
        %callables = core.get %group["callables"] default %empty_list
        core.for %callable in %callables {
          %qualified = core.get %callable["qualified_name"]
          core.append %callable_names, %qualified
        }
        %namespace = core.get %group["namespace"]
        %entry = core.map
        core.set %entry["namespace"] = %namespace
        core.set %entry["placement"] = "actor_prompt"
        core.set %entry["callables"] = %callable_names
        core.append %catalog, %entry
      }
      core.for %group in %discoverable {
        %namespace = core.get %group["namespace"]
        %hint = core.call intrinsic.string.format("discover tools {}", %namespace)
        %entry = core.map
        core.set %entry["namespace"] = %namespace
        core.set %entry["placement"] = "discover"
        core.set %entry["hint"] = %hint
        core.append %catalog, %entry
      }
      core.return %catalog
    }
  }

  op ax.agent.policy @normalize_agent_string_list {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, string) -> list<string> throws"
    body @entry(%value: json, %label: string) {
      %out = core.list
      %is_string = core.type_is %value type "string"
      core.if %is_string {
        %trimmed = core.string_trim %value
        %empty = core.call intrinsic.eq(%trimmed, "")
        core.if %empty {
          %message = core.call intrinsic.string.format("{} entries must be non-empty strings", %label)
          %error = core.call intrinsic.error.runtime(%message)
          core.raise %error
        } else {
          core.append %out, %trimmed
        }
      } else {
        %is_list = core.type_is %value type "list"
        %not_list = core.call intrinsic.not(%is_list)
        core.if %not_list {
          %message = core.call intrinsic.string.format("{} must be a string or string[]", %label)
          %error = core.call intrinsic.error.runtime(%message)
          core.raise %error
        } else {
          core.for %item in %value {
            %item_is_string = core.type_is %item type "string"
            %bad_item = core.call intrinsic.not(%item_is_string)
            core.if %bad_item {
              %message = core.call intrinsic.string.format("{} entries must be strings", %label)
              %error = core.call intrinsic.error.runtime(%message)
              core.raise %error
            } else {
              %trimmed_item = core.string_trim %item
              %empty_item = core.call intrinsic.eq(%trimmed_item, "")
              core.if %empty_item {
                %message = core.call intrinsic.string.format("{} entries must be non-empty strings", %label)
                %error = core.call intrinsic.error.runtime(%message)
                core.raise %error
              } else {
                %already = core.call intrinsic.contains(%out, %trimmed_item)
                %fresh = core.call intrinsic.not(%already)
                core.if %fresh {
                  core.append %out, %trimmed_item
                } else {
                }
              }
            }
          }
        }
      }
      %count = core.call intrinsic.len(%out)
      %empty_out = core.call intrinsic.eq(%count, 0)
      core.if %empty_out {
        %message = core.call intrinsic.string.format("{} requires at least one entry", %label)
        %error = core.call intrinsic.error.runtime(%message)
        core.raise %error
      } else {
      }
      core.return %out
    }
  }

  op ax.agent.policy @normalize_agent_discover_request {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, json) -> json throws"
    body @entry(%state: json, %request: json) {
      %empty_list = core.list
      %tools = core.list
      %skills = core.list
      %flags = core.get %state["policy_flags"]
      %is_string = core.type_is %request type "string"
      %is_list = core.type_is %request type "list"
      %direct_tools = core.call intrinsic.or(%is_string, %is_list)
      core.if %direct_tools {
        %tools = core.call @normalize_agent_string_list(%request, "discover tools")
      } else {
        %is_map = core.type_is %request type "object"
        %bad = core.call intrinsic.not(%is_map)
        core.if %bad {
          %error = core.call intrinsic.error.runtime("discover(...) expects a string, string[], or { tools?, skills? }")
          core.raise %error
        } else {
          %has_tools = core.call intrinsic.map.contains(%request, "tools")
          %has_skills = core.call intrinsic.map.contains(%request, "skills")
          %has_any = core.call intrinsic.or(%has_tools, %has_skills)
          %missing_any = core.call intrinsic.not(%has_any)
          core.if %missing_any {
            %error = core.call intrinsic.error.runtime("discover(...) requires at least one of tools or skills")
            core.raise %error
          } else {
          }
          core.if %has_tools {
            %raw_tools = core.get %request["tools"] default %empty_list
            %tools = core.call @normalize_agent_string_list(%raw_tools, "discover tools")
          } else {
          }
          core.if %has_skills {
            %raw_skills = core.get %request["skills"] default %empty_list
            %skills = core.call @normalize_agent_string_list(%raw_skills, "discover skills")
          } else {
          }
        }
      }
      %tool_count = core.call intrinsic.len(%tools)
      %skill_count = core.call intrinsic.len(%skills)
      %has_tool_items = core.call intrinsic.gt(%tool_count, 0)
      %has_skill_items = core.call intrinsic.gt(%skill_count, 0)
      %discovery_mode = core.get %flags["discoveryMode"] default false
      %skills_mode = core.get %flags["skillsMode"] default false
      %tools_disabled = core.call intrinsic.not(%discovery_mode)
      %skills_disabled = core.call intrinsic.not(%skills_mode)
      %bad_tools = core.call intrinsic.and(%has_tool_items, %tools_disabled)
      core.if %bad_tools {
        %error = core.call intrinsic.error.runtime("discover({ tools }) requires function discovery to be enabled")
        core.raise %error
      } else {
      }
      %bad_skills = core.call intrinsic.and(%has_skill_items, %skills_disabled)
      core.if %bad_skills {
        %error = core.call intrinsic.error.runtime("discover({ skills }) requires skill discovery to be enabled")
        core.raise %error
      } else {
      }
      %out = core.map
      core.set %out["tools"] = %tools
      core.set %out["skills"] = %skills
      core.return %out
    }
  }

  op ax.agent.policy @agent_append_unique_by_field {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json, string) -> json"
    body @entry(%items: json, %item: json, %field: string) {
      %value = core.get %item[%field] default ""
      %found = core.let false
      core.for %existing in %items {
        %existing_value = core.get %existing[%field] default ""
        %matches = core.call intrinsic.eq(%existing_value, %value)
        core.if %matches {
          %found = core.let true
        } else {
        }
      }
      %missing = core.call intrinsic.not(%found)
      core.if %missing {
        core.append %items, %item
      } else {
      }
      core.return %items
    }
  }

  op ax.agent.policy @agent_render_discovered_tool_docs {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json) -> string"
    body @entry(%docs: json) {
      %lines = core.list
      core.for %doc in %docs {
        %qualified = core.get %doc["qualified_name"] default ""
        %description = core.get %doc["description"] default ""
        %line = core.call intrinsic.string.format("- {}: {}", %qualified, %description)
        core.append %lines, %line
      }
      %body = core.call intrinsic.string.join("\n", %lines)
      %empty = core.call intrinsic.eq(%body, "")
      %out = core.let %body
      core.if %empty {
        %out = core.let ""
      } else {
        %out = core.call intrinsic.string.format("Discovered Tool Docs\n{}", %body)
      }
      core.return %out
    }
  }

  op ax.agent.policy @agent_render_loaded_skills {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json) -> string"
    body @entry(%skills: json) {
      %lines = core.list
      core.for %skill in %skills {
        %name = core.get %skill["name"] default ""
        %content = core.get %skill["content"] default ""
        %line = core.call intrinsic.string.format("### {}\n{}", %name, %content)
        core.append %lines, %line
      }
      %body = core.call intrinsic.string.join("\n\n", %lines)
      %empty = core.call intrinsic.eq(%body, "")
      %out = core.let %body
      core.if %empty {
        %out = core.let ""
      } else {
        %out = core.call intrinsic.string.format("Loaded Skills\n{}", %body)
      }
      core.return %out
    }
  }

  op ax.agent.policy @agent_discover {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, json) -> void"
    body @entry(%state: json, %request: json) {
      %empty_list = core.list
      %normalized = core.call @normalize_agent_discover_request(%state, %request)
      %inventory = core.get %state["callable_inventory"] default %empty_list
      %docs = core.get %state["discovered_tool_docs"] default %empty_list
      %skill_docs = core.get %state["loaded_skill_docs"] default %empty_list
      %trace = core.get %state["policy_trace"] default %empty_list
      %action_log = core.get %state["action_log"] default %empty_list
      %tools = core.get %normalized["tools"] default %empty_list
      %skills = core.get %normalized["skills"] default %empty_list
      core.for %wanted in %tools {
        core.for %group in %inventory {
          %namespace = core.get %group["namespace"]
          %namespace_match = core.call intrinsic.eq(%namespace, %wanted)
          %callables = core.get %group["callables"] default %empty_list
          core.if %namespace_match {
            core.for %callable in %callables {
              %doc_name = core.get %callable["name"]
              %doc_qualified = core.get %callable["qualified_name"]
              %doc_kind = core.get %callable["kind"]
              %doc_description = core.get %callable["description"] default ""
              %doc = core.map
              core.set %doc["namespace"] = %namespace
              core.set %doc["name"] = %doc_name
              core.set %doc["qualified_name"] = %doc_qualified
              core.set %doc["kind"] = %doc_kind
              core.set %doc["description"] = %doc_description
              %docs = core.call @agent_append_unique_by_field(%docs, %doc, "qualified_name")
            }
          } else {
            core.for %callable in %callables {
              %qualified = core.get %callable["qualified_name"]
              %name = core.get %callable["name"]
              %qualified_match = core.call intrinsic.eq(%qualified, %wanted)
              %name_match = core.call intrinsic.eq(%name, %wanted)
              %matches = core.call intrinsic.or(%qualified_match, %name_match)
              core.if %matches {
                %kind = core.get %callable["kind"]
                %description = core.get %callable["description"] default ""
                %doc = core.map
                core.set %doc["namespace"] = %namespace
                core.set %doc["name"] = %name
                core.set %doc["qualified_name"] = %qualified
                core.set %doc["kind"] = %kind
                core.set %doc["description"] = %description
                %docs = core.call @agent_append_unique_by_field(%docs, %doc, "qualified_name")
              } else {
              }
            }
          }
        }
      }
      %skill_count = core.call intrinsic.len(%skills)
      %has_skills = core.call intrinsic.gt(%skill_count, 0)
      core.if %has_skills {
        %host_skills = core.call intrinsic.agent.skill_search(%state, %skills)
        %host_count = core.call intrinsic.len(%host_skills)
        %has_host = core.call intrinsic.gt(%host_count, 0)
        core.if %has_host {
          core.for %host_skill in %host_skills {
            %skill_name = core.get %host_skill["name"] default ""
            %skill_id = core.get %host_skill["id"] default %skill_name
            core.set %host_skill["id"] = %skill_id
            %skill_docs = core.call @agent_append_unique_by_field(%skill_docs, %host_skill, "id")
          }
        } else {
          core.for %skill in %skills {
            %doc = core.map
            core.set %doc["id"] = %skill
            core.set %doc["name"] = %skill
            %content = core.call intrinsic.string.format("Skill docs loaded for {}", %skill)
            core.set %doc["content"] = %content
            %skill_docs = core.call @agent_append_unique_by_field(%skill_docs, %doc, "id")
          }
        }
      } else {
      }
      %event = core.map
      core.set %event["type"] = "discover"
      core.set %event["tools"] = %tools
      core.set %event["skills"] = %skills
      core.append %trace, %event
      %action_event = core.map
      core.set %action_event["type"] = "discover"
      core.set %action_event["request"] = %request
      core.set %action_event["tools"] = %tools
      core.set %action_event["skills"] = %skills
      core.append %action_log, %action_event
      core.set %state["discovered_tool_docs"] = %docs
      core.set %state["loaded_skill_docs"] = %skill_docs
      core.set %state["policy_trace"] = %trace
      core.set %state["action_log"] = %action_log
      core.call @agent_record_trace_event(%state, "discover", %event)
      %none = core.call intrinsic.none()
      core.return %none
    }
  }

  op ax.agent.policy @normalize_agent_recall_request {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, json) -> json throws"
    body @entry(%state: json, %request: json) {
      %flags = core.get %state["policy_flags"]
      %enabled = core.get %flags["memoriesMode"] default false
      %disabled = core.call intrinsic.not(%enabled)
      core.if %disabled {
        %error = core.call intrinsic.error.runtime("recall(...) requires memory search to be enabled")
        core.raise %error
      } else {
      }
      %searches = core.call @normalize_agent_string_list(%request, "recall searches")
      %out = core.map
      core.set %out["searches"] = %searches
      core.return %out
    }
  }

  op ax.agent.policy @agent_merge_memory_results {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, json) -> json"
    body @entry(%existing: json, %incoming: json) {
      %out = core.let %existing
      core.for %memory in %incoming {
        %id = core.get %memory["id"] default ""
        %content = core.get %memory["content"] default ""
        %has_id = core.call intrinsic.ne(%id, "")
        %has_content = core.call intrinsic.ne(%content, "")
        %valid = core.call intrinsic.and(%has_id, %has_content)
        core.if %valid {
          %out = core.call @agent_append_unique_by_field(%out, %memory, "id")
        } else {
        }
      }
      core.return %out
    }
  }

  op ax.agent.policy @agent_recall {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, json) -> void"
    body @entry(%state: json, %request: json) {
      %empty_list = core.list
      %normalized = core.call @normalize_agent_recall_request(%state, %request)
      %searches = core.get %normalized["searches"] default %empty_list
      %loaded = core.get %state["loaded_memories"] default %empty_list
      %incoming = core.call intrinsic.agent.memory_search(%state, %searches, %loaded)
      %merged = core.call @agent_merge_memory_results(%loaded, %incoming)
      core.set %state["loaded_memories"] = %merged
      %trace = core.get %state["policy_trace"] default %empty_list
      %event = core.map
      core.set %event["type"] = "recall"
      core.set %event["searches"] = %searches
      core.set %event["loaded"] = %incoming
      core.append %trace, %event
      core.set %state["policy_trace"] = %trace
      %action_log = core.get %state["action_log"] default %empty_list
      %action = core.map
      core.set %action["type"] = "recall"
      core.set %action["searches"] = %searches
      core.set %action["loaded"] = %incoming
      core.append %action_log, %action
      core.set %state["action_log"] = %action_log
      core.call @agent_record_trace_event(%state, "recall", %event)
      %none = core.call intrinsic.none()
      core.return %none
    }
  }

  op ax.agent.policy @normalize_agent_used_request {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, string) -> json throws"
    body @entry(%request: json, %default_stage: string) {
      %is_map = core.type_is %request type "object"
      %id = core.let ""
      %reason = core.let ""
      %stage = core.let %default_stage
      core.if %is_map {
        %id = core.get %request["id"] default ""
        %reason = core.get %request["reason"] default ""
        %stage = core.get %request["stage"] default %default_stage
      } else {
        %id = core.let %request
      }
      %id = core.string_trim %id
      %reason = core.string_trim %reason
      %missing = core.call intrinsic.eq(%id, "")
      core.if %missing {
        %error = core.call intrinsic.error.runtime("used(...) requires a non-empty loaded memory or skill id")
        core.raise %error
      } else {
      }
      %out = core.map
      core.set %out["id"] = %id
      core.set %out["reason"] = %reason
      core.set %out["stage"] = %stage
      core.return %out
    }
  }

  op ax.agent.policy @agent_used {
    attr core_kind = "func"
    attr emit_module = "agent"
    type signature = "(json, json, string) -> void"
    body @entry(%state: json, %request: json, %stage: string) {
      %empty_list = core.list
      %flags = core.get %state["policy_flags"]
      %enabled = core.get %flags["usageTrackingMode"] default false
      %disabled = core.call intrinsic.not(%enabled)
      core.if %disabled {
        %error = core.call intrinsic.error.runtime("used(...) requires usage tracking to be enabled")
        core.raise %error
      } else {
      }
      %normalized = core.call @normalize_agent_used_request(%request, %stage)
      %id = core.get %normalized["id"]
      %reason = core.get %normalized["reason"] default ""
      %normalized_stage = core.get %normalized["stage"] default %stage
      %dedupe_key = core.call intrinsic.string.format("{}\n{}\n{}", %normalized_stage, %id, %reason)
      %memories = core.get %state["loaded_memories"] default %empty_list
      %skills = core.get %state["loaded_skill_docs"] default %empty_list
      %used_memories = core.get %state["used_memories"] default %empty_list
      %used_skills = core.get %state["used_skills"] default %empty_list
      %matched = core.let false
      core.for %memory in %memories {
        %memory_id = core.get %memory["id"] default ""
        %is_match = core.call intrinsic.eq(%memory_id, %id)
        core.if %is_match {
          %record = core.map
          core.set %record["id"] = %id
          core.set %record["reason"] = %reason
          core.set %record["stage"] = %normalized_stage
          core.set %record["dedupe_key"] = %dedupe_key
          %used_memories = core.call @agent_append_unique_by_field(%used_memories, %record, "dedupe_key")
          %matched = core.let true
        } else {
        }
      }
      core.for %skill in %skills {
        %skill_id = core.get %skill["id"] default ""
        %skill_name = core.get %skill["name"] default %skill_id
        %is_match = core.call intrinsic.eq(%skill_id, %id)
        core.if %is_match {
          %record = core.map
          core.set %record["id"] = %id
          core.set %record["name"] = %skill_name
          core.set %record["reason"] = %reason
          core.set %record["stage"] = %normalized_stage
          core.set %record["dedupe_key"] = %dedupe_key
          %used_skills = core.call @agent_append_unique_by_field(%used_skills, %record, "dedupe_key")
          %matched = core.let true
        } else {
        }
      }
      core.set %state["used_memories"] = %used_memories
      core.set %state["used_skills"] = %used_skills
      %trace = core.get %state["policy_trace"] default %empty_list
      %event = core.map
      core.set %event["type"] = "used"
      core.set %event["id"] = %id
      core.set %event["reason"] = %reason
      core.set %event["stage"] = %normalized_stage
      core.set %event["matched"] = %matched
      core.append %trace, %event
      core.set %state["policy_trace"] = %trace
      %action_log = core.get %state["action_log"] default %empty_list
      core.append %action_log, %event
      core.set %state["action_log"] = %action_log
      core.call @agent_record_trace_event(%state, "used", %event)
      %none = core.call intrinsic.none()
      core.return %none
    }
  }

