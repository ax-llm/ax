  op ax.agent.policy @normalize_agent_callable {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, string) -> json throws"
    body @entry(%raw: json, %namespace: string) {
      %name = core.get %raw["name"] default ""
      %missing_name = core.call intrinsic.eq(%name, "")
      core.if %missing_name {
        %error = core.call intrinsic.error.runtime("agent callable name is required")
        core.raise %error
      }
      %kind = core.get %raw["kind"] default "tool"
      %description = core.get %raw["description"] default ""
      %qualified = core.call intrinsic.string.format("{}.{}", %namespace, %name)
      %parameters = core.get %raw["parameters"] default null
      %always_camel = core.get %raw["alwaysInclude"] default false
      %always_include = core.get %raw["always_include"] default %always_camel
      %out = core.map
      core.set %out["name"] = %name
      core.set %out["namespace"] = %namespace
      core.set %out["qualified_name"] = %qualified
      core.set %out["kind"] = %kind
      core.set %out["description"] = %description
      core.set %out["parameters"] = %parameters
      core.set %out["always_include"] = %always_include
      core.return %out
    }
  }

  op ax.agent.policy @normalize_agent_group {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json throws"
    body @entry(%raw: json) {
      %empty_list = core.list
      %name = core.get %raw["name"] default "tools"
      %namespace = core.get %raw["namespace"] default %name
      %reserved = core.call @agent_reserved_runtime_names()
      %conflicts = core.call intrinsic.contains(%reserved, %namespace)
      core.if %conflicts {
        %message = core.call intrinsic.string.format("agent callable namespace conflicts with reserved runtime name: {}", %namespace)
        %error = core.call intrinsic.error.runtime(%message)
        core.raise %error
      }
      %title = core.get %raw["title"] default %namespace
      %description = core.get %raw["description"] default ""
      %selection_camel = core.get %raw["selectionCriteria"] default ""
      %selection_criteria = core.get %raw["selection_criteria"] default %selection_camel
      %always_camel = core.get %raw["alwaysInclude"] default false
      %always_include = core.get %raw["always_include"] default %always_camel
      %functions = core.get %raw["functions"] default %empty_list
      %callables = core.list
      core.for %fn in %functions {
        %callable = core.call @normalize_agent_callable(%fn, %namespace)
        core.append %callables, %callable
      }
      %out = core.map
      core.set %out["namespace"] = %namespace
      core.set %out["title"] = %title
      core.set %out["description"] = %description
      core.set %out["selection_criteria"] = %selection_criteria
      core.set %out["always_include"] = %always_include
      core.set %out["callables"] = %callables
      core.return %out
    }
  }

  op ax.agent.policy @normalize_agent_callable_inventory {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json throws"
    body @entry(%options: json) {
      %empty_list = core.list
      %functions = core.get %options["functions"] default %empty_list
      %groups = core.list
      %flat_callables = core.list
      %has_flat = core.let false
      %has_group = core.let false
      core.for %item in %functions {
        %group_functions = core.get %item["functions"] default null
        %is_group = core.type_is %group_functions type "list"
        core.if %is_group {
          %has_group = core.let true
          core.if %has_flat {
            %error = core.call intrinsic.error.runtime("agent functions cannot mix grouped modules and flat functions")
            core.raise %error
          }
          %group = core.call @normalize_agent_group(%item)
          core.append %groups, %group
        } else {
          %has_flat = core.let true
          core.if %has_group {
            %error = core.call intrinsic.error.runtime("agent functions cannot mix grouped modules and flat functions")
            core.raise %error
          }
          %callable = core.call @normalize_agent_callable(%item, "tools")
          core.append %flat_callables, %callable
        }
      }
      %flat_count = core.call intrinsic.len(%flat_callables)
      %has_any_flat = core.call intrinsic.gt(%flat_count, 0)
      core.if %has_any_flat {
        %flat_group = core.map
        core.set %flat_group["namespace"] = "tools"
        core.set %flat_group["title"] = "Tools"
        core.set %flat_group["description"] = ""
        core.set %flat_group["selection_criteria"] = ""
        core.set %flat_group["always_include"] = true
        core.set %flat_group["callables"] = %flat_callables
        core.append %groups, %flat_group
      }
      core.return %groups
    }
  }

  op ax.agent.policy @split_agent_callable_inventory {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json"
    body @entry(%inventory: json) {
      %inline = core.list
      %discoverable = core.list
      core.for %group in %inventory {
        %always = core.get %group["always_include"] default false
        core.if %always {
          core.append %inline, %group
        } else {
          core.append %discoverable, %group
        }
      }
      %out = core.map
      core.set %out["inline"] = %inline
      core.set %out["discoverable"] = %discoverable
      core.return %out
    }
  }

  op ax.agent.policy @render_agent_discovery_catalog {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json"
    body @entry(%split: json) {
      %empty_list = core.list
      %catalog = core.list
      %inline = core.get %split["inline"] default %empty_list
      %discoverable = core.get %split["discoverable"] default %empty_list
      core.for %group in %inline {
        %callable_names = core.list
        %callables = core.get %group["callables"] default %empty_list
        core.for %callable in %callables {
          %qualified = core.get %callable["qualified_name"]
          core.append %callable_names, %qualified
        }
        %namespace = core.get %group["namespace"]
        %entry = core.map
        core.set %entry["namespace"] = %namespace
        core.set %entry["placement"] = "actor_prompt"
        core.set %entry["callables"] = %callable_names
        core.append %catalog, %entry
      }
      core.for %group in %discoverable {
        %namespace = core.get %group["namespace"]
        %hint = core.call intrinsic.string.format("discover tools {}", %namespace)
        %entry = core.map
        core.set %entry["namespace"] = %namespace
        core.set %entry["placement"] = "discover"
        core.set %entry["hint"] = %hint
        core.append %catalog, %entry
      }
      core.return %catalog
    }
  }

  op ax.agent.policy @normalize_agent_string_list {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, string) -> list<string> throws"
    body @entry(%value: json, %label: string) {
      %out = core.list
      %is_string = core.type_is %value type "string"
      core.if %is_string {
        %trimmed = core.string_trim %value
        %empty = core.call intrinsic.eq(%trimmed, "")
        core.if %empty {
          %message = core.call intrinsic.string.format("{} entries must be non-empty strings", %label)
          %error = core.call intrinsic.error.runtime(%message)
          core.raise %error
        } else {
          core.append %out, %trimmed
        }
      } else {
        %is_list = core.type_is %value type "list"
        %not_list = core.call intrinsic.not(%is_list)
        core.if %not_list {
          %message = core.call intrinsic.string.format("{} must be a string or string[]", %label)
          %error = core.call intrinsic.error.runtime(%message)
          core.raise %error
        } else {
          core.for %item in %value {
            %item_is_string = core.type_is %item type "string"
            %bad_item = core.call intrinsic.not(%item_is_string)
            core.if %bad_item {
              %message = core.call intrinsic.string.format("{} entries must be strings", %label)
              %error = core.call intrinsic.error.runtime(%message)
              core.raise %error
            } else {
              %trimmed_item = core.string_trim %item
              %empty_item = core.call intrinsic.eq(%trimmed_item, "")
              core.if %empty_item {
                %message = core.call intrinsic.string.format("{} entries must be non-empty strings", %label)
                %error = core.call intrinsic.error.runtime(%message)
                core.raise %error
              } else {
                %already = core.call intrinsic.contains(%out, %trimmed_item)
                %fresh = core.call intrinsic.not(%already)
                core.if %fresh {
                  core.append %out, %trimmed_item
                }
              }
            }
          }
        }
      }
      %count = core.call intrinsic.len(%out)
      %empty_out = core.call intrinsic.eq(%count, 0)
      core.if %empty_out {
        %message = core.call intrinsic.string.format("{} requires at least one entry", %label)
        %error = core.call intrinsic.error.runtime(%message)
        core.raise %error
      }
      core.return %out
    }
  }

  op ax.agent.policy @normalize_agent_discover_request {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> json throws"
    body @entry(%state: json, %request: json) {
      %empty_list = core.list
      %tools = core.list
      %skills = core.list
      %flags = core.get %state["policy_flags"]
      %is_string = core.type_is %request type "string"
      %is_list = core.type_is %request type "list"
      %direct_tools = core.call intrinsic.or(%is_string, %is_list)
      core.if %direct_tools {
        %tools = core.call @normalize_agent_string_list(%request, "discover tools")
      } else {
        %is_map = core.type_is %request type "object"
        %bad = core.call intrinsic.not(%is_map)
        core.if %bad {
          %error = core.call intrinsic.error.runtime("discover(...) expects a string, string[], or { tools?, skills? }")
          core.raise %error
        } else {
          %has_tools = core.call intrinsic.map.contains(%request, "tools")
          %has_skills = core.call intrinsic.map.contains(%request, "skills")
          %has_any = core.call intrinsic.or(%has_tools, %has_skills)
          %missing_any = core.call intrinsic.not(%has_any)
          core.if %missing_any {
            %error = core.call intrinsic.error.runtime("discover(...) requires at least one of tools or skills")
            core.raise %error
          }
          core.if %has_tools {
            %raw_tools = core.get %request["tools"] default %empty_list
            %tools = core.call @normalize_agent_string_list(%raw_tools, "discover tools")
          }
          core.if %has_skills {
            %raw_skills = core.get %request["skills"] default %empty_list
            %skills = core.call @normalize_agent_string_list(%raw_skills, "discover skills")
          }
        }
      }
      %tool_count = core.call intrinsic.len(%tools)
      %skill_count = core.call intrinsic.len(%skills)
      %has_tool_items = core.call intrinsic.gt(%tool_count, 0)
      %has_skill_items = core.call intrinsic.gt(%skill_count, 0)
      %discovery_mode = core.get %flags["discoveryMode"] default false
      %skills_mode = core.get %flags["skillsMode"] default false
      %tools_disabled = core.call intrinsic.not(%discovery_mode)
      %skills_disabled = core.call intrinsic.not(%skills_mode)
      %bad_tools = core.call intrinsic.and(%has_tool_items, %tools_disabled)
      core.if %bad_tools {
        %error = core.call intrinsic.error.runtime("discover({ tools }) requires function discovery to be enabled")
        core.raise %error
      }
      %bad_skills = core.call intrinsic.and(%has_skill_items, %skills_disabled)
      core.if %bad_skills {
        %error = core.call intrinsic.error.runtime("discover({ skills }) requires skill discovery to be enabled")
        core.raise %error
      }
      %out = core.map
      core.set %out["tools"] = %tools
      core.set %out["skills"] = %skills
      core.return %out
    }
  }

  op ax.agent.policy @agent_append_unique_by_field {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json, string) -> json"
    body @entry(%items: json, %item: json, %field: string) {
      %value = core.get %item[%field] default ""
      %found = core.let false
      core.for %existing in %items {
        %existing_value = core.get %existing[%field] default ""
        %matches = core.call intrinsic.eq(%existing_value, %value)
        core.if %matches {
          %found = core.let true
        }
      }
      %missing = core.call intrinsic.not(%found)
      core.if %missing {
        core.append %items, %item
      }
      core.return %items
    }
  }

  op ax.agent.policy @agent_normalize_skill_entry {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json"
    body @entry(%entry: json) {
      %is_map = core.type_is %entry type "object"
      core.if %is_map {
      } else {
        %none = core.call intrinsic.none()
        core.return %none
      }
      %name_raw = core.get %entry["name"] default null
      %content = core.get %entry["content"] default null
      %name_is_string = core.type_is %name_raw type "string"
      %content_is_string = core.type_is %content type "string"
      %valid_types = core.call intrinsic.and(%name_is_string, %content_is_string)
      core.if %valid_types {
      } else {
        %none = core.call intrinsic.none()
        core.return %none
      }
      %name = core.string_trim %name_raw
      %name_empty = core.call intrinsic.eq(%name, "")
      core.if %name_empty {
        %none = core.call intrinsic.none()
        core.return %none
      }
      %id_raw = core.get %entry["id"] default %name
      %id = core.let %name
      %id_is_string = core.type_is %id_raw type "string"
      core.if %id_is_string {
        %id_trimmed = core.string_trim %id_raw
        %id_has_value = core.call intrinsic.ne(%id_trimmed, "")
        core.if %id_has_value {
          %id = core.let %id_trimmed
        }
      }
      %out = core.map
      core.set %out["id"] = %id
      core.set %out["name"] = %name
      core.set %out["content"] = %content
      core.return %out
    }
  }

  op ax.agent.policy @agent_merge_skill_results {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> json"
    body @entry(%existing: json, %incoming: json) {
      %by_id = core.map
      %existing_is_list = core.type_is %existing type "list"
      core.if %existing_is_list {
        core.for %entry in %existing {
          %normalized = core.call @agent_normalize_skill_entry(%entry)
          %valid = core.type_is %normalized type "object"
          core.if %valid {
            %id = core.get %normalized["id"]
            core.set %by_id[%id] = %normalized
          }
        }
      }
      %incoming_is_list = core.type_is %incoming type "list"
      core.if %incoming_is_list {
        core.for %entry2 in %incoming {
          %normalized2 = core.call @agent_normalize_skill_entry(%entry2)
          %valid2 = core.type_is %normalized2 type "object"
          core.if %valid2 {
            %id2 = core.get %normalized2["id"]
            core.set %by_id[%id2] = %normalized2
          }
        }
      }
      %ids = core.call intrinsic.map.keys(%by_id)
      %sorted_ids = core.call intrinsic.list.sorted_strings(%ids)
      %out = core.list
      core.for %sorted_id in %sorted_ids {
        %item = core.get %by_id[%sorted_id]
        core.append %out, %item
      }
      core.return %out
    }
  }

  op ax.agent.policy @agent_normalize_skill_catalog {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json"
    body @entry(%catalog: json) {
      %empty = core.list
      %base = core.call @agent_merge_skill_results(%empty, %catalog)
      %catalog_by_id = core.map
      %catalog_is_list = core.type_is %catalog type "list"
      core.if %catalog_is_list {
        core.for %raw in %catalog {
          %normalized = core.call @agent_normalize_skill_entry(%raw)
          %valid = core.type_is %normalized type "object"
          core.if %valid {
            %id = core.get %normalized["id"]
            %description_raw = core.get %raw["description"] default null
            %description_is_string = core.type_is %description_raw type "string"
            core.if %description_is_string {
              core.set %normalized["description"] = %description_raw
            }
            core.set %catalog_by_id[%id] = %normalized
          }
        }
      }
      %base_count = core.call intrinsic.len(%base)
      %has_base = core.call intrinsic.gt(%base_count, 0)
      core.if %has_base {
        %ids = core.call intrinsic.map.keys(%catalog_by_id)
        %sorted_ids = core.call intrinsic.list.sorted_strings(%ids)
        %out = core.list
        core.for %sorted_id in %sorted_ids {
          %item = core.get %catalog_by_id[%sorted_id]
          core.append %out, %item
        }
        core.return %out
      }
      core.return %empty
    }
  }

  op ax.agent.policy @agent_catalog_skill_search {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> json"
    body @entry(%catalog: json, %searches: json) {
      %docs = core.list
      core.for %skill in %catalog {
        %id = core.get %skill["id"] default ""
        %name = core.get %skill["name"] default %id
        %description = core.get %skill["description"] default ""
        %content = core.get %skill["content"] default ""
        %content_head = core.call intrinsic.string.slice(%content, 0, 600)
        %fields = core.list
        %id_field = core.map
        core.set %id_field["text"] = %id
        core.set %id_field["identifier"] = true
        core.append %fields, %id_field
        %name_field = core.map
        core.set %name_field["text"] = %name
        core.set %name_field["weight"] = 2
        core.append %fields, %name_field
        %has_description = core.call intrinsic.ne(%description, "")
        core.if %has_description {
          %description_field = core.map
          core.set %description_field["text"] = %description
          core.set %description_field["weight"] = 2
          core.append %fields, %description_field
        }
        %content_field = core.map
        core.set %content_field["text"] = %content_head
        core.append %fields, %content_field
        %doc = core.map
        core.set %doc["id"] = %id
        core.set %doc["fields"] = %fields
        core.append %docs, %doc
      }
      %opts = core.map
      core.set %opts["topK"] = 2
      core.set %opts["minScore"] = 0
      core.set %opts["marginRatio"] = 0
      core.set %opts["minDocs"] = 1
      %matched_ids = core.list
      core.for %search in %searches {
        %ranked = core.call @agent_rank_documents(%search, %docs, %opts)
        core.for %ranked_entry in %ranked {
          %ranked_id = core.get %ranked_entry["id"] default ""
          %already = core.call intrinsic.contains(%matched_ids, %ranked_id)
          %fresh = core.call intrinsic.not(%already)
          core.if %fresh {
            core.append %matched_ids, %ranked_id
          }
        }
      }
      %out = core.list
      core.for %matched_id in %matched_ids {
        core.for %catalog_skill in %catalog {
          %catalog_id = core.get %catalog_skill["id"] default ""
          %matches = core.call intrinsic.eq(%catalog_id, %matched_id)
          core.if %matches {
            %result = core.map
            %result_name = core.get %catalog_skill["name"] default %catalog_id
            %result_content = core.get %catalog_skill["content"] default ""
            core.set %result["id"] = %catalog_id
            core.set %result["name"] = %result_name
            core.set %result["content"] = %result_content
            core.append %out, %result
          }
        }
      }
      core.return %out
    }
  }

  op ax.agent.policy @agent_catalog_memory_search {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json, json) -> json"
    body @entry(%catalog: json, %searches: json, %already_loaded: json) {
      %candidates = core.list
      %docs = core.list
      core.for %memory in %catalog {
        %id = core.get %memory["id"] default ""
        %loaded = core.call @agent_relevance_has_id(%already_loaded, "id", %id)
        %fresh = core.call intrinsic.not(%loaded)
        core.if %fresh {
          core.append %candidates, %memory
          %content = core.get %memory["content"] default ""
          %content_head = core.call intrinsic.string.slice(%content, 0, 600)
          %fields = core.list
          %id_field = core.map
          core.set %id_field["text"] = %id
          core.set %id_field["identifier"] = true
          core.append %fields, %id_field
          %content_field = core.map
          core.set %content_field["text"] = %content_head
          core.append %fields, %content_field
          %doc = core.map
          core.set %doc["id"] = %id
          core.set %doc["fields"] = %fields
          core.append %docs, %doc
        }
      }
      %opts = core.map
      core.set %opts["topK"] = 3
      core.set %opts["minScore"] = 0
      core.set %opts["marginRatio"] = 0
      core.set %opts["minDocs"] = 1
      %matched_ids = core.list
      core.for %search in %searches {
        %ranked = core.call @agent_rank_documents(%search, %docs, %opts)
        core.for %ranked_entry in %ranked {
          %ranked_id = core.get %ranked_entry["id"] default ""
          %already = core.call intrinsic.contains(%matched_ids, %ranked_id)
          %fresh2 = core.call intrinsic.not(%already)
          core.if %fresh2 {
            core.append %matched_ids, %ranked_id
          }
        }
      }
      %out = core.list
      core.for %matched_id in %matched_ids {
        core.for %candidate in %candidates {
          %candidate_id = core.get %candidate["id"] default ""
          %matches = core.call intrinsic.eq(%candidate_id, %matched_id)
          core.if %matches {
            core.append %out, %candidate
          }
        }
      }
      core.return %out
    }
  }

  op ax.agent.policy @agent_render_discovered_tool_docs {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> string"
    body @entry(%docs: json) {
      %lines = core.list
      core.for %doc in %docs {
        %qualified = core.get %doc["qualified_name"] default ""
        %description = core.get %doc["description"] default ""
        %line = core.call intrinsic.string.format("- {}: {}", %qualified, %description)
        core.append %lines, %line
      }
      %body = core.call intrinsic.string.join("\n", %lines)
      %empty = core.call intrinsic.eq(%body, "")
      %out = core.let %body
      core.if %empty {
        %out = core.let ""
      } else {
        %out = core.call intrinsic.string.format("Discovered Tool Docs\n{}", %body)
      }
      core.return %out
    }
  }

  op ax.agent.policy @agent_render_loaded_skills {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> string"
    body @entry(%skills: json) {
      %lines = core.list
      core.for %skill in %skills {
        %id = core.get %skill["id"] default ""
        %name = core.get %skill["name"] default ""
        %content = core.get %skill["content"] default ""
        %line = core.call intrinsic.string.format("### {}\n\nID: `{}`\n\n{}", %name, %id, %content)
        core.append %lines, %line
      }
      %body = core.call intrinsic.string.join("\n\n", %lines)
      core.return %body
    }
  }

  op ax.agent.policy @agent_render_loaded_memories {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> string"
    body @entry(%memories: json) {
      %lines = core.list
      core.for %memory in %memories {
        %id = core.get %memory["id"] default ""
        %content = core.get %memory["content"] default ""
        %line = core.call intrinsic.string.format("### Memory\n\nID: `{}`\n\n{}", %id, %content)
        core.append %lines, %line
      }
      %body = core.call intrinsic.string.join("\n\n", %lines)
      core.return %body
    }
  }

  op ax.agent.policy @agent_discover {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> void throws"
    body @entry(%state: json, %request: json) {
      %empty_list = core.list
      %normalized = core.call @normalize_agent_discover_request(%state, %request)
      %inventory = core.get %state["callable_inventory"] default %empty_list
      %docs = core.get %state["discovered_tool_docs"] default %empty_list
      %active_stage = core.get %state["active_stage"] default "executor"
      %is_distiller = core.call intrinsic.eq(%active_stage, "distiller")
      %skill_docs = core.get %state["loaded_skill_docs"] default %empty_list
      core.if %is_distiller {
        %skill_docs = core.get %state["distiller_loaded_skill_docs"] default %empty_list
      }
      %trace = core.get %state["policy_trace"] default %empty_list
      %action_log = core.get %state["action_log"] default %empty_list
      %tools = core.get %normalized["tools"] default %empty_list
      %skills = core.get %normalized["skills"] default %empty_list
      core.for %wanted in %tools {
        core.for %group in %inventory {
          %namespace = core.get %group["namespace"]
          %namespace_match = core.call intrinsic.eq(%namespace, %wanted)
          %callables = core.get %group["callables"] default %empty_list
          core.if %namespace_match {
            core.for %callable in %callables {
              %doc_name = core.get %callable["name"]
              %doc_qualified = core.get %callable["qualified_name"]
              %doc_kind = core.get %callable["kind"]
              %doc_description = core.get %callable["description"] default ""
              %doc = core.map
              core.set %doc["namespace"] = %namespace
              core.set %doc["name"] = %doc_name
              core.set %doc["qualified_name"] = %doc_qualified
              core.set %doc["kind"] = %doc_kind
              core.set %doc["description"] = %doc_description
              %docs = core.call @agent_append_unique_by_field(%docs, %doc, "qualified_name")
            }
          } else {
            core.for %callable in %callables {
              %qualified = core.get %callable["qualified_name"]
              %name = core.get %callable["name"]
              %qualified_match = core.call intrinsic.eq(%qualified, %wanted)
              %name_match = core.call intrinsic.eq(%name, %wanted)
              %matches = core.call intrinsic.or(%qualified_match, %name_match)
              core.if %matches {
                %kind = core.get %callable["kind"]
                %description = core.get %callable["description"] default ""
                %doc = core.map
                core.set %doc["namespace"] = %namespace
                core.set %doc["name"] = %name
                core.set %doc["qualified_name"] = %qualified
                core.set %doc["kind"] = %kind
                core.set %doc["description"] = %description
                %docs = core.call @agent_append_unique_by_field(%docs, %doc, "qualified_name")
              }
            }
          }
        }
      }
      %skill_count = core.call intrinsic.len(%skills)
      %has_skills = core.call intrinsic.gt(%skill_count, 0)
      %loaded_from_search = core.list
      %observer_loaded_from_search = core.list
      core.if %has_skills {
        %state_options = core.get %state["options"] default null
        %callback_camel = core.get %state_options["onSkillsSearch"] default null
        %callback_value = core.get %state_options["on_skills_search"] default %callback_camel
        %scripted_camel = core.get %state_options["skillSearchResults"] default null
        %scripted_value = core.get %state_options["skill_search_results"] default %scripted_camel
        %has_callback = core.call intrinsic.is_not_none(%callback_value)
        %has_scripted = core.call intrinsic.is_not_none(%scripted_value)
        %has_host_search = core.call intrinsic.or(%has_callback, %has_scripted)
        core.if %has_host_search {
          %host_skills = core.call intrinsic.agent.skill_search(%state, %skills)
          %observer_loaded_from_search = core.let %host_skills
          %loaded_from_search = core.call @agent_merge_skill_results(%empty_list, %host_skills)
        } else {
          %catalog = core.get %state["skills_catalog"] default %empty_list
          %loaded_from_search = core.call @agent_catalog_skill_search(%catalog, %skills)
          %observer_loaded_from_search = core.let %loaded_from_search
        }
        %skill_docs = core.call @agent_merge_skill_results(%skill_docs, %loaded_from_search)
        %loaded_count = core.call intrinsic.len(%loaded_from_search)
        %loaded_any = core.call intrinsic.gt(%loaded_count, 0)
        core.if %loaded_any {
          %observer_options = core.map
          core.call intrinsic.agent.observer.notify(%state, %observer_options, "loaded_skills", %observer_loaded_from_search)
        }
      }
      %event = core.map
      core.set %event["type"] = "discover"
      core.set %event["tools"] = %tools
      core.set %event["skills"] = %skills
      core.append %trace, %event
      %action_event = core.map
      core.set %action_event["type"] = "discover"
      core.set %action_event["request"] = %request
      core.set %action_event["tools"] = %tools
      core.set %action_event["skills"] = %skills
      core.append %action_log, %action_event
      core.set %state["discovered_tool_docs"] = %docs
      core.if %is_distiller {
        core.set %state["distiller_loaded_skill_docs"] = %skill_docs
      } else {
        core.set %state["loaded_skill_docs"] = %skill_docs
      }
      core.set %state["policy_trace"] = %trace
      core.set %state["action_log"] = %action_log
      core.call @agent_record_trace_event(%state, "discover", %event)
      %none = core.call intrinsic.none()
      core.return %none
    }
  }

  op ax.agent.policy @normalize_agent_recall_request {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> json throws"
    body @entry(%state: json, %request: json) {
      %flags = core.get %state["policy_flags"]
      %enabled = core.get %flags["memoriesMode"] default false
      %disabled = core.call intrinsic.not(%enabled)
      core.if %disabled {
        %error = core.call intrinsic.error.runtime("recall(...) requires memory search to be enabled")
        core.raise %error
      }
      %searches = core.call @normalize_agent_string_list(%request, "recall searches")
      %out = core.map
      core.set %out["searches"] = %searches
      core.return %out
    }
  }

  op ax.agent.policy @agent_merge_memory_results {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> json"
    body @entry(%existing: json, %incoming: json) {
      %by_id = core.map
      %existing_is_list = core.type_is %existing type "list"
      core.if %existing_is_list {
        core.for %memory in %existing {
          %memory_is_map = core.type_is %memory type "object"
          core.if %memory_is_map {
            %id_raw = core.get %memory["id"] default null
            %content = core.get %memory["content"] default null
            %id_is_string = core.type_is %id_raw type "string"
            %content_is_string = core.type_is %content type "string"
            %valid_types = core.call intrinsic.and(%id_is_string, %content_is_string)
            core.if %valid_types {
              %id = core.string_trim %id_raw
              %has_id = core.call intrinsic.ne(%id, "")
              core.if %has_id {
                %normalized = core.map
                core.set %normalized["id"] = %id
                core.set %normalized["content"] = %content
                core.set %by_id[%id] = %normalized
              }
            }
          }
        }
      }
      %incoming_is_list = core.type_is %incoming type "list"
      core.if %incoming_is_list {
        core.for %memory2 in %incoming {
          %memory2_is_map = core.type_is %memory2 type "object"
          core.if %memory2_is_map {
            %id2_raw = core.get %memory2["id"] default null
            %content2 = core.get %memory2["content"] default null
            %id2_is_string = core.type_is %id2_raw type "string"
            %content2_is_string = core.type_is %content2 type "string"
            %valid2_types = core.call intrinsic.and(%id2_is_string, %content2_is_string)
            core.if %valid2_types {
              %id2 = core.string_trim %id2_raw
              %has_id2 = core.call intrinsic.ne(%id2, "")
              core.if %has_id2 {
                %normalized2 = core.map
                core.set %normalized2["id"] = %id2
                core.set %normalized2["content"] = %content2
                core.set %by_id[%id2] = %normalized2
              }
            }
          }
        }
      }
      %ids = core.call intrinsic.map.keys(%by_id)
      %sorted_ids = core.call intrinsic.list.sorted_strings(%ids)
      %out = core.list
      core.for %sorted_id in %sorted_ids {
        %item = core.get %by_id[%sorted_id]
        core.append %out, %item
      }
      core.return %out
    }
  }

  op ax.agent.policy @agent_recall {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> void throws"
    body @entry(%state: json, %request: json) {
      %empty_list = core.list
      %normalized = core.call @normalize_agent_recall_request(%state, %request)
      %searches = core.get %normalized["searches"] default %empty_list
      %loaded = core.get %state["loaded_memories"] default %empty_list
      %state_options = core.get %state["options"] default null
      %callback_camel = core.get %state_options["onMemoriesSearch"] default null
      %callback_value = core.get %state_options["on_memories_search"] default %callback_camel
      %scripted_camel = core.get %state_options["memorySearchResults"] default null
      %scripted_value = core.get %state_options["memory_search_results"] default %scripted_camel
      %has_callback = core.call intrinsic.is_not_none(%callback_value)
      %has_scripted = core.call intrinsic.is_not_none(%scripted_value)
      %has_host_search = core.call intrinsic.or(%has_callback, %has_scripted)
      %incoming = core.list
      %observer_incoming = core.list
      core.if %has_host_search {
        %host_incoming = core.call intrinsic.agent.memory_search(%state, %searches, %loaded)
        %observer_incoming = core.let %host_incoming
        %incoming = core.call @agent_merge_memory_results(%empty_list, %host_incoming)
      } else {
        %catalog = core.get %state["memories_catalog"] default %empty_list
        %incoming = core.call @agent_catalog_memory_search(%catalog, %searches, %loaded)
        %observer_incoming = core.let %incoming
      }
      %merged = core.call @agent_merge_memory_results(%loaded, %incoming)
      core.set %state["loaded_memories"] = %merged
      %incoming_count = core.call intrinsic.len(%incoming)
      %has_incoming = core.call intrinsic.gt(%incoming_count, 0)
      core.if %has_incoming {
        %observer_options = core.map
        core.call intrinsic.agent.observer.notify(%state, %observer_options, "loaded_memories", %observer_incoming)
      }
      %trace = core.get %state["policy_trace"] default %empty_list
      %event = core.map
      core.set %event["type"] = "recall"
      core.set %event["searches"] = %searches
      core.set %event["loaded"] = %incoming
      core.append %trace, %event
      core.set %state["policy_trace"] = %trace
      %action_log = core.get %state["action_log"] default %empty_list
      %action = core.map
      core.set %action["type"] = "recall"
      core.set %action["searches"] = %searches
      core.set %action["loaded"] = %incoming
      core.append %action_log, %action
      core.set %state["action_log"] = %action_log
      core.call @agent_record_trace_event(%state, "recall", %event)
      %none = core.call intrinsic.none()
      core.return %none
    }
  }

  op ax.agent.policy @agent_append_unique_used_entry {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> json"
    body @entry(%items: json, %entry: json) {
      %entry_id = core.get %entry["id"] default ""
      %entry_reason = core.get %entry["reason"] default ""
      %entry_stage = core.get %entry["stage"] default ""
      %exists = core.let false
      core.for %item in %items {
        %item_id = core.get %item["id"] default ""
        %item_reason = core.get %item["reason"] default ""
        %item_stage = core.get %item["stage"] default ""
        %same_id = core.call intrinsic.eq(%entry_id, %item_id)
        %same_reason = core.call intrinsic.eq(%entry_reason, %item_reason)
        %same_stage = core.call intrinsic.eq(%entry_stage, %item_stage)
        %same_id_reason = core.call intrinsic.and(%same_id, %same_reason)
        %same = core.call intrinsic.and(%same_id_reason, %same_stage)
        core.if %same {
          %exists = core.let true
        }
      }
      %missing = core.call intrinsic.not(%exists)
      core.if %missing {
        core.append %items, %entry
      }
      core.return %items
    }
  }

  op ax.agent.policy @normalize_agent_used_request {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, string) -> json throws"
    body @entry(%request: json, %default_stage: string) {
      %is_map = core.type_is %request type "object"
      %id = core.let ""
      %reason = core.let ""
      %stage = core.let %default_stage
      core.if %is_map {
        %id = core.get %request["id"] default ""
        %reason = core.get %request["reason"] default ""
        %stage = core.get %request["stage"] default %default_stage
      } else {
        %id = core.let %request
      }
      %id = core.string_trim %id
      %reason = core.string_trim %reason
      %reason = core.call intrinsic.string.slice(%reason, 0, 300)
      %missing = core.call intrinsic.eq(%id, "")
      core.if %missing {
        %error = core.call intrinsic.error.runtime("used(...) requires a non-empty loaded memory or skill id")
        core.raise %error
      }
      %out = core.map
      core.set %out["id"] = %id
      core.set %out["reason"] = %reason
      core.set %out["stage"] = %stage
      core.return %out
    }
  }

  op ax.agent.policy @agent_used {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json, string) -> void throws"
    body @entry(%state: json, %request: json, %stage: string) {
      %empty_list = core.list
      %flags = core.get %state["policy_flags"]
      %enabled = core.get %flags["usageTrackingMode"] default false
      %disabled = core.call intrinsic.not(%enabled)
      core.if %disabled {
        %error = core.call intrinsic.error.runtime("used(...) requires usage tracking to be enabled")
        core.raise %error
      }
      %normalized = core.call @normalize_agent_used_request(%request, %stage)
      %id = core.get %normalized["id"]
      %reason = core.get %normalized["reason"] default ""
      %normalized_stage = core.get %normalized["stage"] default %stage
      %memories = core.get %state["loaded_memories"] default %empty_list
      %skills = core.get %state["loaded_skill_docs"] default %empty_list
      %is_distiller = core.call intrinsic.eq(%normalized_stage, "distiller")
      core.if %is_distiller {
        %skills = core.get %state["distiller_loaded_skill_docs"] default %empty_list
      }
      %used_memories = core.get %state["used_memories"] default %empty_list
      %used_skills = core.get %state["used_skills"] default %empty_list
      %matched = core.let false
      core.for %memory in %memories {
        %memory_id = core.get %memory["id"] default ""
        %is_match = core.call intrinsic.eq(%memory_id, %id)
        core.if %is_match {
          %record = core.map
          core.set %record["id"] = %id
          core.set %record["reason"] = %reason
          core.set %record["stage"] = %normalized_stage
          %used_memories = core.call @agent_append_unique_used_entry(%used_memories, %record)
          %matched = core.let true
        }
      }
      core.for %skill in %skills {
        %skill_id = core.get %skill["id"] default ""
        %skill_name = core.get %skill["name"] default %skill_id
        %is_match = core.call intrinsic.eq(%skill_id, %id)
        core.if %is_match {
          %record = core.map
          core.set %record["id"] = %id
          core.set %record["name"] = %skill_name
          core.set %record["reason"] = %reason
          core.set %record["stage"] = %normalized_stage
          %used_skills = core.call @agent_append_unique_used_entry(%used_skills, %record)
          %matched = core.let true
        }
      }
      core.set %state["used_memories"] = %used_memories
      core.set %state["used_skills"] = %used_skills
      %trace = core.get %state["policy_trace"] default %empty_list
      %event = core.map
      core.set %event["type"] = "used"
      core.set %event["id"] = %id
      core.set %event["reason"] = %reason
      core.set %event["stage"] = %normalized_stage
      core.set %event["matched"] = %matched
      core.append %trace, %event
      core.set %state["policy_trace"] = %trace
      %action_log = core.get %state["action_log"] default %empty_list
      core.append %action_log, %event
      core.set %state["action_log"] = %action_log
      core.call @agent_record_trace_event(%state, "used", %event)
      %none = core.call intrinsic.none()
      core.return %none
    }
  }

  op ax.agent.policy @normalize_agent_guidance_payload {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, string) -> json throws"
    body @entry(%value: json, %triggered_by: string) {
      %is_map = core.type_is %value type "object"
      %guidance = core.let ""
      %trigger = core.let %triggered_by
      core.if %is_map {
        %guidance = core.get %value["guidance"] default ""
        %trigger = core.get %value["triggeredBy"] default %triggered_by
      } else {
        %guidance = core.let %value
      }
      %guidance = core.string_trim %guidance
      %missing = core.call intrinsic.eq(%guidance, "")
      core.if %missing {
        %error = core.call intrinsic.error.runtime("guideAgent() requires a non-empty string guidance")
        core.raise %error
      }
      %out = core.map
      core.set %out["type"] = "guide_agent"
      core.set %out["guidance"] = %guidance
      %has_trigger = core.call intrinsic.ne(%trigger, "")
      core.if %has_trigger {
        core.set %out["triggeredBy"] = %trigger
      }
      core.return %out
    }
  }

  op ax.agent.policy @agent_append_guidance {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> json"
    body @entry(%state: json, %payload: json) {
      %empty_list = core.list
      %entries = core.get %state["guidance_log"] default %empty_list
      %count = core.call intrinsic.len(%entries)
      %turn = core.call intrinsic.add(%count, 1)
      %guidance = core.get %payload["guidance"] default ""
      %triggered_by = core.get %payload["triggeredBy"] default ""
      %entry = core.map
      core.set %entry["turn"] = %turn
      core.set %entry["guidance"] = %guidance
      %has_trigger = core.call intrinsic.ne(%triggered_by, "")
      core.if %has_trigger {
        core.set %entry["triggeredBy"] = %triggered_by
      }
      core.append %entries, %entry
      core.set %state["guidance_log"] = %entries
      %action_log = core.get %state["action_log"] default %empty_list
      %action = core.map
      core.set %action["type"] = "guide_agent"
      core.set %action["guidance"] = %guidance
      core.set %action["triggeredBy"] = %triggered_by
      core.append %action_log, %action
      core.set %state["action_log"] = %action_log
      core.call @agent_record_trace_event(%state, "guide_agent", %entry)
      core.return %entry
    }
  }

  op ax.agent.policy @agent_execute_callable {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json, json) -> json throws"
    body @entry(%state: json, %request: json, %options: json) {
      %empty_list = core.list
      %result = core.call intrinsic.agent.callable.invoke(%state, %request, %options)
      %qualified = core.get %request["qualified_name"] default ""
      %name = core.get %request["name"] default %qualified
      %args = core.get %request["args"] default %request
      %status = core.get %result["status"] default "ok"
      %trace = core.get %state["function_call_traces"] default %empty_list
      %record = core.map
      core.set %record["qualified_name"] = %qualified
      core.set %record["name"] = %name
      core.set %record["arguments"] = %args
      core.set %record["status"] = %status
      core.set %record["result"] = %result
      core.append %trace, %record
      core.set %state["function_call_traces"] = %trace
      %action_log = core.get %state["action_log"] default %empty_list
      %action = core.map
      core.set %action["type"] = "function_call"
      core.set %action["qualified_name"] = %qualified
      core.set %action["status"] = %status
      core.append %action_log, %action
      core.set %state["action_log"] = %action_log
      %host_event = core.call @agent_normalize_host_boundary_event("callable", %request, %result, %status)
      core.call @agent_record_trace_event(%state, "function_call", %host_event)
      %guidance = core.get %result["guidance"] default null
      %has_guidance = core.call intrinsic.is_not_none(%guidance)
      core.if %has_guidance {
        %payload = core.call @normalize_agent_guidance_payload(%guidance, %qualified)
        core.call @agent_append_guidance(%state, %payload)
        core.set %result["guidance_payload"] = %payload
      }
      core.return %result
    }
  }

  op ax.agent.runtime @normalize_agent_final_payload {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json"
    body @entry(%value: json) {
      %is_map = core.type_is %value type "object"
      core.if %is_map {
        %type = core.get %value["type"] default ""
        %is_final = core.call intrinsic.eq(%type, "final")
        core.if %is_final {
          core.return %value
        }
      }
      %args = core.list
      core.append %args, %value
      %out = core.map
      core.set %out["type"] = "final"
      core.set %out["args"] = %args
      core.return %out
    }
  }

  op ax.agent.runtime @normalize_agent_respond_payload {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json"
