  op ax.agent.trace @agent_replay_trace {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> json throws"
    body @entry(%trace: json, %fixtures: json) {
      %empty_list = core.list
      %events = core.get %trace["events"] default %empty_list
      %event_kinds = core.list
      core.for %event in %events {
        %kind = core.get %event["kind"] default ""
