      %is_map = core.type_is %value type "object"
      core.if %is_map {
        %type = core.get %value["type"] default ""
        %is_respond = core.call intrinsic.eq(%type, "respond")
        core.if %is_respond {
          core.return %value
        }
      }
      %args = core.list
      core.append %args, %value
      %out = core.map
      core.set %out["type"] = "respond"
      core.set %out["args"] = %args
      core.return %out
    }
  }

  op ax.agent.runtime @normalize_agent_clarification_payload {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json throws"
    body @entry(%value: json) {
      %is_map = core.type_is %value type "object"
      %question = core.let ""
      %payload = core.map
      core.if %is_map {
        %type = core.get %value["type"] default ""
        %is_clarification = core.call intrinsic.eq(%type, "askClarification")
        core.if %is_clarification {
          core.return %value
        }
        %message = core.get %value["message"] default ""
        %question = core.get %value["question"] default %message
        %payload = core.let %value
      } else {
        %question = core.let %value
        core.set %payload["question"] = %question
      }
      %missing = core.call intrinsic.eq(%question, "")
      core.if %missing {
        %error = core.call intrinsic.error.runtime("agent clarification question is required")
        core.raise %error
      }
      %args = core.list
      core.append %args, %payload
      %out = core.map
      core.set %out["type"] = "askClarification"
      core.set %out["args"] = %args
      core.return %out
    }
  }

  op ax.agent.policy @agent_optimizer_metadata {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json"
    body @entry(%state: json) {
      %policy = core.get %state["policy"] default null
      %policy_version = core.get %policy["policy_version"] default "agent-runtime-decision-v1"
      %stage_ids = core.list
      core.append %stage_ids, "distiller"
      core.append %stage_ids, "executor"
      core.append %stage_ids, "responder"
      %components = core.list
      %runtime_component = core.map
      core.set %runtime_component["id"] = "agent.actor.runtime_instructions"
      core.set %runtime_component["kind"] = "runtime_instruction"
      core.append %components, %runtime_component
      %discovery_component = core.map
      core.set %discovery_component["id"] = "agent.actor.discovery_policy"
      core.set %discovery_component["kind"] = "policy"
      core.append %components, %discovery_component
      %delegation_component = core.map
      core.set %delegation_component["id"] = "agent.actor.delegation_policy"
      core.set %delegation_component["kind"] = "policy"
      core.append %components, %delegation_component
      %responder_component = core.map
      core.set %responder_component["id"] = "agent.responder.signature"
      core.set %responder_component["kind"] = "stage"
      core.append %components, %responder_component
      %out = core.map
      core.set %out["policy_version"] = %policy_version
      core.set %out["stage_ids"] = %stage_ids
      core.set %out["optimizable_components"] = %components
      core.return %out
    }
  }

  op ax.agent.semantic @agent_refresh_actor_instruction {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> string"
    body @entry(%state: json) {
      %parts = core.list
      %instruction = core.get %state["stage_instruction"] default ""
      %instruction_trimmed = core.string_trim %instruction
      %has_instruction = core.call intrinsic.ne(%instruction_trimmed, "")
      core.if %has_instruction {
        core.append %parts, %instruction_trimmed
      }
      %base = core.get %state["executor_description_base"] default ""
      %base_trimmed = core.string_trim %base
      %has_base = core.call intrinsic.ne(%base_trimmed, "")
      core.if %has_base {
        core.append %parts, %base_trimmed
      }
      %empty_list = core.list
      %addenda = core.get %state["instruction_addenda"] default %empty_list
      core.for %addendum in %addenda {
        %addendum_is_string = core.type_is %addendum type "string"
        core.if %addendum_is_string {
          %addendum_trimmed = core.string_trim %addendum
          %has_addendum = core.call intrinsic.ne(%addendum_trimmed, "")
          core.if %has_addendum {
            core.append %parts, %addendum_trimmed
          }
        }
      }
      %composed = core.call intrinsic.string.join("\n\n", %parts)
      core.set %state["executor_description"] = %composed
      %empty_map = core.map
      %options = core.get %state["options"] default %empty_map
      core.set %options["instruction"] = %instruction_trimmed
      core.set %options["instructionAddenda"] = %addenda
      core.set %state["options"] = %options
      core.return %composed
    }
  }

  op ax.agent.semantic @agent_set_instruction {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, string) -> string"
    body @entry(%state: json, %instruction: string) {
      %trimmed = core.string_trim %instruction
      core.set %state["stage_instruction"] = %trimmed
      %composed = core.call @agent_refresh_actor_instruction(%state)
      core.return %composed
    }
  }

  op ax.agent.semantic @agent_add_actor_instruction {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, string) -> string"
    body @entry(%state: json, %addendum: string) {
      %trimmed = core.string_trim %addendum
      %has_addendum = core.call intrinsic.ne(%trimmed, "")
      core.if %has_addendum {
        %empty_list = core.list
        %addenda = core.get %state["instruction_addenda"] default %empty_list
        core.append %addenda, %trimmed
        core.set %state["instruction_addenda"] = %addenda
      }
      %composed = core.call @agent_refresh_actor_instruction(%state)
      core.return %composed
    }
  }

  op ax.agent.semantic @agent_get_optimizable_components {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, list<json>) -> list<json>"
    body @entry(%state: json, %child_components: json) {
      %components = core.list
      core.for %component in %child_components {
        %id = core.get %component["id"] default ""
        %kind = core.get %component["kind"] default ""
        %is_instruction = core.call intrinsic.eq(%kind, "instruction")
        %is_actor_instruction = core.call intrinsic.contains(%id, ".actor::instruction")
        %is_dead_instruction = core.call intrinsic.and(%is_instruction, %is_actor_instruction)
        %keep = core.call intrinsic.not(%is_dead_instruction)
        core.if %keep {
          core.append %components, %component
        }
      }
      %instruction_component = core.map
      core.set %instruction_component["id"] = "root::instruction"
      core.set %instruction_component["owner"] = "root"
      core.set %instruction_component["kind"] = "instruction"
      %instruction = core.get %state["stage_instruction"] default ""
      core.set %instruction_component["current"] = %instruction
      core.set %instruction_component["description"] = "High-level instruction rendered at the top of the actor definition; survives stage rebuilds."
      core.set %instruction_component["constraints"] = "Keep this as a concise standing strategy or rule."
      core.set %instruction_component["format"] = "text"
      core.append %components, %instruction_component
      %runtime_component = core.map
      core.set %runtime_component["id"] = "root.agent.runtime"
      core.set %runtime_component["owner"] = "root.agent"
      core.set %runtime_component["kind"] = "runtime-policy"
      %empty_map = core.map
      %runtime = core.get %state["runtime_contract"] default %empty_map
      core.set %runtime_component["current"] = %runtime
      core.set %runtime_component["description"] = "Agent runtime-language metadata and code-field policy."
      core.set %runtime_component["format"] = "json"
      core.append %components, %runtime_component
      %policy_component = core.map
      core.set %policy_component["id"] = "root.agent.policy"
      core.set %policy_component["owner"] = "root.agent"
      core.set %policy_component["kind"] = "agent-policy"
      %policy = core.get %state["policy"] default %empty_map
      core.set %policy_component["current"] = %policy
      core.set %policy_component["description"] = "Actor primitive, discovery, delegation, and prompt placement policy."
      core.set %policy_component["format"] = "json"
      core.append %components, %policy_component
      core.return %components
    }
  }

  op ax.agent.semantic @agent_apply_optimized_components {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> string"
    body @entry(%state: json, %component_map: json) {
      %has_instruction = core.call intrinsic.map.contains(%component_map, "root::instruction")
      core.if %has_instruction {
        %instruction = core.get %component_map["root::instruction"] default ""
        core.call @agent_set_instruction(%state, %instruction)
      }
      %has_runtime = core.call intrinsic.map.contains(%component_map, "root.agent.runtime")
      core.if %has_runtime {
        %runtime = core.get %component_map["root.agent.runtime"]
        core.set %state["runtime_contract"] = %runtime
      }
      %has_policy = core.call intrinsic.map.contains(%component_map, "root.agent.policy")
      core.if %has_policy {
        %policy = core.get %component_map["root.agent.policy"]
        core.set %state["policy"] = %policy
      }
      %metadata = core.call @agent_optimizer_metadata(%state)
      core.set %state["optimizer_metadata"] = %metadata
      %composed = core.get %state["executor_description"] default ""
      core.return %composed
    }
  }

  op ax.agent.trace @agent_begin_trace {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json) -> json"
    body @entry(%state: json, %input: json) {
      %events = core.list
      %optimizer = core.get %state["optimizer_metadata"] default null
      %trace = core.map
      core.set %trace["schema_version"] = "axir-agent-trace-v1"
      core.set %trace["kind"] = "agent_run"
      core.set %trace["status"] = "running"
      core.set %trace["input"] = %input
      core.set %trace["events"] = %events
      core.set %trace["optimizer_metadata"] = %optimizer
      core.set %trace["replayable"] = true
      core.set %state["trace"] = %trace
      core.return %trace
    }
  }

  op ax.agent.trace @agent_record_trace_event {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, string, json) -> json"
    body @entry(%state: json, %kind: string, %payload: json) {
      %empty_map = core.map
      %empty_list = core.list
      %trace = core.get %state["trace"] default %empty_map
      %has_trace = core.type_is %trace type "object"
      core.if %has_trace {
      } else {
        %trace = core.call @agent_begin_trace(%state, %empty_map)
      }
      %events = core.get %trace["events"] default %empty_list
      %index = core.call intrinsic.len(%events)
      %event = core.map
      core.set %event["index"] = %index
      core.set %event["kind"] = %kind
      %payload_is_map = core.type_is %payload type "object"
      core.if %payload_is_map {
        %component = core.get %payload["component_id"] default ""
        %has_component = core.call intrinsic.ne(%component, "")
        core.if %has_component {
          core.set %event["component_id"] = %component
        }
        core.set %event["payload"] = %payload
      } else {
        core.set %event["value"] = %payload
      }
      core.append %events, %event
      core.set %trace["events"] = %events
      core.set %state["trace"] = %trace
      core.return %event
    }
  }

  op ax.agent.trace @agent_normalize_host_boundary_event {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(string, json, json, string) -> json"
    body @entry(%boundary: string, %request: json, %result: json, %status: string) {
      %out = core.map
      core.set %out["boundary"] = %boundary
      core.set %out["request"] = %request
      core.set %out["result"] = %result
      core.set %out["status"] = %status
      core.return %out
    }
  }

  op ax.agent.trace @agent_finalize_trace {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, string, json) -> json"
    body @entry(%state: json, %status: string, %output: json) {
      %empty_map = core.map
      %empty_list = core.list
      %trace = core.get %state["trace"] default %empty_map
      %has_trace = core.type_is %trace type "object"
      core.if %has_trace {
      } else {
        %trace = core.call @agent_begin_trace(%state, %empty_map)
      }
      %event_payload = core.map
      core.set %event_payload["output"] = %output
      core.call @agent_record_trace_event(%state, "final", %event_payload)
      %trace = core.get %state["trace"] default %trace
      %events = core.get %trace["events"] default %empty_list
      %event_count = core.call intrinsic.len(%events)
      %usage = core.get %state["usage"] default %empty_map
      %chat_log = core.get %state["chat_log"] default %empty_list
      %action_log = core.get %state["action_log"] default %empty_list
      %policy_trace = core.get %state["policy_trace"] default %empty_list
      %function_traces = core.get %state["function_call_traces"] default %empty_list
      %failure_signals = core.get %state["failure_signals"] default %empty_list
      %optimizer = core.get %state["optimizer_metadata"] default %empty_map
      core.set %trace["status"] = %status
      core.set %trace["final_output"] = %output
      core.set %trace["event_count"] = %event_count
      core.set %trace["usage"] = %usage
      core.set %trace["chat_log"] = %chat_log
      core.set %trace["action_log"] = %action_log
      core.set %trace["policy_trace"] = %policy_trace
      core.set %trace["function_call_traces"] = %function_traces
      core.set %trace["failure_signals"] = %failure_signals
      core.set %trace["optimizer_metadata"] = %optimizer
      core.set %state["trace"] = %trace
      core.return %trace
    }
  }

  op ax.agent.trace @agent_export_trace {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json"
    body @entry(%state: json) {
