module @ax.agent version "0.1" {
  dialect @ax.agent version "0.1"

  op ax.agent.semantic @agent_factory {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    ref parse = @parse_signature
    type signature = "(string|AxSignature, options?:json) -> json throws"
    body @entry(%signature: json, %options: json) {
      %empty_list = core.list
      %empty_map = core.map
      %sig = core.let %signature
      %is_string = core.type_is %signature type "string"
      core.if %is_string {
        %parsed_sig = core.call @parse_signature(%signature)
        %sig = core.let %parsed_sig
      } else {
        %sig = core.let %signature
      }
      %context_camel = core.get %options["contextFields"] default %empty_list
      %context_fields = core.get %options["context_fields"] default %context_camel
      %executor_options = core.get %options["executor_options"] default %empty_map
      %executor_options_camel = core.get %options["executorOptions"] default %executor_options
      %responder_options = core.get %options["responder_options"] default %empty_map
      %responder_options_camel = core.get %options["responderOptions"] default %responder_options
      %executor_exclude_camel = core.get %executor_options_camel["excludeFields"] default %empty_list
      %executor_exclude = core.get %executor_options_camel["exclude_fields"] default %executor_exclude_camel
      %responder_exclude_camel = core.get %responder_options_camel["excludeFields"] default %empty_list
      %responder_exclude = core.get %responder_options_camel["exclude_fields"] default %responder_exclude_camel
      %input_fields = core.get %sig["input_fields"] default %empty_list
      core.for %ctx in %context_fields {
        %found = core.let false
        core.for %field in %input_fields {
          %field_name = core.get %field["name"]
          %matches = core.call intrinsic.eq(%field_name, %ctx)
          core.if %matches {
            %found = core.let true
          }
        }
        %missing = core.call intrinsic.not(%found)
        core.if %missing {
          %message = core.call intrinsic.string.format("context field not found: {}", %ctx)
          %error = core.call intrinsic.error.runtime(%message)
          core.raise %error
        }
      }
      %chat_log = core.list
      %usage = core.map
      %state_alpha = core.map
      %action_log = core.list
      %status_log = core.list
      %state = core.map
      %runtime_contract = core.call @normalize_agent_runtime(%options)
      %has_runtime_direct = core.call intrinsic.map.contains(%options, "runtime")
      %has_runtime_config = core.call intrinsic.map.contains(%options, "runtimeConfig")
      %has_runtime_config_snake = core.call intrinsic.map.contains(%options, "runtime_config")
      %has_any_runtime_config = core.call intrinsic.or(%has_runtime_config, %has_runtime_config_snake)
      %runtime_enabled = core.call intrinsic.or(%has_runtime_direct, %has_any_runtime_config)
      %context_policy = core.call @resolve_agent_context_policy(%options)
      %executor_model_policy = core.call @resolve_agent_executor_model_policy(%options)
      %callable_inventory = core.call @normalize_agent_callable_inventory(%options)
      %callable_split = core.call @split_agent_callable_inventory(%callable_inventory)
      %auto_upgrade = core.call @resolve_agent_auto_upgrade(%options)
      %policy = core.call @normalize_agent_policy(%options)
      %policy_flags = core.call @agent_policy_flags(%options, %callable_split, %auto_upgrade)
      %policy_registry = core.call @agent_policy_registry(%policy, %policy_flags)
      %relevance_ranking_camel = core.get %options["relevanceRanking"] default null
      %relevance_ranking_raw = core.get %options["relevance_ranking"] default %relevance_ranking_camel
      %relevance_ranking_options = core.map
      %relevance_ranking_is_map = core.type_is %relevance_ranking_raw type "object"
      core.if %relevance_ranking_is_map {
        %relevance_ranking_options = core.call intrinsic.map.merge(%relevance_ranking_options, %relevance_ranking_raw)
      }
      %discovery_catalog = core.call @render_agent_discovery_catalog(%callable_split)
      %skills_catalog_camel = core.get %options["skillsCatalog"] default %empty_list
      %skills_catalog_raw = core.get %options["skills_catalog"] default %skills_catalog_camel
      %skills_catalog = core.call @agent_normalize_skill_catalog(%skills_catalog_raw)
      %memories_catalog_camel = core.get %options["memoriesCatalog"] default %empty_list
      %memories_catalog_raw = core.get %options["memories_catalog"] default %memories_catalog_camel
      %memories_catalog = core.call @agent_merge_memory_results(%empty_list, %memories_catalog_raw)
      %discovered_tool_docs = core.list
      %preset_skills_raw = core.get %options["skills"] default %empty_list
      %preset_skill_docs = core.call @agent_merge_skill_results(%empty_list, %preset_skills_raw)
      %loaded_skill_docs = core.call @agent_merge_skill_results(%empty_list, %preset_skill_docs)
      %distiller_loaded_skill_docs = core.list
      %loaded_memories = core.list
      %used_memories = core.list
      %used_skills = core.list
      %guidance_log = core.list
      %function_call_traces = core.list
      %policy_trace = core.list
      %context_events = core.list
      %actor_model_state = core.map
      %trace_events = core.list
      %trace = core.map
      core.set %trace["schema_version"] = "axir-agent-trace-v1"
      core.set %trace["kind"] = "agent_run"
      core.set %trace["status"] = "idle"
      core.set %trace["events"] = %trace_events
      core.set %state["signature"] = %sig
      core.set %state["options"] = %options
      core.set %state["context_fields"] = %context_fields
      core.set %state["executor_exclude_fields"] = %executor_exclude
      core.set %state["responder_exclude_fields"] = %responder_exclude
      %code_field_name = core.get %runtime_contract["code_field_name"] default "javascriptCode"
      %runtime_distiller_signature = core.call intrinsic.string.format("input:json, context:json, memories?:json, discoveredToolDocs?:string, loadedSkills?:string, summarizedActorLog?:string, guidanceLog?:string, actionLog:string, liveRuntimeState?:string, contextPressure?:string -> {}:code", %code_field_name)
      %distiller_signature = core.let "input:json, context:json -> completion:json"
      core.if %runtime_enabled {
        %distiller_signature = core.let %runtime_distiller_signature
      }
      core.set %state["distiller_signature"] = %distiller_signature
      %runtime_executor_signature = core.call intrinsic.string.format("input:json, executorRequest:string, distilledContextSummary?:string, contextMetadata?:string, memories?:json, discoveredToolDocs?:string, loadedSkills?:string, relevanceHints?:string, summarizedActorLog?:string, guidanceLog?:string, actionLog:string, liveRuntimeState?:string, contextPressure?:string -> {}:code", %code_field_name)
      %executor_signature = core.let "input:json, executorRequest:string, distilledContext:json -> completion:json"
      core.if %runtime_enabled {
        %executor_signature = core.let %runtime_executor_signature
      }
      core.set %state["executor_signature"] = %executor_signature
      %llm_query_signature = core.let "task:string, context:json -> answer:string"
      core.set %state["llm_query_signature"] = %llm_query_signature
      %llm_query_description = core.let "You answer ONE focused question using only the provided context object. Return just the answer text — concise, specific, and grounded in the context. Do not restate the question."
      core.set %state["llm_query_description"] = %llm_query_description
      %citations = core.call @resolve_agent_citations(%options, %sig)
      core.set %state["citations"] = %citations
      %responder_signature = core.call @build_responder_signature(%sig, %context_fields, %citations)
      core.set %state["responder_signature"] = %responder_signature
      core.set %state["chat_log"] = %chat_log
      core.set %state["usage"] = %usage
      core.set %state["runtime_state"] = %state_alpha
      core.set %state["action_log"] = %action_log
      core.set %state["status_log"] = %status_log
      core.set %state["runtime_contract"] = %runtime_contract
      core.set %state["runtime_enabled"] = %runtime_enabled
      core.set %state["policy"] = %policy
      core.set %state["policy_flags"] = %policy_flags
      core.set %state["policy_registry"] = %policy_registry
      core.set %state["relevance_ranking_options"] = %relevance_ranking_options
      core.set %state["context_policy"] = %context_policy
      core.set %state["auto_upgrade"] = %auto_upgrade
      %context_map_config = core.get %options["contextMap"] default null
      %has_cm_config = core.call intrinsic.is_not_none(%context_map_config)
      core.if %has_cm_config {
        %cm_initial = core.map
        %cm_map_value = core.get %context_map_config["map"] default null
        %cm_map_is_object = core.type_is %cm_map_value type "object"
        core.if %cm_map_is_object {
          %cm_initial = core.call intrinsic.map.merge(%cm_initial, %cm_map_value)
        }
        %cm_map_is_string = core.type_is %cm_map_value type "string"
        core.if %cm_map_is_string {
          core.set %cm_initial["text"] = %cm_map_value
        }
        %cm_text = core.get %cm_initial["text"] default ""
        core.set %cm_initial["text"] = %cm_text
        %cm_steps = core.get %cm_initial["steps"] default 0
        core.set %cm_initial["steps"] = %cm_steps
        %cm_empty_scores = core.map
        %cm_scores = core.get %cm_initial["scores"] default %cm_empty_scores
        core.set %cm_initial["scores"] = %cm_scores
        %cm_cfg_max = core.get %context_map_config["maxChars"] default 4000
        %cm_max = core.get %cm_initial["maxChars"] default %cm_cfg_max
        core.set %cm_initial["maxChars"] = %cm_max
        %cm_cfg_infinite = core.get %context_map_config["infiniteEvolve"] default true
        %cm_infinite = core.get %cm_initial["infiniteEvolve"] default %cm_cfg_infinite
        core.set %cm_initial["infiniteEvolve"] = %cm_infinite
        %cm_cfg_steps = core.get %context_map_config["evolveSteps"] default 0
        %cm_evolve_steps = core.get %cm_initial["evolveSteps"] default %cm_cfg_steps
        core.set %cm_initial["evolveSteps"] = %cm_evolve_steps
        %cm_cfg_next = core.get %context_map_config["next_id"] default 1
        %cm_next = core.get %cm_initial["next_id"] default %cm_cfg_next
        core.set %cm_initial["next_id"] = %cm_next
        core.set %state["context_map"] = %cm_initial
      }
      core.set %state["executor_model_policy"] = %executor_model_policy
      core.set %state["context_events"] = %context_events
      core.set %state["actor_model_state"] = %actor_model_state
      core.set %state["callable_inventory"] = %callable_inventory
      core.set %state["callable_split"] = %callable_split
      core.set %state["discovery_catalog"] = %discovery_catalog
      core.set %state["skills_catalog"] = %skills_catalog
      core.set %state["memories_catalog"] = %memories_catalog
      core.set %state["discovered_tool_docs"] = %discovered_tool_docs
      core.set %state["preset_skill_docs"] = %preset_skill_docs
      core.set %state["loaded_skill_docs"] = %loaded_skill_docs
      core.set %state["distiller_loaded_skill_docs"] = %distiller_loaded_skill_docs
      core.set %state["loaded_memories"] = %loaded_memories
      core.set %state["used_memories"] = %used_memories
      core.set %state["used_skills"] = %used_skills
      core.set %state["guidance_log"] = %guidance_log
      core.set %state["function_call_traces"] = %function_call_traces
      core.set %state["policy_trace"] = %policy_trace
      core.set %state["trace"] = %trace
      %optimizer_metadata = core.call @agent_optimizer_metadata(%state)
      core.set %state["optimizer_metadata"] = %optimizer_metadata
      %actor_prompt_policy = core.call @build_agent_actor_prompt_policy(%state)
      core.set %state["actor_prompt_policy"] = %actor_prompt_policy
      core.if %runtime_enabled {
        %executor_description = core.call @render_rlm_executor_description(%state, %options)
        core.set %state["executor_description"] = %executor_description
        %responder_description = core.call @render_rlm_responder_description(%state, %options)
        core.set %state["responder_description"] = %responder_description
        %distiller_description = core.call @render_rlm_distiller_description(%state, %options)
        core.set %state["distiller_description"] = %distiller_description
      }
      %executor_description_base = core.get %state["executor_description"] default ""
      core.set %state["executor_description_base"] = %executor_description_base
      %stage_instruction = core.get %options["instruction"] default ""
      core.set %state["stage_instruction"] = %stage_instruction
      %instruction_addenda_camel = core.get %options["instructionAddenda"] default %empty_list
      %instruction_addenda = core.get %options["instruction_addenda"] default %instruction_addenda_camel
      %instruction_addenda_is_list = core.type_is %instruction_addenda type "list"
      core.if %instruction_addenda_is_list {
      } else {
        %instruction_addenda = core.let %empty_list
      }
      core.set %state["instruction_addenda"] = %instruction_addenda
      core.call @agent_refresh_actor_instruction(%state)
      core.return %state
    }
  }

  op ax.agent.runtime @agent_reserved_runtime_names {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "() -> list<string>"
    body @entry {
      %registry = core.call @agent_policy_vocabulary_registry()
      %names = core.get %registry["reserved_runtime_names"] default null
      %names_is_list = core.type_is %names type "list"
      core.if %names_is_list {
      } else {
        %names = core.list
      }
      core.return %names
    }
  }

  op ax.agent.runtime @agent_runtime_reserved_names_for_state {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> list<string>"
    body @entry(%state: json) {
      %empty_list = core.list
      %reserved = core.call @agent_reserved_runtime_names()
      %input_names = core.get %state["runtime_input_names"] default %empty_list
      core.for %name in %input_names {
        %already = core.call intrinsic.contains(%reserved, %name)
        core.if %already {
        } else {
          core.append %reserved, %name
        }
      }
      core.return %reserved
    }
  }

  op ax.agent.runtime @agent_runtime_language_tokens {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(string) -> list<string>"
    body @entry(%language: string) {
      %trimmed = core.string_trim %language
      %sharp_spaced = core.call intrinsic.regex.replace("#", " Sharp ", %trimmed)
      %plus_spaced = core.call intrinsic.regex.replace("\\+", " Plus ", %sharp_spaced)
      %word_spaced = core.call intrinsic.regex.replace("[^A-Za-z0-9]+", " ", %plus_spaced)
      %tokens = core.call intrinsic.string.words(%word_spaced)
      core.return %tokens
    }
  }

  op ax.agent.runtime @agent_runtime_language_alias_key {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(list<string>) -> string"
    body @entry(%tokens: json) {
      %joined = core.call intrinsic.string.join("", %tokens)
      %alias_key = core.call intrinsic.string.lower(%joined)
      core.return %alias_key
    }
  }

  op ax.agent.runtime @agent_runtime_is_javascript_alias {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(string) -> bool"
    body @entry(%alias_key: string) {
      %is_javascript = core.call intrinsic.eq(%alias_key, "javascript")
      %is_js = core.call intrinsic.eq(%alias_key, "js")
      %is_ecmascript = core.call intrinsic.eq(%alias_key, "ecmascript")
      %is_js_or_javascript = core.call intrinsic.or(%is_javascript, %is_js)
      %out = core.call intrinsic.or(%is_js_or_javascript, %is_ecmascript)
      core.return %out
    }
  }

  op ax.agent.runtime @agent_runtime_code_field_name {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(list<string>, bool) -> string"
    body @entry(%tokens: json, %is_javascript: bool) {
      %out = core.let "javascriptCode"
      core.if %is_javascript {
        %out = core.let "javascriptCode"
      } else {
        %count = core.call intrinsic.len(%tokens)
        %has_tokens = core.call intrinsic.gt(%count, 0)
        core.if %has_tokens {
          %prefix = core.call intrinsic.string.lower_camel(%tokens)
          %out = core.call intrinsic.string.format("{}Code", %prefix)
        } else {
          %out = core.let "runtimeCode"
        }
      }
      core.return %out
    }
  }

  op ax.agent.runtime @agent_runtime_code_fence_language {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(list<string>, string, bool) -> string"
    body @entry(%tokens: json, %alias_key: string, %is_javascript: bool) {
      %out = core.let "js"
      core.if %is_javascript {
        %out = core.let "js"
      } else {
        %count = core.call intrinsic.len(%tokens)
        %has_tokens = core.call intrinsic.gt(%count, 0)
        core.if %has_tokens {
          %out = core.let %alias_key
        } else {
          %out = core.let "text"
        }
      }
      core.return %out
    }
  }

  op ax.agent.runtime @normalize_agent_runtime {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json"
    body @entry(%options: json) {
      %empty_map = core.map
      %runtime_camel = core.get %options["runtimeConfig"] default %empty_map
      %runtime = core.get %options["runtime"] default %runtime_camel
      %raw_language = core.get %runtime["language"] default "JavaScript"
      %trimmed_language = core.string_trim %raw_language
      %language_missing = core.call intrinsic.eq(%trimmed_language, "")
      %language = core.let %trimmed_language
      core.if %language_missing {
        %language = core.let "JavaScript"
      }
      %language_tokens = core.call @agent_runtime_language_tokens(%language)
      %alias_key = core.call @agent_runtime_language_alias_key(%language_tokens)
      %is_js = core.call @agent_runtime_is_javascript_alias(%alias_key)
      %code_field_camel = core.get %runtime["codeFieldName"] default ""
      %code_field_name = core.get %runtime["code_field_name"] default %code_field_camel
      %missing_code_field = core.call intrinsic.eq(%code_field_name, "")
      core.if %missing_code_field {
        %code_field_name = core.call @agent_runtime_code_field_name(%language_tokens, %is_js)
      }
      %code_title_camel = core.get %runtime["codeFieldTitle"] default ""
      %code_field_title = core.get %runtime["code_field_title"] default %code_title_camel
      %missing_title = core.call intrinsic.eq(%code_field_title, "")
      core.if %missing_title {
        %code_field_title = core.call intrinsic.string.title_from_camel(%code_field_name)
      }
      %code_fence_camel = core.get %runtime["codeFenceLanguage"] default ""
      %code_fence_language = core.get %runtime["code_fence_language"] default %code_fence_camel
      %missing_fence = core.call intrinsic.eq(%code_fence_language, "")
      core.if %missing_fence {
        %code_fence_language = core.call @agent_runtime_code_fence_language(%language_tokens, %alias_key, %is_js)
      }
      %usage_camel = core.get %runtime["usageInstructions"] default ""
      %usage_instructions = core.get %runtime["usage_instructions"] default %usage_camel
      %missing_usage = core.call intrinsic.eq(%usage_instructions, "")
      core.if %missing_usage {
        %usage_instructions = core.let "Use the active runtime language. Read inputs, call namespaced tools or child agents, use discover(...) before unknown callables, final(...) when complete, and askClarification(...) when blocked."
      }
      %primitives = core.call @agent_reserved_runtime_names()
      %state_hooks = core.list
      core.append %state_hooks, "create_session"
      core.append %state_hooks, "execute_code"
      core.append %state_hooks, "inspect_globals"
      core.append %state_hooks, "export_state"
      core.append %state_hooks, "restore_state"
      core.append %state_hooks, "close_session"
      %out = core.map
      core.set %out["language"] = %language
      core.set %out["code_field_name"] = %code_field_name
      core.set %out["code_field_title"] = %code_field_title
      core.set %out["code_fence_language"] = %code_fence_language
      core.set %out["is_javascript"] = %is_js
      core.set %out["usage_instructions"] = %usage_instructions
      core.set %out["callable_format"] = "namespaced_runtime_call"
      core.set %out["primitives"] = %primitives
      core.set %out["state_hooks"] = %state_hooks
      core.return %out
    }
  }

  op ax.agent.policy @normalize_agent_policy {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json"
    body @entry(%options: json) {
      %empty_map = core.map
      %policy_camel = core.get %options["agentPolicy"] default %empty_map
      %policy_in = core.get %options["agent_policy"] default %policy_camel
      %discovery_default = core.get %policy_in["discovery_default"] default "compact_catalog_prompt_full_docs_runtime_discover"
      %delegation_default = core.get %policy_in["delegation_default"] default "child_agents_as_namespaced_tools"
      %skills_default = core.get %policy_in["skills_default"] default "host_callback_loads_skill_docs_next_executor_prompt"
      %prompt_placement = core.get %policy_in["prompt_placement"] default "runtime_usage_catalog_in_actor_prompt_loaded_docs_next_turn"
      %out = core.map
      core.set %out["policy_version"] = "agent-runtime-decision-v1"
      core.set %out["policy_schema_version"] = "axir-agent-policy-v1"
      core.set %out["discovery_default"] = %discovery_default
      core.set %out["delegation_default"] = %delegation_default
      core.set %out["skills_default"] = %skills_default
      core.set %out["prompt_placement"] = %prompt_placement
      core.set %out["discover_returns"] = "void"
      core.return %out
    }
  }

  op ax.agent.policy @resolve_agent_auto_upgrade {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> json throws"
    body @entry(%options: json) {
      %empty_map = core.map
      %raw_camel = core.get %options["autoUpgrade"] default true
      %raw = core.get %options["auto_upgrade"] default %raw_camel
      %root_is_bool = core.type_is %raw type "bool"
      %root_is_object = core.type_is %raw type "object"
      %root_enabled = core.let true
      %function_enabled = core.let true
      %context_enabled = core.let true
      %function_cfg = core.let %empty_map
      %context_cfg = core.let %empty_map
      core.if %root_is_bool {
        %root_enabled = core.let %raw
        %function_enabled = core.let %raw
        %context_enabled = core.let %raw
      } else {
        core.if %root_is_object {
          %raw_function = core.get %raw["functionDiscovery"] default true
          %raw_function = core.get %raw["function_discovery"] default %raw_function
          %raw_context = core.get %raw["contextFields"] default true
          %raw_context = core.get %raw["context_fields"] default %raw_context
          %raw_function_is_bool = core.type_is %raw_function type "bool"
          core.if %raw_function_is_bool {
            %function_enabled = core.let %raw_function
          } else {
            %raw_function_is_object = core.type_is %raw_function type "object"
            core.if %raw_function_is_object {
              %function_cfg = core.let %raw_function
              %function_enabled = core.let true
            }
          }
          %raw_context_is_bool = core.type_is %raw_context type "bool"
          core.if %raw_context_is_bool {
            %context_enabled = core.let %raw_context
          } else {
            %raw_context_is_object = core.type_is %raw_context type "object"
            core.if %raw_context_is_object {
              %context_cfg = core.let %raw_context
              %context_enabled = core.let true
            }
          }
        } else {
          %root_enabled = core.let true
        }
      }
      %above_camel = core.get %function_cfg["aboveFunctionDocChars"] default 10000
      %above = core.get %function_cfg["above_function_doc_chars"] default %above_camel
      %promote_camel = core.get %context_cfg["promoteAboveChars"] default 8000
      %promote = core.get %context_cfg["promote_above_chars"] default %promote_camel
      %preview_camel = core.get %context_cfg["previewChars"] default 1200
      %preview = core.get %context_cfg["preview_chars"] default %preview_camel
      %above_is_number = core.type_is %above type "number"
      %promote_is_number = core.type_is %promote type "number"
      %preview_is_number = core.type_is %preview type "number"
      %above_bad_type = core.call intrinsic.not(%above_is_number)
      core.if %above_bad_type {
        %error = core.call intrinsic.error.runtime("autoUpgrade.functionDiscovery.aboveFunctionDocChars must be a finite number > 0")
        core.raise %error
      }
      %above_too_low = core.call intrinsic.lte(%above, 0)
      core.if %above_too_low {
        %error2 = core.call intrinsic.error.runtime("autoUpgrade.functionDiscovery.aboveFunctionDocChars must be a finite number > 0")
        core.raise %error2
      }
      %promote_bad_type = core.call intrinsic.not(%promote_is_number)
      core.if %promote_bad_type {
        %error3 = core.call intrinsic.error.runtime("autoUpgrade.contextFields.promoteAboveChars must be a finite number > 0")
        core.raise %error3
      }
      %promote_too_low = core.call intrinsic.lte(%promote, 0)
      core.if %promote_too_low {
        %error4 = core.call intrinsic.error.runtime("autoUpgrade.contextFields.promoteAboveChars must be a finite number > 0")
        core.raise %error4
      }
      %preview_bad_type = core.call intrinsic.not(%preview_is_number)
      core.if %preview_bad_type {
        %error5 = core.call intrinsic.error.runtime("autoUpgrade.contextFields.previewChars must be a finite number > -1")
        core.raise %error5
      }
      %preview_too_low = core.call intrinsic.lt(%preview, 0)
      core.if %preview_too_low {
        %error6 = core.call intrinsic.error.runtime("autoUpgrade.contextFields.previewChars must be a finite number > -1")
        core.raise %error6
      }
      %function = core.map
      core.set %function["enabled"] = %function_enabled
      core.set %function["aboveFunctionDocChars"] = %above
      core.set %function["above_function_doc_chars"] = %above
      %context = core.map
      core.set %context["enabled"] = %context_enabled
      core.set %context["promoteAboveChars"] = %promote
      core.set %context["promote_above_chars"] = %promote
      core.set %context["previewChars"] = %preview
      core.set %context["preview_chars"] = %preview
      %out = core.map
      core.set %out["enabled"] = %root_enabled
      core.set %out["functionDiscovery"] = %function
      core.set %out["function_discovery"] = %function
      core.set %out["contextFields"] = %context
      core.set %out["context_fields"] = %context
      core.return %out
    }
  }

  op ax.agent.policy @agent_discoverable_doc_chars {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> number"
    body @entry(%callable_split: json) {
      %empty_list = core.list
      %discoverable = core.get %callable_split["discoverable"] default %empty_list
      %text = core.call intrinsic.json.stringify(%discoverable)
      %chars = core.call intrinsic.len(%text)
      core.return %chars
    }
  }

  op ax.agent.policy @agent_has_discover_namespace {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json) -> bool"
    body @entry(%callable_split: json) {
      %empty_list = core.list
      %inline = core.get %callable_split["inline"] default %empty_list
      %discoverable = core.get %callable_split["discoverable"] default %empty_list
      core.for %group in %inline {
        %namespace = core.get %group["namespace"] default ""
        %is_discover = core.call intrinsic.eq(%namespace, "discover")
        core.if %is_discover {
          core.return true
        }
      }
      core.for %group2 in %discoverable {
        %namespace2 = core.get %group2["namespace"] default ""
        %is_discover2 = core.call intrinsic.eq(%namespace2, "discover")
        core.if %is_discover2 {
          core.return true
        }
      }
      core.return false
    }
  }

  op ax.agent.policy @agent_policy_flags {
    attr core_kind = "func"
    attr emit_module = "agent"
    attr private = true
    type signature = "(json, json, json) -> json throws"
    body @entry(%options: json, %callable_split: json, %auto_upgrade: json) {
      %empty_list = core.list
      %has_function_discovery_camel = core.call intrinsic.map.contains(%options, "functionDiscovery")
      %has_function_discovery_snake = core.call intrinsic.map.contains(%options, "function_discovery")
      %has_function_discovery = core.call intrinsic.or(%has_function_discovery_camel, %has_function_discovery_snake)
      %function_discovery_camel = core.get %options["functionDiscovery"] default false
      %function_discovery_direct = core.get %options["function_discovery"] default %function_discovery_camel
      %function_discovery = core.let %function_discovery_direct
      core.if %has_function_discovery {
      } else {
        %auto_function = core.get %auto_upgrade["functionDiscovery"] default null
        %auto_function_enabled = core.get %auto_function["enabled"] default true
        %auto_threshold = core.get %auto_function["aboveFunctionDocChars"] default 10000
        %doc_chars = core.call @agent_discoverable_doc_chars(%callable_split)
        %above_threshold = core.call intrinsic.gt(%doc_chars, %auto_threshold)
        %has_discover_namespace = core.call @agent_has_discover_namespace(%callable_split)
        %safe_namespace = core.call intrinsic.not(%has_discover_namespace)
        %auto_allowed = core.call intrinsic.and(%auto_function_enabled, %above_threshold)
        %auto_enabled = core.call intrinsic.and(%auto_allowed, %safe_namespace)
        core.if %auto_enabled {
          %function_discovery = core.let true
        } else {
          %function_discovery = core.let false
        }
      }
      %skills_camel = core.get %options["skillsMode"] default false
      %skills_direct = core.get %options["skills_mode"] default %skills_camel
      %has_skills_callback = core.call intrinsic.map.contains(%options, "onSkillsSearch")
      %has_skills_callback_snake = core.call intrinsic.map.contains(%options, "on_skills_search")
      %has_any_skills_callback = core.call intrinsic.or(%has_skills_callback, %has_skills_callback_snake)
      %skills_catalog_camel = core.get %options["skillsCatalog"] default %empty_list
      %skills_catalog = core.get %options["skills_catalog"] default %skills_catalog_camel
      %skills_catalog_is_list = core.type_is %skills_catalog type "list"
      %skills_catalog_count = core.let 0
      core.if %skills_catalog_is_list {
        %skills_catalog_count = core.call intrinsic.len(%skills_catalog)
      }
      %has_skills_catalog = core.call intrinsic.gt(%skills_catalog_count, 0)
      %skills_callback_mode = core.call intrinsic.or(%skills_direct, %has_any_skills_callback)
      %skills_mode = core.call intrinsic.or(%skills_callback_mode, %has_skills_catalog)
      %memories_camel = core.get %options["memoriesMode"] default false
      %memories_direct = core.get %options["memories_mode"] default %memories_camel
      %has_memories_callback = core.call intrinsic.map.contains(%options, "onMemoriesSearch")
      %has_memories_callback_snake = core.call intrinsic.map.contains(%options, "on_memories_search")
      %has_any_memories_callback = core.call intrinsic.or(%has_memories_callback, %has_memories_callback_snake)
      %memories_catalog_camel = core.get %options["memoriesCatalog"] default %empty_list
      %memories_catalog = core.get %options["memories_catalog"] default %memories_catalog_camel
      %memories_catalog_is_list = core.type_is %memories_catalog type "list"
      %memories_catalog_count = core.let 0
      core.if %memories_catalog_is_list {
        %memories_catalog_count = core.call intrinsic.len(%memories_catalog)
      }
      %has_memories_catalog = core.call intrinsic.gt(%memories_catalog_count, 0)
      %memories_callback_mode = core.call intrinsic.or(%memories_direct, %has_any_memories_callback)
      %memories_mode = core.call intrinsic.or(%memories_callback_mode, %has_memories_catalog)
      %usage_camel = core.get %options["usageTrackingMode"] default false
      %usage_direct = core.get %options["usage_tracking_mode"] default %usage_camel
      %used_memories_observer = core.get %options["onUsedMemories"] default null
      %used_memories_observer_snake = core.get %options["on_used_memories"] default %used_memories_observer
      %used_skills_observer = core.get %options["onUsedSkills"] default null
      %used_skills_observer_snake = core.get %options["on_used_skills"] default %used_skills_observer
      %has_used_memories_observer = core.call intrinsic.is_not_none(%used_memories_observer_snake)
      %has_used_skills_observer = core.call intrinsic.is_not_none(%used_skills_observer_snake)
      %has_used_observer = core.call intrinsic.or(%has_used_memories_observer, %has_used_skills_observer)
      %usage_enabled = core.call intrinsic.or(%usage_direct, %has_used_observer)
      %status_camel = core.get %options["hasAgentStatusCallback"] default false
      %status_direct = core.get %options["has_agent_status_callback"] default %status_camel
      %has_status_callback = core.call intrinsic.map.contains(%options, "agentStatusCallback")
      %status_mode = core.call intrinsic.or(%status_direct, %has_status_callback)
      %inspect_camel = core.get %options["hasInspectRuntime"] default false
      %inspect_direct = core.get %options["has_inspect_runtime"] default %inspect_camel
      %context_config = core.get %options["context"] default null
      %has_context_config = core.type_is %context_config type "object"
      %inspect_mode = core.call intrinsic.or(%inspect_direct, %has_context_config)
      %relevance_camel = core.get %options["relevanceRanking"] default true
      %relevance_raw = core.get %options["relevance_ranking"] default %relevance_camel
      %relevance_is_false = core.call intrinsic.eq(%relevance_raw, false)
      %relevance_enabled = core.call intrinsic.not(%relevance_is_false)
      %module_hint_enabled = core.call intrinsic.and(%relevance_enabled, %function_discovery)
      %skills_hint_enabled = core.call intrinsic.and(%relevance_enabled, %has_skills_catalog)
      %memories_hint_enabled = core.call intrinsic.and(%relevance_enabled, %has_memories_catalog)
      %domain_hint_left = core.call intrinsic.or(%module_hint_enabled, %skills_hint_enabled)
      %relevance_hints_enabled = core.call intrinsic.or(%domain_hint_left, %memories_hint_enabled)
      %combined_discovery_skills = core.call intrinsic.and(%function_discovery, %skills_mode)
      %direct_response_camel = core.get %options["directResponse"] default "auto"
      %direct_response = core.get %options["direct_response"] default %direct_response_camel
      %direct_response_is_auto = core.call intrinsic.eq(%direct_response, "auto")
      %direct_response_is_off = core.call intrinsic.eq(%direct_response, "off")
      %direct_response_valid = core.call intrinsic.or(%direct_response_is_auto, %direct_response_is_off)
      %direct_response_invalid = core.call intrinsic.not(%direct_response_valid)
      core.if %direct_response_invalid {
        %direct_response_error = core.call intrinsic.error.runtime("directResponse must be 'auto' or 'off'")
        core.raise %direct_response_error
      }
      %direct_respond_enabled = core.call intrinsic.not(%direct_response_is_off)
      %inline_callables = core.get %callable_split["inline"] default %empty_list
      %discoverable_callables = core.get %callable_split["discoverable"] default %empty_list
      %inline_callable_count = core.call intrinsic.len(%inline_callables)
      %discoverable_callable_count = core.call intrinsic.len(%discoverable_callables)
      %callable_count = core.call intrinsic.add(%inline_callable_count, %discoverable_callable_count)
      %has_callables = core.call intrinsic.gt(%callable_count, 0)
      %direct_respond_static = core.call intrinsic.not(%has_callables)
      %direct_respond_mode = core.call intrinsic.and(%direct_respond_enabled, %has_callables)
      %direct_respond_only = core.call intrinsic.and(%direct_respond_enabled, %direct_respond_static)
      %out = core.map
      core.set %out["discoveryMode"] = %function_discovery
      core.set %out["skillsMode"] = %skills_mode
      core.set %out["memoriesMode"] = %memories_mode
      core.set %out["usageTrackingMode"] = %usage_enabled
      core.set %out["hasAgentStatusCallback"] = %status_mode
      core.set %out["hasInspectRuntime"] = %inspect_mode
      core.set %out["relevanceRanking"] = %relevance_enabled
      core.set %out["moduleHintEnabled"] = %module_hint_enabled
      core.set %out["skillsHintEnabled"] = %skills_hint_enabled
      core.set %out["memoriesHintEnabled"] = %memories_hint_enabled
      core.set %out["relevanceHintsEnabled"] = %relevance_hints_enabled
      core.set %out["directRespondEnabled"] = %direct_respond_enabled
      core.set %out["directRespondMode"] = %direct_respond_mode
      core.set %out["directRespondOnly"] = %direct_respond_only
      core.set %out["discoveryMode+skillsMode"] = %combined_discovery_skills
      core.return %out
    }
  }

