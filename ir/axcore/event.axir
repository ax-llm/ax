module @ax.event version "0.1" {
  dialect @ax.event version "0.1"

  op ax.event.record @AxEventEnvelope {
    attr core_kind = "record"
    attr public = true
    tag "axevent"
    type fields = "specversion:string,id:string,source:string,type:string,subject?:string,time?:string,data?:json"
