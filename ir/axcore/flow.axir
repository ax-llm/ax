module @ax.flow version "0.1" {
  dialect @ax.flow version "0.1"

  op ax.flow.semantic @flow_factory {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(options?:json) -> json"
    body @entry(%options: json) {
      %empty_map = core.map
      %empty_list = core.list
      %opts_missing = core.call intrinsic.is_none(%options)
      %opts = core.let %options
      core.if %opts_missing {
        %opts = core.let %empty_map
      }
      %steps = core.list
      %traces = core.list
      %chat_log = core.list
      %usage = core.map
      %demos = core.map
      %state = core.map
      %id = core.get %opts["id"] default "root.flow"
      core.set %state["program_kind"] = "axflow"
      core.set %state["program_id"] = %id
      core.set %state["options"] = %opts
      core.set %state["steps"] = %steps
      core.set %state["returns"] = %empty_map
      core.set %state["demos"] = %demos
      core.set %state["traces"] = %traces
      core.set %state["chat_log"] = %chat_log
      core.set %state["usage"] = %usage
      core.return %state
    }
  }

  op ax.flow.semantic @flow_step {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(kind:string, name:string, program:json, options:json) -> json throws"
    body @entry(%kind: string, %name: string, %program: json, %options: json) {
      %trimmed = core.string_trim %name
      %missing_name = core.call intrinsic.eq(%trimmed, "")
      core.if %missing_name {
        %err = core.call intrinsic.error.runtime("flow step name is required")
        core.raise %err
      }
      %empty_map = core.map
      %opts_missing = core.call intrinsic.is_none(%options)
      %opts = core.let %options
      core.if %opts_missing {
        %opts = core.let %empty_map
      }
      %step = core.map
      core.set %step["kind"] = %kind
      core.set %step["name"] = %trimmed
      core.set %step["nodeName"] = %trimmed
      core.set %step["program"] = %program
      core.set %step["options"] = %opts
      %reads_empty = core.list
      %reads = core.get %opts["reads"] default %reads_empty
      %writes_default = core.list
      %is_execute = core.call intrinsic.eq(%kind, "execute")
      %is_derive = core.call intrinsic.eq(%kind, "derive")
      %is_parallel = core.call intrinsic.eq(%kind, "parallel")
      %is_parallel_merge = core.call intrinsic.eq(%kind, "parallelMerge")
      core.if %is_execute {
        %execute_write = core.call intrinsic.string.format("{}Result", %trimmed)
        core.append %writes_default, %execute_write
      }
      core.if %is_derive {
        core.append %writes_default, %trimmed
      }
      core.if %is_parallel {
        core.append %writes_default, "_parallelResults"
      }
      core.if %is_parallel_merge {
        core.append %writes_default, %trimmed
      }
      %writes = core.get %opts["writes"] default %writes_default
      %default_barrier = core.let true
      %may_parallel = core.call intrinsic.or(%is_execute, %is_derive)
      core.if %may_parallel {
        %default_barrier = core.let false
      }
      %barrier_from_snake = core.get %opts["is_barrier"] default %default_barrier
      %barrier_from_camel = core.get %opts["isBarrier"] default %barrier_from_snake
      %barrier = core.get %opts["barrier"] default %barrier_from_camel
      core.set %step["reads"] = %reads
      core.set %step["writes"] = %writes
      core.set %step["isBarrier"] = %barrier
      core.return %step
    }
  }

  op ax.flow.semantic @flow_add_step {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(flow:json, step:json) -> json throws"
    body @entry(%flow: json, %step: json) {
      %steps = core.get %flow["steps"]
      %name = core.get %step["name"] default ""
      core.for %existing in %steps {
        %existing_name = core.get %existing["name"] default ""
        %duplicate = core.call intrinsic.eq(%existing_name, %name)
        core.if %duplicate {
          %message = core.call intrinsic.string.format("duplicate flow step: {}", %name)
          %err = core.call intrinsic.error.runtime(%message)
          core.raise %err
        }
      }
      core.append %steps, %step
      core.set %flow["steps"] = %steps
      core.return %flow
    }
  }

  op ax.flow.semantic @flow_set_returns {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(flow:json, returns:json) -> json"
    body @entry(%flow: json, %returns: json) {
      %empty_map = core.map
      %missing = core.call intrinsic.is_none(%returns)
      %spec = core.let %returns
      core.if %missing {
        %spec = core.let %empty_map
      }
      core.set %flow["returns"] = %spec
      core.return %flow
    }
  }

  op ax.flow.semantic @flow_plan_entry {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(step:json, step_index:i64) -> json"
    body @entry(%step: json, %step_index: i64) {
      %empty_list = core.list
      %kind = core.get %step["kind"] default "execute"
      %name = core.get %step["name"] default ""
      %reads = core.get %step["reads"] default %empty_list
      %writes = core.get %step["writes"] default %empty_list
      %barrier_snake = core.get %step["is_barrier"] default false
      %barrier_camel = core.get %step["isBarrier"] default %barrier_snake
      %barrier = core.get %step["barrier"] default %barrier_camel
      %entry = core.map
      core.set %entry["name"] = %name
      core.set %entry["kind"] = %kind
      core.set %entry["reads"] = %reads
      core.set %entry["writes"] = %writes
      core.set %entry["barrier"] = %barrier
      core.set %entry["stepIndex"] = %step_index
      core.return %entry
    }
  }

  op ax.flow.semantic @flow_plan_can_share_group {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(group:list<json>, candidate:json) -> bool"
    body @entry(%group: json, %candidate: json) {
      %empty_list = core.list
      %candidate_barrier = core.get %candidate["barrier"] default true
      %candidate_writes = core.get %candidate["writes"] default %empty_list
      %candidate_reads = core.get %candidate["reads"] default %empty_list
      %write_count = core.call intrinsic.len(%candidate_writes)
      %no_writes = core.call intrinsic.eq(%write_count, 0)
      %can_share = core.let true
      core.if %candidate_barrier {
        %can_share = core.let false
      }
      core.if %no_writes {
        %can_share = core.let false
      }
      core.for %existing in %group {
        %existing_barrier = core.get %existing["barrier"] default true
        core.if %existing_barrier {
          %can_share = core.let false
        }
        %existing_writes = core.get %existing["writes"] default %empty_list
        %existing_reads = core.get %existing["reads"] default %empty_list
        core.for %read in %candidate_reads {
          %read_conflict = core.call intrinsic.contains(%existing_writes, %read)
          core.if %read_conflict {
            %can_share = core.let false
          }
        }
        core.for %existing_read in %existing_reads {
          %reverse_read_conflict = core.call intrinsic.contains(%candidate_writes, %existing_read)
          core.if %reverse_read_conflict {
            %can_share = core.let false
          }
        }
        core.for %write in %candidate_writes {
          %write_conflict = core.call intrinsic.contains(%existing_writes, %write)
          core.if %write_conflict {
            %can_share = core.let false
          }
        }
      }
      core.return %can_share
    }
  }

  op ax.flow.semantic @flow_plan {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(flow:json) -> json"
    body @entry(%flow: json) {
      %steps = core.get %flow["steps"]
      %plan_steps = core.list
      %step_index = core.let 0
      core.for %step in %steps {
        %entry = core.call @flow_plan_entry(%step, %step_index)
        core.append %plan_steps, %entry
        %next_step_index = core.call intrinsic.add(%step_index, 1)
        %step_index = core.let %next_step_index
      }
      %empty_map = core.map
      %returns = core.get %flow["returns"] default %empty_map
      %has_returns = core.call intrinsic.truthy(%returns)
      core.if %has_returns {
        %return_reads = core.list
        %return_writes = core.list
        %returns_entry = core.map
        core.set %returns_entry["name"] = "returns"
        core.set %returns_entry["kind"] = "returns"
        core.set %returns_entry["reads"] = %return_reads
        core.set %returns_entry["writes"] = %return_writes
        core.set %returns_entry["barrier"] = true
        core.set %returns_entry["stepIndex"] = %step_index
        core.append %plan_steps, %returns_entry
        %return_next_step_index = core.call intrinsic.add(%step_index, 1)
        %step_index = core.let %return_next_step_index
      }
      %groups = core.list
      %current_group = core.list
      core.for %plan_step in %plan_steps {
        %barrier = core.get %plan_step["barrier"] default true
        %current_count = core.call intrinsic.len(%current_group)
        %has_current = core.call intrinsic.gt(%current_count, 0)
        core.if %barrier {
          core.if %has_current {
            %group = core.map
            %level = core.call intrinsic.len(%groups)
            core.set %group["level"] = %level
            core.set %group["steps"] = %current_group
            core.append %groups, %group
            %current_group = core.list
          }
          %single_steps = core.list
          core.append %single_steps, %plan_step
          %single_group = core.map
          %single_level = core.call intrinsic.len(%groups)
          core.set %single_group["level"] = %single_level
          core.set %single_group["steps"] = %single_steps
          core.append %groups, %single_group
        } else {
          %can_add = core.let true
          core.if %has_current {
            %can_add = core.call @flow_plan_can_share_group(%current_group, %plan_step)
          }
          core.if %can_add {
            core.append %current_group, %plan_step
          } else {
            %group = core.map
            %level = core.call intrinsic.len(%groups)
            core.set %group["level"] = %level
            core.set %group["steps"] = %current_group
            core.append %groups, %group
            %current_group = core.list
            core.append %current_group, %plan_step
          }
        }
      }
      %remaining_count = core.call intrinsic.len(%current_group)
      %has_remaining = core.call intrinsic.gt(%remaining_count, 0)
      core.if %has_remaining {
        %group = core.map
        %level = core.call intrinsic.len(%groups)
        core.set %group["level"] = %level
        core.set %group["steps"] = %current_group
        core.append %groups, %group
      }
      %max_parallelism = core.let 1
      core.for %group in %groups {
        %group_steps = core.get %group["steps"]
        %group_count = core.call intrinsic.len(%group_steps)
        %bigger = core.call intrinsic.gt(%group_count, %max_parallelism)
        core.if %bigger {
          %max_parallelism = core.let %group_count
        }
      }
      %plan = core.map
      %total_steps = core.call intrinsic.len(%plan_steps)
      %parallel_groups = core.call intrinsic.len(%groups)
      core.set %plan["totalSteps"] = %total_steps
      core.set %plan["parallelGroups"] = %parallel_groups
      core.set %plan["maxParallelism"] = %max_parallelism
      core.set %plan["steps"] = %plan_steps
      core.set %plan["groups"] = %groups
      core.return %plan
    }
  }

  op ax.flow.semantic @flow_cache_key {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(values:json) -> string"
    body @entry(%values: json) {
      %key = core.call intrinsic.json.stable_stringify(%values)
      core.return %key
    }
  }

  op ax.flow.semantic @flow_cache_read_write {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(flow:json, values:json, options:json, mode:string, cachedValue:json) -> json"
    body @entry(%flow: json, %values: json, %options: json, %mode: string, %cached_value: json) {
      %empty_map = core.map
      %opts_missing = core.call intrinsic.is_none(%options)
      %opts = core.let %options
      core.if %opts_missing {
        %opts = core.let %empty_map
      }
      %key = core.call @flow_cache_key(%values)
      %store_snake = core.get %opts["cache_store"] default null
      %store = core.get %opts["cacheStore"] default %store_snake
      %has_store = core.call intrinsic.is_not_none(%store)
      %read_error_snake = core.get %opts["cache_read_error"] default false
      %read_error = core.get %opts["cacheReadError"] default %read_error_snake
      %write_error_snake = core.get %opts["cache_write_error"] default false
      %write_error = core.get %opts["cacheWriteError"] default %write_error_snake
      %is_read = core.call intrinsic.eq(%mode, "read")
      %is_write = core.call intrinsic.eq(%mode, "write")
      %none = core.call intrinsic.none()
      %result = core.map
      core.set %result["key"] = %key
      core.set %result["hit"] = false
      core.set %result["value"] = %none
      core.if %is_read {
        %can_read_store = core.call intrinsic.and(%has_store, %read_error)
        %skip_read = core.call intrinsic.truthy(%can_read_store)
        core.if %skip_read {
        } else {
          core.if %has_store {
            %cached = core.get %store[%key] default null
            %hit = core.call intrinsic.is_not_none(%cached)
            core.if %hit {
              core.set %result["hit"] = true
              core.set %result["value"] = %cached
            }
          }
        }
      }
      core.if %is_write {
        %can_write_store = core.call intrinsic.and(%has_store, %write_error)
        %skip_write = core.call intrinsic.truthy(%can_write_store)
        core.if %skip_write {
        } else {
          core.if %has_store {
            core.set %store[%key] = %cached_value
            core.set %result["value"] = %cached_value
          }
        }
      }
      core.return %result
    }
  }

  op ax.flow.semantic @flow_check_abort {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(options:json, location:string) -> void throws"
    body @entry(%options: json, %location: string) {
      %none = core.call intrinsic.none()
      %abort_snake = core.get %options["abort_before_step"] default false
      %abort_camel = core.get %options["abortBeforeStep"] default %abort_snake
      %aborted = core.get %options["aborted"] default %abort_camel
      %abort = core.get %options["abort"] default %aborted
      core.if %abort {
        %message = core.call intrinsic.string.format("Flow aborted at {}", %location)
        %err = core.call intrinsic.error.runtime(%message)
        core.raise %err
      }
      core.return %none
    }
  }

  op ax.flow.semantic @flow_project_returns {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(state:json, returns:json) -> json"
    body @entry(%state: json, %returns: json) {
      %empty_map = core.map
      %spec = core.let %returns
      %missing = core.call intrinsic.is_none(%returns)
      core.if %missing {
        %spec = core.let %empty_map
      }
      %has_returns = core.call intrinsic.truthy(%spec)
      %output = core.let %state
      core.if %has_returns {
        %projected = core.map
        %keys = core.call intrinsic.map.keys(%spec)
        core.for %key in %keys {
          %path = core.get %spec[%key]
          %value = core.call @flow_get_path(%state, %path)
          core.set %projected[%key] = %value
        }
        %output = core.let %projected
      }
      core.return %output
    }
  }

  op ax.flow.semantic @flow_get_path {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(state:json, path:json) -> json"
    body @entry(%state: json, %path: json) {
      %none = core.call intrinsic.none()
      %path_text = core.call intrinsic.string.str(%path)
      %parts = core.call intrinsic.string.split(%path_text, ".")
      %current = core.let %state
      core.for %part in %parts {
        %is_object = core.type_is %current type "object"
        core.if %is_object {
          %current = core.get %current[%part] default %none
        } else {
          %current = core.let %none
        }
      }
      core.return %current
    }
  }

  op ax.flow.semantic @flow_record_child_chat_log {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(flow:json, node:string, program:json) -> json"
    body @entry(%flow: json, %node: string, %program: json) {
      %empty_list = core.list
      %chat_log = core.get %flow["chat_log"] default %empty_list
      %child_log = core.call intrinsic.agent.stage_chat_log(%program)
      core.for %entry in %child_log {
        %entry_name = core.get %entry["name"] default ""
        %has_entry_name = core.call intrinsic.truthy(%entry_name)
        core.if %has_entry_name {
          %prefixed_entry_name = core.call intrinsic.string.format("{}.{}", %node, %entry_name)
          core.set %entry["name"] = %prefixed_entry_name
        } else {
          core.set %entry["name"] = %node
        }
        core.append %chat_log, %entry
      }
      core.set %flow["chat_log"] = %chat_log
      core.return %chat_log
    }
  }

  op ax.flow.semantic @flow_record_child_usage {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(flow:json, node:string, program:json) -> json"
    body @entry(%flow: json, %node: string, %program: json) {
      %empty_map = core.map
      %usage = core.get %flow["usage"] default %empty_map
      %child_usage = core.call intrinsic.agent.stage_usage(%program)
      %has_usage = core.call intrinsic.truthy(%child_usage)
      core.if %has_usage {
        core.set %usage[%node] = %child_usage
      }
      core.set %flow["usage"] = %usage
      core.return %usage
    }
  }

  op ax.flow.semantic @flow_record_child_traces {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(flow:json, node:string, program:json) -> json"
    body @entry(%flow: json, %node: string, %program: json) {
      %empty_list = core.list
      %traces = core.get %flow["traces"] default %empty_list
      %child_traces = core.call intrinsic.agent.stage_traces(%program)
      core.for %trace in %child_traces {
        %entry = core.map
        core.set %entry["kind"] = "flow_child_trace"
        core.set %entry["name"] = %node
        core.set %entry["trace"] = %trace
        core.append %traces, %entry
      }
      core.set %flow["traces"] = %traces
      core.return %traces
    }
  }

  op ax.flow.semantic @flow_execute_program_node {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(flow:json, step:json, client:json, state:json, options:json) -> json throws"
    body @entry(%flow: json, %step: json, %client: json, %state: json, %options: json) {
      %empty_map = core.map
      %name = core.get %step["name"] default ""
      %kind = core.get %step["kind"] default "execute"
      %program = core.get %step["program"]
      %step_options = core.get %step["options"] default %empty_map
      %base_options = core.get %flow["options"] default %empty_map
      %runtime_base = core.call intrinsic.map.merge(%base_options, %options)
      %runtime_options = core.call intrinsic.map.merge(%runtime_base, %step_options)
      %trace_label_in = core.get %options["traceLabel"] default ""
      %has_trace_label = core.call intrinsic.truthy(%trace_label_in)
      %trace_label = core.call intrinsic.string.format("Node:{}", %name)
      core.if %has_trace_label {
        %trace_label = core.call intrinsic.string.format("Node:{} ({})", %name, %trace_label_in)
      }
      core.set %runtime_options["traceLabel"] = %trace_label
      %abort_during_snake = core.get %options["abort_during_step"] default false
      %abort_during = core.get %options["abortDuringStep"] default %abort_during_snake
      %abort_node_snake = core.get %options["abort_during_node"] default ""
      %abort_node = core.get %options["abortDuringNode"] default %abort_node_snake
      %abort_named = core.call intrinsic.eq(%abort_node, %name)
      %abort_no_name = core.call intrinsic.eq(%abort_node, "")
      %abort_this_node = core.call intrinsic.and(%abort_during, %abort_named)
      %abort_any_node = core.call intrinsic.and(%abort_during, %abort_no_name)
      %abort_now = core.call intrinsic.or(%abort_this_node, %abort_any_node)
      core.if %abort_now {
        %abort_message = core.call intrinsic.string.format("Flow aborted at flow-node-{}", %name)
        %abort_error = core.call intrinsic.error.runtime(%abort_message)
        core.raise %abort_error
      }
      %result = core.call intrinsic.agent.stage_forward(%program, %client, %state, %runtime_options)
      %out = core.call intrinsic.map.merge(%state, %empty_map)
      %result_key = core.call intrinsic.string.format("{}Result", %name)
      core.set %out[%result_key] = %result
      %out = core.call intrinsic.map.update(%out, %result)
      core.call @flow_record_child_chat_log(%flow, %name, %program)
      core.call @flow_record_child_usage(%flow, %name, %program)
      core.call @flow_record_child_traces(%flow, %name, %program)
      core.return %out
    }
  }

  op ax.flow.semantic @flow_execute_step {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(flow:json, step:json, plan_step:json, client:json, state:json, options:json) -> json throws"
    body @entry(%flow: json, %step: json, %plan_step: json, %client: json, %state: json, %options: json) {
      %empty_map = core.map
      %missing_step = core.call intrinsic.is_none(%step)
      core.if %missing_step {
        core.return %state
      }
      %kind = core.get %step["kind"] default "execute"
      %name = core.get %step["name"] default ""
      %step_options_for_guard = core.get %step["options"] default %empty_map
      %guard = core.get %step_options_for_guard["guard"] default null
      %has_guard = core.call intrinsic.is_not_none(%guard)
      core.if %has_guard {
        %guard_matches = core.call @flow_evaluate_data_predicate(%guard, %state, false)
        %skip_guarded_step = core.call intrinsic.not(%guard_matches)
        core.if %skip_guarded_step {
          core.return %state
        }
      }
      %location = core.call intrinsic.string.format("flow-step-{}", %name)
      core.call @flow_check_abort(%options, %location)
      %traces = core.get %flow["traces"]
      %program_id = core.get %flow["program_id"] default "root.flow"
      %event_payload = core.map
      core.set %event_payload["name"] = %name
      core.set %event_payload["kind"] = %kind
      %step_index = core.get %plan_step["stepIndex"] default 0
      core.set %event_payload["stepIndex"] = %step_index
      %step_event = core.call @program_trace_event(%program_id, "flow_step", %event_payload)
      core.append %traces, %step_event
      %is_map = core.call intrinsic.eq(%kind, "map")
      core.if %is_map {
        %program = core.get %step["program"]
        %mapped = core.call intrinsic.object.call_method(%program, "call", %state)
        %out = core.call intrinsic.map.merge(%state, %empty_map)
        %result_key = core.call intrinsic.string.format("{}Result", %name)
        core.set %out[%result_key] = %mapped
        %out = core.call intrinsic.map.update(%out, %mapped)
        core.return %out
      }
      %is_branch = core.call intrinsic.eq(%kind, "branch")
      core.if %is_branch {
        %step_options = core.get %step["options"] default %empty_map
        %predicate = core.get %step_options["predicate"] default null
        %has_predicate = core.call intrinsic.is_not_none(%predicate)
        %branch_value_default = core.get %step_options["value"] default false
        %branch_value = core.get %step_options["branchValue"] default %branch_value_default
        core.if %has_predicate {
          %branch_value = core.call @flow_evaluate_data_predicate(%predicate, %state, %branch_value)
        }
        %default_branches = core.list
        %branches = core.get %step_options["branches"] default %default_branches
        %current = core.let %state
        %matched = core.let false
        core.for %branch in %branches {
          %when = core.get %branch["when"] default null
          %matches = core.call intrinsic.eq(%when, %branch_value)
          core.if %matches {
            %branch_steps = core.get %branch["steps"] default %default_branches
            %current = core.call @flow_execute_nested_steps(%flow, %client, %branch_steps, %current, %options)
            %matched = core.let true
          }
        }
        core.return %current
      }
      %is_while = core.call intrinsic.eq(%kind, "while")
      core.if %is_while {
        %step_options = core.get %step["options"] default %empty_map
        %condition = core.get %step_options["condition"] default null
        %has_condition = core.call intrinsic.is_not_none(%condition)
        %default_body = core.list
        %body_steps = core.get %step_options["steps"] default %default_body
        %max_iterations_snake = core.get %step_options["max_iterations"] default 100
        %max_iterations = core.get %step_options["maxIterations"] default %max_iterations_snake
        %current = core.let %state
        %iterations = core.let 0
        core.loop {
          %condition_result = core.get %step_options["conditionResult"] default false
          core.if %has_condition {
            %condition_result = core.call @flow_evaluate_data_predicate(%condition, %current, %condition_result)
          }
          %should_continue = core.call intrinsic.truthy(%condition_result)
          %done = core.call intrinsic.not(%should_continue)
          core.if %done {
            core.break
          }
          %too_many = core.call intrinsic.gte(%iterations, %max_iterations)
          core.if %too_many {
            %message = core.call intrinsic.string.format("While loop exceeded maximum iterations ({})", %max_iterations)
            %err = core.call intrinsic.error.runtime(%message)
            core.raise %err
          }
          core.call @flow_check_abort(%options, "flow-while")
          %current = core.call @flow_execute_nested_steps(%flow, %client, %body_steps, %current, %options)
          %iterations = core.call intrinsic.add(%iterations, 1)
        }
        core.return %current
      }
      %is_feedback = core.call intrinsic.eq(%kind, "feedback")
      core.if %is_feedback {
        %step_options = core.get %step["options"] default %empty_map
        %condition = core.get %step_options["condition"] default null
        %has_condition = core.call intrinsic.is_not_none(%condition)
        %default_body = core.list
        %body_steps = core.get %step_options["steps"] default %default_body
        %max_iterations_snake = core.get %step_options["max_iterations"] default 10
        %max_iterations = core.get %step_options["maxIterations"] default %max_iterations_snake
        %label = core.get %step_options["label"] default %name
        %iteration_key = core.call intrinsic.string.format("_feedback_{}_iterations", %label)
        %current = core.call intrinsic.map.merge(%state, %empty_map)
        %existing_iterations = core.get %current[%iteration_key] default null
        %missing_iterations = core.call intrinsic.is_none(%existing_iterations)
        core.if %missing_iterations {
          core.set %current[%iteration_key] = 1
        }
        %iterations = core.let 1
        core.loop {
          %condition_result = core.get %step_options["conditionResult"] default false
          core.if %has_condition {
            %condition_result = core.call @flow_evaluate_data_predicate(%condition, %current, %condition_result)
          }
          %should_continue = core.call intrinsic.truthy(%condition_result)
          %done = core.call intrinsic.not(%should_continue)
          core.if %done {
            core.break
          }
          %too_many = core.call intrinsic.gte(%iterations, %max_iterations)
          core.if %too_many {
            core.break
          }
          %location = core.call intrinsic.string.format("flow-feedback-{}", %label)
          core.call @flow_check_abort(%options, %location)
          %iterations = core.call intrinsic.add(%iterations, 1)
          core.set %current[%iteration_key] = %iterations
          %current = core.call @flow_execute_nested_steps(%flow, %client, %body_steps, %current, %options)
        }
        core.return %current
      }
      %is_parallel = core.call intrinsic.eq(%kind, "parallel")
      core.if %is_parallel {
        %step_options = core.get %step["options"] default %empty_map
        %default_results = core.list
        %parallel_results_snake = core.get %step_options["parallel_results"] default %default_results
        %parallel_results = core.get %step_options["parallelResults"] default %parallel_results_snake
        %out = core.call intrinsic.map.merge(%state, %empty_map)
        core.set %out["_parallelResults"] = %parallel_results
        core.return %out
      }
      %is_parallel_merge = core.call intrinsic.eq(%kind, "parallelMerge")
      core.if %is_parallel_merge {
        %step_options = core.get %step["options"] default %empty_map
        %results = core.get %state["_parallelResults"] default null
        %results_is_list = core.type_is %results type "list"
        %bad_results = core.call intrinsic.not(%results_is_list)
        core.if %bad_results {
          %err = core.call intrinsic.error.runtime("No parallel results found for merge")
          core.raise %err
        }
        %merge_output_snake = core.get %step_options["merge_output"] default %results
        %merge_output = core.get %step_options["mergeOutput"] default %merge_output_snake
        %out = core.call intrinsic.map.merge(%state, %empty_map)
        %none = core.call intrinsic.none()
        core.set %out["_parallelResults"] = %none
        core.set %out[%name] = %merge_output
        core.return %out
      }
      %is_derive = core.call intrinsic.eq(%kind, "derive")
      core.if %is_derive {
        %empty_list = core.list
        %program = core.get %step["program"]
        %reads = core.get %step["reads"] default %empty_list
        %writes = core.get %step["writes"] default %empty_list
        %input_field = core.call intrinsic.list.get(%reads, 0, "")
        %output_field = core.call intrinsic.list.get(%writes, 0, %name)
        %input_value = core.get %state[%input_field] default null
        %out = core.call intrinsic.map.merge(%state, %empty_map)
        %input_is_list = core.type_is %input_value type "list"
        core.if %input_is_list {
          %results = core.list
          core.for %item in %input_value {
            %item_state = core.call intrinsic.map.merge(%state, %empty_map)
            core.set %item_state["__item"] = %item
            %res_state = core.call intrinsic.object.call_method(%program, "call", %item_state)
            %derived = core.get %res_state["__derived"]
            core.append %results, %derived
          }
          core.set %out[%output_field] = %results
        } else {
          %item_state = core.call intrinsic.map.merge(%state, %empty_map)
          core.set %item_state["__item"] = %input_value
          %res_state = core.call intrinsic.object.call_method(%program, "call", %item_state)
          %derived = core.get %res_state["__derived"]
          core.set %out[%output_field] = %derived
        }
        core.return %out
      }
      %program_out = core.call @flow_execute_program_node(%flow, %step, %client, %state, %options)
      core.return %program_out
    }
  }

  op ax.flow.semantic @flow_merge_parallel_results {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(state:json, result:json) -> json"
    body @entry(%state: json, %result: json) {
      %merged = core.call intrinsic.map.merge(%state, %result)
      core.return %merged
    }
  }

  op ax.flow.semantic @flow_execute_nested_steps {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(flow:json, client:json, steps:list<json>, state:json, options:json) -> json throws"
    body @entry(%flow: json, %client: json, %steps: json, %state: json, %options: json) {
      %empty_map = core.map
      %nested = core.call intrinsic.map.merge(%flow, %empty_map)
      %traces = core.get %flow["traces"]
      %chat_log = core.get %flow["chat_log"]
      %usage = core.get %flow["usage"]
      core.set %nested["steps"] = %steps
      core.set %nested["returns"] = %empty_map
      core.set %nested["traces"] = %traces
      core.set %nested["chat_log"] = %chat_log
      core.set %nested["usage"] = %usage
      %out = core.call @flow_execute_steps(%nested, %client, %state, %options)
      %nested_traces = core.get %nested["traces"]
      %nested_chat_log = core.get %nested["chat_log"]
      %nested_usage = core.get %nested["usage"]
      core.set %flow["traces"] = %nested_traces
      core.set %flow["chat_log"] = %nested_chat_log
      core.set %flow["usage"] = %nested_usage
      core.return %out
    }
  }

  op ax.flow.semantic @flow_execute_steps {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(flow:json, client:json, state:json, options:json) -> json throws"
    body @entry(%flow: json, %client: json, %state: json, %options: json) {
      %empty_map = core.map
      %empty_list = core.list
      %steps = core.get %flow["steps"] default %empty_list
      %plan = core.call @flow_plan(%flow)
      %plan_steps = core.get %plan["steps"] default %empty_list
      %planned_groups = core.get %plan["groups"] default %empty_list
      %flow_options = core.get %flow["options"] default %empty_map
      %flow_auto_camel = core.get %flow_options["autoParallel"] default true
      %flow_auto = core.get %flow_options["auto_parallel"] default %flow_auto_camel
      %option_auto_camel = core.get %options["autoParallel"] default true
      %option_auto = core.get %options["auto_parallel"] default %option_auto_camel
      %auto_parallel = core.call intrinsic.and(%flow_auto, %option_auto)
      %groups = core.let %planned_groups
      core.if %auto_parallel {
      } else {
        %sequential_groups = core.list
        core.for %plan_step in %plan_steps {
          %single = core.list
          core.append %single, %plan_step
          %group = core.map
          %level = core.call intrinsic.len(%sequential_groups)
          core.set %group["level"] = %level
          core.set %group["steps"] = %single
          core.append %sequential_groups, %group
        }
        %groups = core.let %sequential_groups
      }
      %current = core.let %state
      core.for %group in %groups {
        %level = core.get %group["level"] default 0
        %location = core.call intrinsic.string.format("flow-parallel-group-{}", %level)
        core.call @flow_check_abort(%options, %location)
        %group_steps = core.get %group["steps"] default %empty_list
        %group_count = core.call intrinsic.len(%group_steps)
        %record_groups_snake = core.get %options["record_flow_groups"] default false
        %record_groups = core.get %options["recordFlowGroups"] default %record_groups_snake
        core.if %record_groups {
          %traces = core.get %flow["traces"] default %empty_list
          %program_id = core.get %flow["program_id"] default "root.flow"
          %group_payload = core.map
          core.set %group_payload["level"] = %level
          core.set %group_payload["stepCount"] = %group_count
          core.set %group_payload["steps"] = %group_steps
          %group_event = core.call @program_trace_event(%program_id, "flow_group", %group_payload)
          core.append %traces, %group_event
        }
        %is_parallel_group = core.call intrinsic.gt(%group_count, 1)
        core.if %is_parallel_group {
          %group_start = core.call intrinsic.map.merge(%current, %empty_map)
          core.for %plan_step in %group_steps {
            %index = core.get %plan_step["stepIndex"] default 0
            %step = core.call intrinsic.list.get(%steps, %index, null)
            %result_state = core.call @flow_execute_step(%flow, %step, %plan_step, %client, %group_start, %options)
            %current = core.call @flow_merge_parallel_results(%current, %result_state)
          }
        } else {
          core.for %plan_step in %group_steps {
            %index = core.get %plan_step["stepIndex"] default 0
            %step = core.call intrinsic.list.get(%steps, %index, null)
            %current = core.call @flow_execute_step(%flow, %step, %plan_step, %client, %current, %options)
          }
        }
      }
      core.return %current
    }
  }

  op ax.flow.semantic @flow_forward {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(flow:json, client:json, values:json, options?:json) -> json throws"
    body @entry(%flow: json, %client: json, %values: json, %options: json) {
      %empty_map = core.map
      %opts_missing = core.call intrinsic.is_none(%options)
      %opts = core.let %options
      core.if %opts_missing {
        %opts = core.let %empty_map
      }
      %cache_read = core.call @flow_cache_read_write(%flow, %values, %opts, "read", null)
      %cache_hit = core.get %cache_read["hit"] default false
      core.if %cache_hit {
        %cached_value = core.get %cache_read["value"]
        core.return %cached_value
      }
      %fresh_traces = core.list
      %fresh_chat_log = core.list
      %fresh_usage = core.map
      core.set %flow["traces"] = %fresh_traces
      core.set %flow["chat_log"] = %fresh_chat_log
      core.set %flow["usage"] = %fresh_usage
      %state = core.call intrinsic.map.merge(%empty_map, %values)
      %traces = core.get %flow["traces"]
      %program_id = core.get %flow["program_id"] default "root.flow"
      %cache_key = core.call @flow_cache_key(%values)
      %begin = core.call @program_trace_event(%program_id, "flow_start", %state)
      core.append %traces, %begin
      %state = core.call @flow_execute_steps(%flow, %client, %state, %opts)
      %returns = core.get %flow["returns"] default %empty_map
      %output = core.call @flow_project_returns(%state, %returns)
      core.call @flow_cache_read_write(%flow, %values, %opts, "write", %output)
      %done_payload = core.map
      core.set %done_payload["cache_key"] = %cache_key
      core.set %done_payload["output"] = %output
      %done = core.call @program_trace_event(%program_id, "flow_done", %done_payload)
      core.append %traces, %done
      core.return %output
    }
  }

  op ax.flow.semantic @flow_get_optimizable_components {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(flow:json) -> list<json>"
    body @entry(%flow: json) {
      %empty_list = core.list
      %empty_map = core.map
      %owner = core.get %flow["program_id"] default "root.flow"
      %plan = core.call @flow_plan(%flow)
      %current_plan = core.get %flow["optimized_graph_plan"] default %plan
      %components = core.list
      %graph_id = core.call intrinsic.string.format("{}::graph-plan", %owner)
      %constraints = core.list
      core.append %constraints, "Preserve node names, dependencies, and return contract."
      %validation = core.map
      core.set %validation["schema"] = "axflow-plan-v1"
      %graph = core.call @optimization_component(%graph_id, %owner, "flow-graph", %current_plan, "AxFlow execution graph and planner barrier metadata.", %constraints, %empty_list, false, "json", %validation)
      core.append %components, %graph
      %steps = core.get %flow["steps"] default %empty_list
      core.for %step in %steps {
        %program = core.get %step["program"]
        %name = core.get %step["name"] default ""
        %child_components = core.call intrinsic.program.components(%program)
        core.for %component in %child_components {
          %child = core.call @program_prefix_component(%component, %owner, %name)
          core.append %components, %child
        }
      }
      core.return %components
    }
  }

  op ax.flow.semantic @flow_apply_optimized_components {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(flow:json, component_map:json) -> json throws"
    body @entry(%flow: json, %component_map: json) {
      %empty_map = core.map
      %empty_list = core.list
      %updates_missing = core.call intrinsic.is_none(%component_map)
      %updates = core.let %component_map
      core.if %updates_missing {
        %updates = core.let %empty_map
      }
      %components = core.call @flow_get_optimizable_components(%flow)
      core.call @validate_optimization_component_map(%components, %updates)
      %owner = core.get %flow["program_id"] default "root.flow"
      %graph_id = core.call intrinsic.string.format("{}::graph-plan", %owner)
      %graph_update = core.get %updates[%graph_id] default null
      %has_graph_update = core.call intrinsic.is_not_none(%graph_update)
      core.if %has_graph_update {
        %graph_is_object = core.type_is %graph_update type "object"
        %bad_graph = core.call intrinsic.not(%graph_is_object)
        core.if %bad_graph {
          %err = core.call intrinsic.error.runtime("optimized flow graph-plan component must be an object")
          core.raise %err
        }
        core.set %flow["optimized_graph_plan"] = %graph_update
      }
      %steps = core.get %flow["steps"] default %empty_list
      core.for %step in %steps {
        %program = core.get %step["program"]
        %name = core.get %step["name"] default ""
        %prefix = core.call @program_child_component_prefix(%owner, %name)
        %child_updates = core.call @program_slice_component_map(%updates, %prefix)
        %has_child_updates = core.call intrinsic.truthy(%child_updates)
        core.if %has_child_updates {
          core.call intrinsic.program.apply_components(%program, %child_updates)
        }
      }
      core.return %flow
    }
  }

  op ax.flow.semantic @flow_snapshot_components {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(flow:json) -> json"
    body @entry(%flow: json) {
      %components = core.call @flow_get_optimizable_components(%flow)
      %snapshot = core.call @optimization_component_current_map(%components)
      core.return %snapshot
    }
  }

  op ax.flow.semantic @flow_restore_components {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(flow:json, snapshot:json) -> json throws"
    body @entry(%flow: json, %snapshot: json) {
      %restored = core.call @flow_apply_optimized_components(%flow, %snapshot)
      core.return %restored
    }
  }

  op ax.flow.semantic @flow_evaluate_optimization {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(flow:json, client:json, dataset:json, candidate_map:json, options:json) -> json throws"
    body @entry(%flow: json, %client: json, %dataset: json, %candidate_map: json, %options: json) {
      %empty_map = core.map
      %empty_list = core.list
      %opts_missing = core.call intrinsic.is_none(%options)
      %opts = core.let %options
      core.if %opts_missing {
        %opts = core.let %empty_map
      }
      %candidate_missing = core.call intrinsic.is_none(%candidate_map)
      %candidate = core.let %candidate_map
      core.if %candidate_missing {
        %candidate = core.let %empty_map
      }
      %normalized = core.call @normalize_optimization_dataset(%dataset)
      %train = core.get %normalized["train"] default %empty_list
      %phase = core.get %opts["phase"] default "train"
      %max_calls_snake = core.get %opts["max_metric_calls"] default 2147483647
      %max_calls = core.get %opts["maxMetricCalls"] default %max_calls_snake
      %forward_options = core.get %opts["forward_options"] default %empty_map
      %original = core.call @flow_snapshot_components(%flow)
      %rows = core.list
      %calls = core.let 0
      %result = core.map
      core.try {
        %has_candidate = core.call intrinsic.truthy(%candidate)
        core.if %has_candidate {
          core.call @flow_apply_optimized_components(%flow, %candidate)
        }
        core.for %task in %train {
          %too_many = core.call intrinsic.gte(%calls, %max_calls)
          core.if %too_many {
            %message = core.call intrinsic.string.format("max metric calls exceeded: {}", %max_calls)
            %err = core.call intrinsic.error.runtime(%message)
            core.raise %err
          }
          %next_calls = core.call intrinsic.add(%calls, 1)
          %calls = core.let %next_calls
          %error = core.call intrinsic.none()
          %prediction = core.map
          core.try {
            %input = core.get %task["input"] default %task
            %output = core.call @flow_forward(%flow, %client, %input, %forward_options)
            %trace = core.map
            %traces = core.get %flow["traces"] default %empty_list
            %chat_log = core.get %flow["chat_log"] default %empty_list
            %usage = core.get %flow["usage"] default %empty_map
            core.set %trace["traces"] = %traces
            core.set %trace["chat_log"] = %chat_log
            %prediction = core.call @build_agent_eval_prediction(%output, %chat_log, %usage, %trace)
          } catch %forward_error {
            %error_message = core.call intrinsic.exception.message(%forward_error)
            %error = core.map
            core.set %error["message"] = %error_message
            %trace = core.map
            %traces = core.get %flow["traces"] default %empty_list
            %chat_log = core.get %flow["chat_log"] default %empty_list
            %usage = core.get %flow["usage"] default %empty_map
            core.set %trace["traces"] = %traces
            core.set %trace["chat_log"] = %chat_log
            core.set %prediction["completionType"] = "error"
            core.set %prediction["error"] = %error
            core.set %prediction["functionCalls"] = %empty_list
            core.set %prediction["actionLog"] = %chat_log
            core.set %prediction["usage"] = %usage
            core.set %prediction["trace"] = %trace
            core.set %prediction["turnCount"] = 0
          }
          %completion_type = core.get %prediction["completionType"] default "final"
          %is_error = core.call intrinsic.eq(%completion_type, "error")
          %default_score = core.let 1
          core.if %is_error {
            %default_score = core.let 0
          }
          %score_from_score = core.get %task["score"] default %default_score
          %score_from_scores = core.get %task["scores"] default %score_from_score
          %raw_scores = core.get %task["metric_score"] default %score_from_scores
          %scores = core.call @normalize_optimization_metric_scores(%raw_scores)
          %scalar_base = core.call @scalarize_optimization_scores(%scores, %opts)
          %scalar = core.call @adjust_optimization_score_for_actions(%scalar_base, %task, %prediction)
          %trace_for_row = core.get %prediction["trace"]
          %row = core.call @build_optimization_eval_row(%task, %prediction, %scores, %scalar, %trace_for_row, %error)
          core.append %rows, %row
        }
        %result = core.call @build_optimization_eval_result(%rows, %candidate, %phase)
        core.call @flow_restore_components(%flow, %original)
      } catch %outer_error {
        core.call @flow_restore_components(%flow, %original)
        core.raise %outer_error
      }
      core.return %result
    }
  }

  op ax.flow.semantic @flow_optimize_with {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(flow:json, dataset:json, options:json, evaluator_available:bool) -> json throws"
    body @entry(%flow: json, %dataset: json, %options: json, %evaluator_available: bool) {
      %empty_map = core.map
      %empty_list = core.list
      %components = core.call @flow_get_optimizable_components(%flow)
      %trace = core.map
      %traces = core.get %flow["traces"] default %empty_list
      %chat_log = core.get %flow["chat_log"] default %empty_list
      core.set %trace["traces"] = %traces
      core.set %trace["chat_log"] = %chat_log
      %run = core.call @prepare_optimizer_run("axflow", %components, %dataset, %options, %trace, %evaluator_available)
      %request = core.get %run["request"] default %empty_map
      core.return %request
    }
  }

  op ax.flow.semantic @flow_evaluate_data_predicate {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(predicate:json, state:json, fallback:json) -> json throws"
    body @entry(%predicate: json, %state: json, %fallback: json) {
      %missing = core.call intrinsic.is_none(%predicate)
      core.if %missing {
        core.return %fallback
      }
      %has_node = core.call intrinsic.map.contains(%predicate, "nodeName")
      %has_field = core.call intrinsic.map.contains(%predicate, "field")
      %is_data = core.call intrinsic.and(%has_node, %has_field)
      core.if %is_data {
        %node = core.get %predicate["nodeName"] default ""
        %field = core.get %predicate["field"] default ""
        %result_key = core.call intrinsic.string.format("{}Result", %node)
        %empty = core.map
        %result = core.get %state[%result_key] default %empty
        %value = core.get %result[%field] default null
        %missing_nested = core.call intrinsic.is_none(%value)
        core.if %missing_nested {
          %value = core.get %state[%field] default null
        }
        %has_expected = core.call intrinsic.map.contains(%predicate, "value")
        core.if %has_expected {
          %expected = core.get %predicate["value"]
          %expected_text = core.call intrinsic.string.lower(%expected)
          %is_true = core.call intrinsic.eq(%expected_text, "true")
          %is_false = core.call intrinsic.eq(%expected_text, "false")
          core.if %is_true {
            %actual = core.call intrinsic.truthy(%value)
            core.return %actual
          }
          core.if %is_false {
            %actual = core.call intrinsic.truthy(%value)
            %actual = core.call intrinsic.not(%actual)
            core.return %actual
          }
          %matches = core.call intrinsic.eq(%value, %expected)
          core.return %matches
        }
        %truthy = core.call intrinsic.truthy(%value)
        core.return %truthy
      }
      %called = core.call intrinsic.object.call_method(%predicate, "call", %state)
      core.return %called
    }
  }

  op ax.flow.semantic @flow_mermaid_fail {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(message:string, line:i64) -> void throws"
    body @entry(%message: string, %line: i64) {
      %with_line = core.call intrinsic.string.format("{} (line {})", %message, %line)
      %err = core.call intrinsic.error.runtime(%with_line)
      core.raise %err
    }
  }

  op ax.flow.semantic @flow_mermaid_register_node {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(ast:json, id:string, shape:string, label:json, line:i64) -> json throws"
    body @entry(%ast: json, %id: string, %shape: string, %label: json, %line: i64) {
      %valid = core.regex_match %id pattern "^[A-Za-z_][A-Za-z0-9_]*$"
      %invalid = core.call intrinsic.not(%valid)
      core.if %invalid {
        core.call @flow_mermaid_fail("Expected a node id", %line)
      }
      %nodes = core.get %ast["nodes"]
      %known = core.call intrinsic.map.contains(%nodes, %id)
      core.if %known {
        %existing = core.get %nodes[%id]
        %existing_label = core.get %existing["label"] default null
        %missing_existing_label = core.call intrinsic.is_none(%existing_label)
        %has_label = core.call intrinsic.is_not_none(%label)
        %replace = core.call intrinsic.and(%missing_existing_label, %has_label)
        core.if %replace {
          core.set %existing["shape"] = %shape
          core.set %existing["label"] = %label
        }
        core.return %existing
      }
      %node = core.map
      core.set %node["id"] = %id
      core.set %node["shape"] = %shape
      core.set %node["label"] = %label
      core.set %node["line"] = %line
      core.set %nodes[%id] = %node
      %order = core.get %ast["order"]
      %index = core.call intrinsic.len(%order)
      core.append %order, %id
      %order_index = core.get %ast["orderIndex"]
      core.set %order_index[%id] = %index
      core.return %node
    }
  }

  op ax.flow.semantic @flow_mermaid_parse_node_ref {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(ast:json, text:string, line:i64) -> string throws"
    body @entry(%ast: json, %text: string, %line: i64) {
      %source = core.string_trim %text
      %source_len = core.call intrinsic.len(%source)
      %empty = core.call intrinsic.eq(%source_len, 0)
      core.if %empty {
        core.call @flow_mermaid_fail("Expected a node id", %line)
      }
      %split_at = core.let %source_len
      %delimiters = core.list
      core.append %delimiters, "["
      core.append %delimiters, "("
      core.append %delimiters, "{"
      core.for %delimiter in %delimiters {
        %candidate = core.call intrinsic.string.find_outside_quotes(%source, %delimiter)
        %found = core.call intrinsic.gte(%candidate, 0)
        %earlier = core.call intrinsic.lt(%candidate, %split_at)
        %use = core.call intrinsic.and(%found, %earlier)
        core.if %use {
          %split_at = core.let %candidate
        }
      }
      %id_raw = core.call intrinsic.string.slice(%source, 0, %split_at)
      %id = core.string_trim %id_raw
      %tail = core.call intrinsic.string.slice(%source, %split_at)
      %tail = core.string_trim %tail
      %shape = core.let "rect"
      %label = core.call intrinsic.none()
      %has_tail = core.call intrinsic.truthy(%tail)
      core.if %has_tail {
        %starts_round_bracket = core.call intrinsic.string.starts_with(%tail, "([")
        %starts_double_round = core.call intrinsic.string.starts_with(%tail, "((")
        %starts_round = core.call intrinsic.string.starts_with(%tail, "(")
        %starts_rect = core.call intrinsic.string.starts_with(%tail, "[")
        %starts_diamond = core.call intrinsic.string.starts_with(%tail, "{")
        %group = core.map
        core.if %starts_round {
          %group = core.call intrinsic.string.extract_leading_group(%tail, "(", ")")
          %shape = core.let "round"
        } else {
          core.if %starts_rect {
            %group = core.call intrinsic.string.extract_leading_group(%tail, "[", "]")
            %shape = core.let "rect"
          } else {
            core.if %starts_diamond {
              %group = core.call intrinsic.string.extract_leading_group(%tail, "{", "}")
              %shape = core.let "diamond"
            } else {
              core.call @flow_mermaid_fail("Unexpected content after node id", %line)
            }
          }
        }
        %balanced = core.get %group["balanced"] default false
        %rest = core.get %group["rest"] default ""
        %rest = core.string_trim %rest
        %trailing = core.call intrinsic.truthy(%rest)
        %bad = core.call intrinsic.not(%balanced)
        %bad = core.call intrinsic.or(%bad, %trailing)
        core.if %bad {
          core.call @flow_mermaid_fail("Unexpected content after node shape", %line)
        }
        %label_text = core.get %group["group"] default ""
        core.if %starts_round_bracket {
          %shape = core.let "round"
          %inner_len = core.call intrinsic.len(%label_text)
          %inner_end = core.call intrinsic.add(%inner_len, -1)
          %label_text = core.call intrinsic.string.slice(%label_text, 1, %inner_end)
        }
        core.if %starts_double_round {
          %shape = core.let "rect"
          %inner_len = core.call intrinsic.len(%label_text)
          %inner_end = core.call intrinsic.add(%inner_len, -1)
          %label_text = core.call intrinsic.string.slice(%label_text, 1, %inner_end)
        }
        %label_text = core.string_trim %label_text
        %quoted_double = core.call intrinsic.string.starts_with(%label_text, "\"")
        %quoted_single = core.call intrinsic.string.starts_with(%label_text, "'")
        %quoted = core.call intrinsic.or(%quoted_double, %quoted_single)
        core.if %quoted {
          %label_len = core.call intrinsic.len(%label_text)
          %label_end = core.call intrinsic.add(%label_len, -1)
          %label_text = core.call intrinsic.string.slice(%label_text, 1, %label_end)
        }
        %label = core.let %label_text
      }
      %node = core.call @flow_mermaid_register_node(%ast, %id, %shape, %label, %line)
      %is_diamond = core.call intrinsic.eq(%shape, "diamond")
      core.if %is_diamond {
        %tail_len = core.call intrinsic.len(%tail)
        %close_index = core.call intrinsic.add(%tail_len, -1)
        %open_brace = core.call intrinsic.string.slice(%tail, 0, 1)
        %close_brace = core.call intrinsic.string.slice(%tail, %close_index)
        core.set %node["open"] = %open_brace
        core.set %node["close"] = %close_brace
      }
      core.return %id
    }
  }

  op ax.flow.semantic @flow_mermaid_parse_group {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(ast:json, text:string, line:i64) -> list<string> throws"
    body @entry(%ast: json, %text: string, %line: i64) {
      %parts = core.call intrinsic.string.split_top_level(%text, "&")
      %ids = core.list
      core.for %part in %parts {
        %id = core.call @flow_mermaid_parse_node_ref(%ast, %part, %line)
        core.append %ids, %id
      }
      core.return %ids
    }
  }

  op ax.flow.semantic @flow_mermaid_parse {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(text:string) -> json throws"
    body @entry(%text: string) {
      %ast = core.map
      %directives = core.map
      %directive_order = core.list
      %nodes = core.map
      %order = core.list
      %order_index = core.map
      %edges = core.list
      core.set %ast["direction"] = "TD"
      core.set %ast["directives"] = %directives
      core.set %ast["directiveOrder"] = %directive_order
      core.set %ast["nodes"] = %nodes
      core.set %ast["order"] = %order
      core.set %ast["orderIndex"] = %order_index
      core.set %ast["edges"] = %edges
      %saw_header = core.let false
      %lines = core.call intrinsic.string.split(%text, "\n")
      %line_number = core.let 0
      core.for %raw in %lines {
        %line_number = core.call intrinsic.add(%line_number, 1)
        %line = core.string_trim %raw
        %is_empty = core.call intrinsic.eq(%line, "")
        core.if %is_empty {
        } else {
          %is_ax = core.regex_match %line pattern "^%%ax\\s+"
          %is_comment = core.regex_match %line pattern "^%%"
          core.if %is_ax {
            %percent = core.call intrinsic.string.slice(%line, 0, 1)
            core.set %ast["percent"] = %percent
            %directive_body = core.call intrinsic.string.slice(%line, 5)
            %parts = core.call intrinsic.string.split_once(%directive_body, ":")
            %found_colon = core.get %parts["found"] default false
            core.if %found_colon {
            } else {
              core.call @flow_mermaid_fail("Invalid Ax directive", %line_number)
            }
            %id = core.get %parts["left"] default ""
            %id = core.string_trim %id
            %sig = core.get %parts["right"] default ""
            %sig = core.string_trim %sig
            %valid_id = core.regex_match %id pattern "^[A-Za-z_][A-Za-z0-9_]*$"
            %invalid_id = core.call intrinsic.not(%valid_id)
            core.if %invalid_id {
              core.call @flow_mermaid_fail("Invalid Ax directive node id", %line_number)
            }
            %duplicate = core.call intrinsic.map.contains(%directives, %id)
            core.if %duplicate {
              %message = core.call intrinsic.string.format("Duplicate Ax directive for node \"{}\"", %id)
              core.call @flow_mermaid_fail(%message, %line_number)
            }
            core.set %directives[%id] = %sig
            core.append %directive_order, %id
          } else {
            core.if %is_comment {
            } else {
              %is_flowchart = core.call intrinsic.string.starts_with(%line, "flowchart ")
              %is_graph = core.call intrinsic.string.starts_with(%line, "graph ")
              %is_header = core.call intrinsic.or(%is_flowchart, %is_graph)
              core.if %is_header {
                core.if %saw_header {
                  core.call @flow_mermaid_fail("Multiple flowchart headers", %line_number)
                }
                %words = core.call intrinsic.string.words(%line)
                %direction = core.call intrinsic.list.get(%words, 1, "")
                %is_td = core.call intrinsic.eq(%direction, "TD")
                %is_lr = core.call intrinsic.eq(%direction, "LR")
                %is_bt = core.call intrinsic.eq(%direction, "BT")
                %is_rl = core.call intrinsic.eq(%direction, "RL")
                %supported_a = core.call intrinsic.or(%is_td, %is_lr)
                %supported_b = core.call intrinsic.or(%is_bt, %is_rl)
                %supported = core.call intrinsic.or(%supported_a, %supported_b)
                %unsupported = core.call intrinsic.not(%supported)
                core.if %unsupported {
                  core.call @flow_mermaid_fail("Unsupported flowchart direction", %line_number)
                }
                core.set %ast["direction"] = %direction
                %saw_header = core.let true
              } else {
                core.if %saw_header {
                } else {
                  core.call @flow_mermaid_fail("Missing flowchart header", %line_number)
                }
                %unsupported_construct = core.regex_match %line pattern "^(subgraph\\b|end\\b|style\\b|classDef\\b|class\\b|linkStyle\\b|click\\b|direction\\b)"
                core.if %unsupported_construct {
                  core.call @flow_mermaid_fail("Unsupported mermaid construct", %line_number)
                }
                %unsupported_arrow = core.regex_match %line pattern "(-\\.+->|={2,}>|---|~~~)"
                core.if %unsupported_arrow {
                  core.call @flow_mermaid_fail("Unsupported arrow syntax", %line_number)
                }
                %segments = core.call intrinsic.string.split_top_level(%line, "-->")
                %segment_count = core.call intrinsic.len(%segments)
                %from_text = core.call intrinsic.list.get(%segments, 0, "")
                %from_ids = core.call @flow_mermaid_parse_group(%ast, %from_text, %line_number)
                %segment_index = core.let 1
                core.loop {
                  %done = core.call intrinsic.gte(%segment_index, %segment_count)
                  core.if %done {
                    core.break
                  }
                  %segment = core.call intrinsic.list.get(%segments, %segment_index, "")
                  %segment = core.string_trim %segment
                  %label = core.call intrinsic.none()
                  %has_label = core.call intrinsic.string.starts_with(%segment, "|")
                  core.if %has_label {
                    %after_bar = core.call intrinsic.string.slice(%segment, 1)
                    %label_parts = core.call intrinsic.string.split_once(%after_bar, "|")
                    %label_closed = core.get %label_parts["found"] default false
                    core.if %label_closed {
                    } else {
                      core.call @flow_mermaid_fail("Unterminated edge label", %line_number)
                    }
                    %label = core.get %label_parts["left"] default ""
                    %label = core.string_trim %label
                    %segment = core.get %label_parts["right"] default ""
                    %segment = core.string_trim %segment
                  }
                  %to_ids = core.call @flow_mermaid_parse_group(%ast, %segment, %line_number)
                  core.for %from_node in %from_ids {
                    core.for %to in %to_ids {
                      %edge = core.map
                      core.set %edge["from"] = %from_node
                      core.set %edge["to"] = %to
                      core.set %edge["label"] = %label
                      core.set %edge["line"] = %line_number
                      core.append %edges, %edge
                    }
                  }
                  %from_ids = core.let %to_ids
                  %segment_index = core.call intrinsic.add(%segment_index, 1)
                }
              }
            }
          }
        }
      }
      core.if %saw_header {
      } else {
        core.call @flow_mermaid_fail("Missing flowchart header", 1)
      }
      %node_count = core.call intrinsic.len(%order)
      %no_nodes = core.call intrinsic.eq(%node_count, 0)
      core.if %no_nodes {
        core.call @flow_mermaid_fail("No nodes found in the diagram", 1)
      }
      core.return %ast
    }
  }

  op ax.flow.semantic @flow_mermaid_reachable {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(start:string, target:string, edges:list<json>) -> bool"
    body @entry(%start: string, %target: string, %edges: json) {
      %queue = core.list
      core.append %queue, %start
      %seen = core.map
      core.set %seen[%start] = true
      %index = core.let 0
      core.loop {
        %count = core.call intrinsic.len(%queue)
        %done = core.call intrinsic.gte(%index, %count)
        core.if %done {
          core.break
        }
        %current = core.call intrinsic.list.get(%queue, %index, "")
        %index = core.call intrinsic.add(%index, 1)
        core.for %edge in %edges {
          %from_node = core.get %edge["from"] default ""
          %matches = core.call intrinsic.eq(%from_node, %current)
          core.if %matches {
            %to = core.get %edge["to"] default ""
            %found = core.call intrinsic.eq(%to, %target)
            core.if %found {
              core.return true
            }
            %known = core.call intrinsic.map.contains(%seen, %to)
            %is_new = core.call intrinsic.not(%known)
            core.if %is_new {
              core.set %seen[%to] = true
              core.append %queue, %to
            }
          }
        }
      }
      core.return false
    }
  }

  op ax.flow.semantic @flow_mermaid_topological_order {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(document_order:list<string>, edges:list<json>) -> list<string> throws"
    body @entry(%document_order: json, %edges: json) {
      %result = core.list
      %processed = core.map
      %total = core.call intrinsic.len(%document_order)
      core.loop {
        %count = core.call intrinsic.len(%result)
        %done = core.call intrinsic.gte(%count, %total)
        core.if %done {
          core.break
        }
        %progress = core.let false
        core.for %id in %document_order {
          %known = core.call intrinsic.map.contains(%processed, %id)
          core.if %known {
          } else {
            %ready = core.let true
            core.for %edge in %edges {
              %to = core.get %edge["to"] default ""
              %incoming = core.call intrinsic.eq(%to, %id)
              core.if %incoming {
                %parent = core.get %edge["from"] default ""
                %parent_done = core.call intrinsic.map.contains(%processed, %parent)
                %waiting = core.call intrinsic.not(%parent_done)
                core.if %waiting {
                  %ready = core.let false
                }
              }
            }
            core.if %ready {
              core.set %processed[%id] = true
              core.append %result, %id
              %progress = core.let true
            }
          }
        }
        core.if %progress {
        } else {
          core.call @flow_mermaid_fail("Cycle without a classified back-edge", 1)
        }
      }
      core.return %result
    }
  }

  op ax.flow.semantic @flow_mermaid_decision {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(node:string, ast:json, infos:json) -> json throws"
    body @entry(%node: string, %ast: json, %infos: json) {
      %empty = core.map
      %info = core.get %infos[%node] default %empty
      %signature = core.get %info["signature"] default null
      %missing_signature = core.call intrinsic.is_none(%signature)
      core.if %missing_signature {
        %message = core.call intrinsic.string.format("Decision node \"{}\" needs an Ax signature directive", %node)
        core.call @flow_mermaid_fail(%message, 1)
      }
      %outputs = core.get %info["outputs"] default null
      %nodes = core.get %ast["nodes"]
      %node_ast = core.get %nodes[%node]
      %shape = core.get %node_ast["shape"] default "rect"
      %is_diamond = core.call intrinsic.eq(%shape, "diamond")
      %field_name = core.let ""
      core.if %is_diamond {
        %field_name = core.get %node_ast["label"] default ""
      } else {
        %candidate_count = core.let 0
        core.for %field in %outputs {
          %type = core.get %field["type"]
          %type_name = core.get %type["name"] default ""
          %is_class = core.call intrinsic.eq(%type_name, "class")
          %is_boolean = core.call intrinsic.eq(%type_name, "boolean")
          %eligible = core.call intrinsic.or(%is_class, %is_boolean)
          core.if %eligible {
            %candidate_count = core.call intrinsic.add(%candidate_count, 1)
            %field_name = core.get %field["name"] default ""
          }
        }
        %one = core.call intrinsic.eq(%candidate_count, 1)
        core.if %one {
        } else {
          %message = core.call intrinsic.string.format("Cannot infer decision field for node \"{}\"", %node)
          core.call @flow_mermaid_fail(%message, 1)
        }
      }
      %chosen = core.call intrinsic.none()
      core.for %field in %outputs {
        %name = core.get %field["name"] default ""
        %matches = core.call intrinsic.eq(%name, %field_name)
        core.if %matches {
          %chosen = core.let %field
        }
      }
      %missing = core.call intrinsic.is_none(%chosen)
      core.if %missing {
        %message = core.call intrinsic.string.format("Decision field \"{}\" is not an output of node \"{}\"", %field_name, %node)
        core.call @flow_mermaid_fail(%message, 1)
      }
      %type = core.get %chosen["type"]
      %decision = core.map
      core.set %decision["nodeName"] = %node
      core.set %decision["field"] = %field_name
      %decision_type = core.get %type["name"] default ""
      core.set %decision["type"] = %decision_type
      %empty_options = core.list
      %decision_options = core.get %type["options"] default %empty_options
      core.set %decision["options"] = %decision_options
      core.return %decision
    }
  }

  op ax.flow.semantic @flow_mermaid_guards_compatible {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(nodes:list<string>, guards:json) -> bool"
    body @entry(%nodes: json, %guards: json) {
      %count = core.call intrinsic.len(%nodes)
      %enough = core.call intrinsic.gt(%count, 1)
      core.if %enough {
      } else {
        core.return false
      }
      %first_node = core.call intrinsic.list.get(%nodes, 0, "")
      %first = core.get %guards[%first_node] default null
      %missing_first = core.call intrinsic.is_none(%first)
      core.if %missing_first {
        core.return false
      }
      %owner = core.get %first["nodeName"] default ""
      %field = core.get %first["field"] default ""
      %values = core.map
      core.for %node in %nodes {
        %guard = core.get %guards[%node] default null
        %missing = core.call intrinsic.is_none(%guard)
        core.if %missing {
          core.return false
        }
        %guard_owner = core.get %guard["nodeName"] default ""
        %guard_field = core.get %guard["field"] default ""
        %same_owner = core.call intrinsic.eq(%guard_owner, %owner)
        %same_field = core.call intrinsic.eq(%guard_field, %field)
        %same = core.call intrinsic.and(%same_owner, %same_field)
        %different = core.call intrinsic.not(%same)
        core.if %different {
          core.return false
        }
        %value = core.get %guard["value"] default null
        %value_key = core.call intrinsic.string.str(%value)
        %duplicate = core.call intrinsic.map.contains(%values, %value_key)
        core.if %duplicate {
          core.return false
        }
        core.set %values[%value_key] = true
      }
      core.return true
    }
  }

  op ax.flow.semantic @flow_mermaid_execute_step {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(info:json, guard:json) -> json throws"
    body @entry(%info: json, %guard: json) {
      %name = core.get %info["id"] default ""
      %program = core.get %info["program"] default null
      %kind = core.get %info["kind"] default "execute"
      %options = core.map
      %reads = core.get %info["reads"]
      %resolved_reads = core.list
      core.for %read in %reads {
        core.append %resolved_reads, %read
      }
      %writes = core.list
      %result_key = core.call intrinsic.string.format("{}Result", %name)
      core.append %writes, %result_key
      core.set %options["writes"] = %writes
      %signature_text = core.get %info["signatureText"] default ""
      %has_signature = core.call intrinsic.truthy(%signature_text)
      core.if %has_signature {
        core.set %options["signatureText"] = %signature_text
      }
      %has_guard = core.call intrinsic.is_not_none(%guard)
      core.if %has_guard {
        core.set %options["guard"] = %guard
        %guard_node = core.get %guard["nodeName"] default ""
        %guard_read = core.call intrinsic.string.format("{}Result", %guard_node)
        %has_guard_read = core.call intrinsic.contains(%resolved_reads, %guard_read)
        %missing_guard_read = core.call intrinsic.not(%has_guard_read)
        core.if %missing_guard_read {
          core.append %resolved_reads, %guard_read
        }
      }
      core.set %options["reads"] = %resolved_reads
      %step = core.call @flow_step(%kind, %name, %program, %options)
      %meta = core.map
      core.set %meta["kind"] = %kind
      core.set %meta["nodeName"] = %name
      core.set %step["meta"] = %meta
      core.return %step
    }
  }

  op ax.flow.semantic @flow_mermaid_parse_max {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(label:string, fallback:i64) -> i64 throws"
    body @entry(%label: string, %fallback: i64) {
      %parts = core.call intrinsic.string.split_trim_nonempty(%label, ",")
      %max = core.let %fallback
      core.for %part in %parts {
        %starts = core.call intrinsic.string.starts_with(%part, "max ")
        core.if %starts {
          %raw = core.call intrinsic.string.slice(%part, 4)
          %parsed = core.call intrinsic.json.parse(%raw)
          %max = core.let %parsed
        }
      }
      core.return %max
    }
  }

  op ax.flow.semantic @flow_mermaid_compile {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(ast:json, bindings:json) -> json throws"
    body @entry(%ast: json, %bindings: json) {
      %empty_map = core.map
      %empty_list = core.list
      %opts = core.get %bindings["options"] default %empty_map
      %flow = core.call @flow_factory(%opts)
      %order = core.get %ast["order"]
      %order_index = core.get %ast["orderIndex"]
      %edges = core.get %ast["edges"]
      %directives = core.get %ast["directives"]
      %node_bindings = core.get %bindings["nodes"] default %empty_map
      %conditions = core.get %bindings["conditions"] default %empty_map
      %forward_edges = core.list
      %back_edges = core.list
      core.for %edge in %edges {
        %from_node = core.get %edge["from"]
        %to = core.get %edge["to"]
        %from_index = core.get %order_index[%from_node]
        %to_index = core.get %order_index[%to]
        %points_backward = core.call intrinsic.gte(%from_index, %to_index)
        %closes_cycle = core.call @flow_mermaid_reachable(%to, %from_node, %edges)
        %is_back = core.call intrinsic.and(%points_backward, %closes_cycle)
        core.if %is_back {
          %label = core.get %edge["label"] default null
          %missing_label = core.call intrinsic.is_none(%label)
          core.if %missing_label {
            %message = core.call intrinsic.string.format("Back-edges need a label: {} --> {}", %from_node, %to)
            %edge_line_number = core.get %edge["line"] default 1
            core.call @flow_mermaid_fail(%message, %edge_line_number)
          }
          core.append %back_edges, %edge
        } else {
          core.append %forward_edges, %edge
        }
      }
      %compile_order = core.call @flow_mermaid_topological_order(%order, %forward_edges)
      %compile_order_index = core.map
      %compile_index = core.let 0
      core.for %compile_id in %compile_order {
        core.set %compile_order_index[%compile_id] = %compile_index
        %compile_index = core.call intrinsic.add(%compile_index, 1)
      }
      core.set %ast["compileOrder"] = %compile_order
      %infos = core.map
      %producers = core.map
      %missing_nodes = core.list
      core.for %id in %compile_order {
        %has_directive = core.call intrinsic.map.contains(%directives, %id)
        %has_binding = core.call intrinsic.map.contains(%node_bindings, %id)
        %resolved = core.call intrinsic.or(%has_directive, %has_binding)
        core.if %resolved {
        } else {
          core.append %missing_nodes, %id
        }
        %info = core.map
        %info_reads = core.list
        core.set %info["id"] = %id
        core.set %info["kind"] = "execute"
        core.set %info["reads"] = %info_reads
        %signature_text = core.get %directives[%id] default ""
        core.set %info["signatureText"] = %signature_text
        %program = core.get %node_bindings[%id] default %signature_text
        core.set %info["program"] = %program
        %missing_directive = core.call intrinsic.not(%has_directive)
        %binding_only = core.call intrinsic.and(%has_binding, %missing_directive)
        core.if %binding_only {
          core.set %info["kind"] = "map"
        }
        core.if %has_directive {
          %signature = core.call @parse_signature(%signature_text)
          core.set %info["signature"] = %signature
          %inputs = core.call @signature_input_fields(%signature)
          %outputs = core.call @signature_output_fields(%signature)
          core.set %info["inputs"] = %inputs
          core.set %info["outputs"] = %outputs
          core.for %field in %outputs {
            %field_name = core.get %field["name"] default ""
            %field_producers = core.get %producers[%field_name] default null
            %missing_field_producers = core.call intrinsic.is_none(%field_producers)
            core.if %missing_field_producers {
              %field_producers = core.list
              core.set %producers[%field_name] = %field_producers
            }
            core.append %field_producers, %id
          }
        }
        core.set %infos[%id] = %info
      }
      %missing_count = core.call intrinsic.len(%missing_nodes)
      %has_missing = core.call intrinsic.gt(%missing_count, 0)
      core.if %has_missing {
        %joined = core.call intrinsic.string.join(", ", %missing_nodes)
        %message = core.call intrinsic.string.format("No signature for node(s): {}", %joined)
        core.call @flow_mermaid_fail(%message, 1)
      }

      %guards = core.map
      core.for %edge in %forward_edges {
        %label = core.get %edge["label"] default null
        %has_label = core.call intrinsic.is_not_none(%label)
        core.if %has_label {
          %starts_if = core.call intrinsic.string.starts_with(%label, "if ")
          %starts_while = core.call intrinsic.string.starts_with(%label, "while ")
          %reserved = core.call intrinsic.or(%starts_if, %starts_while)
          core.if %reserved {
            %edge_line_number = core.get %edge["line"] default 1
            core.call @flow_mermaid_fail("if/while labels are only valid on back-edges", %edge_line_number)
          }
          %from_node = core.get %edge["from"]
          %decision = core.call @flow_mermaid_decision(%from_node, %ast, %infos)
          %type = core.get %decision["type"] default ""
          %is_class = core.call intrinsic.eq(%type, "class")
          core.if %is_class {
            %options = core.get %decision["options"] default %empty_list
            %valid_option = core.call intrinsic.contains(%options, %label)
            %invalid_option = core.call intrinsic.not(%valid_option)
            core.if %invalid_option {
              %field = core.get %decision["field"] default ""
              %message = core.call intrinsic.string.format("\"{}\" is not an option of \"{}.{}\"", %label, %from_node, %field)
              %edge_line_number = core.get %edge["line"] default 1
              core.call @flow_mermaid_fail(%message, %edge_line_number)
            }
          }
          core.set %decision["value"] = %label
          %to = core.get %edge["to"]
          core.set %guards[%to] = %decision
        }
      }
      core.for %id in %compile_order {
        %already_guarded = core.call intrinsic.map.contains(%guards, %id)
        core.if %already_guarded {
        } else {
          %incoming = core.list
          core.for %edge in %forward_edges {
            %to = core.get %edge["to"] default ""
            %matches = core.call intrinsic.eq(%to, %id)
            core.if %matches {
              %incoming_from = core.get %edge["from"] default ""
              core.append %incoming, %incoming_from
            }
          }
          %incoming_count = core.call intrinsic.len(%incoming)
          %one_incoming = core.call intrinsic.eq(%incoming_count, 1)
          core.if %one_incoming {
            %parent = core.call intrinsic.list.get(%incoming, 0, "")
            %parent_guard = core.get %guards[%parent] default null
            %has_parent_guard = core.call intrinsic.is_not_none(%parent_guard)
            core.if %has_parent_guard {
              core.set %guards[%id] = %parent_guard
            }
          }
        }
      }

      %natural_inputs = core.map
      core.for %id in %compile_order {
        %info = core.get %infos[%id]
        %signature = core.get %info["signature"] default null
        %has_signature = core.call intrinsic.is_not_none(%signature)
        core.if %has_signature {
          %inputs = core.get %info["inputs"] default %empty_list
          %reads = core.list
          core.for %field in %inputs {
            %field_name = core.get %field["name"] default ""
            %all_producers = core.get %producers[%field_name] default %empty_list
            %upstream = core.list
            core.for %producer in %all_producers {
              %not_self = core.call intrinsic.ne(%producer, %id)
              core.if %not_self {
                %reachable = core.call @flow_mermaid_reachable(%producer, %id, %forward_edges)
                core.if %reachable {
                  core.append %upstream, %producer
                }
              }
            }
            %upstream_count = core.call intrinsic.len(%upstream)
            %ambiguous = core.call intrinsic.gt(%upstream_count, 1)
            core.if %ambiguous {
              %compatible = core.call @flow_mermaid_guards_compatible(%upstream, %guards)
              %bad_ambiguity = core.call intrinsic.not(%compatible)
              core.if %bad_ambiguity {
                %a = core.call intrinsic.list.get(%upstream, 0, "")
                %b = core.call intrinsic.list.get(%upstream, 1, "")
                %pair = core.call intrinsic.string.format("{} and {}", %a, %b)
                %message = core.call intrinsic.string.format("Input \"{}\" of node \"{}\" is produced by {} at the same distance", %field_name, %id, %pair)
                core.call @flow_mermaid_fail(%message, 1)
              }
            }
            %has_upstream = core.call intrinsic.gt(%upstream_count, 0)
            core.if %has_upstream {
              core.for %producer in %upstream {
                %read = core.call intrinsic.string.format("{}Result", %producer)
                core.append %reads, %read
              }
            } else {
              %producer_count = core.call intrinsic.len(%all_producers)
              %has_other_producer = core.call intrinsic.gt(%producer_count, 0)
              core.if %has_other_producer {
                %producer = core.call intrinsic.list.get(%all_producers, 0, "")
                %same_only = core.call intrinsic.eq(%producer, %id)
                core.if %same_only {
                  core.set %natural_inputs[%field_name] = %field
                } else {
                  %message = core.call intrinsic.string.format("\"{}\" of node \"{}\" is produced by \"{}\" which is not upstream", %field_name, %id, %producer)
                  core.call @flow_mermaid_fail(%message, 1)
                }
              } else {
                core.set %natural_inputs[%field_name] = %field
              }
            }
          }
          core.set %info["reads"] = %reads
        }
      }

      %self_while = core.map
      core.for %edge in %back_edges {
        %from_node = core.get %edge["from"]
        %to = core.get %edge["to"]
        %label = core.get %edge["label"] default ""
        %parts = core.call intrinsic.string.split_trim_nonempty(%label, ",")
        %main = core.call intrinsic.list.get(%parts, 0, "")
        %is_while = core.call intrinsic.string.starts_with(%main, "while ")
        %self = core.call intrinsic.eq(%from_node, %to)
        %self_loop = core.call intrinsic.and(%is_while, %self)
        core.if %self_loop {
          core.set %self_while[%from_node] = %edge
        }
      }

      %steps = core.get %flow["steps"]
      %loop_index = core.let 0
      core.for %id in %compile_order {
        %info = core.get %infos[%id]
        %guard = core.get %guards[%id] default null
        %has_self_while = core.call intrinsic.map.contains(%self_while, %id)
        core.if %has_self_while {
        } else {
          %step = core.call @flow_mermaid_execute_step(%info, %guard)
          core.append %steps, %step
        }
        core.for %edge in %back_edges {
          %from_node = core.get %edge["from"]
          %matches_source = core.call intrinsic.eq(%from_node, %id)
          core.if %matches_source {
            %loop_index = core.call intrinsic.add(%loop_index, 1)
            %to = core.get %edge["to"]
            %label = core.get %edge["label"] default ""
            %label_parts = core.call intrinsic.string.split_trim_nonempty(%label, ",")
            %main = core.call intrinsic.list.get(%label_parts, 0, "")
            %is_while = core.call intrinsic.string.starts_with(%main, "while ")
            %is_if = core.call intrinsic.string.starts_with(%main, "if ")
            %loop_kind = core.let "feedback"
            %fallback_max = core.let 10
            core.if %is_while {
              %loop_kind = core.let "while"
              %fallback_max = core.let 100
            }
            %max = core.call @flow_mermaid_parse_max(%label, %fallback_max)
            %body = core.list
            %to_index = core.get %compile_order_index[%to]
            %from_index = core.get %compile_order_index[%from_node]
            core.for %body_id in %compile_order {
              %body_index = core.get %compile_order_index[%body_id]
              %after_start = core.call intrinsic.gte(%body_index, %to_index)
              %before_end = core.call intrinsic.lte(%body_index, %from_index)
              %in_body = core.call intrinsic.and(%after_start, %before_end)
              core.if %in_body {
                %body_info = core.get %infos[%body_id]
                %body_guard = core.get %guards[%body_id] default null
                %body_step = core.call @flow_mermaid_execute_step(%body_info, %body_guard)
                core.append %body, %body_step
              }
            }
            %loop_options = core.map
            core.set %loop_options["steps"] = %body
            core.set %loop_options["maxIterations"] = %max
            core.set %loop_options["label"] = %to
            %meta = core.map
            core.set %meta["kind"] = %loop_kind
            core.set %meta["maxIterations"] = %max
            core.set %meta["target"] = %to
            core.if %is_while {
              %condition_name = core.call intrinsic.string.slice(%main, 6)
              %condition_name = core.string_trim %condition_name
              %condition = core.get %conditions[%condition_name] default null
              %missing_condition = core.call intrinsic.is_none(%condition)
              core.if %missing_condition {
                %message = core.call intrinsic.string.format("Missing condition binding \"{}\"", %condition_name)
                %edge_line_number = core.get %edge["line"] default 1
                core.call @flow_mermaid_fail(%message, %edge_line_number)
              }
              core.set %loop_options["condition"] = %condition
              core.set %loop_options["conditionName"] = %condition_name
              core.set %meta["conditionName"] = %condition_name
            } else {
              core.if %is_if {
                %condition_name = core.call intrinsic.string.slice(%main, 3)
                %condition_name = core.string_trim %condition_name
                %condition = core.get %conditions[%condition_name] default null
                %missing_condition = core.call intrinsic.is_none(%condition)
                core.if %missing_condition {
                  %message = core.call intrinsic.string.format("Missing condition binding \"{}\"", %condition_name)
                  %edge_line_number = core.get %edge["line"] default 1
                  core.call @flow_mermaid_fail(%message, %edge_line_number)
                }
                core.set %loop_options["condition"] = %condition
                core.set %loop_options["conditionName"] = %condition_name
                core.set %meta["conditionName"] = %condition_name
              } else {
                %decision = core.call @flow_mermaid_decision(%from_node, %ast, %infos)
                core.set %decision["value"] = %main
                core.set %loop_options["condition"] = %decision
                core.set %loop_options["decision"] = %decision
                core.set %meta["decision"] = %decision
              }
            }
            %loop_name = core.call intrinsic.string.format("{}{}", %loop_kind, %loop_index)
            %loop_step = core.call @flow_step(%loop_kind, %loop_name, null, %loop_options)
            core.set %loop_step["meta"] = %meta
            core.append %steps, %loop_step
          }
        }
      }

      %terminal_fields = core.map
      %returns = core.map
      core.for %id in %compile_order {
        %has_outgoing = core.let false
        core.for %edge in %forward_edges {
          %from_node = core.get %edge["from"] default ""
          %matches = core.call intrinsic.eq(%from_node, %id)
          core.if %matches {
            %has_outgoing = core.let true
          }
        }
        core.if %has_outgoing {
        } else {
          %info = core.get %infos[%id]
          %signature = core.get %info["signature"] default null
          %has_signature = core.call intrinsic.is_not_none(%signature)
          core.if %has_signature {
            %outputs = core.get %info["outputs"] default %empty_list
            core.for %field in %outputs {
              %name = core.get %field["name"] default ""
              %duplicate = core.call intrinsic.map.contains(%terminal_fields, %name)
              core.if %duplicate {
                %message = core.call intrinsic.string.format("Output field \"{}\" is produced by multiple terminal nodes", %name)
                core.call @flow_mermaid_fail(%message, 1)
              }
              core.set %terminal_fields[%name] = %field
              %path = core.call intrinsic.string.format("{}Result.{}", %id, %name)
              core.set %returns[%name] = %path
            }
          }
        }
      }
      core.set %flow["returns"] = %returns
      core.set %flow["mermaidAst"] = %ast
      core.set %flow["mermaidBindings"] = %bindings
      core.set %flow["mermaidInputFields"] = %natural_inputs
      core.set %flow["mermaidOutputFields"] = %terminal_fields
      core.return %flow
    }
  }

  op ax.flow.semantic @flow_mermaid_render_ast {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(ast:json, options:json) -> string throws"
    body @entry(%ast: json, %options: json) {
      %empty_map = core.map
      %opts_missing = core.call intrinsic.is_none(%options)
      %opts = core.let %options
      core.if %opts_missing {
        %opts = core.let %empty_map
      }
      %direction = core.get %opts["direction"] default "TD"
      %lines = core.list
      %header = core.call intrinsic.string.format("flowchart {}", %direction)
      core.append %lines, %header
      %directives = core.get %ast["directives"]
      %directive_order = core.get %ast["directiveOrder"]
      %percent = core.get %ast["percent"] default ""
      core.for %id in %directive_order {
        %signature_text = core.get %directives[%id]
        %signature = core.call @parse_signature(%signature_text)
        %canonical = core.call @signature_to_string(%signature)
        %prefix = core.call intrinsic.string.format("{}{}ax", %percent, %percent)
        %directive = core.call intrinsic.string.format("  {} {}: {}", %prefix, %id, %canonical)
        core.append %lines, %directive
      }
      core.append %lines, ""
      %nodes = core.get %ast["nodes"]
      %order = core.get %ast["order"]
      %compile_order = core.get %ast["compileOrder"] default %order
      %order_index = core.get %ast["orderIndex"]
      %edges = core.get %ast["edges"]
      core.for %id in %compile_order {
        %node = core.get %nodes[%id]
        %shape = core.get %node["shape"] default "rect"
        %label = core.get %node["label"] default null
        %is_diamond = core.call intrinsic.eq(%shape, "diamond")
        core.if %is_diamond {
        } else {
          %spaced_title = core.call intrinsic.string.title_from_camel(%id)
          %lower_title = core.call intrinsic.string.lower(%spaced_title)
          %label = core.call intrinsic.string.title_from_camel(%lower_title)
        }
        %statement = core.call intrinsic.string.format("  {}[{}]", %id, %label)
        core.if %is_diamond {
          %open_brace = core.get %node["open"] default ""
          %close_brace = core.get %node["close"] default ""
          %wrapped = core.call intrinsic.string.format("{}{}{}", %open_brace, %label, %close_brace)
          %statement = core.call intrinsic.string.format("  {}{}", %id, %wrapped)
        }
        core.append %lines, %statement
        core.for %edge in %edges {
          %to = core.get %edge["to"] default ""
          %arrives = core.call intrinsic.eq(%to, %id)
          core.if %arrives {
            %from_node = core.get %edge["from"] default ""
            %from_index = core.get %order_index[%from_node]
            %to_index = core.get %order_index[%to]
            %points_backward = core.call intrinsic.gte(%from_index, %to_index)
            %closes_cycle = core.call @flow_mermaid_reachable(%to, %from_node, %edges)
            %back = core.call intrinsic.and(%points_backward, %closes_cycle)
            %forward = core.call intrinsic.not(%back)
            core.if %forward {
              %label = core.get %edge["label"] default null
              %has_label = core.call intrinsic.is_not_none(%label)
              %edge_line = core.call intrinsic.string.format("  {} --> {}", %from_node, %to)
              core.if %has_label {
                %edge_line = core.call intrinsic.string.format("  {} -->|{}| {}", %from_node, %label, %to)
              }
              core.append %lines, %edge_line
            }
          }
        }
      }
      core.for %edge in %edges {
        %from_node = core.get %edge["from"] default ""
        %to = core.get %edge["to"] default ""
        %from_index = core.get %order_index[%from_node]
        %to_index = core.get %order_index[%to]
        %points_backward = core.call intrinsic.gte(%from_index, %to_index)
        %closes_cycle = core.call @flow_mermaid_reachable(%to, %from_node, %edges)
        %back = core.call intrinsic.and(%points_backward, %closes_cycle)
        core.if %back {
          %label = core.get %edge["label"] default null
          %has_label = core.call intrinsic.is_not_none(%label)
          %edge_line = core.call intrinsic.string.format("  {} --> {}", %from_node, %to)
          core.if %has_label {
            %edge_line = core.call intrinsic.string.format("  {} -->|{}| {}", %from_node, %label, %to)
          }
          core.append %lines, %edge_line
        }
      }
      core.append %lines, ""
      %rendered = core.call intrinsic.string.join("\n", %lines)
      core.return %rendered
    }
  }

  op ax.flow.semantic @flow_mermaid_render_flow {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(flow:json, options:json) -> string throws"
    body @entry(%flow: json, %options: json) {
      %empty_map = core.map
      %opts_missing = core.call intrinsic.is_none(%options)
      %opts = core.let %options
      core.if %opts_missing {
        %opts = core.let %empty_map
      }
      %direction = core.get %opts["direction"] default "TD"
      %lines = core.list
      %header = core.call intrinsic.string.format("flowchart {}", %direction)
      core.append %lines, %header
      %steps = core.get %flow["steps"]
      %percent = core.get %flow["mermaidPercent"] default ""
      core.for %step in %steps {
        %kind = core.get %step["kind"] default "execute"
        %is_execute = core.call intrinsic.eq(%kind, "execute")
        core.if %is_execute {
          %step_options = core.get %step["options"] default %empty_map
          %signature_text = core.get %step_options["signatureText"] default ""
          %has_signature = core.call intrinsic.truthy(%signature_text)
          core.if %has_signature {
            %signature = core.call @parse_signature(%signature_text)
            %canonical = core.call @signature_to_string(%signature)
            %name = core.get %step["name"] default ""
            %prefix = core.call intrinsic.string.format("{}{}ax", %percent, %percent)
            %directive = core.call intrinsic.string.format("  {} {}: {}", %prefix, %name, %canonical)
            core.append %lines, %directive
          }
        }
      }
      core.append %lines, ""
      %diamonds = core.map
      core.for %step in %steps {
        %meta = core.get %step["meta"] default %empty_map
        %decision = core.get %meta["decision"] default null
        %has_decision = core.call intrinsic.is_not_none(%decision)
        core.if %has_decision {
          %node = core.get %decision["nodeName"] default ""
          %field = core.get %decision["field"] default ""
          core.set %diamonds[%node] = %field
        }
      }
      %seen = core.map
      core.for %step in %steps {
        %kind = core.get %step["kind"] default "execute"
        %is_execute = core.call intrinsic.eq(%kind, "execute")
        %is_map = core.call intrinsic.eq(%kind, "map")
        %material = core.call intrinsic.or(%is_execute, %is_map)
        core.if %material {
          %name = core.get %step["name"] default ""
          %known = core.call intrinsic.map.contains(%seen, %name)
          core.if %known {
          } else {
            core.set %seen[%name] = true
            %spaced_title = core.call intrinsic.string.title_from_camel(%name)
            %lower_title = core.call intrinsic.string.lower(%spaced_title)
            %title = core.call intrinsic.string.title_from_camel(%lower_title)
            %diamond = core.get %diamonds[%name] default null
            %has_diamond = core.call intrinsic.is_not_none(%diamond)
            %statement = core.call intrinsic.string.format("  {}[{}]", %name, %title)
            core.if %has_diamond {
              %open_brace = core.get %flow["mermaidOpenBrace"] default ""
              %close_brace = core.get %flow["mermaidCloseBrace"] default ""
              %wrapped = core.call intrinsic.string.format("{}{}{}", %open_brace, %diamond, %close_brace)
              %statement = core.call intrinsic.string.format("  {}{}", %name, %wrapped)
            }
            core.append %lines, %statement
            %step_options = core.get %step["options"] default %empty_map
            %empty_reads = core.list
            %step_reads = core.get %step["reads"] default %empty_reads
            %reads = core.get %step_options["reads"] default %step_reads
            core.for %read in %reads {
              %is_result = core.call intrinsic.string.ends_with(%read, "Result")
              core.if %is_result {
                %read_len = core.call intrinsic.len(%read)
                %producer_end = core.call intrinsic.add(%read_len, -6)
                %producer = core.call intrinsic.string.slice(%read, 0, %producer_end)
                %edge_line = core.call intrinsic.string.format("  {} --> {}", %producer, %name)
                core.append %lines, %edge_line
              }
            }
          }
        }
      }
      core.append %lines, ""
      %rendered = core.call intrinsic.string.join("\n", %lines)
      core.return %rendered
    }
  }

  op ax.flow.semantic @flow_from_mermaid {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    tag "src/ax/flow/mermaid.ts"
    type signature = "(text:string, bindings?:json) -> json throws"
    body @entry(%text: string, %bindings: json) {
      %empty_map = core.map
      %missing = core.call intrinsic.is_none(%bindings)
      %resolved = core.let %bindings
      core.if %missing {
        %resolved = core.let %empty_map
      }
      %ast = core.call @flow_mermaid_parse(%text)
      %flow = core.call @flow_mermaid_compile(%ast, %resolved)
      core.return %flow
    }
  }

  op ax.flow.semantic @flow_to_mermaid {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    tag "src/ax/flow/mermaid.ts"
    type signature = "(flow:json, options?:json) -> string throws"
    body @entry(%flow: json, %options: json) {
      %ast = core.get %flow["mermaidAst"] default null
      %has_ast = core.call intrinsic.is_not_none(%ast)
      core.if %has_ast {
        %rendered = core.call @flow_mermaid_render_ast(%ast, %options)
        core.return %rendered
      }
      %rendered = core.call @flow_mermaid_render_flow(%flow, %options)
      core.return %rendered
    }
  }
}
