module @ax.flow version "0.1" {
  dialect @ax.flow version "0.1"

  op ax.flow.semantic @flow_factory {
    attr core_kind = "func"
    attr emit_module = "flow"
    type signature = "(options?:json) -> json"
    body @entry(%options: json) {
      %empty_map = core.map
      %empty_list = core.list
      %opts_missing = core.call intrinsic.is_none(%options)
      %opts = core.let %options
      core.if %opts_missing {
        %opts = core.let %empty_map
      } else {
      }
      %steps = core.list
      %traces = core.list
      %chat_log = core.list
      %usage = core.map
      %demos = core.map
      %state = core.map
      %id = core.get %opts["id"] default "root.flow"
      core.set %state["program_kind"] = "axflow"
      core.set %state["program_id"] = %id
      core.set %state["options"] = %opts
      core.set %state["steps"] = %steps
      core.set %state["returns"] = %empty_map
      core.set %state["demos"] = %demos
      core.set %state["traces"] = %traces
      core.set %state["chat_log"] = %chat_log
      core.set %state["usage"] = %usage
      core.return %state
    }
  }

  op ax.flow.semantic @flow_step {
    attr core_kind = "func"
    attr emit_module = "flow"
    type signature = "(kind:string, name:string, program:json, options:json) -> json throws"
    body @entry(%kind: string, %name: string, %program: json, %options: json) {
      %trimmed = core.string_trim %name
      %missing_name = core.call intrinsic.eq(%trimmed, "")
      core.if %missing_name {
        %err = core.call intrinsic.error.runtime("flow step name is required")
        core.raise %err
      } else {
      }
      %empty_map = core.map
      %opts_missing = core.call intrinsic.is_none(%options)
      %opts = core.let %options
      core.if %opts_missing {
        %opts = core.let %empty_map
      } else {
      }
      %step = core.map
      core.set %step["kind"] = %kind
      core.set %step["name"] = %trimmed
      core.set %step["nodeName"] = %trimmed
      core.set %step["program"] = %program
      core.set %step["options"] = %opts
      %reads_empty = core.list
      %reads = core.get %opts["reads"] default %reads_empty
      %writes_default = core.list
      %is_execute = core.call intrinsic.eq(%kind, "execute")
      %is_derive = core.call intrinsic.eq(%kind, "derive")
      %is_parallel = core.call intrinsic.eq(%kind, "parallel")
      %is_parallel_merge = core.call intrinsic.eq(%kind, "parallelMerge")
      core.if %is_execute {
        %execute_write = core.call intrinsic.string.format("{}Result", %trimmed)
        core.append %writes_default, %execute_write
      } else {
      }
      core.if %is_derive {
        core.append %writes_default, %trimmed
      } else {
      }
      core.if %is_parallel {
        core.append %writes_default, "_parallelResults"
      } else {
      }
      core.if %is_parallel_merge {
        core.append %writes_default, %trimmed
      } else {
      }
      %writes = core.get %opts["writes"] default %writes_default
      %default_barrier = core.let true
      %may_parallel = core.call intrinsic.or(%is_execute, %is_derive)
      core.if %may_parallel {
        %default_barrier = core.let false
      } else {
      }
      %barrier_from_snake = core.get %opts["is_barrier"] default %default_barrier
      %barrier_from_camel = core.get %opts["isBarrier"] default %barrier_from_snake
      %barrier = core.get %opts["barrier"] default %barrier_from_camel
      core.set %step["reads"] = %reads
      core.set %step["writes"] = %writes
      core.set %step["isBarrier"] = %barrier
      core.return %step
    }
  }

  op ax.flow.semantic @flow_add_step {
    attr core_kind = "func"
    attr emit_module = "flow"
    type signature = "(flow:json, step:json) -> json throws"
    body @entry(%flow: json, %step: json) {
      %steps = core.get %flow["steps"]
      %name = core.get %step["name"] default ""
      core.for %existing in %steps {
        %existing_name = core.get %existing["name"] default ""
        %duplicate = core.call intrinsic.eq(%existing_name, %name)
        core.if %duplicate {
          %message = core.call intrinsic.string.format("duplicate flow step: {}", %name)
          %err = core.call intrinsic.error.runtime(%message)
          core.raise %err
        } else {
        }
      }
      core.append %steps, %step
      core.set %flow["steps"] = %steps
      core.return %flow
    }
  }

  op ax.flow.semantic @flow_set_returns {
    attr core_kind = "func"
    attr emit_module = "flow"
    type signature = "(flow:json, returns:json) -> json"
    body @entry(%flow: json, %returns: json) {
      %empty_map = core.map
      %missing = core.call intrinsic.is_none(%returns)
      %spec = core.let %returns
      core.if %missing {
        %spec = core.let %empty_map
      } else {
      }
      core.set %flow["returns"] = %spec
      core.return %flow
    }
  }

  op ax.flow.semantic @flow_plan_entry {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(step:json, step_index:i64) -> json"
    body @entry(%step: json, %step_index: i64) {
      %empty_list = core.list
      %kind = core.get %step["kind"] default "execute"
      %name = core.get %step["name"] default ""
      %reads = core.get %step["reads"] default %empty_list
      %writes = core.get %step["writes"] default %empty_list
      %barrier_snake = core.get %step["is_barrier"] default false
      %barrier_camel = core.get %step["isBarrier"] default %barrier_snake
      %barrier = core.get %step["barrier"] default %barrier_camel
      %entry = core.map
      core.set %entry["name"] = %name
      core.set %entry["kind"] = %kind
      core.set %entry["reads"] = %reads
      core.set %entry["writes"] = %writes
      core.set %entry["barrier"] = %barrier
      core.set %entry["stepIndex"] = %step_index
      core.return %entry
    }
  }

  op ax.flow.semantic @flow_plan_can_share_group {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(group:list<json>, candidate:json) -> bool"
    body @entry(%group: json, %candidate: json) {
      %empty_list = core.list
      %candidate_barrier = core.get %candidate["barrier"] default true
      %candidate_writes = core.get %candidate["writes"] default %empty_list
      %candidate_reads = core.get %candidate["reads"] default %empty_list
      %write_count = core.call intrinsic.len(%candidate_writes)
      %no_writes = core.call intrinsic.eq(%write_count, 0)
      %can_share = core.let true
      core.if %candidate_barrier {
        %can_share = core.let false
      } else {
      }
      core.if %no_writes {
        %can_share = core.let false
      } else {
      }
      core.for %existing in %group {
        %existing_barrier = core.get %existing["barrier"] default true
        core.if %existing_barrier {
          %can_share = core.let false
        } else {
        }
        %existing_writes = core.get %existing["writes"] default %empty_list
        %existing_reads = core.get %existing["reads"] default %empty_list
        core.for %read in %candidate_reads {
          %read_conflict = core.call intrinsic.contains(%existing_writes, %read)
          core.if %read_conflict {
            %can_share = core.let false
          } else {
          }
        }
        core.for %existing_read in %existing_reads {
          %reverse_read_conflict = core.call intrinsic.contains(%candidate_writes, %existing_read)
          core.if %reverse_read_conflict {
            %can_share = core.let false
          } else {
          }
        }
        core.for %write in %candidate_writes {
          %write_conflict = core.call intrinsic.contains(%existing_writes, %write)
          core.if %write_conflict {
            %can_share = core.let false
          } else {
          }
        }
      }
      core.return %can_share
    }
  }

  op ax.flow.semantic @flow_plan {
    attr core_kind = "func"
    attr emit_module = "flow"
    type signature = "(flow:json) -> json"
    body @entry(%flow: json) {
      %steps = core.get %flow["steps"]
      %plan_steps = core.list
      %step_index = core.let 0
      core.for %step in %steps {
        %entry = core.call @flow_plan_entry(%step, %step_index)
        core.append %plan_steps, %entry
        %next_step_index = core.call intrinsic.add(%step_index, 1)
        %step_index = core.let %next_step_index
      }
      %empty_map = core.map
      %returns = core.get %flow["returns"] default %empty_map
      %has_returns = core.call intrinsic.truthy(%returns)
      core.if %has_returns {
        %return_reads = core.list
        %return_writes = core.list
        %returns_entry = core.map
        core.set %returns_entry["name"] = "returns"
        core.set %returns_entry["kind"] = "returns"
        core.set %returns_entry["reads"] = %return_reads
        core.set %returns_entry["writes"] = %return_writes
        core.set %returns_entry["barrier"] = true
        core.set %returns_entry["stepIndex"] = %step_index
        core.append %plan_steps, %returns_entry
        %return_next_step_index = core.call intrinsic.add(%step_index, 1)
        %step_index = core.let %return_next_step_index
      } else {
      }
      %groups = core.list
      %current_group = core.list
      core.for %plan_step in %plan_steps {
        %barrier = core.get %plan_step["barrier"] default true
        %current_count = core.call intrinsic.len(%current_group)
        %has_current = core.call intrinsic.gt(%current_count, 0)
        core.if %barrier {
          core.if %has_current {
            %group = core.map
            %level = core.call intrinsic.len(%groups)
            core.set %group["level"] = %level
            core.set %group["steps"] = %current_group
            core.append %groups, %group
            %current_group = core.list
          } else {
          }
          %single_steps = core.list
          core.append %single_steps, %plan_step
          %single_group = core.map
          %single_level = core.call intrinsic.len(%groups)
          core.set %single_group["level"] = %single_level
          core.set %single_group["steps"] = %single_steps
          core.append %groups, %single_group
        } else {
          %can_add = core.let true
          core.if %has_current {
            %can_add = core.call @flow_plan_can_share_group(%current_group, %plan_step)
          } else {
          }
          core.if %can_add {
            core.append %current_group, %plan_step
          } else {
            %group = core.map
            %level = core.call intrinsic.len(%groups)
            core.set %group["level"] = %level
            core.set %group["steps"] = %current_group
            core.append %groups, %group
            %current_group = core.list
            core.append %current_group, %plan_step
          }
        }
      }
      %remaining_count = core.call intrinsic.len(%current_group)
      %has_remaining = core.call intrinsic.gt(%remaining_count, 0)
      core.if %has_remaining {
        %group = core.map
        %level = core.call intrinsic.len(%groups)
        core.set %group["level"] = %level
        core.set %group["steps"] = %current_group
        core.append %groups, %group
      } else {
      }
      %max_parallelism = core.let 1
      core.for %group in %groups {
        %group_steps = core.get %group["steps"]
        %group_count = core.call intrinsic.len(%group_steps)
        %bigger = core.call intrinsic.gt(%group_count, %max_parallelism)
        core.if %bigger {
          %max_parallelism = core.let %group_count
        } else {
        }
      }
      %plan = core.map
      %total_steps = core.call intrinsic.len(%plan_steps)
      %parallel_groups = core.call intrinsic.len(%groups)
      core.set %plan["totalSteps"] = %total_steps
      core.set %plan["parallelGroups"] = %parallel_groups
      core.set %plan["maxParallelism"] = %max_parallelism
      core.set %plan["steps"] = %plan_steps
      core.set %plan["groups"] = %groups
      core.return %plan
    }
  }

  op ax.flow.semantic @flow_cache_key {
    attr core_kind = "func"
    attr emit_module = "flow"
    type signature = "(values:json) -> string"
    body @entry(%values: json) {
      %key = core.call intrinsic.json.stable_stringify(%values)
      core.return %key
    }
  }

  op ax.flow.semantic @flow_cache_read_write {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(flow:json, values:json, options:json, mode:string, cachedValue:json) -> json"
    body @entry(%flow: json, %values: json, %options: json, %mode: string, %cached_value: json) {
      %empty_map = core.map
      %opts_missing = core.call intrinsic.is_none(%options)
      %opts = core.let %options
      core.if %opts_missing {
        %opts = core.let %empty_map
      } else {
      }
      %key = core.call @flow_cache_key(%values)
      %store_snake = core.get %opts["cache_store"] default null
      %store = core.get %opts["cacheStore"] default %store_snake
      %has_store = core.call intrinsic.is_not_none(%store)
      %read_error_snake = core.get %opts["cache_read_error"] default false
      %read_error = core.get %opts["cacheReadError"] default %read_error_snake
      %write_error_snake = core.get %opts["cache_write_error"] default false
      %write_error = core.get %opts["cacheWriteError"] default %write_error_snake
      %is_read = core.call intrinsic.eq(%mode, "read")
      %is_write = core.call intrinsic.eq(%mode, "write")
      %none = core.call intrinsic.none()
      %result = core.map
      core.set %result["key"] = %key
      core.set %result["hit"] = false
      core.set %result["value"] = %none
      core.if %is_read {
        %can_read_store = core.call intrinsic.and(%has_store, %read_error)
        %skip_read = core.call intrinsic.truthy(%can_read_store)
        core.if %skip_read {
        } else {
          core.if %has_store {
            %cached = core.get %store[%key] default null
            %hit = core.call intrinsic.is_not_none(%cached)
            core.if %hit {
              core.set %result["hit"] = true
              core.set %result["value"] = %cached
            } else {
            }
          } else {
          }
        }
      } else {
      }
      core.if %is_write {
        %can_write_store = core.call intrinsic.and(%has_store, %write_error)
        %skip_write = core.call intrinsic.truthy(%can_write_store)
        core.if %skip_write {
        } else {
          core.if %has_store {
            core.set %store[%key] = %cached_value
            core.set %result["value"] = %cached_value
          } else {
          }
        }
      } else {
      }
      core.return %result
    }
  }

  op ax.flow.semantic @flow_check_abort {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(options:json, location:string) -> void throws"
    body @entry(%options: json, %location: string) {
      %none = core.call intrinsic.none()
      %abort_snake = core.get %options["abort_before_step"] default false
      %abort_camel = core.get %options["abortBeforeStep"] default %abort_snake
      %aborted = core.get %options["aborted"] default %abort_camel
      %abort = core.get %options["abort"] default %aborted
      core.if %abort {
        %message = core.call intrinsic.string.format("Flow aborted at {}", %location)
        %err = core.call intrinsic.error.runtime(%message)
        core.raise %err
      } else {
      }
      core.return %none
    }
  }

  op ax.flow.semantic @flow_project_returns {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(state:json, returns:json) -> json"
    body @entry(%state: json, %returns: json) {
      %empty_map = core.map
      %spec = core.let %returns
      %missing = core.call intrinsic.is_none(%returns)
      core.if %missing {
        %spec = core.let %empty_map
      } else {
      }
      %has_returns = core.call intrinsic.truthy(%spec)
      %output = core.let %state
      core.if %has_returns {
        %projected = core.map
        %keys = core.call intrinsic.map.keys(%spec)
        core.for %key in %keys {
          %path = core.get %spec[%key]
          %value = core.call @flow_get_path(%state, %path)
          core.set %projected[%key] = %value
        }
        %output = core.let %projected
      } else {
      }
      core.return %output
    }
  }

  op ax.flow.semantic @flow_get_path {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(state:json, path:json) -> json"
    body @entry(%state: json, %path: json) {
      %none = core.call intrinsic.none()
      %path_text = core.call intrinsic.string.str(%path)
      %parts = core.call intrinsic.string.split(%path_text, ".")
      %current = core.let %state
      core.for %part in %parts {
        %is_object = core.type_is %current type "object"
        core.if %is_object {
          %current = core.get %current[%part] default %none
        } else {
          %current = core.let %none
        }
      }
      core.return %current
    }
  }

  op ax.flow.semantic @flow_record_child_chat_log {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(flow:json, node:string, program:json) -> json"
    body @entry(%flow: json, %node: string, %program: json) {
      %empty_list = core.list
      %chat_log = core.get %flow["chat_log"] default %empty_list
      %child_log = core.call intrinsic.agent.stage_chat_log(%program)
      core.for %entry in %child_log {
        %entry_name = core.get %entry["name"] default ""
        %has_entry_name = core.call intrinsic.truthy(%entry_name)
        core.if %has_entry_name {
          %prefixed_entry_name = core.call intrinsic.string.format("{}.{}", %node, %entry_name)
          core.set %entry["name"] = %prefixed_entry_name
        } else {
          core.set %entry["name"] = %node
        }
        core.append %chat_log, %entry
      }
      core.set %flow["chat_log"] = %chat_log
      core.return %chat_log
    }
  }

  op ax.flow.semantic @flow_record_child_usage {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(flow:json, node:string, program:json) -> json"
    body @entry(%flow: json, %node: string, %program: json) {
      %empty_map = core.map
      %usage = core.get %flow["usage"] default %empty_map
      %child_usage = core.call intrinsic.agent.stage_usage(%program)
      %has_usage = core.call intrinsic.truthy(%child_usage)
      core.if %has_usage {
        core.set %usage[%node] = %child_usage
      } else {
      }
      core.set %flow["usage"] = %usage
      core.return %usage
    }
  }

  op ax.flow.semantic @flow_record_child_traces {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(flow:json, node:string, program:json) -> json"
    body @entry(%flow: json, %node: string, %program: json) {
      %empty_list = core.list
      %traces = core.get %flow["traces"] default %empty_list
      %child_traces = core.call intrinsic.agent.stage_traces(%program)
      core.for %trace in %child_traces {
        %entry = core.map
        core.set %entry["kind"] = "flow_child_trace"
        core.set %entry["name"] = %node
        core.set %entry["trace"] = %trace
        core.append %traces, %entry
      }
      core.set %flow["traces"] = %traces
      core.return %traces
    }
  }

  op ax.flow.semantic @flow_execute_program_node {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(flow:json, step:json, client:json, state:json, options:json) -> json throws"
    body @entry(%flow: json, %step: json, %client: json, %state: json, %options: json) {
      %empty_map = core.map
      %name = core.get %step["name"] default ""
      %kind = core.get %step["kind"] default "execute"
      %program = core.get %step["program"]
      %step_options = core.get %step["options"] default %empty_map
      %base_options = core.get %flow["options"] default %empty_map
      %runtime_base = core.call intrinsic.map.merge(%base_options, %options)
      %runtime_options = core.call intrinsic.map.merge(%runtime_base, %step_options)
      %trace_label_in = core.get %options["traceLabel"] default ""
      %has_trace_label = core.call intrinsic.truthy(%trace_label_in)
      %trace_label = core.call intrinsic.string.format("Node:{}", %name)
      core.if %has_trace_label {
        %trace_label = core.call intrinsic.string.format("Node:{} ({})", %name, %trace_label_in)
      } else {
      }
      core.set %runtime_options["traceLabel"] = %trace_label
      %abort_during_snake = core.get %options["abort_during_step"] default false
      %abort_during = core.get %options["abortDuringStep"] default %abort_during_snake
      %abort_node_snake = core.get %options["abort_during_node"] default ""
      %abort_node = core.get %options["abortDuringNode"] default %abort_node_snake
      %abort_named = core.call intrinsic.eq(%abort_node, %name)
      %abort_no_name = core.call intrinsic.eq(%abort_node, "")
      %abort_this_node = core.call intrinsic.and(%abort_during, %abort_named)
      %abort_any_node = core.call intrinsic.and(%abort_during, %abort_no_name)
      %abort_now = core.call intrinsic.or(%abort_this_node, %abort_any_node)
      core.if %abort_now {
        %abort_message = core.call intrinsic.string.format("Flow aborted at flow-node-{}", %name)
        %abort_error = core.call intrinsic.error.runtime(%abort_message)
        core.raise %abort_error
      } else {
      }
      %result = core.call intrinsic.agent.stage_forward(%program, %client, %state, %runtime_options)
      %out = core.call intrinsic.map.merge(%state, %empty_map)
      %result_key = core.call intrinsic.string.format("{}Result", %name)
      core.set %out[%result_key] = %result
      %is_derive = core.call intrinsic.eq(%kind, "derive")
      core.if %is_derive {
        core.set %out[%name] = %result
      } else {
      }
      %out = core.call intrinsic.map.update(%out, %result)
      core.call @flow_record_child_chat_log(%flow, %name, %program)
      core.call @flow_record_child_usage(%flow, %name, %program)
      core.call @flow_record_child_traces(%flow, %name, %program)
      core.return %out
    }
  }

  op ax.flow.semantic @flow_execute_step {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(flow:json, step:json, plan_step:json, client:json, state:json, options:json) -> json throws"
    body @entry(%flow: json, %step: json, %plan_step: json, %client: json, %state: json, %options: json) {
      %empty_map = core.map
      %missing_step = core.call intrinsic.is_none(%step)
      core.if %missing_step {
        core.return %state
      } else {
      }
      %kind = core.get %step["kind"] default "execute"
      %name = core.get %step["name"] default ""
      %location = core.call intrinsic.string.format("flow-step-{}", %name)
      core.call @flow_check_abort(%options, %location)
      %traces = core.get %flow["traces"]
      %program_id = core.get %flow["program_id"] default "root.flow"
      %event_payload = core.map
      core.set %event_payload["name"] = %name
      core.set %event_payload["kind"] = %kind
      %step_index = core.get %plan_step["stepIndex"] default 0
      core.set %event_payload["stepIndex"] = %step_index
      %step_event = core.call @program_trace_event(%program_id, "flow_step", %event_payload)
      core.append %traces, %step_event
      %is_map = core.call intrinsic.eq(%kind, "map")
      core.if %is_map {
        %program = core.get %step["program"]
        %mapped = core.call intrinsic.object.call_method(%program, "call", %state)
        %out = core.call intrinsic.map.merge(%state, %empty_map)
        %result_key = core.call intrinsic.string.format("{}Result", %name)
        core.set %out[%result_key] = %mapped
        %out = core.call intrinsic.map.update(%out, %mapped)
        core.return %out
      } else {
      }
      %is_branch = core.call intrinsic.eq(%kind, "branch")
      core.if %is_branch {
        %step_options = core.get %step["options"] default %empty_map
        %predicate = core.get %step_options["predicate"] default null
        %has_predicate = core.call intrinsic.is_not_none(%predicate)
        %branch_value_default = core.get %step_options["value"] default false
        %branch_value = core.get %step_options["branchValue"] default %branch_value_default
        core.if %has_predicate {
          %branch_value = core.call intrinsic.object.call_method(%predicate, "call", %state)
        } else {
        }
        %default_branches = core.list
        %branches = core.get %step_options["branches"] default %default_branches
        %current = core.let %state
        %matched = core.let false
        core.for %branch in %branches {
          %when = core.get %branch["when"] default null
          %matches = core.call intrinsic.eq(%when, %branch_value)
          core.if %matches {
            %branch_steps = core.get %branch["steps"] default %default_branches
            %current = core.call @flow_execute_nested_steps(%flow, %client, %branch_steps, %current, %options)
            %matched = core.let true
          } else {
          }
        }
        core.return %current
      } else {
      }
      %is_while = core.call intrinsic.eq(%kind, "while")
      core.if %is_while {
        %step_options = core.get %step["options"] default %empty_map
        %condition = core.get %step_options["condition"] default null
        %has_condition = core.call intrinsic.is_not_none(%condition)
        %default_body = core.list
        %body_steps = core.get %step_options["steps"] default %default_body
        %max_iterations_snake = core.get %step_options["max_iterations"] default 100
        %max_iterations = core.get %step_options["maxIterations"] default %max_iterations_snake
        %current = core.let %state
        %iterations = core.let 0
        core.loop {
          %condition_result = core.get %step_options["conditionResult"] default false
          core.if %has_condition {
            %condition_result = core.call intrinsic.object.call_method(%condition, "call", %current)
          } else {
          }
          %should_continue = core.call intrinsic.truthy(%condition_result)
          %done = core.call intrinsic.not(%should_continue)
          core.if %done {
            core.break
          } else {
          }
          %too_many = core.call intrinsic.gte(%iterations, %max_iterations)
          core.if %too_many {
            %message = core.call intrinsic.string.format("While loop exceeded maximum iterations ({})", %max_iterations)
            %err = core.call intrinsic.error.runtime(%message)
            core.raise %err
          } else {
          }
          core.call @flow_check_abort(%options, "flow-while")
          %current = core.call @flow_execute_nested_steps(%flow, %client, %body_steps, %current, %options)
          %iterations = core.call intrinsic.add(%iterations, 1)
        }
        core.return %current
      } else {
      }
      %is_feedback = core.call intrinsic.eq(%kind, "feedback")
      core.if %is_feedback {
        %step_options = core.get %step["options"] default %empty_map
        %condition = core.get %step_options["condition"] default null
        %has_condition = core.call intrinsic.is_not_none(%condition)
        %default_body = core.list
        %body_steps = core.get %step_options["steps"] default %default_body
        %max_iterations_snake = core.get %step_options["max_iterations"] default 10
        %max_iterations = core.get %step_options["maxIterations"] default %max_iterations_snake
        %label = core.get %step_options["label"] default %name
        %iteration_key = core.call intrinsic.string.format("_feedback_{}_iterations", %label)
        %current = core.call intrinsic.map.merge(%state, %empty_map)
        %existing_iterations = core.get %current[%iteration_key] default null
        %missing_iterations = core.call intrinsic.is_none(%existing_iterations)
        core.if %missing_iterations {
          core.set %current[%iteration_key] = 1
        } else {
        }
        %iterations = core.let 1
        core.loop {
          %condition_result = core.get %step_options["conditionResult"] default false
          core.if %has_condition {
            %condition_result = core.call intrinsic.object.call_method(%condition, "call", %current)
          } else {
          }
          %should_continue = core.call intrinsic.truthy(%condition_result)
          %done = core.call intrinsic.not(%should_continue)
          core.if %done {
            core.break
          } else {
          }
          %too_many = core.call intrinsic.gte(%iterations, %max_iterations)
          core.if %too_many {
            core.break
          } else {
          }
          %location = core.call intrinsic.string.format("flow-feedback-{}", %label)
          core.call @flow_check_abort(%options, %location)
          %iterations = core.call intrinsic.add(%iterations, 1)
          core.set %current[%iteration_key] = %iterations
          %current = core.call @flow_execute_nested_steps(%flow, %client, %body_steps, %current, %options)
        }
        core.return %current
      } else {
      }
      %is_parallel = core.call intrinsic.eq(%kind, "parallel")
      core.if %is_parallel {
        %step_options = core.get %step["options"] default %empty_map
        %default_results = core.list
        %parallel_results_snake = core.get %step_options["parallel_results"] default %default_results
        %parallel_results = core.get %step_options["parallelResults"] default %parallel_results_snake
        %out = core.call intrinsic.map.merge(%state, %empty_map)
        core.set %out["_parallelResults"] = %parallel_results
        core.return %out
      } else {
      }
      %is_parallel_merge = core.call intrinsic.eq(%kind, "parallelMerge")
      core.if %is_parallel_merge {
        %step_options = core.get %step["options"] default %empty_map
        %results = core.get %state["_parallelResults"] default null
        %results_is_list = core.type_is %results type "list"
        %bad_results = core.call intrinsic.not(%results_is_list)
        core.if %bad_results {
          %err = core.call intrinsic.error.runtime("No parallel results found for merge")
          core.raise %err
        } else {
        }
        %merge_output_snake = core.get %step_options["merge_output"] default %results
        %merge_output = core.get %step_options["mergeOutput"] default %merge_output_snake
        %out = core.call intrinsic.map.merge(%state, %empty_map)
        %none = core.call intrinsic.none()
        core.set %out["_parallelResults"] = %none
        core.set %out[%name] = %merge_output
        core.return %out
      } else {
      }
      %program_out = core.call @flow_execute_program_node(%flow, %step, %client, %state, %options)
      core.return %program_out
    }
  }

  op ax.flow.semantic @flow_merge_parallel_results {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(state:json, result:json) -> json"
    body @entry(%state: json, %result: json) {
      %merged = core.call intrinsic.map.merge(%state, %result)
      core.return %merged
    }
  }

  op ax.flow.semantic @flow_execute_nested_steps {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(flow:json, client:json, steps:list<json>, state:json, options:json) -> json throws"
    body @entry(%flow: json, %client: json, %steps: json, %state: json, %options: json) {
      %empty_map = core.map
      %nested = core.call intrinsic.map.merge(%flow, %empty_map)
      %traces = core.get %flow["traces"]
      %chat_log = core.get %flow["chat_log"]
      %usage = core.get %flow["usage"]
      core.set %nested["steps"] = %steps
      core.set %nested["returns"] = %empty_map
      core.set %nested["traces"] = %traces
      core.set %nested["chat_log"] = %chat_log
      core.set %nested["usage"] = %usage
      %out = core.call @flow_execute_steps(%nested, %client, %state, %options)
      %nested_traces = core.get %nested["traces"]
      %nested_chat_log = core.get %nested["chat_log"]
      %nested_usage = core.get %nested["usage"]
      core.set %flow["traces"] = %nested_traces
      core.set %flow["chat_log"] = %nested_chat_log
      core.set %flow["usage"] = %nested_usage
      core.return %out
    }
  }

  op ax.flow.semantic @flow_execute_steps {
    attr core_kind = "func"
    attr emit_module = "flow"
    attr private = true
    type signature = "(flow:json, client:json, state:json, options:json) -> json throws"
    body @entry(%flow: json, %client: json, %state: json, %options: json) {
      %empty_map = core.map
      %empty_list = core.list
      %steps = core.get %flow["steps"] default %empty_list
      %plan = core.call @flow_plan(%flow)
      %plan_steps = core.get %plan["steps"] default %empty_list
      %planned_groups = core.get %plan["groups"] default %empty_list
      %flow_options = core.get %flow["options"] default %empty_map
      %flow_auto_camel = core.get %flow_options["autoParallel"] default true
      %flow_auto = core.get %flow_options["auto_parallel"] default %flow_auto_camel
      %option_auto_camel = core.get %options["autoParallel"] default true
      %option_auto = core.get %options["auto_parallel"] default %option_auto_camel
      %auto_parallel = core.call intrinsic.and(%flow_auto, %option_auto)
      %groups = core.let %planned_groups
      core.if %auto_parallel {
      } else {
        %sequential_groups = core.list
        core.for %plan_step in %plan_steps {
          %single = core.list
          core.append %single, %plan_step
          %group = core.map
          %level = core.call intrinsic.len(%sequential_groups)
          core.set %group["level"] = %level
          core.set %group["steps"] = %single
          core.append %sequential_groups, %group
        }
        %groups = core.let %sequential_groups
      }
      %current = core.let %state
      core.for %group in %groups {
        %level = core.get %group["level"] default 0
        %location = core.call intrinsic.string.format("flow-parallel-group-{}", %level)
        core.call @flow_check_abort(%options, %location)
        %group_steps = core.get %group["steps"] default %empty_list
        %group_count = core.call intrinsic.len(%group_steps)
        %record_groups_snake = core.get %options["record_flow_groups"] default false
        %record_groups = core.get %options["recordFlowGroups"] default %record_groups_snake
        core.if %record_groups {
          %traces = core.get %flow["traces"] default %empty_list
          %program_id = core.get %flow["program_id"] default "root.flow"
          %group_payload = core.map
          core.set %group_payload["level"] = %level
          core.set %group_payload["stepCount"] = %group_count
          core.set %group_payload["steps"] = %group_steps
          %group_event = core.call @program_trace_event(%program_id, "flow_group", %group_payload)
          core.append %traces, %group_event
        } else {
        }
        %is_parallel_group = core.call intrinsic.gt(%group_count, 1)
        core.if %is_parallel_group {
          %group_start = core.call intrinsic.map.merge(%current, %empty_map)
          core.for %plan_step in %group_steps {
            %index = core.get %plan_step["stepIndex"] default 0
            %step = core.call intrinsic.list.get(%steps, %index, null)
            %result_state = core.call @flow_execute_step(%flow, %step, %plan_step, %client, %group_start, %options)
            %current = core.call @flow_merge_parallel_results(%current, %result_state)
          }
        } else {
          core.for %plan_step in %group_steps {
            %index = core.get %plan_step["stepIndex"] default 0
            %step = core.call intrinsic.list.get(%steps, %index, null)
            %current = core.call @flow_execute_step(%flow, %step, %plan_step, %client, %current, %options)
          }
        }
      }
      core.return %current
    }
  }

  op ax.flow.semantic @flow_forward {
    attr core_kind = "func"
    attr emit_module = "flow"
    type signature = "(flow:json, client:json, values:json, options?:json) -> json throws"
    body @entry(%flow: json, %client: json, %values: json, %options: json) {
      %empty_map = core.map
      %opts_missing = core.call intrinsic.is_none(%options)
      %opts = core.let %options
      core.if %opts_missing {
        %opts = core.let %empty_map
      } else {
      }
      %cache_read = core.call @flow_cache_read_write(%flow, %values, %opts, "read", null)
      %cache_hit = core.get %cache_read["hit"] default false
      core.if %cache_hit {
        %cached_value = core.get %cache_read["value"]
        core.return %cached_value
      } else {
      }
      %fresh_traces = core.list
      %fresh_chat_log = core.list
      %fresh_usage = core.map
      core.set %flow["traces"] = %fresh_traces
      core.set %flow["chat_log"] = %fresh_chat_log
      core.set %flow["usage"] = %fresh_usage
      %state = core.call intrinsic.map.merge(%empty_map, %values)
      %traces = core.get %flow["traces"]
      %program_id = core.get %flow["program_id"] default "root.flow"
      %cache_key = core.call @flow_cache_key(%values)
      %begin = core.call @program_trace_event(%program_id, "flow_start", %state)
      core.append %traces, %begin
      %state = core.call @flow_execute_steps(%flow, %client, %state, %opts)
      %returns = core.get %flow["returns"] default %empty_map
      %output = core.call @flow_project_returns(%state, %returns)
      core.call @flow_cache_read_write(%flow, %values, %opts, "write", %output)
      %done_payload = core.map
      core.set %done_payload["cache_key"] = %cache_key
      core.set %done_payload["output"] = %output
      %done = core.call @program_trace_event(%program_id, "flow_done", %done_payload)
      core.append %traces, %done
      core.return %output
    }
  }

  op ax.flow.semantic @flow_get_optimizable_components {
    attr core_kind = "func"
    attr emit_module = "flow"
    type signature = "(flow:json) -> list<json>"
    body @entry(%flow: json) {
      %empty_list = core.list
      %empty_map = core.map
      %owner = core.get %flow["program_id"] default "root.flow"
      %plan = core.call @flow_plan(%flow)
      %current_plan = core.get %flow["optimized_graph_plan"] default %plan
      %components = core.list
      %graph_id = core.call intrinsic.string.format("{}::graph-plan", %owner)
      %constraints = core.list
      core.append %constraints, "Preserve node names, dependencies, and return contract."
      %validation = core.map
      core.set %validation["schema"] = "axflow-plan-v1"
      %graph = core.call @optimization_component(%graph_id, %owner, "flow-graph", %current_plan, "AxFlow execution graph and planner barrier metadata.", %constraints, %empty_list, false, "json", %validation)
      core.append %components, %graph
      %steps = core.get %flow["steps"] default %empty_list
      core.for %step in %steps {
        %program = core.get %step["program"]
        %name = core.get %step["name"] default ""
        %child_components = core.call intrinsic.program.components(%program)
        core.for %component in %child_components {
          %child = core.call @program_prefix_component(%component, %owner, %name)
          core.append %components, %child
        }
      }
      core.return %components
    }
  }

  op ax.flow.semantic @flow_apply_optimized_components {
    attr core_kind = "func"
    attr emit_module = "flow"
    type signature = "(flow:json, component_map:json) -> json throws"
    body @entry(%flow: json, %component_map: json) {
      %empty_map = core.map
      %empty_list = core.list
      %updates_missing = core.call intrinsic.is_none(%component_map)
      %updates = core.let %component_map
      core.if %updates_missing {
        %updates = core.let %empty_map
      } else {
      }
      %components = core.call @flow_get_optimizable_components(%flow)
      core.call @validate_optimization_component_map(%components, %updates)
      %owner = core.get %flow["program_id"] default "root.flow"
      %graph_id = core.call intrinsic.string.format("{}::graph-plan", %owner)
      %graph_update = core.get %updates[%graph_id] default null
      %has_graph_update = core.call intrinsic.is_not_none(%graph_update)
      core.if %has_graph_update {
        %graph_is_object = core.type_is %graph_update type "object"
        %bad_graph = core.call intrinsic.not(%graph_is_object)
        core.if %bad_graph {
          %err = core.call intrinsic.error.runtime("optimized flow graph-plan component must be an object")
          core.raise %err
        } else {
        }
        core.set %flow["optimized_graph_plan"] = %graph_update
      } else {
      }
      %steps = core.get %flow["steps"] default %empty_list
      core.for %step in %steps {
        %program = core.get %step["program"]
        %name = core.get %step["name"] default ""
        %prefix = core.call @program_child_component_prefix(%owner, %name)
        %child_updates = core.call @program_slice_component_map(%updates, %prefix)
        %has_child_updates = core.call intrinsic.truthy(%child_updates)
        core.if %has_child_updates {
          core.call intrinsic.program.apply_components(%program, %child_updates)
        } else {
        }
      }
      core.return %flow
    }
  }

  op ax.flow.semantic @flow_snapshot_components {
    attr core_kind = "func"
    attr emit_module = "flow"
    type signature = "(flow:json) -> json"
    body @entry(%flow: json) {
      %components = core.call @flow_get_optimizable_components(%flow)
      %snapshot = core.call @optimization_component_current_map(%components)
      core.return %snapshot
    }
  }

  op ax.flow.semantic @flow_restore_components {
    attr core_kind = "func"
    attr emit_module = "flow"
    type signature = "(flow:json, snapshot:json) -> json throws"
    body @entry(%flow: json, %snapshot: json) {
      %restored = core.call @flow_apply_optimized_components(%flow, %snapshot)
      core.return %restored
    }
  }

  op ax.flow.semantic @flow_evaluate_optimization {
    attr core_kind = "func"
    attr emit_module = "flow"
    type signature = "(flow:json, client:json, dataset:json, candidate_map:json, options:json) -> json throws"
    body @entry(%flow: json, %client: json, %dataset: json, %candidate_map: json, %options: json) {
      %empty_map = core.map
      %empty_list = core.list
      %opts_missing = core.call intrinsic.is_none(%options)
      %opts = core.let %options
      core.if %opts_missing {
        %opts = core.let %empty_map
      } else {
      }
      %candidate_missing = core.call intrinsic.is_none(%candidate_map)
      %candidate = core.let %candidate_map
      core.if %candidate_missing {
        %candidate = core.let %empty_map
      } else {
      }
      %normalized = core.call @normalize_optimization_dataset(%dataset)
      %train = core.get %normalized["train"] default %empty_list
      %phase = core.get %opts["phase"] default "train"
      %max_calls_snake = core.get %opts["max_metric_calls"] default 2147483647
      %max_calls = core.get %opts["maxMetricCalls"] default %max_calls_snake
      %forward_options = core.get %opts["forward_options"] default %empty_map
      %original = core.call @flow_snapshot_components(%flow)
      %rows = core.list
      %calls = core.let 0
      %result = core.map
      core.try {
        %has_candidate = core.call intrinsic.truthy(%candidate)
        core.if %has_candidate {
          core.call @flow_apply_optimized_components(%flow, %candidate)
        } else {
        }
        core.for %task in %train {
          %too_many = core.call intrinsic.gte(%calls, %max_calls)
          core.if %too_many {
            %message = core.call intrinsic.string.format("max metric calls exceeded: {}", %max_calls)
            %err = core.call intrinsic.error.runtime(%message)
            core.raise %err
          } else {
          }
          %next_calls = core.call intrinsic.add(%calls, 1)
          %calls = core.let %next_calls
          %error = core.call intrinsic.none()
          %prediction = core.map
          core.try {
            %input = core.get %task["input"] default %task
            %output = core.call @flow_forward(%flow, %client, %input, %forward_options)
            %trace = core.map
            %traces = core.get %flow["traces"] default %empty_list
            %chat_log = core.get %flow["chat_log"] default %empty_list
            %usage = core.get %flow["usage"] default %empty_map
            core.set %trace["traces"] = %traces
            core.set %trace["chat_log"] = %chat_log
            %prediction = core.call @build_agent_eval_prediction(%output, %chat_log, %usage, %trace)
          } catch %forward_error {
            %error_message = core.call intrinsic.exception.message(%forward_error)
            %error = core.map
            core.set %error["message"] = %error_message
            %trace = core.map
            %traces = core.get %flow["traces"] default %empty_list
            %chat_log = core.get %flow["chat_log"] default %empty_list
            %usage = core.get %flow["usage"] default %empty_map
            core.set %trace["traces"] = %traces
            core.set %trace["chat_log"] = %chat_log
            core.set %prediction["completionType"] = "error"
            core.set %prediction["error"] = %error
            core.set %prediction["functionCalls"] = %empty_list
            core.set %prediction["actionLog"] = %chat_log
            core.set %prediction["usage"] = %usage
            core.set %prediction["trace"] = %trace
            core.set %prediction["turnCount"] = 0
          }
          %completion_type = core.get %prediction["completionType"] default "final"
          %is_error = core.call intrinsic.eq(%completion_type, "error")
          %default_score = core.let 1
          core.if %is_error {
            %default_score = core.let 0
          } else {
          }
          %score_from_score = core.get %task["score"] default %default_score
          %score_from_scores = core.get %task["scores"] default %score_from_score
          %raw_scores = core.get %task["metric_score"] default %score_from_scores
          %scores = core.call @normalize_optimization_metric_scores(%raw_scores)
          %scalar_base = core.call @scalarize_optimization_scores(%scores, %opts)
          %scalar = core.call @adjust_optimization_score_for_actions(%scalar_base, %task, %prediction)
          %trace_for_row = core.get %prediction["trace"]
          %row = core.call @build_optimization_eval_row(%task, %prediction, %scores, %scalar, %trace_for_row, %error)
          core.append %rows, %row
        }
        %result = core.call @build_optimization_eval_result(%rows, %candidate, %phase)
        core.call @flow_restore_components(%flow, %original)
      } catch %outer_error {
        core.call @flow_restore_components(%flow, %original)
        core.raise %outer_error
      }
      core.return %result
    }
  }

  op ax.flow.semantic @flow_optimize_with {
    attr core_kind = "func"
    attr emit_module = "flow"
    type signature = "(flow:json, dataset:json, options:json, evaluator_available:bool) -> json throws"
    body @entry(%flow: json, %dataset: json, %options: json, %evaluator_available: bool) {
      %empty_map = core.map
      %empty_list = core.list
      %components = core.call @flow_get_optimizable_components(%flow)
      %trace = core.map
      %traces = core.get %flow["traces"] default %empty_list
      %chat_log = core.get %flow["chat_log"] default %empty_list
      core.set %trace["traces"] = %traces
      core.set %trace["chat_log"] = %chat_log
      %run = core.call @prepare_optimizer_run("axflow", %components, %dataset, %options, %trace, %evaluator_available)
      %request = core.get %run["request"] default %empty_map
      core.return %request
    }
  }
}
