module @ax.validate version "0.1" {
  dialect @ax.validate version "0.1"

  op ax.validate.error @AxValidationError {
    attr core_kind = "error"
    type fields = "message:string,path?:string"
  }

  op ax.validate.semantic @validate_fields {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "schema"
    tag "src/ax/dsp/extract/structuredJson.ts"
    type signature = "(list<Field>, json, context:string) -> void throws"
    body @entry(%fields: list<Field>, %values: json, %context: string) {
      core.call @validate_fields_impl(%fields, %values, %context)
      core.return
    }
  }

  op ax.validate.semantic @validate_output {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "schema"
    ref validate = @validate_fields
    tag "structured-output-validation"
    type signature = "(list<Field>, json) -> json throws"
    body @entry(%fields: list<Field>, %values: json) {
      %validated = core.call @validate_output_impl(%fields, %values)
      core.return %validated
    }
  }

  op ax.validate.semantic @validate_value {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "schema"
    tag "src/ax/dsp/util.ts"
    type signature = "(Field, json, path?:string) -> void throws"
    body @entry(%field: Field, %value: json, %path: string) {
      core.call @validate_value_impl(%field, %value, %path)
      core.return
    }
  }

  op ax.validate.semantic @strip_internal_fields {
    attr core_kind = "func"
    attr emit_module = "schema"
    attr emit_name = "strip_internal"
    tag "internal-output"
    type signature = "(list<Field>, json) -> json"
    body @entry(%fields: list<Field>, %values: json) {
      %public_values = core.call @strip_internal_fields_impl(%fields, %values)
      core.return %public_values
    }
  }

  op ax.validate.semantic @validate_fields_impl {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "schema"
    attr private = true
    tag "validate-fields-core-helper"
    type signature = "(list<Field>, json, string) -> void throws"
    body @entry(%fields: list<Field>, %values: json, %context: string) {
      %values_is_object = core.type_is %values type "object"
      %values_not_object = core.call intrinsic.not(%values_is_object)
      core.if %values_not_object {
        %message = core.call intrinsic.string.format("{} must be an object", %context)
        %error = core.call intrinsic.error.validation(%message)
        core.raise %error
      }
      core.for %field in %fields {
        %field_name = core.get %field["name"]
        %field_title = core.get %field["title"]
        %is_optional = core.get %field["is_optional"] default false
        %has_value = core.call intrinsic.map.contains(%values, %field_name)
        %missing = core.call intrinsic.not(%has_value)
        %field_value = core.get %values[%field_name]
        %is_null = core.call intrinsic.is_none(%field_value)
        %missing_or_null = core.call intrinsic.or(%missing, %is_null)
        core.if %missing_or_null {
          %required_missing = core.call intrinsic.not(%is_optional)
          core.if %required_missing {
            %message = core.call intrinsic.string.format("Required field is missing: '{}'", %field_title)
            %error = core.call intrinsic.error.validation(%message)
            core.raise %error
          }
        } else {
          %child_path = core.call intrinsic.string.format("{}.{}", %context, %field_name)
          core.call @validate_value_impl(%field, %field_value, %child_path)
        }
      }
      core.return
    }
  }

  op ax.validate.semantic @validate_output_impl {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "schema"
    attr private = true
    tag "validate-output-core-helper"
    type signature = "(list<Field>, json) -> json throws"
    body @entry(%fields: list<Field>, %values: json) {
      %normalized = core.let %values
      core.for %field in %fields {
        %field_name = core.get %field["name"]
        %field_title = core.get %field["title"]
        %has_name = core.call intrinsic.map.contains(%normalized, %field_name)
        %missing_name = core.call intrinsic.not(%has_name)
        %has_title = core.call intrinsic.map.contains(%normalized, %field_title)
        %alias_title = core.call intrinsic.and(%missing_name, %has_title)
        core.if %alias_title {
          %title_value = core.get %normalized[%field_title]
          core.set %normalized[%field_name] = %title_value
        }
      }
      core.call @validate_fields_impl(%fields, %normalized, "output")
      core.return %normalized
    }
  }

  op ax.validate.semantic @validate_string_constraints_impl {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "schema"
    attr private = true
    tag "validate-string-constraints-core-helper"
    type signature = "(string, Field) -> void throws"
    body @entry(%value: string, %field: Field) {
      %typ = core.get %field["type"]
      %title = core.get %field["title"]
      %min_length = core.get %typ["min_length"]
      %has_min = core.call intrinsic.is_not_none(%min_length)
      core.if %has_min {
        %length = core.call intrinsic.len(%value)
        %too_short = core.call intrinsic.lt(%length, %min_length)
        core.if %too_short {
          %message = core.call intrinsic.string.format("Field '{}' failed validation: String must be at least {} characters long.", %title, %min_length)
          %error = core.call intrinsic.error.validation(%message)
          core.raise %error
        }
      }
      %max_length = core.get %typ["max_length"]
      %has_max = core.call intrinsic.is_not_none(%max_length)
      core.if %has_max {
        %length = core.call intrinsic.len(%value)
        %too_long = core.call intrinsic.gt(%length, %max_length)
        core.if %too_long {
          %message = core.call intrinsic.string.format("Field '{}' failed validation: String must be at most {} characters long.", %title, %max_length)
          %error = core.call intrinsic.error.validation(%message)
          core.raise %error
        }
      }
      %pattern = core.get %typ["pattern"]
      %has_pattern = core.call intrinsic.is_not_none(%pattern)
      core.if %has_pattern {
        %matches = core.regex_match %value pattern %pattern
        %pattern_failed = core.call intrinsic.not(%matches)
        core.if %pattern_failed {
          %message = core.call intrinsic.string.format("Field '{}' failed validation: String must match pattern /{}/.", %title, %pattern)
          %error = core.call intrinsic.error.validation(%message)
          core.raise %error
        }
      }
      %format = core.get %typ["format"]
      %is_email = core.call intrinsic.eq(%format, "email")
      core.if %is_email {
        %valid_email = core.regex_match %value pattern "^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$"
        %invalid_email = core.call intrinsic.not(%valid_email)
        core.if %invalid_email {
          %message = core.call intrinsic.string.format("Field '{}' failed validation: String must be a valid email address.", %title)
          %error = core.call intrinsic.error.validation(%message)
          core.raise %error
        }
      }
      %url_formats = core.list
      core.append %url_formats, "uri"
      core.append %url_formats, "url"
      %is_url_format = core.call intrinsic.contains(%url_formats, %format)
      core.if %is_url_format {
        %valid_url = core.call intrinsic.url.valid(%value)
        %invalid_url = core.call intrinsic.not(%valid_url)
        core.if %invalid_url {
          %message = core.call intrinsic.string.format("Invalid URL for '{}': Invalid URL format.", %title)
          %error = core.call intrinsic.error.validation(%message)
          core.raise %error
        }
      }
      core.return
    }
  }

  op ax.validate.semantic @validate_number_constraints_impl {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "schema"
    attr private = true
    tag "validate-number-constraints-core-helper"
    type signature = "(f64, Field) -> void throws"
    body @entry(%value: f64, %field: Field) {
      %typ = core.get %field["type"]
      %title = core.get %field["title"]
      %minimum = core.get %typ["minimum"]
      %has_minimum = core.call intrinsic.is_not_none(%minimum)
      core.if %has_minimum {
        %too_small = core.call intrinsic.lt(%value, %minimum)
        core.if %too_small {
          %message = core.call intrinsic.string.format("Field '{}' failed validation: Number must be at least {}.", %title, %minimum)
          %error = core.call intrinsic.error.validation(%message)
          core.raise %error
        }
      }
      %maximum = core.get %typ["maximum"]
      %has_maximum = core.call intrinsic.is_not_none(%maximum)
      core.if %has_maximum {
        %too_large = core.call intrinsic.gt(%value, %maximum)
        core.if %too_large {
          %message = core.call intrinsic.string.format("Field '{}' failed validation: Number must be at most {}.", %title, %maximum)
          %error = core.call intrinsic.error.validation(%message)
          core.raise %error
        }
      }
      core.return
    }
  }

  op ax.validate.semantic @validate_value_impl {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "schema"
    attr private = true
    tag "validate-value-core-helper"
    type signature = "(Field, json, string) -> void throws"
    body @entry(%field: Field, %value: json, %path: string) {
      %field_name = core.get %field["name"]
      %typ = core.get %field["type"]
      %type_name = core.get %typ["name"]
      %is_array = core.get %typ["is_array"] default false
      core.if %is_array {
        %is_list = core.type_is %value type "list"
        %not_list = core.call intrinsic.not(%is_list)
        core.if %not_list {
          %message = core.call intrinsic.string.format("{} must be an array", %path)
          %error = core.call intrinsic.error.validation(%message)
          core.raise %error
        }
        %item_field = core.call intrinsic.field.item(%field)
        core.for %item in %value {
          core.call @validate_value_impl(%item_field, %item, %path)
        }
        core.return
      }
      %is_image = core.call intrinsic.eq(%type_name, "image")
      core.if %is_image {
        %valid_image = core.call intrinsic.media.valid_image(%value)
        %invalid_image = core.call intrinsic.not(%valid_image)
        core.if %invalid_image {
          %message = core.call intrinsic.string.format("Validation failed: Expected '{}' to be type 'object ({{ mimeType: string; data: string }})'", %field_name)
          %error = core.call intrinsic.error.validation(%message)
          core.raise %error
        }
        core.return
      }
      %is_audio = core.call intrinsic.eq(%type_name, "audio")
      core.if %is_audio {
        %valid_audio = core.call intrinsic.media.valid_audio(%value)
        %invalid_audio = core.call intrinsic.not(%valid_audio)
        core.if %invalid_audio {
          %message = core.call intrinsic.string.format("Validation failed: Expected '{}' to be type 'string or object ({{ data: string; format?: string }})'", %field_name)
          %error = core.call intrinsic.error.validation(%message)
          core.raise %error
        }
        core.return
      }
      %is_file = core.call intrinsic.eq(%type_name, "file")
      core.if %is_file {
        %valid_file = core.call intrinsic.media.valid_file(%value)
        %invalid_file = core.call intrinsic.not(%valid_file)
        core.if %invalid_file {
          %message = core.call intrinsic.string.format("Validation failed: Expected '{}' to be type 'object ({{ mimeType: string; data: string }} | {{ mimeType: string; fileUri: string }})'", %field_name)
          %error = core.call intrinsic.error.validation(%message)
          core.raise %error
        }
        core.return
      }
      %is_url = core.call intrinsic.eq(%type_name, "url")
      core.if %is_url {
        %valid_url_shape = core.call intrinsic.media.valid_url_shape(%value)
        %invalid_url_shape = core.call intrinsic.not(%valid_url_shape)
        core.if %invalid_url_shape {
          %message = core.call intrinsic.string.format("Validation failed: Expected '{}' to be type 'string or object ({{ url: string; title?: string; description?: string }})'", %field_name)
          %error = core.call intrinsic.error.validation(%message)
          core.raise %error
        }
        %url_is_string = core.type_is %value type "string"
        core.if %url_is_string {
          %valid_url = core.call intrinsic.url.valid(%value)
          %invalid_url = core.call intrinsic.not(%valid_url)
          core.if %invalid_url {
            %field_title = core.get %field["title"]
            %message = core.call intrinsic.string.format("Invalid URL for '{}': Invalid URL format.", %field_title)
            %error = core.call intrinsic.error.validation(%message)
            core.raise %error
          }
        }
        core.return
      }
      %string_types = core.list
      core.append %string_types, "string"
      core.append %string_types, "code"
      core.append %string_types, "date"
      core.append %string_types, "datetime"
      core.append %string_types, "dateRange"
      core.append %string_types, "datetimeRange"
      %is_string_type = core.call intrinsic.contains(%string_types, %type_name)
      core.if %is_string_type {
        %is_string = core.type_is %value type "string"
        %not_string = core.call intrinsic.not(%is_string)
        core.if %not_string {
          %message = core.call intrinsic.string.format("Validation failed: Expected '{}' to be a {}", %field_name, %type_name)
          %error = core.call intrinsic.error.validation(%message)
          core.raise %error
        }
        core.call @validate_string_constraints_impl(%value, %field)
        core.return
      }
      %is_number_type = core.call intrinsic.eq(%type_name, "number")
      core.if %is_number_type {
        %is_number = core.type_is %value type "number"
        %not_number = core.call intrinsic.not(%is_number)
        core.if %not_number {
          %message = core.call intrinsic.string.format("Validation failed: Expected '{}' to be a number", %field_name)
          %error = core.call intrinsic.error.validation(%message)
          core.raise %error
        }
        core.call @validate_number_constraints_impl(%value, %field)
        core.return
      }
      %is_boolean_type = core.call intrinsic.eq(%type_name, "boolean")
      core.if %is_boolean_type {
        %is_boolean = core.type_is %value type "boolean"
        %not_boolean = core.call intrinsic.not(%is_boolean)
        core.if %not_boolean {
          %message = core.call intrinsic.string.format("Validation failed: Expected '{}' to be a boolean", %field_name)
          %error = core.call intrinsic.error.validation(%message)
          core.raise %error
        }
        core.return
      }
      %is_class_type = core.call intrinsic.eq(%type_name, "class")
      core.if %is_class_type {
        %is_class_string = core.type_is %value type "string"
        %not_class_string = core.call intrinsic.not(%is_class_string)
        core.if %not_class_string {
          %message = core.call intrinsic.string.format("Validation failed: Expected '{}' to be a class", %field_name)
          %error = core.call intrinsic.error.validation(%message)
          core.raise %error
        }
        %options = core.get %typ["options"]
        %has_options = core.call intrinsic.truthy(%options)
        core.if %has_options {
          %known_class = core.call intrinsic.contains(%options, %value)
          %unknown_class = core.call intrinsic.not(%known_class)
          core.if %unknown_class {
            %message = core.call intrinsic.string.format("{} must be one of {}", %path, %options)
            %error = core.call intrinsic.error.validation(%message)
            core.raise %error
          }
        }
        core.return
      }
      %is_json_type = core.call intrinsic.eq(%type_name, "json")
      core.if %is_json_type {
        %is_json = core.type_is %value type "json"
        %not_json = core.call intrinsic.not(%is_json)
        core.if %not_json {
          %message = core.call intrinsic.string.format("Validation failed: Expected '{}' to be JSON", %field_name)
          %error = core.call intrinsic.error.validation(%message)
          core.raise %error
        }
        core.return
      }
      %is_object_type = core.call intrinsic.eq(%type_name, "object")
      core.if %is_object_type {
        %is_object = core.type_is %value type "object"
        %not_object = core.call intrinsic.not(%is_object)
        core.if %not_object {
          %message = core.call intrinsic.string.format("{} must be an object", %path)
          %error = core.call intrinsic.error.validation(%message)
          core.raise %error
        }
        %nested_map = core.get %typ["fields"]
        %has_nested = core.call intrinsic.truthy(%nested_map)
        core.if %has_nested {
          %nested_fields = core.call intrinsic.fields.from_map(%nested_map)
          core.call @validate_fields_impl(%nested_fields, %value, %path)
        }
        core.return
      }
      core.return
    }
  }

  op ax.validate.semantic @strip_internal_fields_impl {
    attr core_kind = "func"
    attr emit_module = "schema"
    attr private = true
    tag "strip-internal-core-helper"
    type signature = "(list<Field>, json) -> json"
    body @entry(%fields: list<Field>, %values: json) {
      %public_values = core.map
      core.for %field in %fields {
        %is_internal = core.get %field["is_internal"] default false
        %is_public = core.call intrinsic.not(%is_internal)
        %field_name = core.get %field["name"]
        %has_value = core.call intrinsic.map.contains(%values, %field_name)
        %keep = core.call intrinsic.and(%is_public, %has_value)
        core.if %keep {
          %field_value = core.call intrinsic.map.get(%values, %field_name)
          core.set %public_values[%field_name] = %field_value
        }
      }
      core.return %public_values
    }
  }
}
