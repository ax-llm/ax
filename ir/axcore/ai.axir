                attr args = [%is_system, %is_user]
                attr callee = "intrinsic.or"
                attr result = %valid_left
              }
              op core.call {
                attr args = [%is_assistant, %is_function]
                attr callee = "intrinsic.or"
                attr result = %valid_right
              }
              op core.call {
                attr args = [%valid_left, %valid_right]
                attr callee = "intrinsic.or"
                attr result = %valid_role
              }
              op core.call {
                attr args = [%valid_role]
                attr callee = "intrinsic.not"
                attr result = %invalid_role
