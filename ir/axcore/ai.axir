  op ax.ai.semantic @normalize_stream_delta {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "ai"
    tag "src/ax/ai/openai/api.ts"
    type signature = "(json, json) -> AxChatResponse throws"
    body @entry(%raw: json, %state: json) {
      %response = core.call @openai_normalize_stream_delta(%raw, %state)
