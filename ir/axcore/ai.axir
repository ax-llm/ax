  op ax.ai.semantic @merge_model_config {
    attr core_kind = "func"
    attr emit_module = "ai"
    tag "src/ax/ai/base.ts"
    type signature = "(AxModelConfig, AxModelConfig?, AxAIServiceOptions?) -> AxModelConfig"
    body @entry(%base: json, %override: json, %options: json) {
      %merged = core.call intrinsic.map.merge(%base, %override)
      %has_stream_option = core.call intrinsic.map.contains(%options, "stream")
      core.if %has_stream_option {
        %stream = core.get %options["stream"]
        core.set %merged["stream"] = %stream
      }
      %out = core.map
      core.for %key in %merged {
        %value = core.get %merged[%key]
        %include = core.call intrinsic.is_not_none(%value)
        core.if %include {
          core.set %out[%key] = %value
        }
      }
      core.return %out
    }
  }

  op ax.ai.semantic @validate_chat_request {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "ai"
    tag "src/ax/ai/types.ts"
    type signature = "(AxChatRequest) -> void throws"
    body @entry(%request: AxChatRequest) {
      %realtime = core.get %request["realtime"]
      %has_realtime = core.call intrinsic.truthy(%realtime)
      core.if %has_realtime {
        %error = core.call intrinsic.ai.error.unsupported("OpenAI-compatible beta does not support realtime requests")
        core.raise %error
      }
      %prompt = core.get %request["chat_prompt"]
      %prompt_is_list = core.type_is %prompt type "list"
      %prompt_len = core.call intrinsic.len(%prompt)
      %prompt_empty = core.call intrinsic.eq(%prompt_len, 0)
      %prompt_not_list = core.call intrinsic.not(%prompt_is_list)
      %bad_prompt = core.call intrinsic.or(%prompt_not_list, %prompt_empty)
      core.if %bad_prompt {
        %error = core.call intrinsic.ai.error.response("Chat prompt is empty")
        core.raise %error
      }
      core.for %message in %prompt {
        %role = core.get %message["role"]
        %is_system = core.call intrinsic.eq(%role, "system")
        %is_user = core.call intrinsic.eq(%role, "user")
        %is_assistant = core.call intrinsic.eq(%role, "assistant")
        %is_function = core.call intrinsic.eq(%role, "function")
        %valid_left = core.call intrinsic.or(%is_system, %is_user)
        %valid_right = core.call intrinsic.or(%is_assistant, %is_function)
        %valid_role = core.call intrinsic.or(%valid_left, %valid_right)
        %invalid_role = core.call intrinsic.not(%valid_role)
        core.if %invalid_role {
          %message_text = core.call intrinsic.string.format("Invalid chat message role: {}", %role)
          %error = core.call intrinsic.ai.error.response(%message_text)
          core.raise %error
        }
        %content = core.get %message["content"]
        %function_calls = core.get %message["function_calls"]
        %has_content = core.call intrinsic.truthy(%content)
        %has_calls = core.call intrinsic.truthy(%function_calls)
        %has_assistant_payload = core.call intrinsic.or(%has_content, %has_calls)
        %missing_assistant_payload = core.call intrinsic.not(%has_assistant_payload)
        %bad_assistant = core.call intrinsic.and(%is_assistant, %missing_assistant_payload)
        core.if %bad_assistant {
          %error = core.call intrinsic.ai.error.response("Assistant content is required when no tool calls are provided")
          core.raise %error
        }
      }
      core.return
    }
  }

  op ax.ai.semantic @build_chat_request {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "ai"
    ref validate = @validate_chat_request
    type signature = "(AxAIService, AxChatRequest, AxAIServiceOptions?) -> json throws"
    body @entry(%service: AxAIService, %request: AxChatRequest, %options: json) {
      core.call @validate_chat_request(%request)
      %payload = core.call @openai_build_chat_request(%request)
      core.return %payload
    }
  }

  op ax.ai.semantic @normalize_chat_response {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "ai"
    tag "src/ax/ai/openai/api.ts"
    type signature = "(json) -> AxChatResponse throws"
    body @entry(%raw: json) {
      %response = core.call @openai_normalize_chat_response(%raw)
      core.return %response
