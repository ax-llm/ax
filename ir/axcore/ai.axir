  op ax.ai.semantic @normalize_embed_response {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "ai"
    tag "src/ax/ai/openai/api.ts"
    type signature = "(json) -> AxEmbedResponse throws"
    body @entry(%raw: json) {
      %response = core.call @openai_normalize_embed_response(%raw)
