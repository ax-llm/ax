    }
  }

  op ax.ai.semantic @normalize_token_usage {
    attr core_kind = "func"
    attr emit_module = "ai"
    tag "token-usage-core-helper"
    type signature = "(json) -> json"
    body @entry(%usage: json) {
      %out = core.map
      %input_tokens = core.get %usage["input_tokens"] default 0
      %prompt_tokens_snake = core.get %usage["prompt_tokens"] default %input_tokens
      %prompt_tokens = core.get %usage["promptTokens"] default %prompt_tokens_snake
      %output_tokens = core.get %usage["output_tokens"] default 0
      %completion_tokens_snake = core.get %usage["completion_tokens"] default %output_tokens
      %completion_tokens = core.get %usage["completionTokens"] default %completion_tokens_snake
      %computed_total_tokens = core.call intrinsic.add(%prompt_tokens, %completion_tokens)
      %total_tokens_snake = core.get %usage["total_tokens"] default %computed_total_tokens
      %total_tokens = core.get %usage["totalTokens"] default %total_tokens_snake
      core.set %out["prompt_tokens"] = %prompt_tokens
      core.set %out["completion_tokens"] = %completion_tokens
      core.set %out["total_tokens"] = %total_tokens
      %thoughts_tokens_snake = core.get %usage["thoughts_tokens"]
      %thoughts_tokens = core.get %usage["thoughtsTokens"] default %thoughts_tokens_snake
      %has_thoughts = core.call intrinsic.is_not_none(%thoughts_tokens)
      core.if %has_thoughts {
        core.set %out["thoughts_tokens"] = %thoughts_tokens
      }
      %reasoning_tokens_snake = core.get %usage["reasoning_tokens"]
      %reasoning_tokens = core.get %usage["reasoningTokens"] default %reasoning_tokens_snake
      %has_reasoning = core.call intrinsic.is_not_none(%reasoning_tokens)
      core.if %has_reasoning {
        core.set %out["reasoning_tokens"] = %reasoning_tokens
      }
      %cache_read_tokens_snake = core.get %usage["cache_read_tokens"]
      %cache_read_tokens = core.get %usage["cacheReadTokens"] default %cache_read_tokens_snake
      %has_cache_read = core.call intrinsic.is_not_none(%cache_read_tokens)
      core.if %has_cache_read {
        core.set %out["cache_read_tokens"] = %cache_read_tokens
      }
      %cache_creation_tokens_snake = core.get %usage["cache_creation_tokens"]
      %cache_creation_tokens = core.get %usage["cacheCreationTokens"] default %cache_creation_tokens_snake
      %has_cache_creation = core.call intrinsic.is_not_none(%cache_creation_tokens)
      core.if %has_cache_creation {
        core.set %out["cache_creation_tokens"] = %cache_creation_tokens
      }
      %service_tier_snake = core.get %usage["service_tier"]
      %service_tier = core.get %usage["serviceTier"] default %service_tier_snake
      %has_service_tier = core.call intrinsic.is_not_none(%service_tier)
      core.if %has_service_tier {
        core.set %out["service_tier"] = %service_tier
      }
      %speed = core.get %usage["speed"]
      %has_speed = core.call intrinsic.is_not_none(%speed)
      core.if %has_speed {
        core.set %out["speed"] = %speed
      }
      core.return %out
    }
  }

  op ax.ai.semantic @merge_usage_context {
    attr core_kind = "func"
    attr emit_module = "ai"
    tag "usage-context-core-helper"
    type signature = "(json?, json?) -> json"
    body @entry(%defaults: json, %overrides: json) {
      %merged = core.call intrinsic.map.merge(%defaults, %overrides)
      %default_attributes = core.get %defaults["attributes"]
      %override_attributes = core.get %overrides["attributes"]
      %attributes = core.call intrinsic.map.merge(%default_attributes, %override_attributes)
      %has_attributes = core.call intrinsic.truthy(%attributes)
      core.if %has_attributes {
        core.set %merged["attributes"] = %attributes
      }
      core.return %merged
    }
  }

  op ax.ai.semantic @build_usage_event {
    attr core_kind = "func"
    attr emit_module = "ai"
    tag "usage-event-core-helper"
    type signature = "(string, json, json?, bool) -> json"
    body @entry(%operation: string, %response: json, %options: json, %streaming: bool) {
      %model_usage_snake = core.get %response["model_usage"]
      %top_model_usage = core.get %response["modelUsage"] default %model_usage_snake
      %model_usage = core.let %top_model_usage
      %results = core.get %response["results"]
      core.for %result in %results {
        %result_usage_snake = core.get %result["model_usage"]
        %result_usage = core.get %result["modelUsage"] default %result_usage_snake
        %has_result_usage = core.call intrinsic.truthy(%result_usage)
        core.if %has_result_usage {
          %model_usage = core.let %result_usage
        }
      }
      %tokens = core.get %model_usage["tokens"]
      %has_tokens = core.call intrinsic.truthy(%tokens)
      %missing_tokens = core.call intrinsic.not(%has_tokens)
      core.if %missing_tokens {
        %none = core.call intrinsic.none()
        core.return %none
      }
      %event = core.map
      core.set %event["operation"] = %operation
      %ai_name = core.get %model_usage["ai"]
      %model = core.get %model_usage["model"]
      %normalized_tokens = core.call @normalize_token_usage(%tokens)
      core.set %event["ai"] = %ai_name
      core.set %event["model"] = %model
      core.set %event["tokens"] = %normalized_tokens
      core.set %event["streaming"] = %streaming
      %usage_context_snake = core.get %options["usage_context"]
      %usage_context = core.get %options["usageContext"] default %usage_context_snake
      %has_context = core.call intrinsic.truthy(%usage_context)
      core.if %has_context {
        core.set %event["context"] = %usage_context
      }
      %option_session_snake = core.get %options["session_id"]
      %option_session = core.get %options["sessionId"] default %option_session_snake
      %response_session_snake = core.get %response["session_id"]
      %response_session = core.get %response["sessionId"] default %response_session_snake
      %session_id = core.call intrinsic.coalesce(%response_session, %option_session)
      %has_session_id = core.call intrinsic.is_not_none(%session_id)
      core.if %has_session_id {
        core.set %event["sessionId"] = %session_id
      }
      %remote_id_snake = core.get %response["remote_id"]
      %remote_id = core.get %response["remoteId"] default %remote_id_snake
      %has_remote_id = core.call intrinsic.is_not_none(%remote_id)
      core.if %has_remote_id {
        core.set %event["remoteId"] = %remote_id
      }
      %remote_request_id_snake = core.get %response["remote_request_id"]
      %remote_request_id = core.get %response["remoteRequestId"] default %remote_request_id_snake
      %has_remote_request_id = core.call intrinsic.is_not_none(%remote_request_id)
      core.if %has_remote_request_id {
        core.set %event["remoteRequestId"] = %remote_request_id
      }
      %remote_session_id_snake = core.get %response["remote_session_id"]
      %remote_session_id = core.get %response["remoteSessionId"] default %remote_session_id_snake
      %has_remote_session_id = core.call intrinsic.is_not_none(%remote_session_id)
      core.if %has_remote_session_id {
        core.set %event["remoteSessionId"] = %remote_session_id
      }
      core.return %event
    }
  }

  op ax.ai.semantic @ai_model_usage_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "model-usage-core-helper"
    type signature = "(string, string, json) -> json"
    body @entry(%ai_name: string, %model: string, %usage: json) {
      %has_usage = core.call intrinsic.truthy(%usage)
      %missing_usage = core.call intrinsic.not(%has_usage)
      core.if %missing_usage {
        %none = core.call intrinsic.none()
        core.return %none
      }
      %tokens = core.call @normalize_token_usage(%usage)
      %out = core.map
      core.set %out["ai"] = %ai_name
      core.set %out["model"] = %model
      core.set %out["tokens"] = %tokens
      core.return %out
    }
  }

  op ax.ai.semantic @chat_response_to_completion {
    attr core_kind = "func"
    attr emit_module = "ai"
    tag "legacy-completion-compat"
    type signature = "(AxChatResponse) -> json"
    body @entry(%response: AxChatResponse) {
      %empty_results = core.list
      %results = core.get %response["results"] default %empty_results
      %empty_result = core.map
      %result = core.call intrinsic.list.get(%results, 0, %empty_result)
      %content = core.get %result["content"] default ""
      %calls = core.list
      %empty_calls = core.list
      %function_calls = core.get %result["function_calls"] default %empty_calls
      core.for %call in %function_calls {
        %fn = core.get %call["function"]
        %id = core.get %call["id"]
        %name = core.get %fn["name"]
        %params = core.get %fn["params"]
        %compat_call = core.map
        core.set %compat_call["id"] = %id
        core.set %compat_call["name"] = %name
        core.set %compat_call["params"] = %params
        core.append %calls, %compat_call
      }
      %model_usage = core.get %response["model_usage"]
      %usage = core.get %model_usage["tokens"]
      %out = core.map
      core.set %out["content"] = %content
      core.set %out["function_calls"] = %calls
      core.set %out["usage"] = %usage
      core.return %out
    }
  }

  op ax.ai.semantic @record_ai_metrics {
    attr core_kind = "func"
    tag "src/ax/ai/base.ts"
    type signature = "(AxAIService, kind:string, durationMs:f64, error?:json) -> void"
  }
}
