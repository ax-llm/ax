module @ax.stream version "0.1" {
  dialect @ax.stream version "0.1"

  op ax.stream.semantic @fold_stream {
    attr core_kind = "func"
    attr emit_module = "gen"
    tag "src/ax/dsp/response/streaming.ts"
    type signature = "(list<json>) -> string"
    body @entry(%events: list<json>) {
      %chunks = core.list
      core.for %event in %events {
        %parts = core.call @stream_event_content_parts_impl(%event)
        core.for %part in %parts {
          core.append %chunks, %part
        }
      }
      %folded = core.string_join %chunks sep ""
      core.return %folded
    }
  }

  op ax.stream.semantic @stream_event_content_parts_impl {
    attr core_kind = "func"
    attr emit_module = "gen"
    attr private = true
    tag "stream-event-content-parts-core-helper"
    type signature = "(json) -> list<string>"
    body @entry(%event: json) {
      %parts = core.call intrinsic.stream.event_content_parts(%event)
      core.return %parts
    }
  }
}
