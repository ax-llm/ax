  op ax.provider.semantic @openai_responses_content_part_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr effect = "throws"
    attr private = true
    tag "openai-responses-content-core-helper"
    type signature = "(json, string) -> json throws"
    body @entry(%part: json, %role: string) {
      %type = core.get %part["type"] default "text"
      %is_assistant = core.call intrinsic.eq(%role, "assistant")
      %is_text = core.call intrinsic.eq(%type, "text")
      core.if %is_text {
        %out = core.map
        %out_type = core.let "input_text"
        core.if %is_assistant {
          %out_type = core.let "output_text"
        } else {
        }
        core.set %out["type"] = %out_type
        %part_text = core.get %part["text"] default ""
        core.set %out["text"] = %part_text
        core.return %out
      } else {
      }
      %is_image = core.call intrinsic.eq(%type, "image")
      core.if %is_image {
        %mime_camel = core.get %part["mimeType"] default "image/png"
        %mime = core.get %part["mime_type"] default %mime_camel
        %part_data = core.get %part["data"]
        %data = core.get %part["image"] default %part_data
        %url = core.call intrinsic.string.format("data:{};base64,{}", %mime, %data)
        %details = core.get %part["details"] default "auto"
        %out = core.map
        core.set %out["type"] = "input_image"
        %image_url = core.map
        core.set %image_url["url"] = %url
        core.set %image_url["details"] = %details
        core.set %out["image_url"] = %image_url
        core.return %out
      } else {
      }
      %is_audio = core.call intrinsic.eq(%type, "audio")
      core.if %is_audio {
        %audio_alt = core.get %part["audio"]
        %data = core.get %part["data"] default %audio_alt
        %format = core.get %part["format"] default "wav"
        %out = core.map
        core.set %out["type"] = "input_audio"
        %input_audio = core.map
        core.set %input_audio["data"] = %data
        core.set %input_audio["format"] = %format
        core.set %out["input_audio"] = %input_audio
        core.return %out
      } else {
      }
      %message = core.call intrinsic.string.format("Unsupported Responses content part: {}", %type)
      %error = core.call intrinsic.ai.error.unsupported(%message)
      core.raise %error
    }
  }

  op ax.provider.semantic @openai_responses_normalize_chat_response {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr effect = "throws"
    tag "src/ax/ai/openai/responses_api.ts"
    type signature = "(json, string, string) -> AxChatResponse throws"
    body @entry(%raw: json, %ai_name: string, %model: string) {
      %empty_output = core.list
      %output = core.get %raw["output"] default %empty_output
      %result = core.map
      core.set %result["index"] = 0
      core.set %result["id"] = "0"
      core.set %result["content"] = ""
      %empty_function_calls = core.list
      core.set %result["function_calls"] = %empty_function_calls
      core.set %result["finish_reason"] = "stop"
      core.for %item in %output {
        core.call @openai_responses_merge_output_item_impl(%result, %item)
      }
      %results = core.list
      core.append %results, %result
      %raw_model = core.get %raw["model"] default %model
      %usage = core.get %raw["usage"]
      %model_usage = core.call @ai_model_usage_impl(%ai_name, %raw_model, %usage)
      %out = core.map
      core.set %out["results"] = %results
      %raw_id = core.get %raw["id"]
      core.set %out["remote_id"] = %raw_id
      core.set %out["model_usage"] = %model_usage
      core.return %out
    }
  }

  op ax.provider.semantic @openai_responses_merge_output_item_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "openai-responses-output-core-helper"
    type signature = "(json, json) -> void"
    body @entry(%result: json, %item: json) {
      %type = core.get %item["type"]
      %is_message = core.call intrinsic.eq(%type, "message")
      core.if %is_message {
        %item_id = core.get %item["id"] default "0"
        core.set %result["id"] = %item_id
        %empty_content = core.list
        %item_content = core.get %item["content"] default %empty_content
        %content = core.call @openai_responses_content_to_text_impl(%item_content)
        core.set %result["content"] = %content
        %citations = core.call @openai_responses_extract_citations_impl(%item_content)
        %has_citations = core.call intrinsic.truthy(%citations)
        core.if %has_citations {
          core.set %result["citations"] = %citations
        } else {
        }
      } else {
      }
      %is_function = core.call intrinsic.eq(%type, "function_call")
      core.if %is_function {
        %call = core.call @openai_responses_function_call_impl(%item)
        %calls = core.list
        core.append %calls, %call
        core.set %result["function_calls"] = %calls
        core.set %result["finish_reason"] = "function_call"
      } else {
      }
      core.return
    }
  }

  op ax.provider.semantic @openai_responses_content_to_text_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "openai-responses-output-core-helper"
    type signature = "(list<json>) -> string"
    body @entry(%content: list<json>) {
      %parts = core.list
      core.for %part in %content {
        %type = core.get %part["type"]
        %is_text = core.call intrinsic.eq(%type, "output_text")
        core.if %is_text {
          %text = core.get %part["text"] default ""
          core.append %parts, %text
        } else {
        }
        %is_refusal = core.call intrinsic.eq(%type, "refusal")
        core.if %is_refusal {
          %text = core.get %part["refusal"] default ""
          core.append %parts, %text
        } else {
        }
      }
      %out = core.call intrinsic.string.join("", %parts)
      core.return %out
    }
  }

  op ax.provider.semantic @openai_responses_extract_citations_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "openai-responses-citations-core-helper"
    type signature = "(list<json>) -> list<json>"
    body @entry(%content: list<json>) {
      %out = core.list
      core.for %part in %content {
        %empty_annotations = core.list
        %annotations = core.get %part["annotations"] default %empty_annotations
        core.for %annotation in %annotations {
          %url = core.get %annotation["url"]
          %has_url = core.call intrinsic.truthy(%url)
          core.if %has_url {
            %title = core.get %annotation["title"]
