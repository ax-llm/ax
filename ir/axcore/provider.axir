  op ax.provider.semantic @openai_responses_normalize_stream_delta {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr effect = "throws"
    tag "src/ax/ai/openai/responses_api.ts"
    type signature = "(json, json, string, string) -> AxChatResponse throws"
    body @entry(%event: json, %state: json, %ai_name: string, %model: string) {
      %type = core.get %event["type"]
      %empty_response = core.map
      %event_response = core.get %event["response"] default %empty_response
      %event_response_id = core.get %event_response["id"]
      %event_response_id_fallback = core.get %event["response_id"] default %event_response_id
      %remote_id = core.get %event["id"] default %event_response_id_fallback
      %has_remote = core.call intrinsic.truthy(%remote_id)
      core.if %has_remote {
        core.set %state["remote_id"] = %remote_id
      } else {
      }
      %stable_remote = core.get %state["remote_id"] default %remote_id
      %result = core.map
      core.set %result["index"] = 0
      %event_item_id = core.get %event["item_id"] default "0"
      core.set %result["id"] = %event_item_id
      core.set %result["content"] = ""
      %empty_calls = core.list
      core.set %result["function_calls"] = %empty_calls
      %none_finish = core.call intrinsic.none()
      core.set %result["finish_reason"] = %none_finish
      %is_text_delta = core.call intrinsic.eq(%type, "response.output_text.delta")
      core.if %is_text_delta {
        %text_delta = core.get %event["delta"] default ""
        core.set %result["content"] = %text_delta
      } else {
      }
      %is_output_added = core.call intrinsic.eq(%type, "response.output_item.added")
      core.if %is_output_added {
        %empty_item = core.map
        %item = core.get %event["item"] default %empty_item
        core.call @openai_responses_merge_output_item_impl(%result, %item)
      } else {
      }
      %is_args_delta = core.call intrinsic.eq(%type, "response.function_call_arguments.delta")
      core.if %is_args_delta {
        %event_call_id = core.get %event["call_id"] default "0"
        %call_id = core.get %event["item_id"] default %event_call_id
        %event_name = core.get %event["name"]
        %event_delta = core.get %event["delta"] default ""
        %function = core.map
        core.set %function["name"] = %event_name
        core.set %function["params"] = %event_delta
        %call = core.map
        core.set %call["id"] = %call_id
        core.set %call["type"] = "function"
        core.set %call["function"] = %function
        %calls = core.list
        core.append %calls, %call
        core.set %result["function_calls"] = %calls
        core.set %result["finish_reason"] = "function_call"
      } else {
      }
      %is_completed = core.call intrinsic.eq(%type, "response.completed")
      %usage = core.call intrinsic.none()
      core.if %is_completed {
        %usage = core.get %event_response["usage"]
        core.set %result["finish_reason"] = "stop"
      } else {
      }
      %results = core.list
      core.append %results, %result
      %raw_model = core.get %event_response["model"] default %model
      %model_usage = core.call @ai_model_usage_impl(%ai_name, %raw_model, %usage)
      %out = core.map
      core.set %out["results"] = %results
      core.set %out["remote_id"] = %stable_remote
      core.set %out["model_usage"] = %model_usage
      core.return %out
    }
  }

