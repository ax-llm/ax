        %input = core.get %block["input"] default ""
        core.set %function["name"] = %name
        core.set %function["params"] = %input
        %call = core.map
        %id = core.get %block["id"] default %name
        core.set %call["id"] = %id
        core.set %call["type"] = "function"
        core.set %call["function"] = %function
        core.append %function_calls, %call
      } else {
      }
      %is_thinking = core.call intrinsic.eq(%type, "thinking")
      core.if %is_thinking {
        %thinking = core.get %block["thinking"] default ""
        core.append %thought_parts, %thinking
        %thought_block = core.map
        core.set %thought_block["data"] = %thinking
        core.set %thought_block["encrypted"] = false
        %signature = core.get %block["signature"]
        %has_signature = core.call intrinsic.is_not_none(%signature)
        core.if %has_signature {
          core.set %thought_block["signature"] = %signature
        } else {
        }
        core.append %thought_blocks, %thought_block
      } else {
      }
      %is_redacted = core.call intrinsic.eq(%type, "redacted_thinking")
      core.if %is_redacted {
        %data = core.get %block["data"]
        %data_alt = core.get %block["thinking"] default %data
        core.append %thought_parts, %data_alt
        %thought_block = core.map
        core.set %thought_block["data"] = %data_alt
        core.set %thought_block["encrypted"] = true
        %signature = core.get %block["signature"]
        %has_signature = core.call intrinsic.is_not_none(%signature)
        core.if %has_signature {
          core.set %thought_block["signature"] = %signature
        } else {
        }
        core.append %thought_blocks, %thought_block
      } else {
      }
      core.return
    }
  }

