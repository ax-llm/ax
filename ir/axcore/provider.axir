      } else {
      }
      %is_mistral = core.call intrinsic.eq(%profile, "mistral")
      core.if %is_mistral {
        %payload = core.call @provider_apply_mistral_chat_quirks(%payload)
      } else {
      }
      %is_grok = core.call intrinsic.eq(%profile, "grok")
      core.if %is_grok {
        %payload = core.call @provider_apply_grok_chat_quirks(%payload, %request, %model_config)
      } else {
      }
      core.return %payload
    }
  }

  op ax.provider.semantic @provider_apply_deepseek_chat_quirks {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "deepseek-openai-compatible-quirks"
    type signature = "(payload:json, model_config:json) -> json"
    body @entry(%payload: json, %model_config: json) {
      %model = core.get %payload["model"] default ""
      %is_flash = core.call intrinsic.eq(%model, "deepseek-v4-flash")
      %is_pro = core.call intrinsic.eq(%model, "deepseek-v4-pro")
      %supports_thinking = core.call intrinsic.or(%is_flash, %is_pro)
      %is_reasoner = core.call intrinsic.eq(%model, "deepseek-reasoner")
      %unsupported_tool_choice_left = core.call intrinsic.or(%supports_thinking, %is_reasoner)
      core.if %supports_thinking {
        %budget_snake = core.get %model_config["thinking_token_budget"]
        %budget = core.get %model_config["thinkingTokenBudget"] default %budget_snake
        %reasoning = core.get %payload["reasoning_effort"]
        %has_budget = core.call intrinsic.is_not_none(%budget)
        %has_reasoning = core.call intrinsic.is_not_none(%reasoning)
        %has_thinking_signal = core.call intrinsic.or(%has_budget, %has_reasoning)
        %budget_is_none = core.call intrinsic.eq(%budget, "none")
        %reasoning_is_none = core.call intrinsic.eq(%reasoning, "none")
        %disabled_signal = core.call intrinsic.or(%budget_is_none, %reasoning_is_none)
        %not_disabled_signal = core.call intrinsic.not(%disabled_signal)
        %thinking_enabled = core.call intrinsic.and(%has_thinking_signal, %not_disabled_signal)
        %thinking = core.map
        core.if %thinking_enabled {
          core.set %thinking["type"] = "enabled"
          %is_xhigh = core.call intrinsic.eq(%reasoning, "xhigh")
          %budget_is_highest = core.call intrinsic.eq(%budget, "highest")
          %is_max_effort = core.call intrinsic.or(%is_xhigh, %budget_is_highest)
          core.if %is_max_effort {
            core.set %payload["reasoning_effort"] = "max"
          } else {
            %is_high = core.call intrinsic.eq(%reasoning, "high")
            core.if %is_high {
              core.set %payload["reasoning_effort"] = "high"
            } else {
              core.set %payload["reasoning_effort"] = "high"
            }
          }
          core.call intrinsic.map.delete(%payload, "temperature")
          core.call intrinsic.map.delete(%payload, "top_p")
          core.call intrinsic.map.delete(%payload, "presence_penalty")
          core.call intrinsic.map.delete(%payload, "frequency_penalty")
        } else {
          core.set %thinking["type"] = "disabled"
          core.call intrinsic.map.delete(%payload, "reasoning_effort")
        }
        core.set %payload["thinking"] = %thinking
      } else {
      }
      core.if %unsupported_tool_choice_left {
        %tool_choice = core.get %payload["tool_choice"]
        %choice_none = core.call intrinsic.eq(%tool_choice, "none")
        core.if %choice_none {
          core.call intrinsic.map.delete(%payload, "tools")
        } else {
        }
        core.call intrinsic.map.delete(%payload, "tool_choice")
      } else {
      }
      core.return %payload
    }
  }

  op ax.provider.semantic @provider_apply_mistral_chat_quirks {
    attr core_kind = "func"
