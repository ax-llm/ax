      core.if %has_out {
      } else {
        %input = core.get %request["input"]
        %has_input = core.call intrinsic.is_not_none(%input)
        core.if %has_input {
          %message = core.map
          core.set %message["role"] = "user"
          core.set %message["content"] = %input
          core.append %out, %message
        } else {
        }
      }
      core.return %out
    }
  }

  op ax.provider.semantic @openai_realtime_content_parts_impl {
