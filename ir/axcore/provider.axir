  op ax.provider.semantic @openai_build_chat_request {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "ai"
    ref generic = @build_chat_request
    tag "src/ax/ai/openai/api.ts"
    type signature = "(AxChatRequest) -> json throws"
    body @entry(%request: AxChatRequest) {
      %payload = core.map
      %model = core.get %request["model"]
      core.set %payload["model"] = %model
      %messages = core.list
      %chat_prompt = core.get %request["chat_prompt"]
      core.for %message in %chat_prompt {
        %provider_message = core.call @openai_message_impl(%message)
        core.append %messages, %provider_message
      }
      core.set %payload["messages"] = %messages
      %empty_functions = core.list
      %functions = core.get %request["functions"] default %empty_functions
      %has_functions = core.call intrinsic.truthy(%functions)
      core.if %has_functions {
        %tools = core.list
        core.for %fn in %functions {
          %tool = core.call @openai_tool_spec_impl(%fn)
          core.append %tools, %tool
        }
        core.set %payload["tools"] = %tools
        %tool_choice = core.get %request["function_call"] default "auto"
        core.set %payload["tool_choice"] = %tool_choice
      }
      %response_format = core.get %request["response_format"]
      %has_response_format = core.call intrinsic.truthy(%response_format)
      core.if %has_response_format {
        %response_format_type = core.get %response_format["type"]
        %is_json_object = core.call intrinsic.eq(%response_format_type, "json_object")
        core.if %is_json_object {
          %json_mode_message = core.map
          core.set %json_mode_message["role"] = "system"
          core.set %json_mode_message["content"] = "JSON output is required. Return only the requested JSON object."
          core.append %messages, %json_mode_message
          core.set %payload["messages"] = %messages
        }
        %is_json_schema = core.call intrinsic.eq(%response_format_type, "json_schema")
        core.if %is_json_schema {
          %json_schema_format = core.map
          %schema = core.get %response_format["schema"]
          core.set %json_schema_format["type"] = "json_schema"
          core.set %json_schema_format["json_schema"] = %schema
          core.set %payload["response_format"] = %json_schema_format
        } else {
          core.set %payload["response_format"] = %response_format
        }
      }
      %model_config = core.get %request["model_config"]
      core.call @openai_apply_model_config_impl(%payload, %model_config)
      core.return %payload
    }
  }

  op ax.provider.semantic @openai_apply_model_config_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "openai-model-config-core-helper"
    type signature = "(json, json) -> void"
    body @entry(%payload: json, %model_config: json) {
      core.call @openai_copy_config_key_impl(%payload, %model_config, "max_tokens", "max_completion_tokens")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "maxTokens", "max_completion_tokens")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "temperature", "temperature")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "top_p", "top_p")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "topP", "top_p")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "n", "n")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "presence_penalty", "presence_penalty")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "presencePenalty", "presence_penalty")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "frequency_penalty", "frequency_penalty")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "frequencyPenalty", "frequency_penalty")
      %stop_snake = core.get %model_config["stop_sequences"]
      %stop = core.get %model_config["stopSequences"] default %stop_snake
      %has_stop = core.call intrinsic.truthy(%stop)
      core.if %has_stop {
        core.set %payload["stop"] = %stop
      }
      %stream = core.get %model_config["stream"]
      %is_stream = core.call intrinsic.truthy(%stream)
      core.if %is_stream {
        core.set %payload["stream"] = true
        %stream_options = core.map
        core.set %stream_options["include_usage"] = true
        core.set %payload["stream_options"] = %stream_options
      }
      core.return
    }
  }

  op ax.provider.semantic @openai_copy_config_key_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "openai-config-copy-core-helper"
    type signature = "(json, json, string, string) -> void"
    body @entry(%payload: json, %model_config: json, %source: string, %target: string) {
      %has_source = core.call intrinsic.map.contains(%model_config, %source)
      core.if %has_source {
        %value = core.get %model_config[%source]
        core.set %payload[%target] = %value
      }
      core.return
    }
  }

  op ax.provider.semantic @openai_message_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "openai-message-core-helper"
    type signature = "(json) -> json throws"
    body @entry(%message: json) {
      %role = core.get %message["role"]
      %content = core.get %message["content"] default ""
      %is_system = core.call intrinsic.eq(%role, "system")
      core.if %is_system {
        %out = core.map
        core.set %out["role"] = "system"
        core.set %out["content"] = %content
        core.return %out
      }
      %is_user = core.call intrinsic.eq(%role, "user")
      core.if %is_user {
        %content_is_list = core.type_is %content type "list"
        core.if %content_is_list {
          %parts = core.list
          core.for %part in %content {
            %provider_part = core.call @openai_content_part_impl(%part)
            core.append %parts, %provider_part
          }
          %content = core.let %parts
        }
        %out = core.map
        core.set %out["role"] = "user"
        core.set %out["content"] = %content
        %name = core.get %message["name"]
        %has_name = core.call intrinsic.truthy(%name)
        core.if %has_name {
          core.set %out["name"] = %name
        }
        core.return %out
      }
      %is_assistant = core.call intrinsic.eq(%role, "assistant")
      core.if %is_assistant {
        %empty_calls = core.list
        %calls_snake = core.get %message["function_calls"] default %empty_calls
        %calls = core.get %message["functionCalls"] default %calls_snake
        %has_calls = core.call intrinsic.truthy(%calls)
        %out = core.map
        core.set %out["role"] = "assistant"
        core.if %has_calls {
          %assistant_content = core.get %message["content"]
          %has_assistant_content = core.call intrinsic.is_not_none(%assistant_content)
          core.if %has_assistant_content {
            core.set %out["content"] = %assistant_content
          }
          %tool_calls = core.list
          core.for %call in %calls {
            %provider_call = core.call @openai_tool_call_to_provider_impl(%call)
            core.append %tool_calls, %provider_call
          }
          core.set %out["tool_calls"] = %tool_calls
        } else {
          core.set %out["content"] = %content
        }
        core.return %out
      }
      %is_function = core.call intrinsic.eq(%role, "function")
      core.if %is_function {
        %out = core.map
        %result = core.get %message["result"] default ""
        %function_id_snake = core.get %message["function_id"]
        %function_id = core.get %message["functionId"] default %function_id_snake
        core.set %out["role"] = "tool"
        core.set %out["content"] = %result
        core.set %out["tool_call_id"] = %function_id
        core.return %out
      }
      %message_text = core.call intrinsic.string.format("Invalid role: {}", %role)
      %error = core.call intrinsic.ai.error.response(%message_text)
      core.raise %error
    }
  }

  op ax.provider.semantic @openai_content_part_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "openai-content-part-core-helper"
    type signature = "(json) -> json throws"
    body @entry(%part: json) {
      %type = core.get %part["type"]
      %is_text = core.call intrinsic.eq(%type, "text")
      core.if %is_text {
        %text = core.get %part["text"] default ""
        %out = core.map
        core.set %out["type"] = "text"
        core.set %out["text"] = %text
        core.return %out
      }
      %is_image = core.call intrinsic.eq(%type, "image")
      core.if %is_image {
        %mime_snake = core.get %part["mime_type"]
        %mime_raw = core.get %part["mimeType"] default %mime_snake
        %mime = core.call intrinsic.coalesce(%mime_raw, "image/png")
        %image_value = core.get %part["image"]
        %image_raw = core.get %part["data"] default %image_value
        %image = core.call intrinsic.coalesce(%image_raw, "")
        %is_data_url = core.call intrinsic.string.starts_with(%image, "data:")
        %url = core.const ""
        core.if %is_data_url {
          %url = core.let %image
        } else {
          %url = core.call intrinsic.string.format("data:{};base64,{}", %mime, %image)
        }
        %details = core.get %part["details"] default "auto"
        %image_url = core.map
        core.set %image_url["url"] = %url
        core.set %image_url["detail"] = %details
        %out = core.map
        core.set %out["type"] = "image_url"
        core.set %out["image_url"] = %image_url
        core.return %out
      }
      %message = core.call intrinsic.string.format("OpenAI-compatible beta does not support content part type: {}", %type)
      %error = core.call intrinsic.ai.error.unsupported(%message)
      core.raise %error
    }
  }

  op ax.provider.semantic @openai_tool_call_to_provider_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "openai-tool-call-provider-core-helper"
    type signature = "(json) -> json"
    body @entry(%call: json) {
      %fn = core.get %call["function"]
      %params = core.get %fn["params"]
      %params_is_string = core.type_is %params type "string"
      core.if %params_is_string {
      } else {
        %params_json = core.call intrinsic.json.stringify(%params)
        %params = core.let %params_json
      }
      %id = core.get %call["id"]
      %name = core.get %fn["name"]
      %function = core.map
      core.set %function["name"] = %name
      core.set %function["arguments"] = %params
      %out = core.map
      core.set %out["id"] = %id
      core.set %out["type"] = "function"
      core.set %out["function"] = %function
      core.return %out
    }
  }

  op ax.provider.semantic @openai_tool_spec_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "openai-tool-spec-core-helper"
    type signature = "(json) -> json"
    body @entry(%fn: json) {
      %name = core.get %fn["name"]
      %description = core.get %fn["description"] default ""
      %parameters = core.get %fn["parameters"]
      %function = core.map
      core.set %function["name"] = %name
      core.set %function["description"] = %description
      %has_parameters = core.call intrinsic.truthy(%parameters)
      core.if %has_parameters {
        core.set %function["parameters"] = %parameters
      }
      %out = core.map
      core.set %out["type"] = "function"
      core.set %out["function"] = %function
      core.return %out
    }
  }

  op ax.provider.semantic @openai_build_embed_request {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "ai"
    ref generic = @build_embed_request
    tag "src/ax/ai/openai/api.ts"
    type signature = "(AxEmbedRequest) -> json throws"
    body @entry(%request: AxEmbedRequest) {
      %embed_model_snake = core.get %request["embed_model"]
      %model = core.get %request["embedModel"] default %embed_model_snake
      %empty_texts = core.list
      %texts = core.get %request["texts"] default %empty_texts
      %payload = core.map
      core.set %payload["model"] = %model
      core.set %payload["input"] = %texts
      %dimensions = core.get %request["dimensions"]
      %has_dimensions = core.call intrinsic.truthy(%dimensions)
      core.if %has_dimensions {
        core.set %payload["dimensions"] = %dimensions
      }
      core.return %payload
    }
  }

  op ax.provider.semantic @openai_normalize_chat_response {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "ai"
    ref generic = @normalize_chat_response
    tag "src/ax/ai/openai/api.ts"
    type signature = "(json, ai_name?:string, model?:string) -> AxChatResponse throws"
    body @entry(%raw: json, %ai_name: string, %model: string) {
      %raw_is_object = core.type_is %raw type "object"
      %raw_not_object = core.call intrinsic.not(%raw_is_object)
      core.if %raw_not_object {
        %error = core.call intrinsic.ai.error.response("provider response must be a JSON object", %raw)
        core.raise %error
      }
      %provider_error = core.get %raw["error"]
      %has_provider_error = core.call intrinsic.truthy(%provider_error)
      core.if %has_provider_error {
        %message = core.get %provider_error["message"] default "provider response error"
        %error = core.call intrinsic.ai.error.response(%message, %raw)
        core.raise %error
      }
      %choices = core.get %raw["choices"]
      %choices_is_list = core.type_is %choices type "list"
      %bad_choices = core.call intrinsic.not(%choices_is_list)
      core.if %bad_choices {
        %error = core.call intrinsic.ai.error.response("provider response missing choices", %raw)
        core.raise %error
      }
      %results = core.list
      core.for %choice in %choices {
        %result = core.call @openai_normalize_choice_impl(%choice, %raw)
        core.append %results, %result
      }
      %raw_model = core.get %raw["model"]
      %used_model = core.call intrinsic.coalesce(%raw_model, %model)
      %usage = core.get %raw["usage"]
      %model_usage = core.call @ai_model_usage_impl(%ai_name, %used_model, %usage)
      %remote_id = core.get %raw["id"]
      %out = core.map
      core.set %out["results"] = %results
      core.set %out["remote_id"] = %remote_id
      core.set %out["model_usage"] = %model_usage
      core.return %out
    }
  }

  op ax.provider.semantic @openai_normalize_choice_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "openai-choice-core-helper"
    type signature = "(json, json) -> json throws"
    body @entry(%choice: json, %raw: json) {
      %empty_message = core.map
      %message = core.get %choice["message"] default %empty_message
      %refusal = core.get %message["refusal"]
      %has_refusal = core.call intrinsic.truthy(%refusal)
      core.if %has_refusal {
        %error = core.call intrinsic.ai.error.refusal(%refusal, %raw)
        core.raise %error
      }
      %index = core.get %choice["index"] default 0
      %id = core.call intrinsic.string.str(%index)
      %content_raw = core.get %message["content"]
      %content = core.call intrinsic.none()
      %has_content = core.call intrinsic.truthy(%content_raw)
      core.if %has_content {
        %content = core.let %content_raw
      } else {
        %content = core.call intrinsic.none()
      }
      %empty_calls = core.list
      %tool_calls = core.get %message["tool_calls"] default %empty_calls
      %function_calls = core.call @openai_normalize_tool_calls_impl(%tool_calls)
      %finish_reason_raw = core.get %choice["finish_reason"]
      %finish_reason = core.call @openai_finish_reason_impl(%finish_reason_raw)
      %out = core.map
      core.set %out["index"] = %index
      core.set %out["id"] = %id
      core.set %out["content"] = %content
      core.set %out["function_calls"] = %function_calls
      core.set %out["finish_reason"] = %finish_reason
      core.return %out
    }
  }

  op ax.provider.semantic @openai_normalize_tool_calls_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "openai-tool-call-normalize-core-helper"
    type signature = "(list<json>) -> list<json>"
    body @entry(%calls: list<json>) {
      %out = core.list
      core.for %call in %calls {
        %fn = core.get %call["function"]
        %params = core.get %fn["arguments"]
        %params_is_string = core.type_is %params type "string"
        core.if %params_is_string {
          core.try {
            %parsed_params = core.call intrinsic.json.parse(%params)
            %params = core.let %parsed_params
          } catch %parse_error {
          }
        }
        %id = core.get %call["id"]
        %name = core.get %fn["name"]
        %function = core.map
        core.set %function["name"] = %name
        core.set %function["params"] = %params
        %normalized = core.map
        core.set %normalized["id"] = %id
        core.set %normalized["type"] = "function"
        core.set %normalized["function"] = %function
        core.append %out, %normalized
      }
      core.return %out
    }
  }

  op ax.provider.semantic @openai_finish_reason_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "openai-finish-reason-core-helper"
    type signature = "(json) -> json"
    body @entry(%value: json) {
      %is_stop = core.call intrinsic.eq(%value, "stop")
      core.if %is_stop {
        core.return "stop"
      }
      %is_length = core.call intrinsic.eq(%value, "length")
      core.if %is_length {
        core.return "length"
      }
      %is_content_filter = core.call intrinsic.eq(%value, "content_filter")
      core.if %is_content_filter {
        core.return "error"
      }
      %is_tool_calls = core.call intrinsic.eq(%value, "tool_calls")
      %is_function_call = core.call intrinsic.eq(%value, "function_call")
      %is_call = core.call intrinsic.or(%is_tool_calls, %is_function_call)
      core.if %is_call {
        core.return "function_call"
      }
      %none = core.call intrinsic.none()
      core.return %none
    }
  }

  op ax.provider.semantic @openai_normalize_embed_response {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "ai"
    ref generic = @normalize_embed_response
    tag "src/ax/ai/openai/api.ts"
    type signature = "(json, ai_name?:string, model?:string) -> AxEmbedResponse throws"
    body @entry(%raw: json, %ai_name: string, %model: string) {
      %embeddings = core.list
      %empty_data = core.list
      %data = core.get %raw["data"] default %empty_data
      core.for %item in %data {
        %embedding = core.get %item["embedding"]
        core.append %embeddings, %embedding
      }
      %raw_model = core.get %raw["model"]
      %used_model = core.call intrinsic.coalesce(%raw_model, %model)
      %usage = core.get %raw["usage"]
      %model_usage = core.call @ai_model_usage_impl(%ai_name, %used_model, %usage)
      %remote_id = core.get %raw["id"]
      %out = core.map
      core.set %out["embeddings"] = %embeddings
      core.set %out["remote_id"] = %remote_id
      core.set %out["model_usage"] = %model_usage
      core.return %out
    }
  }

  op ax.provider.semantic @openai_normalize_stream_delta {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "ai"
    ref generic = @normalize_stream_delta
    tag "src/ax/ai/openai/api.ts"
    type signature = "(json, json, ai_name?:string, model?:string) -> AxChatResponse throws"
    body @entry(%raw: json, %state: json, %ai_name: string, %model: string) {
      %raw_is_object = core.type_is %raw type "object"
      %raw_not_object = core.call intrinsic.not(%raw_is_object)
      core.if %raw_not_object {
        %error = core.call intrinsic.ai.error.stream("provider stream event must be a JSON object", %raw, true)
        core.raise %error
      }
      %provider_error = core.get %raw["error"]
      %has_provider_error = core.call intrinsic.truthy(%provider_error)
      core.if %has_provider_error {
        %message = core.get %provider_error["message"] default "provider stream error"
        %error = core.call intrinsic.ai.error.stream(%message, %raw, true)
        core.raise %error
      }
      %index_ids = core.get %state["index_ids"]
      %missing_index_ids = core.call intrinsic.is_none(%index_ids)
      core.if %missing_index_ids {
        %new_index_ids = core.map
        core.set %state["index_ids"] = %new_index_ids
        %index_ids = core.let %new_index_ids
      }
      %raw_remote_id = core.get %raw["id"]
      %has_raw_remote_id = core.call intrinsic.truthy(%raw_remote_id)
      core.if %has_raw_remote_id {
        core.set %state["remote_id"] = %raw_remote_id
      }
      %remote_id = core.get %state["remote_id"] default %raw_remote_id
      %results = core.list
      %empty_choices = core.list
      %choices = core.get %raw["choices"] default %empty_choices
      core.for %choice in %choices {
        %result = core.call @openai_stream_choice_impl(%choice, %index_ids)
        core.append %results, %result
      }
      %raw_model = core.get %raw["model"]
      %used_model = core.call intrinsic.coalesce(%raw_model, %model)
      %usage = core.get %raw["usage"]
      %model_usage = core.call @ai_model_usage_impl(%ai_name, %used_model, %usage)
      %out = core.map
      core.set %out["results"] = %results
      core.set %out["remote_id"] = %remote_id
      core.set %out["model_usage"] = %model_usage
      core.return %out
    }
  }

  op ax.provider.semantic @openai_stream_choice_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "openai-stream-choice-core-helper"
    type signature = "(json, json) -> json"
    body @entry(%choice: json, %index_ids: json) {
      %empty_delta = core.map
      %delta = core.get %choice["delta"] default %empty_delta
      %calls = core.list
      %empty_tool_calls = core.list
      %tool_calls = core.get %delta["tool_calls"] default %empty_tool_calls
      core.for %call in %tool_calls {
        %call_index = core.get %call["index"] default 0
        %call_id = core.get %call["id"]
        %has_call_id = core.call intrinsic.truthy(%call_id)
        core.if %has_call_id {
          core.set %index_ids[%call_index] = %call_id
        }
        %stable_id = core.get %index_ids[%call_index]
        %has_stable_id = core.call intrinsic.truthy(%stable_id)
        core.if %has_stable_id {
          %fn = core.get %call["function"]
          %name = core.get %fn["name"]
          %arguments = core.get %fn["arguments"]
          %function = core.map
          core.set %function["name"] = %name
          core.set %function["params"] = %arguments
          %normalized = core.map
          core.set %normalized["id"] = %stable_id
          core.set %normalized["type"] = "function"
          core.set %normalized["function"] = %function
          core.append %calls, %normalized
        }
      }
      %index = core.get %choice["index"] default 0
      %id = core.call intrinsic.string.str(%index)
      %content = core.get %delta["content"]
      %finish_reason_raw = core.get %choice["finish_reason"]
      %finish_reason = core.call @openai_finish_reason_impl(%finish_reason_raw)
      %out = core.map
      core.set %out["index"] = %index
      core.set %out["id"] = %id
      core.set %out["content"] = %content
      core.set %out["function_calls"] = %calls
      core.set %out["finish_reason"] = %finish_reason
      core.return %out
    }
  }

  op ax.provider.semantic @openai_normalize_error {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "ai"
    tag "src/ax/util/apicall.ts"
    type signature = "(i64, json, request?:json) -> AxAIServiceError throws"
    body @entry(%status: i64, %body: json, %request: json) {
      %message = core.let %body
      %code = core.call intrinsic.none()
      %body_is_object = core.type_is %body type "object"
      core.if %body_is_object {
        %error_body = core.get %body["error"] default %body
        %error_is_object = core.type_is %error_body type "object"
        core.if %error_is_object {
          %body_text = core.call intrinsic.string.str(%body)
          %message_value = core.get %error_body["message"] default %body_text
          %code_value = core.get %error_body["code"]
          %message = core.let %message_value
          %code = core.let %code_value
        } else {
          %message_value = core.call intrinsic.string.str(%error_body)
          %message = core.let %message_value
        }
      }
      %is_401 = core.call intrinsic.eq(%status, 401)
      %is_403 = core.call intrinsic.eq(%status, 403)
      %is_auth = core.call intrinsic.or(%is_401, %is_403)
      core.if %is_auth {
        %error = core.call intrinsic.ai.error.auth(%message, %status, %code, %body, %request)
        core.return %error
      }
      %is_408 = core.call intrinsic.eq(%status, 408)
      %is_504 = core.call intrinsic.eq(%status, 504)
      %is_timeout = core.call intrinsic.or(%is_408, %is_504)
      core.if %is_timeout {
        %error = core.call intrinsic.ai.error.timeout(%message, %status, %code, %body, %request, true)
        core.return %error
      }
      %is_429 = core.call intrinsic.eq(%status, 429)
      %is_500 = core.call intrinsic.eq(%status, 500)
      %is_502 = core.call intrinsic.eq(%status, 502)
      %is_503 = core.call intrinsic.eq(%status, 503)
      %retry_left = core.call intrinsic.or(%is_429, %is_500)
      %retry_right = core.call intrinsic.or(%is_502, %is_503)
      %retry_some = core.call intrinsic.or(%retry_left, %retry_right)
      %retryable = core.call intrinsic.or(%retry_some, %is_504)
      %error = core.call intrinsic.ai.error.status(%message, %status, %code, %body, %request, %retryable)
      core.return %error
    }
  }

