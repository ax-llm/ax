  op ax.provider.semantic @provider_build_chat_request {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr effect = "throws"
    tag "provider-operation-dispatch"
    type signature = "(profile:string, AxChatRequest) -> json throws"
    body @entry(%profile: string, %request: AxChatRequest) {
      %provider_id = core.call @provider_normalize_profile(%profile)
      %is_responses = core.call intrinsic.eq(%provider_id, "openai-responses")
      %is_gemini = core.call intrinsic.eq(%provider_id, "google-gemini")
      %is_anthropic = core.call intrinsic.eq(%provider_id, "anthropic")
      %payload = core.map
      core.if %is_responses {
        %responses_payload = core.call @openai_responses_build_chat_request(%request)
        %payload = core.let %responses_payload
      } else {
        core.if %is_gemini {
          %gemini_payload = core.call @gemini_build_chat_request(%request)
          %payload = core.let %gemini_payload
        } else {
          core.if %is_anthropic {
            %anthropic_payload = core.call @anthropic_build_chat_request(%request)
            %payload = core.let %anthropic_payload
          } else {
            %compatible_payload = core.call @openai_build_chat_request(%request)
            %payload = core.let %compatible_payload
          }
        }
      }
      %payload_with_quirks = core.call @provider_apply_openai_compatible_profile_quirks(%provider_id, %payload, %request)
      %payload = core.let %payload_with_quirks
      core.return %payload
    }
  }

  op ax.provider.semantic @provider_apply_openai_compatible_profile_quirks {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "provider-operation-dispatch"
    type signature = "(profile:string, payload:json, request:json) -> json"
    body @entry(%profile: string, %payload: json, %request: json) {
