  op ax.provider.semantic @openai_realtime_compatible_build_setup {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "openai-compatible-realtime-audio-core-helper"
    type signature = "(descriptor:json, request:json) -> json"
    body @entry(%descriptor: json, %request: json) {
      %audio_descriptor = core.get %descriptor["audio"]
      %output_audio_descriptor = core.get %audio_descriptor["output"]
      %default_voice = core.get %output_audio_descriptor["defaultVoice"] default "alloy"
      %request_audio = core.get %request["audio"]
      %request_output_audio = core.get %request_audio["output"]
      %request_voice = core.get %request_output_audio["voice"] default %default_voice
      %voice_id = core.get %request_voice["id"] default %request_voice
      %output_rate = core.get %request_output_audio["sampleRate"]
      %output_rate_snake = core.get %request_output_audio["sample_rate"] default %output_rate
      %default_output_rate = core.get %output_audio_descriptor["sampleRate"] default 24000
      %output_sample_rate = core.get %request_output_audio["rate"] default %output_rate_snake
      %has_output_sample_rate = core.call intrinsic.is_not_none(%output_sample_rate)
      core.if %has_output_sample_rate {
      } else {
        %output_sample_rate = core.let %default_output_rate
      }
      %input_audio_descriptor = core.get %audio_descriptor["input"]
      %request_input_audio = core.get %request_audio["input"]
      %input_rate = core.get %request_input_audio["sampleRate"]
      %input_rate_snake = core.get %request_input_audio["sample_rate"] default %input_rate
      %default_input_rate = core.get %input_audio_descriptor["sampleRate"] default 24000
      %input_sample_rate = core.get %request_input_audio["rate"] default %input_rate_snake
      %has_input_sample_rate = core.call intrinsic.is_not_none(%input_sample_rate)
      core.if %has_input_sample_rate {
      } else {
        %input_sample_rate = core.let %default_input_rate
      }
      %session = core.map
      core.set %session["voice"] = %voice_id
      %turn_detection_none = core.call intrinsic.none()
      core.set %session["turn_detection"] = %turn_detection_none
      %audio = core.map
      %input = core.map
      %input_format = core.map
      core.set %input_format["type"] = "audio/pcm"
      core.set %input_format["rate"] = %input_sample_rate
      core.set %input["format"] = %input_format
      core.set %audio["input"] = %input
      %output = core.map
      %output_format = core.map
      core.set %output_format["type"] = "audio/pcm"
      core.set %output_format["rate"] = %output_sample_rate
      core.set %output["format"] = %output_format
      core.set %audio["output"] = %output
      core.set %session["audio"] = %audio
      %modalities = core.call intrinsic.json.parse("[\"audio\"]")
      core.set %session["modalities"] = %modalities
      %instructions = core.call @realtime_request_system_instruction_impl(%request)
      %has_instructions = core.call intrinsic.truthy(%instructions)
      core.if %has_instructions {
        core.set %session["instructions"] = %instructions
      }
      %out = core.map
      core.set %out["type"] = "session.update"
      core.set %out["session"] = %session
      core.return %out
    }
  }

  op ax.provider.semantic @openai_realtime_compatible_build_input {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "openai-compatible-realtime-audio-core-helper"
    type signature = "(descriptor:json, request:json) -> list<json>"
    body @entry(%descriptor: json, %request: json) {
      %events = core.list
      %messages = core.call @realtime_request_user_messages_impl(%request)
      core.for %message in %messages {
        %content = core.get %message["content"] default ""
        %parts = core.call @openai_realtime_content_parts_impl(%content)
        %item = core.map
        core.set %item["type"] = "message"
        core.set %item["role"] = "user"
        core.set %item["content"] = %parts
        %event = core.map
        core.set %event["type"] = "conversation.item.create"
        core.set %event["item"] = %item
        core.append %events, %event
      }
      %response = core.map
      %response_modalities = core.call intrinsic.json.parse("[\"audio\"]")
      core.set %response["modalities"] = %response_modalities
      %response_event = core.map
      core.set %response_event["type"] = "response.create"
      core.set %response_event["response"] = %response
      core.append %events, %response_event
      core.return %events
    }
  }

  op ax.provider.semantic @gemini_live_bidi_build_setup {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "ai"
    attr private = true
    tag "gemini-live-bidi-realtime-audio-core-helper"
    type signature = "(descriptor:json, request:json) -> json throws"
    body @entry(%descriptor: json, %request: json) {
      %response_format = core.get %request["response_format"]
      %has_response_format = core.call intrinsic.truthy(%response_format)
      core.if %has_response_format {
        %error = core.call intrinsic.ai.error.unsupported("Gemini Live audio does not support structured response formats")
        core.raise %error
      }
      %default_model = core.get %descriptor["defaultModel"] default "gemini-2.5-flash-native-audio-preview-12-2025"
      %request_model = core.get %request["model"] default %default_model
      %model_prefix = core.call intrinsic.contains(%request_model, "models/")
      %model = core.let %request_model
      core.if %model_prefix {
      } else {
        %model = core.call intrinsic.string.format("models/{}", %request_model)
      }
      %audio_descriptor = core.get %descriptor["audio"]
      %output_audio_descriptor = core.get %audio_descriptor["output"]
      %request_audio = core.get %request["audio"]
      %request_output_audio = core.get %request_audio["output"]
      %default_voice = core.get %output_audio_descriptor["defaultVoice"] default "Kore"
      %voice = core.get %request_output_audio["voice"] default %default_voice
      %voice_name = core.get %voice["name"] default %voice
      %setup = core.map
      core.set %setup["model"] = %model
      %generation_config = core.map
      %modalities = core.call intrinsic.json.parse("[\"AUDIO\"]")
      core.set %generation_config["responseModalities"] = %modalities
      %speech_config = core.map
      %voice_config = core.map
      %prebuilt_voice = core.map
      core.set %prebuilt_voice["voiceName"] = %voice_name
      core.set %voice_config["prebuiltVoiceConfig"] = %prebuilt_voice
      core.set %speech_config["voiceConfig"] = %voice_config
      core.set %generation_config["speechConfig"] = %speech_config
      core.set %setup["generationConfig"] = %generation_config
      %include_transcript = core.get %request_output_audio["transcript"] default true
      core.if %include_transcript {
        %transcript = core.map
        core.set %setup["outputAudioTranscription"] = %transcript
      }
      %instructions = core.call @realtime_request_system_instruction_impl(%request)
      %has_instructions = core.call intrinsic.truthy(%instructions)
      core.if %has_instructions {
        %part = core.map
        core.set %part["text"] = %instructions
        %parts = core.list
        core.append %parts, %part
        %system_instruction = core.map
        core.set %system_instruction["parts"] = %parts
        core.set %setup["systemInstruction"] = %system_instruction
      }
      %out = core.map
      core.set %out["setup"] = %setup
      core.return %out
    }
  }

  op ax.provider.semantic @gemini_live_bidi_build_input {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "ai"
    attr private = true
    tag "gemini-live-bidi-realtime-audio-core-helper"
    type signature = "(descriptor:json, request:json) -> list<json> throws"
    body @entry(%descriptor: json, %request: json) {
      %events = core.list
      %messages = core.call @realtime_request_user_messages_impl(%request)
      core.for %message in %messages {
        %content = core.get %message["content"] default ""
        %is_list = core.type_is %content type "list"
        %text_parts = core.list
        %audio_events = core.list
        core.if %is_list {
          core.for %part in %content {
            %part_type = core.get %part["type"] default "text"
            %is_text = core.call intrinsic.eq(%part_type, "text")
            core.if %is_text {
              %text_part = core.map
              %text = core.get %part["text"] default ""
              core.set %text_part["text"] = %text
              core.append %text_parts, %text_part
            }
            %is_audio = core.call intrinsic.eq(%part_type, "audio")
            core.if %is_audio {
              %format = core.get %part["format"] default "pcm16"
              %format_lower = core.call intrinsic.string.lower(%format)
              %is_pcm16 = core.call intrinsic.eq(%format_lower, "pcm16")
              %is_pcm = core.call intrinsic.eq(%format_lower, "pcm")
              %valid_pcm = core.call intrinsic.or(%is_pcm16, %is_pcm)
              core.if %valid_pcm {
              } else {
                %error = core.call intrinsic.ai.error.unsupported("Gemini Live audio input must be PCM")
                core.raise %error
              }
              %data = core.get %part["data"] default ""
              %sample_rate = core.get %part["sampleRate"]
              %sample_rate_snake = core.get %part["sample_rate"] default %sample_rate
              %sample_rate_final = core.let %sample_rate_snake
              %has_sample_rate = core.call intrinsic.is_not_none(%sample_rate_final)
              core.if %has_sample_rate {
              } else {
                %sample_rate_final = core.let 16000
              }
              %mime = core.call intrinsic.string.format("audio/pcm;rate={}", %sample_rate_final)
              %audio = core.map
              core.set %audio["data"] = %data
              core.set %audio["mimeType"] = %mime
              %realtime_input = core.map
              core.set %realtime_input["audio"] = %audio
              %audio_event = core.map
              core.set %audio_event["realtimeInput"] = %realtime_input
              core.append %audio_events, %audio_event
            }
          }
        } else {
          %text_part = core.map
          core.set %text_part["text"] = %content
          core.append %text_parts, %text_part
        }
        %text_count = core.call intrinsic.len(%text_parts)
        %has_text = core.call intrinsic.gt(%text_count, 0)
        core.if %has_text {
          %turn = core.map
          core.set %turn["role"] = "user"
          core.set %turn["parts"] = %text_parts
          %turns = core.list
          core.append %turns, %turn
          %client_content = core.map
          core.set %client_content["turns"] = %turns
          core.set %client_content["turnComplete"] = false
          %content_event = core.map
          core.set %content_event["clientContent"] = %client_content
          core.append %events, %content_event
        }
        core.for %audio_event in %audio_events {
          core.append %events, %audio_event
        }
      }
      %stream_end = core.map
      core.set %stream_end["audioStreamEnd"] = true
      %end_event = core.map
      core.set %end_event["realtimeInput"] = %stream_end
      core.append %events, %end_event
      core.return %events
    }
  }

  op ax.provider.semantic @realtime_request_system_instruction_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "provider-realtime-audio-core-helper"
    type signature = "(request:json) -> string"
    body @entry(%request: json) {
      %direct = core.get %request["instructions"]
      %has_direct = core.call intrinsic.truthy(%direct)
      core.if %has_direct {
        core.return %direct
      }
      %empty_prompt = core.list
      %prompt = core.get %request["chat_prompt"] default %empty_prompt
      %parts = core.list
      core.for %message in %prompt {
        %role = core.get %message["role"]
        %is_system = core.call intrinsic.eq(%role, "system")
        core.if %is_system {
          %content = core.get %message["content"] default ""
          core.append %parts, %content
        }
      }
      %out = core.call intrinsic.string.join("\n", %parts)
      core.return %out
    }
  }

  op ax.provider.semantic @realtime_request_user_messages_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "provider-realtime-audio-core-helper"
    type signature = "(request:json) -> list<json>"
    body @entry(%request: json) {
      %empty_prompt = core.list
      %prompt = core.get %request["chat_prompt"] default %empty_prompt
      %out = core.list
      core.for %message in %prompt {
        %role = core.get %message["role"]
        %is_user = core.call intrinsic.eq(%role, "user")
        core.if %is_user {
          core.append %out, %message
        }
      }
      %count = core.call intrinsic.len(%out)
      %has_out = core.call intrinsic.gt(%count, 0)
      core.if %has_out {
      } else {
        %input = core.get %request["input"]
        %has_input = core.call intrinsic.is_not_none(%input)
        core.if %has_input {
          %message = core.map
          core.set %message["role"] = "user"
          core.set %message["content"] = %input
          core.append %out, %message
        }
      }
      core.return %out
    }
  }

  op ax.provider.semantic @openai_realtime_content_parts_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "openai-compatible-realtime-audio-core-helper"
    type signature = "(content:json) -> list<json>"
    body @entry(%content: json) {
      %parts = core.list
      %is_list = core.type_is %content type "list"
      core.if %is_list {
        core.for %part in %content {
          %type = core.get %part["type"] default "text"
          %is_audio = core.call intrinsic.eq(%type, "audio")
          core.if %is_audio {
            %audio_part = core.map
            core.set %audio_part["type"] = "input_audio"
            %input_audio = core.map
            %data = core.get %part["data"] default ""
            core.set %input_audio["data"] = %data
            %format = core.get %part["format"] default "pcm16"
            core.set %input_audio["format"] = %format
            core.set %audio_part["input_audio"] = %input_audio
            core.append %parts, %audio_part
          } else {
            %text_part = core.map
            core.set %text_part["type"] = "input_text"
            %text = core.get %part["text"] default ""
            core.set %text_part["text"] = %text
            core.append %parts, %text_part
          }
        }
      } else {
        %part = core.map
        core.set %part["type"] = "input_text"
        core.set %part["text"] = %content
        core.append %parts, %part
      }
      core.return %parts
    }
  }

  op ax.provider.semantic @provider_build_chat_request {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "ai"
    tag "provider-operation-dispatch"
    type signature = "(profile:string, AxChatRequest) -> json throws"
    body @entry(%profile: string, %request: AxChatRequest) {
      %provider_id = core.call @provider_normalize_profile(%profile)
      %is_responses = core.call intrinsic.eq(%provider_id, "openai-responses")
      %is_gemini = core.call intrinsic.eq(%provider_id, "google-gemini")
      %is_anthropic = core.call intrinsic.eq(%provider_id, "anthropic")
      %payload = core.map
      core.if %is_responses {
        %responses_payload = core.call @openai_responses_build_chat_request(%request)
        %payload = core.let %responses_payload
      } else {
        core.if %is_gemini {
          %gemini_payload = core.call @gemini_build_chat_request(%request)
          %payload = core.let %gemini_payload
        } else {
          core.if %is_anthropic {
            %anthropic_payload = core.call @anthropic_build_chat_request(%request)
            %payload = core.let %anthropic_payload
          } else {
            %compatible_payload = core.call @openai_build_chat_request(%request)
            %payload = core.let %compatible_payload
          }
        }
      }
      %payload_with_quirks = core.call @provider_apply_openai_compatible_profile_quirks(%provider_id, %payload, %request)
      %payload = core.let %payload_with_quirks
      core.return %payload
    }
  }

  op ax.provider.semantic @provider_apply_openai_compatible_profile_quirks {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "provider-operation-dispatch"
    type signature = "(profile:string, payload:json, request:json) -> json"
    body @entry(%profile: string, %payload: json, %request: json) {
      %empty_map = core.map
      %model_config = core.get %request["model_config"] default %empty_map
      %is_deepseek = core.call intrinsic.eq(%profile, "deepseek")
      core.if %is_deepseek {
        %payload = core.call @provider_apply_deepseek_chat_quirks(%payload, %model_config)
      }
      %is_mistral = core.call intrinsic.eq(%profile, "mistral")
      core.if %is_mistral {
        %payload = core.call @provider_apply_mistral_chat_quirks(%payload)
      }
      %is_grok = core.call intrinsic.eq(%profile, "grok")
      core.if %is_grok {
        %payload = core.call @provider_apply_grok_chat_quirks(%payload, %request, %model_config)
      }
      core.return %payload
    }
  }

  op ax.provider.semantic @provider_apply_deepseek_chat_quirks {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "deepseek-openai-compatible-quirks"
    type signature = "(payload:json, model_config:json) -> json"
    body @entry(%payload: json, %model_config: json) {
      %model = core.get %payload["model"] default ""
      %is_flash = core.call intrinsic.eq(%model, "deepseek-v4-flash")
      %is_pro = core.call intrinsic.eq(%model, "deepseek-v4-pro")
      %supports_thinking = core.call intrinsic.or(%is_flash, %is_pro)
      %is_reasoner = core.call intrinsic.eq(%model, "deepseek-reasoner")
      %unsupported_tool_choice_left = core.call intrinsic.or(%supports_thinking, %is_reasoner)
      core.if %supports_thinking {
        %budget_snake = core.get %model_config["thinking_token_budget"]
        %budget = core.get %model_config["thinkingTokenBudget"] default %budget_snake
        %reasoning = core.get %payload["reasoning_effort"]
        %has_budget = core.call intrinsic.is_not_none(%budget)
        %has_reasoning = core.call intrinsic.is_not_none(%reasoning)
        %has_thinking_signal = core.call intrinsic.or(%has_budget, %has_reasoning)
        %budget_is_none = core.call intrinsic.eq(%budget, "none")
        %reasoning_is_none = core.call intrinsic.eq(%reasoning, "none")
        %disabled_signal = core.call intrinsic.or(%budget_is_none, %reasoning_is_none)
        %not_disabled_signal = core.call intrinsic.not(%disabled_signal)
        %thinking_enabled = core.call intrinsic.and(%has_thinking_signal, %not_disabled_signal)
        %thinking = core.map
        core.if %thinking_enabled {
          core.set %thinking["type"] = "enabled"
          %is_xhigh = core.call intrinsic.eq(%reasoning, "xhigh")
          %budget_is_highest = core.call intrinsic.eq(%budget, "highest")
          %is_max_effort = core.call intrinsic.or(%is_xhigh, %budget_is_highest)
          core.if %is_max_effort {
            core.set %payload["reasoning_effort"] = "max"
          } else {
            %is_high = core.call intrinsic.eq(%reasoning, "high")
            core.if %is_high {
              core.set %payload["reasoning_effort"] = "high"
            } else {
              core.set %payload["reasoning_effort"] = "high"
            }
          }
          core.call intrinsic.map.delete(%payload, "temperature")
          core.call intrinsic.map.delete(%payload, "top_p")
          core.call intrinsic.map.delete(%payload, "presence_penalty")
          core.call intrinsic.map.delete(%payload, "frequency_penalty")
        } else {
          core.set %thinking["type"] = "disabled"
          core.call intrinsic.map.delete(%payload, "reasoning_effort")
        }
        core.set %payload["thinking"] = %thinking
      }
      core.if %unsupported_tool_choice_left {
        %tool_choice = core.get %payload["tool_choice"]
        %choice_none = core.call intrinsic.eq(%tool_choice, "none")
        core.if %choice_none {
          core.call intrinsic.map.delete(%payload, "tools")
        }
        core.call intrinsic.map.delete(%payload, "tool_choice")
      }
      core.return %payload
    }
  }

  op ax.provider.semantic @provider_apply_mistral_chat_quirks {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "mistral-openai-compatible-quirks"
    type signature = "(payload:json) -> json"
    body @entry(%payload: json) {
      %max_completion = core.get %payload["max_completion_tokens"]
      %has_max_completion = core.call intrinsic.is_not_none(%max_completion)
      core.if %has_max_completion {
        core.set %payload["max_tokens"] = %max_completion
        core.call intrinsic.map.delete(%payload, "max_completion_tokens")
      }
      %empty_list = core.list
      %messages = core.get %payload["messages"] default %empty_list
      core.for %message in %messages {
        %content = core.get %message["content"]
        %content_is_list = core.type_is %content type "list"
        core.if %content_is_list {
          core.for %part in %content {
            %part_type = core.get %part["type"] default ""
            %is_image_url = core.call intrinsic.eq(%part_type, "image_url")
            core.if %is_image_url {
              %empty_image = core.map
              %image = core.get %part["image_url"] default %empty_image
              %url = core.get %image["url"]
              %next_image = core.map
              core.set %next_image["url"] = %url
              core.set %part["image_url"] = %next_image
            }
          }
        }
      }
      core.return %payload
    }
  }

  op ax.provider.semantic @provider_apply_grok_chat_quirks {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "grok-openai-compatible-quirks"
    type signature = "(payload:json, request:json, model_config:json) -> json"
    body @entry(%payload: json, %request: json, %model_config: json) {
      %model = core.get %payload["model"] default ""
      %is_grok43 = core.call intrinsic.eq(%model, "grok-4.3")
      %is_grok43_latest = core.call intrinsic.eq(%model, "grok-4.3-latest")
      %is_grok43_any = core.call intrinsic.or(%is_grok43, %is_grok43_latest)
      core.if %is_grok43_any {
        %budget_snake = core.get %model_config["thinking_token_budget"]
        %budget = core.get %model_config["thinkingTokenBudget"] default %budget_snake
        %has_budget = core.call intrinsic.is_not_none(%budget)
        core.if %has_budget {
          %is_none = core.call intrinsic.eq(%budget, "none")
          %is_minimal = core.call intrinsic.eq(%budget, "minimal")
          %is_low = core.call intrinsic.eq(%budget, "low")
          %is_medium = core.call intrinsic.eq(%budget, "medium")
          %is_high = core.call intrinsic.eq(%budget, "high")
          %is_highest = core.call intrinsic.eq(%budget, "highest")
          %lowish = core.call intrinsic.or(%is_minimal, %is_low)
          %highish = core.call intrinsic.or(%is_high, %is_highest)
          core.if %is_none {
            core.set %payload["reasoning_effort"] = "none"
          } else {
            core.if %lowish {
              core.set %payload["reasoning_effort"] = "low"
            } else {
              core.if %is_medium {
                core.set %payload["reasoning_effort"] = "medium"
              } else {
                core.if %highish {
                  core.set %payload["reasoning_effort"] = "high"
                }
              }
            }
          }
        }
        core.call intrinsic.map.delete(%payload, "presence_penalty")
        core.call intrinsic.map.delete(%payload, "frequency_penalty")
        core.call intrinsic.map.delete(%payload, "stop")
      } else {
        core.call intrinsic.map.delete(%payload, "reasoning_effort")
      }
      %empty_map = core.map
      %search_snake = core.get %request["search_parameters"]
      %search_camel = core.get %request["searchParameters"] default %search_snake
      %search_config_snake = core.get %model_config["search_parameters"] default %search_camel
      %search = core.get %model_config["searchParameters"] default %search_config_snake
      %has_search = core.call intrinsic.is_not_none(%search)
      core.if %has_search {
        %search_payload = core.map
        %mode = core.get %search["mode"]
        %return_citations = core.get %search["returnCitations"]
        %return_citations_snake = core.get %search["return_citations"] default %return_citations
        %from_date = core.get %search["fromDate"]
        %from_date_snake = core.get %search["from_date"] default %from_date
        %to_date = core.get %search["toDate"]
        %to_date_snake = core.get %search["to_date"] default %to_date
        %max_results = core.get %search["maxSearchResults"]
        %max_results_snake = core.get %search["max_search_results"] default %max_results
        %sources = core.get %search["sources"]
        %has_mode = core.call intrinsic.is_not_none(%mode)
        core.if %has_mode {
          core.set %search_payload["mode"] = %mode
        }
        %has_return_citations = core.call intrinsic.is_not_none(%return_citations_snake)
        core.if %has_return_citations {
          core.set %search_payload["return_citations"] = %return_citations_snake
        }
        %has_from_date = core.call intrinsic.is_not_none(%from_date_snake)
        core.if %has_from_date {
          core.set %search_payload["from_date"] = %from_date_snake
        }
        %has_to_date = core.call intrinsic.is_not_none(%to_date_snake)
        core.if %has_to_date {
          core.set %search_payload["to_date"] = %to_date_snake
        }
        %has_max_results = core.call intrinsic.is_not_none(%max_results_snake)
        core.if %has_max_results {
          core.set %search_payload["max_search_results"] = %max_results_snake
        }
        core.if %sources {
          %mapped_sources = core.list
          core.for %source in %sources {
            %mapped_source = core.map
            %source_type = core.get %source["type"]
            %source_country = core.get %source["country"]
            %excluded_websites_camel = core.get %source["excludedWebsites"]
            %excluded_websites = core.get %source["excluded_websites"] default %excluded_websites_camel
            %allowed_websites_camel = core.get %source["allowedWebsites"]
            %allowed_websites = core.get %source["allowed_websites"] default %allowed_websites_camel
            %safe_search_camel = core.get %source["safeSearch"]
            %safe_search = core.get %source["safe_search"] default %safe_search_camel
            %x_handles_camel = core.get %source["xHandles"]
            %x_handles = core.get %source["x_handles"] default %x_handles_camel
            %links = core.get %source["links"]
            %has_source_type = core.call intrinsic.is_not_none(%source_type)
            core.if %has_source_type {
              core.set %mapped_source["type"] = %source_type
            }
            %has_source_country = core.call intrinsic.is_not_none(%source_country)
            core.if %has_source_country {
              core.set %mapped_source["country"] = %source_country
            }
            %has_excluded_websites = core.call intrinsic.is_not_none(%excluded_websites)
            core.if %has_excluded_websites {
              core.set %mapped_source["excluded_websites"] = %excluded_websites
            }
            %has_allowed_websites = core.call intrinsic.is_not_none(%allowed_websites)
            core.if %has_allowed_websites {
              core.set %mapped_source["allowed_websites"] = %allowed_websites
            }
            %has_safe_search = core.call intrinsic.is_not_none(%safe_search)
            core.if %has_safe_search {
              core.set %mapped_source["safe_search"] = %safe_search
            }
            %has_x_handles = core.call intrinsic.is_not_none(%x_handles)
            core.if %has_x_handles {
              core.set %mapped_source["x_handles"] = %x_handles
            }
            %has_links = core.call intrinsic.is_not_none(%links)
            core.if %has_links {
              core.set %mapped_source["links"] = %links
            }
            core.append %mapped_sources, %mapped_source
          }
          core.set %search_payload["sources"] = %mapped_sources
        }
        core.set %payload["search_parameters"] = %search_payload
      }
      core.return %payload
    }
  }

  op ax.provider.semantic @provider_build_embed_request {
    attr core_kind = "func"
    attr emit_module = "ai"
    tag "provider-operation-dispatch"
    type signature = "(profile:string, AxEmbedRequest) -> json throws"
    body @entry(%profile: string, %request: AxEmbedRequest) {
      %provider_id = core.call @provider_normalize_profile(%profile)
      %is_gemini = core.call intrinsic.eq(%provider_id, "google-gemini")
      %is_anthropic = core.call intrinsic.eq(%provider_id, "anthropic")
      %payload = core.map
      core.if %is_gemini {
        %gemini_payload = core.call @gemini_build_embed_request(%request)
        %payload = core.let %gemini_payload
      } else {
        core.if %is_anthropic {
          %error = core.call intrinsic.ai.error.unsupported("embed is not supported by Anthropic provider")
          core.raise %error
        } else {
          %openai_payload = core.call @openai_build_embed_request(%request)
          %payload = core.let %openai_payload
        }
      }
      core.return %payload
    }
  }

  op ax.provider.semantic @provider_normalize_chat_response {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "ai"
    tag "provider-operation-dispatch"
    type signature = "(profile:string, json, string, string) -> AxChatResponse throws"
    body @entry(%profile: string, %raw: json, %ai_name: string, %model: string) {
      %provider_id = core.call @provider_normalize_profile(%profile)
      %is_responses = core.call intrinsic.eq(%provider_id, "openai-responses")
      %is_gemini = core.call intrinsic.eq(%provider_id, "google-gemini")
      %is_anthropic = core.call intrinsic.eq(%provider_id, "anthropic")
      %response = core.map
      core.if %is_responses {
        %responses_response = core.call @openai_responses_normalize_chat_response(%raw, %ai_name, %model)
        %response = core.let %responses_response
      } else {
        core.if %is_gemini {
          %gemini_response = core.call @gemini_normalize_chat_response(%raw, %ai_name, %model)
          %response = core.let %gemini_response
        } else {
          core.if %is_anthropic {
            %anthropic_response = core.call @anthropic_normalize_chat_response(%raw, %ai_name, %model)
            %response = core.let %anthropic_response
          } else {
            %compatible_response = core.call @openai_normalize_chat_response(%raw, %ai_name, %model)
            %response = core.let %compatible_response
          }
        }
      }
      core.return %response
    }
  }

