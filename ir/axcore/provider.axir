    body @entry(%event: json, %state: json, %ai_name: string, %model: string) {
      %type = core.get %event["type"]
      %is_error_event = core.call intrinsic.contains(%type, "error")
      core.if %is_error_event {
        %empty_error_payload = core.map
        %error_payload = core.get %event["error"] default %empty_error_payload
        %error_message = core.get %error_payload["message"] default "realtime audio provider error"
        %error = core.call intrinsic.ai.error.response(%error_message, %event)
        core.raise %error
      } else {
      }
      %result = core.map
      core.set %result["index"] = 0
      %realtime_response_id = core.get %event["response_id"]
      %realtime_item_id = core.get %event["item_id"] default %realtime_response_id
      %has_realtime_item_id = core.call intrinsic.is_not_none(%realtime_item_id)
      core.if %has_realtime_item_id {
      } else {
        %realtime_item_id = core.let "0"
      }
      core.set %result["id"] = %realtime_item_id
      core.set %result["content"] = ""
      %realtime_empty_calls = core.list
      core.set %result["function_calls"] = %realtime_empty_calls
      %realtime_none_finish = core.call intrinsic.none()
      core.set %result["finish_reason"] = %realtime_none_finish
      %is_text = core.call intrinsic.eq(%type, "response.text.delta")
      %is_output_text = core.call intrinsic.eq(%type, "response.output_text.delta")
      %is_any_text = core.call intrinsic.or(%is_text, %is_output_text)
      %is_transcript = core.call intrinsic.eq(%type, "conversation.item.input_audio_transcription.delta")
      %is_output_transcript = core.call intrinsic.eq(%type, "response.output_audio_transcript.delta")
      %is_audio_transcript = core.call intrinsic.eq(%type, "response.audio_transcript.delta")
      %is_realtime_transcript = core.call intrinsic.or(%is_transcript, %is_output_transcript)
      %is_realtime_transcript = core.call intrinsic.or(%is_realtime_transcript, %is_audio_transcript)
      %is_audio = core.call intrinsic.eq(%type, "response.audio.delta")
      %is_output_audio = core.call intrinsic.eq(%type, "response.output_audio.delta")
      %is_any_audio = core.call intrinsic.or(%is_audio, %is_output_audio)
      core.if %is_any_text {
        %realtime_text_delta = core.get %event["delta"] default ""
        core.set %result["content"] = %realtime_text_delta
      } else {
      }
      core.if %is_realtime_transcript {
        %realtime_transcript_delta = core.get %event["delta"] default ""
        core.set %result["content"] = %realtime_transcript_delta
      } else {
      }
      core.if %is_any_audio {
        %audio_delta = core.get %event["delta"] default ""
        %audio = core.map
        core.set %audio["data"] = %audio_delta
        core.set %audio["format"] = "pcm16"
        core.set %audio["is_delta"] = true
        core.set %result["audio"] = %audio
      } else {
      }
      %is_done = core.call intrinsic.string.ends_with(%type, ".done")
      core.if %is_done {
        core.set %result["finish_reason"] = "stop"
      } else {
      }
      %realtime_empty_response = core.map
      %realtime_response = core.get %event["response"] default %realtime_empty_response
      %event_usage = core.get %event["usage"]
      %usage = core.get %realtime_response["usage"] default %event_usage
      %model_usage = core.call @ai_model_usage_impl(%ai_name, %model, %usage)
      %results = core.list
      core.append %results, %result
      %event_id = core.get %event["id"]
      %event_response_id = core.get %event["response_id"] default %event_id
      %remote_id = core.get %realtime_response["id"] default %event_response_id
      %out = core.map
      core.set %out["results"] = %results
      core.set %out["remote_id"] = %remote_id
      core.set %out["model_usage"] = %model_usage
      core.return %out
    }
  }

  op ax.provider.semantic @gemini_live_bidi_normalize_realtime_event {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr effect = "throws"
    attr private = true
    tag "gemini-live-bidi-realtime-audio-core-helper"
    type signature = "(json, json, string, string) -> AxChatResponse throws"
    body @entry(%event: json, %state: json, %ai_name: string, %model: string) {
      %error_payload = core.get %event["error"]
      %has_error = core.call intrinsic.is_not_none(%error_payload)
      core.if %has_error {
        %error_message = core.get %error_payload["message"] default "Gemini Live realtime audio provider error"
        %error = core.call intrinsic.ai.error.response(%error_message, %event)
        core.raise %error
      } else {
      }
      %result = core.map
      core.set %result["index"] = 0
      core.set %result["id"] = "0"
      core.set %result["content"] = ""
      %calls = core.list
      core.set %result["function_calls"] = %calls
      %none_finish = core.call intrinsic.none()
      core.set %result["finish_reason"] = %none_finish
      %text_parts = core.list
      %function_calls = core.list
      %empty_top_tool_call = core.map
      %top_tool_call = core.get %event["toolCall"] default %empty_top_tool_call
      %empty_top_function_calls = core.list
      %top_function_calls = core.get %top_tool_call["functionCalls"] default %empty_top_function_calls
      core.for %top_function_call in %top_function_calls {
        %top_part = core.map
        core.set %top_part["functionCall"] = %top_function_call
        core.call @gemini_merge_response_part_impl(%result, %text_parts, %function_calls, %top_part)
      }
      %empty_server = core.map
      %server = core.get %event["serverContent"] default %empty_server
      %output_transcription = core.get %server["outputTranscription"]
      %has_output_transcription = core.call intrinsic.is_not_none(%output_transcription)
      core.if %has_output_transcription {
        %transcript_text = core.get %output_transcription["text"] default ""
        core.append %text_parts, %transcript_text
      } else {
      }
      %input_transcription = core.get %server["inputTranscription"]
      %has_input_transcription = core.call intrinsic.is_not_none(%input_transcription)
      core.if %has_input_transcription {
        %input_text = core.get %input_transcription["text"] default ""
        core.append %text_parts, %input_text
      } else {
      }
      %empty_model_turn = core.map
      %model_turn = core.get %server["modelTurn"] default %empty_model_turn
      %empty_parts = core.list
      %parts = core.get %model_turn["parts"] default %empty_parts
      core.for %part in %parts {
        %inline_data = core.get %part["inlineData"]
        %has_inline_data = core.call intrinsic.is_not_none(%inline_data)
        core.if %has_inline_data {
          %mime = core.get %inline_data["mimeType"] default "audio/pcm"
          %data = core.get %inline_data["data"] default ""
          %audio = core.map
          core.set %audio["data"] = %data
          core.set %audio["mimeType"] = %mime
          core.set %audio["format"] = "pcm16"
          core.set %audio["sampleRate"] = 24000
          core.set %audio["is_delta"] = true
          core.set %result["audio"] = %audio
        } else {
          core.call @gemini_merge_response_part_impl(%result, %text_parts, %function_calls, %part)
        }
      }
      %content = core.call intrinsic.string.join("", %text_parts)
      core.set %result["content"] = %content
      %call_count = core.call intrinsic.len(%function_calls)
      %has_calls = core.call intrinsic.gt(%call_count, 0)
      core.if %has_calls {
        core.set %result["function_calls"] = %function_calls
        core.set %result["finish_reason"] = "function_call"
      } else {
      }
      %turn_complete = core.get %server["turnComplete"] default false
      core.if %turn_complete {
        core.set %result["finish_reason"] = "stop"
      } else {
      }
      %usage = core.get %event["usageMetadata"]
      %gemini_usage = core.call @gemini_usage_impl(%usage)
      %model_usage = core.call @ai_model_usage_impl(%ai_name, %model, %gemini_usage)
      %results = core.list
      core.append %results, %result
      %event_id = core.get %event["id"] default "gemini-live"
      %out = core.map
      core.set %out["results"] = %results
      core.set %out["remote_id"] = %event_id
      core.set %out["model_usage"] = %model_usage
      core.return %out
    }
  }

  op ax.provider.semantic @gemini_build_chat_request {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr effect = "throws"
    tag "src/ax/ai/google-gemini/api.ts"
    type signature = "(AxChatRequest) -> json throws"
    body @entry(%request: AxChatRequest) {
      %payload = core.map
      %empty_prompt = core.list
      %prompt = core.get %request["chat_prompt"] default %empty_prompt
      %system_parts = core.list
      %contents = core.list
      core.for %message in %prompt {
        %role = core.get %message["role"]
        %is_system = core.call intrinsic.eq(%role, "system")
        core.if %is_system {
          %system_text = core.get %message["content"] default ""
          core.append %system_parts, %system_text
        } else {
          %mapped = core.call @gemini_message_impl(%message)
          %has_mapped = core.call intrinsic.is_not_none(%mapped)
          core.if %has_mapped {
            core.append %contents, %mapped
          } else {
          }
        }
      }
      %system_count = core.call intrinsic.len(%system_parts)
      %has_system = core.call intrinsic.gt(%system_count, 0)
      core.if %has_system {
        %system_text_joined = core.call intrinsic.string.join(" ", %system_parts)
        %system_part = core.map
        core.set %system_part["text"] = %system_text_joined
        %system_part_list = core.list
        core.append %system_part_list, %system_part
        %system_instruction = core.map
        core.set %system_instruction["role"] = "user"
        core.set %system_instruction["parts"] = %system_part_list
        core.set %payload["systemInstruction"] = %system_instruction
      } else {
      }
      core.set %payload["contents"] = %contents
      %generation_config = core.map
      core.set %generation_config["candidateCount"] = 1
      core.set %generation_config["responseMimeType"] = "text/plain"
      %empty_model_config = core.map
      %model_config = core.get %request["model_config"] default %empty_model_config
      core.call @gemini_apply_model_config_impl(%generation_config, %model_config)
      %response_format = core.get %request["response_format"]
      %has_response_format = core.call intrinsic.truthy(%response_format)
      core.if %has_response_format {
        core.set %generation_config["responseMimeType"] = "application/json"
        %format_type = core.get %response_format["type"] default ""
        %is_json_schema = core.call intrinsic.eq(%format_type, "json_schema")
        core.if %is_json_schema {
          %schema_container = core.get %response_format["schema"]
          %schema = core.get %schema_container["schema"] default %schema_container
          core.set %generation_config["responseJsonSchema"] = %schema
        } else {
        }
      } else {
      }
      %model = core.get %request["model"] default "gemini-2.5-flash"
      %is_gemini3 = core.call intrinsic.string.starts_with(%model, "gemini-3")
      core.if %is_gemini3 {
        %temperature = core.get %generation_config["temperature"]
        %missing_temperature = core.call intrinsic.is_none(%temperature)
        core.if %missing_temperature {
          core.set %generation_config["temperature"] = 1
        } else {
          %too_low = core.call intrinsic.lt(%temperature, 1)
          core.if %too_low {
            core.set %generation_config["temperature"] = 1
          } else {
          }
        }
      } else {
      }
      core.set %payload["generationConfig"] = %generation_config
      %empty_functions = core.list
      %functions = core.get %request["functions"] default %empty_functions
      %has_functions = core.call intrinsic.truthy(%functions)
      core.if %has_functions {
        %function_declarations = core.list
        core.for %fn in %functions {
          %decl = core.call @gemini_function_declaration_impl(%fn)
          core.append %function_declarations, %decl
        }
        %tool = core.map
        core.set %tool["function_declarations"] = %function_declarations
        %tools = core.list
        core.append %tools, %tool
        core.set %payload["tools"] = %tools
        %tool_config = core.call @gemini_tool_config_impl(%request)
        core.set %payload["toolConfig"] = %tool_config
      } else {
      }
      core.return %payload
    }
  }

