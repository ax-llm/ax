      %is_message_delta = core.call intrinsic.eq(%type, "message_delta")
      core.if %is_message_delta {
        %delta = core.get %event["delta"]
        %stop = core.get %delta["stop_reason"]
        %is_refusal = core.call intrinsic.eq(%stop, "refusal")
