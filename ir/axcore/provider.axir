        %has_budget = core.call intrinsic.is_not_none(%budget)
        core.if %has_budget {
          %is_none = core.call intrinsic.eq(%budget, "none")
          %is_minimal = core.call intrinsic.eq(%budget, "minimal")
          %is_low = core.call intrinsic.eq(%budget, "low")
          %is_medium = core.call intrinsic.eq(%budget, "medium")
          %is_high = core.call intrinsic.eq(%budget, "high")
          %is_highest = core.call intrinsic.eq(%budget, "highest")
          %lowish = core.call intrinsic.or(%is_minimal, %is_low)
          %highish = core.call intrinsic.or(%is_high, %is_highest)
          core.if %is_none {
            core.set %payload["reasoning_effort"] = "none"
          } else {
            core.if %lowish {
              core.set %payload["reasoning_effort"] = "low"
            } else {
              core.if %is_medium {
                core.set %payload["reasoning_effort"] = "medium"
              } else {
                core.if %highish {
                  core.set %payload["reasoning_effort"] = "high"
                } else {
                }
              }
            }
          }
        } else {
        }
        core.call intrinsic.map.delete(%payload, "presence_penalty")
        core.call intrinsic.map.delete(%payload, "frequency_penalty")
        core.call intrinsic.map.delete(%payload, "stop")
      } else {
        core.call intrinsic.map.delete(%payload, "reasoning_effort")
      }
      %empty_map = core.map
      %search_snake = core.get %request["search_parameters"]
      %search_camel = core.get %request["searchParameters"] default %search_snake
      %search_config_snake = core.get %model_config["search_parameters"] default %search_camel
      %search = core.get %model_config["searchParameters"] default %search_config_snake
      %has_search = core.call intrinsic.is_not_none(%search)
      core.if %has_search {
        %search_payload = core.map
        %mode = core.get %search["mode"]
        %return_citations = core.get %search["returnCitations"]
        %return_citations_snake = core.get %search["return_citations"] default %return_citations
        %from_date = core.get %search["fromDate"]
        %from_date_snake = core.get %search["from_date"] default %from_date
        %to_date = core.get %search["toDate"]
        %to_date_snake = core.get %search["to_date"] default %to_date
        %max_results = core.get %search["maxSearchResults"]
        %max_results_snake = core.get %search["max_search_results"] default %max_results
        %sources = core.get %search["sources"]
        %has_mode = core.call intrinsic.is_not_none(%mode)
        core.if %has_mode {
          core.set %search_payload["mode"] = %mode
        } else {
        }
        %has_return_citations = core.call intrinsic.is_not_none(%return_citations_snake)
        core.if %has_return_citations {
          core.set %search_payload["return_citations"] = %return_citations_snake
        } else {
        }
        %has_from_date = core.call intrinsic.is_not_none(%from_date_snake)
        core.if %has_from_date {
          core.set %search_payload["from_date"] = %from_date_snake
        } else {
        }
        %has_to_date = core.call intrinsic.is_not_none(%to_date_snake)
        core.if %has_to_date {
          core.set %search_payload["to_date"] = %to_date_snake
        } else {
        }
        %has_max_results = core.call intrinsic.is_not_none(%max_results_snake)
        core.if %has_max_results {
          core.set %search_payload["max_search_results"] = %max_results_snake
        } else {
        }
        core.if %sources {
          %mapped_sources = core.list
          core.for %source in %sources {
            %mapped_source = core.map
            %source_type = core.get %source["type"]
            %source_country = core.get %source["country"]
