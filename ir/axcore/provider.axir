      } else {
        %audio = core.let %raw
      }
      %out = core.map
      core.set %out["audio"] = %audio
      core.set %out["format"] = %format
      core.return %out
    }
  }

  op ax.provider.semantic @openai_responses_normalize_realtime_event {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "ai"
    tag "src/ax/ai/openai/realtime.ts"
    type signature = "(json, json, string, string) -> AxChatResponse throws"
    body @entry(%event: json, %state: json, %ai_name: string, %model: string) {
      %type = core.get %event["type"]
      %is_error_event = core.call intrinsic.contains(%type, "error")
      core.if %is_error_event {
        %empty_error_payload = core.map
        %error_payload = core.get %event["error"] default %empty_error_payload
        %error_message = core.get %error_payload["message"] default "realtime audio provider error"
        %error = core.call intrinsic.ai.error.response(%error_message, %event)
        core.raise %error
      }
      %result = core.map
      core.set %result["index"] = 0
      %realtime_response_id = core.get %event["response_id"]
      %realtime_item_id = core.get %event["item_id"] default %realtime_response_id
      %has_realtime_item_id = core.call intrinsic.is_not_none(%realtime_item_id)
      core.if %has_realtime_item_id {
      } else {
        %realtime_item_id = core.let "0"
      }
      core.set %result["id"] = %realtime_item_id
      core.set %result["content"] = ""
      %realtime_empty_calls = core.list
      core.set %result["function_calls"] = %realtime_empty_calls
      %realtime_none_finish = core.call intrinsic.none()
      core.set %result["finish_reason"] = %realtime_none_finish
      %is_text = core.call intrinsic.eq(%type, "response.text.delta")
      %is_output_text = core.call intrinsic.eq(%type, "response.output_text.delta")
      %is_any_text = core.call intrinsic.or(%is_text, %is_output_text)
      %is_transcript = core.call intrinsic.eq(%type, "conversation.item.input_audio_transcription.delta")
      %is_output_transcript = core.call intrinsic.eq(%type, "response.output_audio_transcript.delta")
      %is_audio_transcript = core.call intrinsic.eq(%type, "response.audio_transcript.delta")
      %is_realtime_transcript = core.call intrinsic.or(%is_transcript, %is_output_transcript)
      %is_realtime_transcript = core.call intrinsic.or(%is_realtime_transcript, %is_audio_transcript)
      %is_audio = core.call intrinsic.eq(%type, "response.audio.delta")
      %is_output_audio = core.call intrinsic.eq(%type, "response.output_audio.delta")
      %is_any_audio = core.call intrinsic.or(%is_audio, %is_output_audio)
      core.if %is_any_text {
        %realtime_text_delta = core.get %event["delta"] default ""
        core.set %result["content"] = %realtime_text_delta
      }
      core.if %is_realtime_transcript {
        %realtime_transcript_delta = core.get %event["delta"] default ""
        core.set %result["content"] = %realtime_transcript_delta
      }
      core.if %is_any_audio {
        %audio_delta = core.get %event["delta"] default ""
        %audio = core.map
        core.set %audio["data"] = %audio_delta
        core.set %audio["format"] = "pcm16"
        core.set %audio["is_delta"] = true
        core.set %result["audio"] = %audio
      }
      %is_done = core.call intrinsic.string.ends_with(%type, ".done")
      core.if %is_done {
        core.set %result["finish_reason"] = "stop"
      }
      %realtime_empty_response = core.map
      %realtime_response = core.get %event["response"] default %realtime_empty_response
      %event_usage = core.get %event["usage"]
      %usage = core.get %realtime_response["usage"] default %event_usage
      %model_usage = core.call @ai_model_usage_impl(%ai_name, %model, %usage)
      %results = core.list
      core.append %results, %result
      %event_id = core.get %event["id"]
      %event_response_id = core.get %event["response_id"] default %event_id
      %remote_id = core.get %realtime_response["id"] default %event_response_id
      %out = core.map
      core.set %out["results"] = %results
      core.set %out["remote_id"] = %remote_id
      core.set %out["model_usage"] = %model_usage
      core.return %out
    }
  }

  op ax.provider.semantic @gemini_live_bidi_normalize_realtime_event {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "ai"
    attr private = true
    tag "gemini-live-bidi-realtime-audio-core-helper"
    type signature = "(json, json, string, string) -> AxChatResponse throws"
    body @entry(%event: json, %state: json, %ai_name: string, %model: string) {
      %error_payload = core.get %event["error"]
      %has_error = core.call intrinsic.is_not_none(%error_payload)
      core.if %has_error {
        %error_message = core.get %error_payload["message"] default "Gemini Live realtime audio provider error"
        %error = core.call intrinsic.ai.error.response(%error_message, %event)
        core.raise %error
      }
      %result = core.map
      core.set %result["index"] = 0
      core.set %result["id"] = "0"
      core.set %result["content"] = ""
      %calls = core.list
      core.set %result["function_calls"] = %calls
      %none_finish = core.call intrinsic.none()
      core.set %result["finish_reason"] = %none_finish
      %text_parts = core.list
      %function_calls = core.list
      %empty_top_tool_call = core.map
      %top_tool_call = core.get %event["toolCall"] default %empty_top_tool_call
      %empty_top_function_calls = core.list
      %top_function_calls = core.get %top_tool_call["functionCalls"] default %empty_top_function_calls
      core.for %top_function_call in %top_function_calls {
        %top_part = core.map
        core.set %top_part["functionCall"] = %top_function_call
        core.call @gemini_merge_response_part_impl(%result, %text_parts, %function_calls, %top_part)
      }
      %empty_server = core.map
      %server = core.get %event["serverContent"] default %empty_server
      %output_transcription = core.get %server["outputTranscription"]
      %has_output_transcription = core.call intrinsic.is_not_none(%output_transcription)
      core.if %has_output_transcription {
        %transcript_text = core.get %output_transcription["text"] default ""
        core.append %text_parts, %transcript_text
      }
      %input_transcription = core.get %server["inputTranscription"]
      %has_input_transcription = core.call intrinsic.is_not_none(%input_transcription)
      core.if %has_input_transcription {
        %input_text = core.get %input_transcription["text"] default ""
        core.append %text_parts, %input_text
      }
      %empty_model_turn = core.map
      %model_turn = core.get %server["modelTurn"] default %empty_model_turn
      %empty_parts = core.list
      %parts = core.get %model_turn["parts"] default %empty_parts
      core.for %part in %parts {
        %inline_data = core.get %part["inlineData"]
        %has_inline_data = core.call intrinsic.is_not_none(%inline_data)
        core.if %has_inline_data {
          %mime = core.get %inline_data["mimeType"] default "audio/pcm"
          %data = core.get %inline_data["data"] default ""
          %audio = core.map
          core.set %audio["data"] = %data
          core.set %audio["mimeType"] = %mime
          core.set %audio["format"] = "pcm16"
          core.set %audio["sampleRate"] = 24000
          core.set %audio["is_delta"] = true
          core.set %result["audio"] = %audio
        } else {
          core.call @gemini_merge_response_part_impl(%result, %text_parts, %function_calls, %part)
        }
      }
      %content = core.call intrinsic.string.join("", %text_parts)
      core.set %result["content"] = %content
      %call_count = core.call intrinsic.len(%function_calls)
      %has_calls = core.call intrinsic.gt(%call_count, 0)
      core.if %has_calls {
        core.set %result["function_calls"] = %function_calls
        core.set %result["finish_reason"] = "function_call"
      }
      %turn_complete = core.get %server["turnComplete"] default false
      core.if %turn_complete {
        core.set %result["finish_reason"] = "stop"
      }
      %usage = core.get %event["usageMetadata"]
      %gemini_usage = core.call @gemini_usage_impl(%usage)
      %model_usage = core.call @ai_model_usage_impl(%ai_name, %model, %gemini_usage)
      %results = core.list
      core.append %results, %result
      %event_id = core.get %event["id"] default "gemini-live"
      %out = core.map
      core.set %out["results"] = %results
      core.set %out["remote_id"] = %event_id
      core.set %out["model_usage"] = %model_usage
      core.return %out
    }
  }

  op ax.provider.semantic @gemini_build_chat_request {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "ai"
    attr private = true
    tag "src/ax/ai/google-gemini/api.ts"
    type signature = "(AxChatRequest) -> json throws"
    body @entry(%request: AxChatRequest) {
      %payload = core.map
      %empty_prompt = core.list
      %prompt = core.get %request["chat_prompt"] default %empty_prompt
      %system_parts = core.list
      %contents = core.list
      core.for %message in %prompt {
        %role = core.get %message["role"]
        %is_system = core.call intrinsic.eq(%role, "system")
        core.if %is_system {
          %system_text = core.get %message["content"] default ""
          core.append %system_parts, %system_text
        } else {
          %mapped = core.call @gemini_message_impl(%message)
          %has_mapped = core.call intrinsic.is_not_none(%mapped)
          core.if %has_mapped {
            core.append %contents, %mapped
          }
        }
      }
      %system_count = core.call intrinsic.len(%system_parts)
      %has_system = core.call intrinsic.gt(%system_count, 0)
      core.if %has_system {
        %system_text_joined = core.call intrinsic.string.join(" ", %system_parts)
        %system_part = core.map
        core.set %system_part["text"] = %system_text_joined
        %system_part_list = core.list
        core.append %system_part_list, %system_part
        %system_instruction = core.map
        core.set %system_instruction["role"] = "user"
        core.set %system_instruction["parts"] = %system_part_list
        core.set %payload["systemInstruction"] = %system_instruction
      }
      core.set %payload["contents"] = %contents
      %generation_config = core.map
      core.set %generation_config["candidateCount"] = 1
      core.set %generation_config["responseMimeType"] = "text/plain"
      %empty_model_config = core.map
      %model_config = core.get %request["model_config"] default %empty_model_config
      core.call @gemini_apply_model_config_impl(%generation_config, %model_config)
      %response_format = core.get %request["response_format"]
      %has_response_format = core.call intrinsic.truthy(%response_format)
      core.if %has_response_format {
        core.set %generation_config["responseMimeType"] = "application/json"
        %format_type = core.get %response_format["type"] default ""
        %is_json_schema = core.call intrinsic.eq(%format_type, "json_schema")
        core.if %is_json_schema {
          %schema_container = core.get %response_format["schema"]
          %schema = core.get %schema_container["schema"] default %schema_container
          core.set %generation_config["responseJsonSchema"] = %schema
        }
      }
      %model = core.get %request["model"] default "gemini-2.5-flash"
      %is_gemini3 = core.call intrinsic.string.starts_with(%model, "gemini-3")
      core.if %is_gemini3 {
        %temperature = core.get %generation_config["temperature"]
        %missing_temperature = core.call intrinsic.is_none(%temperature)
        core.if %missing_temperature {
          core.set %generation_config["temperature"] = 1
        } else {
          %too_low = core.call intrinsic.lt(%temperature, 1)
          core.if %too_low {
            core.set %generation_config["temperature"] = 1
          }
        }
      }
      core.set %payload["generationConfig"] = %generation_config
      %empty_functions = core.list
      %functions = core.get %request["functions"] default %empty_functions
      %has_functions = core.call intrinsic.truthy(%functions)
      core.if %has_functions {
        %function_declarations = core.list
        core.for %fn in %functions {
          %decl = core.call @gemini_function_declaration_impl(%fn)
          core.append %function_declarations, %decl
        }
        %tool = core.map
        core.set %tool["function_declarations"] = %function_declarations
        %tools = core.list
        core.append %tools, %tool
        core.set %payload["tools"] = %tools
        %tool_config = core.call @gemini_tool_config_impl(%request)
        core.set %payload["toolConfig"] = %tool_config
      }
      core.return %payload
    }
  }

  op ax.provider.semantic @gemini_apply_model_config_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "gemini-model-config-core-helper"
    type signature = "(json, json) -> void"
    body @entry(%payload: json, %model_config: json) {
      core.call @openai_copy_config_key_impl(%payload, %model_config, "maxTokens", "maxOutputTokens")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "max_tokens", "maxOutputTokens")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "temperature", "temperature")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "topP", "topP")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "top_p", "topP")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "topK", "topK")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "top_k", "topK")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "frequencyPenalty", "frequencyPenalty")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "frequency_penalty", "frequencyPenalty")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "n", "candidateCount")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "stopSequences", "stopSequences")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "stop_sequences", "stopSequences")
      core.return
    }
  }

  op ax.provider.semantic @gemini_message_impl {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "ai"
    attr private = true
    tag "gemini-message-core-helper"
    type signature = "(json) -> json throws"
    body @entry(%message: json) {
      %role = core.get %message["role"]
      %is_user = core.call intrinsic.eq(%role, "user")
      core.if %is_user {
        %content = core.get %message["content"] default ""
        %parts = core.call @gemini_content_parts_impl(%content)
        %out = core.map
        core.set %out["role"] = "user"
        core.set %out["parts"] = %parts
        core.return %out
      }
      %is_assistant = core.call intrinsic.eq(%role, "assistant")
      core.if %is_assistant {
        %parts = core.list
        %content = core.get %message["content"] default ""
        %has_content = core.call intrinsic.truthy(%content)
        core.if %has_content {
          %text_part = core.map
          core.set %text_part["text"] = %content
          core.append %parts, %text_part
        }
        %empty_calls = core.list
        %calls = core.get %message["function_calls"] default %empty_calls
        %calls_camel = core.get %message["functionCalls"] default %calls
        core.for %call in %calls_camel {
          %function = core.get %call["function"]
          %name = core.get %function["name"]
          %empty_args = core.map
          %args = core.get %function["params"] default %empty_args
          %args_is_string = core.type_is %args type "string"
          core.if %args_is_string {
            core.try {
              %parsed = core.call intrinsic.json.parse(%args)
              %args = core.let %parsed
            } catch %parse_error {
              %args = core.map
            }
          }
          %function_call = core.map
          core.set %function_call["name"] = %name
          core.set %function_call["args"] = %args
          %part = core.map
          core.set %part["functionCall"] = %function_call
          core.append %parts, %part
        }
        %out = core.map
        core.set %out["role"] = "model"
        core.set %out["parts"] = %parts
        core.return %out
      }
      %is_function = core.call intrinsic.eq(%role, "function")
      core.if %is_function {
        %name = core.get %message["name"]
        %function_id = core.get %message["function_id"] default %name
        %function_id_camel = core.get %message["functionId"] default %function_id
        %result_value = core.get %message["result"]
        %response = core.map
        core.set %response["result"] = %result_value
        %function_response = core.map
        core.set %function_response["name"] = %function_id_camel
        core.set %function_response["response"] = %response
        %part = core.map
        core.set %part["functionResponse"] = %function_response
        %parts = core.list
        core.append %parts, %part
        %out = core.map
        core.set %out["role"] = "user"
        core.set %out["parts"] = %parts
        core.return %out
      }
      %none = core.call intrinsic.none()
      core.return %none
    }
  }

  op ax.provider.semantic @gemini_content_parts_impl {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "ai"
    attr private = true
    tag "gemini-content-core-helper"
    type signature = "(json) -> list<json> throws"
    body @entry(%content: json) {
      %parts = core.list
      %is_list = core.type_is %content type "list"
      core.if %is_list {
        core.for %part in %content {
          %mapped = core.call @gemini_content_part_impl(%part)
          core.append %parts, %mapped
        }
      } else {
        %part = core.map
        core.set %part["text"] = %content
        core.append %parts, %part
      }
      core.return %parts
    }
  }

  op ax.provider.semantic @gemini_content_part_impl {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "ai"
    attr private = true
    tag "gemini-content-core-helper"
    type signature = "(json) -> json throws"
    body @entry(%part: json) {
      %type = core.get %part["type"] default "text"
      %is_text = core.call intrinsic.eq(%type, "text")
      core.if %is_text {
        %out = core.map
        %text = core.get %part["text"] default ""
        core.set %out["text"] = %text
        core.return %out
      }
      %is_image = core.call intrinsic.eq(%type, "image")
      core.if %is_image {
        %mime = core.get %part["mimeType"] default "image/png"
        %image_alt = core.get %part["data"]
        %image = core.get %part["image"] default %image_alt
        %inline = core.map
        core.set %inline["mimeType"] = %mime
        core.set %inline["data"] = %image
        %out = core.map
        core.set %out["inlineData"] = %inline
        core.return %out
      }
      %is_audio = core.call intrinsic.eq(%type, "audio")
      core.if %is_audio {
        %format = core.get %part["format"] default "wav"
        %default_mime = core.call intrinsic.string.format("audio/{}", %format)
        %mime = core.get %part["mimeType"] default %default_mime
        %audio_alt = core.get %part["audio"]
        %data = core.get %part["data"] default %audio_alt
        %inline = core.map
        core.set %inline["mimeType"] = %mime
        core.set %inline["data"] = %data
        %out = core.map
        core.set %out["inlineData"] = %inline
        core.return %out
      }
      %is_file = core.call intrinsic.eq(%type, "file")
      core.if %is_file {
        %mime = core.get %part["mimeType"] default "application/octet-stream"
        %file_uri = core.get %part["fileUri"]
        %has_uri = core.call intrinsic.truthy(%file_uri)
        core.if %has_uri {
          %file_data = core.map
          core.set %file_data["mimeType"] = %mime
          core.set %file_data["fileUri"] = %file_uri
          %out = core.map
          core.set %out["fileData"] = %file_data
          core.return %out
        } else {
          %data = core.get %part["data"]
          %inline = core.map
          core.set %inline["mimeType"] = %mime
          core.set %inline["data"] = %data
          %out = core.map
          core.set %out["inlineData"] = %inline
          core.return %out
        }
      }
      %message = core.call intrinsic.string.format("Chat prompt content type not supported: {}", %type)
      %error = core.call intrinsic.ai.error.unsupported(%message)
      core.raise %error
    }
  }

  op ax.provider.semantic @gemini_function_declaration_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "gemini-tool-core-helper"
    type signature = "(json) -> json"
    body @entry(%fn: json) {
      %decl = core.map
      %name = core.get %fn["name"]
      %description = core.get %fn["description"] default ""
      %empty_parameters = core.map
      %parameters = core.get %fn["parameters"] default %empty_parameters
      core.set %decl["name"] = %name
      core.set %decl["description"] = %description
      core.set %decl["parameters"] = %parameters
      core.return %decl
    }
  }

  op ax.provider.semantic @gemini_tool_config_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "gemini-tool-core-helper"
    type signature = "(json) -> json"
    body @entry(%request: json) {
      %function_call = core.get %request["function_call"] default "auto"
      %config = core.map
      %function_calling = core.map
      %is_none = core.call intrinsic.eq(%function_call, "none")
      %is_required = core.call intrinsic.eq(%function_call, "required")
      %is_auto = core.call intrinsic.eq(%function_call, "auto")
      core.if %is_none {
        core.set %function_calling["mode"] = "NONE"
      } else {
        core.if %is_required {
          core.set %function_calling["mode"] = "ANY"
        } else {
          core.if %is_auto {
            core.set %function_calling["mode"] = "AUTO"
          } else {
            core.set %function_calling["mode"] = "ANY"
            %function = core.get %function_call["function"]
            %name = core.get %function["name"]
            %has_name = core.call intrinsic.truthy(%name)
            core.if %has_name {
              %allowed = core.list
              core.append %allowed, %name
              core.set %function_calling["allowed_function_names"] = %allowed
            }
          }
        }
      }
      core.set %config["function_calling_config"] = %function_calling
      core.return %config
    }
  }

  op ax.provider.semantic @gemini_build_embed_request {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "src/ax/ai/google-gemini/api.ts"
    type signature = "(AxEmbedRequest) -> json"
    body @entry(%request: AxEmbedRequest) {
      %payload = core.map
      %empty_texts = core.list
      %texts = core.get %request["texts"] default %empty_texts
      %model = core.get %request["embed_model"] default "gemini-embedding-2"
      %requests = core.list
      core.for %text in %texts {
        %part = core.map
        core.set %part["text"] = %text
        %parts = core.list
        core.append %parts, %part
        %content = core.map
        core.set %content["parts"] = %parts
        %item = core.map
        %model_name = core.call intrinsic.string.format("models/{}", %model)
        core.set %item["model"] = %model_name
        core.set %item["content"] = %content
        core.append %requests, %item
      }
      core.set %payload["requests"] = %requests
      core.return %payload
    }
  }

  op ax.provider.semantic @gemini_normalize_chat_response {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "ai"
    attr private = true
    tag "src/ax/ai/google-gemini/api.ts"
    type signature = "(json, string, string) -> AxChatResponse throws"
    body @entry(%raw: json, %ai_name: string, %model: string) {
      %empty_candidates = core.list
      %candidates = core.get %raw["candidates"] default %empty_candidates
      %results = core.list
      %maps_widget_token = core.call intrinsic.none()
      core.for %candidate in %candidates {
        %result = core.map
        core.set %result["index"] = 0
        %finish = core.get %candidate["finishReason"] default "STOP"
        %is_max = core.call intrinsic.eq(%finish, "MAX_TOKENS")
        core.if %is_max {
          core.set %result["finish_reason"] = "length"
        } else {
          %is_stop = core.call intrinsic.eq(%finish, "STOP")
          core.if %is_stop {
            core.set %result["finish_reason"] = "stop"
          } else {
            %message = core.call intrinsic.string.format("Gemini finish reason was blocked: {}", %finish)
            %error = core.call intrinsic.ai.error.refusal(%message, %raw)
            core.raise %error
          }
        }
        %empty_content = core.map
        %content = core.get %candidate["content"] default %empty_content
        %empty_parts = core.list
        %parts = core.get %content["parts"] default %empty_parts
        %text_parts = core.list
        %function_calls = core.list
        core.for %part in %parts {
          core.call @gemini_merge_response_part_impl(%result, %text_parts, %function_calls, %part)
        }
        %content_text = core.call intrinsic.string.join("", %text_parts)
        core.set %result["content"] = %content_text
        core.set %result["function_calls"] = %function_calls
        %call_count = core.call intrinsic.len(%function_calls)
        %has_calls = core.call intrinsic.gt(%call_count, 0)
        core.if %has_calls {
          core.set %result["finish_reason"] = "function_call"
        }
        %citations = core.call @gemini_extract_citations_impl(%candidate)
        %has_citations = core.call intrinsic.truthy(%citations)
        core.if %has_citations {
          core.set %result["citations"] = %citations
        }
        core.append %results, %result
        %grounding = core.get %candidate["groundingMetadata"]
        %token = core.get %grounding["googleMapsWidgetContextToken"]
        %has_token = core.call intrinsic.truthy(%token)
        core.if %has_token {
          %maps_widget_token = core.let %token
        }
      }
      %usage_raw = core.get %raw["usageMetadata"]
      %usage = core.call @gemini_usage_impl(%usage_raw)
      %model_version = core.get %raw["modelVersion"]
      %raw_model = core.get %raw["modelVersion"] default %model
      %model_usage = core.call @ai_model_usage_impl(%ai_name, %raw_model, %usage)
      %out = core.map
      core.set %out["results"] = %results
      %remote_id = core.get %raw["responseId"]
      %has_remote = core.call intrinsic.truthy(%remote_id)
      core.if %has_remote {
        core.set %out["remote_id"] = %remote_id
      }
      core.set %out["model_usage"] = %model_usage
      %has_model_version = core.call intrinsic.truthy(%model_version)
      %has_widget = core.call intrinsic.is_not_none(%maps_widget_token)
      %has_metadata = core.call intrinsic.or(%has_model_version, %has_widget)
      core.if %has_metadata {
        %google = core.map
        core.if %has_model_version {
          core.set %google["modelVersion"] = %model_version
        }
        core.if %has_widget {
          core.set %google["mapsWidgetContextToken"] = %maps_widget_token
        }
        %metadata = core.map
        core.set %metadata["google"] = %google
        core.set %out["provider_metadata"] = %metadata
      }
      core.return %out
    }
  }

  op ax.provider.semantic @gemini_merge_response_part_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "gemini-output-core-helper"
    type signature = "(json, list<json>, list<json>, json) -> void"
    body @entry(%result: json, %text_parts: list<json>, %function_calls: list<json>, %part: json) {
      %text = core.get %part["text"]
      %has_text = core.call intrinsic.is_not_none(%text)
      core.if %has_text {
        %is_thought = core.get %part["thought"] default false
        core.if %is_thought {
          core.set %result["thought"] = %text
        } else {
          core.append %text_parts, %text
        }
      }
      %function_call = core.get %part["functionCall"]
      %has_call = core.call intrinsic.is_not_none(%function_call)
      core.if %has_call {
        %name = core.get %function_call["name"]
        %empty_args = core.map
        %args = core.get %function_call["args"] default %empty_args
        %function = core.map
        core.set %function["name"] = %name
        core.set %function["params"] = %args
        %call = core.map
        core.set %call["id"] = %name
        core.set %call["type"] = "function"
        core.set %call["function"] = %function
        core.append %function_calls, %call
      }
      core.return
    }
  }

  op ax.provider.semantic @gemini_extract_citations_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "gemini-citations-core-helper"
    type signature = "(json) -> list<json>"
    body @entry(%candidate: json) {
      %out = core.list
      %citation_meta = core.get %candidate["citationMetadata"]
      %empty_citations = core.list
      %citations = core.get %citation_meta["citations"] default %empty_citations
      core.for %citation in %citations {
        %uri = core.get %citation["uri"]
        %has_uri = core.call intrinsic.truthy(%uri)
        core.if %has_uri {
          %item = core.map
          core.set %item["url"] = %uri
          %title = core.get %citation["title"]
          %has_title = core.call intrinsic.is_not_none(%title)
          core.if %has_title {
            core.set %item["title"] = %title
          }
          %license = core.get %citation["license"]
          %has_license = core.call intrinsic.is_not_none(%license)
          core.if %has_license {
            core.set %item["license"] = %license
          }
          core.append %out, %item
        }
      }
      %grounding = core.get %candidate["groundingMetadata"]
      %chunks = core.get %grounding["groundingChunks"] default %empty_citations
      core.for %chunk in %chunks {
        %maps = core.get %chunk["maps"]
        %maps_uri = core.get %maps["uri"]
        %has_maps = core.call intrinsic.truthy(%maps_uri)
        core.if %has_maps {
          %item = core.map
          core.set %item["url"] = %maps_uri
          %title = core.get %maps["title"]
          %has_title = core.call intrinsic.is_not_none(%title)
          core.if %has_title {
            core.set %item["title"] = %title
          }
          core.append %out, %item
        }
        %retrieved = core.get %chunk["retrievedContext"]
        %retrieved_uri = core.get %retrieved["uri"]
        %media_id = core.get %retrieved["media_id"]
        %has_retrieved_uri = core.call intrinsic.truthy(%retrieved_uri)
        %has_media = core.call intrinsic.truthy(%media_id)
        %has_retrieved = core.call intrinsic.or(%has_retrieved_uri, %has_media)
        core.if %has_retrieved {
          %item = core.map
          %url = core.get %retrieved["uri"] default ""
          core.set %item["url"] = %url
          %title = core.get %retrieved["title"]
          %has_title = core.call intrinsic.is_not_none(%title)
          core.if %has_title {
            core.set %item["title"] = %title
          }
          core.if %has_media {
            core.set %item["mediaId"] = %media_id
          }
          %pages = core.get %retrieved["page_numbers"]
          %has_pages = core.call intrinsic.is_not_none(%pages)
          core.if %has_pages {
            core.set %item["pageNumbers"] = %pages
          }
          core.append %out, %item
        }
      }
      core.return %out
    }
  }

  op ax.provider.semantic @gemini_usage_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "gemini-usage-core-helper"
    type signature = "(json) -> json"
    body @entry(%usage: json) {
      %has_usage = core.call intrinsic.truthy(%usage)
      core.if %has_usage {
      } else {
        %none = core.call intrinsic.none()
        core.return %none
      }
      %out = core.map
      %cached = core.get %usage["cachedContentTokenCount"] default 0
      %prompt_raw = core.get %usage["promptTokenCount"] default 0
      %negative_cached = core.call intrinsic.mul(-1, %cached)
      %prompt = core.call intrinsic.add(%prompt_raw, %negative_cached)
      %completion = core.get %usage["candidatesTokenCount"] default 0
      %total = core.get %usage["totalTokenCount"] default 0
      core.set %out["prompt_tokens"] = %prompt
      core.set %out["completion_tokens"] = %completion
      core.set %out["total_tokens"] = %total
      %thoughts = core.get %usage["thoughtsTokenCount"]
      %has_thoughts = core.call intrinsic.is_not_none(%thoughts)
      core.if %has_thoughts {
        core.set %out["reasoning_tokens"] = %thoughts
      }
      %has_cached = core.call intrinsic.gt(%cached, 0)
      core.if %has_cached {
        core.set %out["cache_read_tokens"] = %cached
      }
      core.return %out
    }
  }

  op ax.provider.semantic @gemini_normalize_embed_response {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "src/ax/ai/google-gemini/api.ts"
    type signature = "(json, string, string) -> AxEmbedResponse"
    body @entry(%raw: json, %ai_name: string, %model: string) {
      %out = core.map
      %embeddings = core.list
      %empty_raw_embeddings = core.list
      %raw_embeddings = core.get %raw["embeddings"] default %empty_raw_embeddings
      core.for %embedding in %raw_embeddings {
        %values = core.get %embedding["values"] default %embedding
        core.append %embeddings, %values
      }
      %empty_predictions = core.list
      %predictions = core.get %raw["predictions"] default %empty_predictions
      core.for %prediction in %predictions {
        %prediction_embedding = core.get %prediction["embeddings"]
        %values = core.get %prediction_embedding["values"] default %prediction_embedding
        core.append %embeddings, %values
      }
      core.set %out["embeddings"] = %embeddings
      core.return %out
    }
  }

  op ax.provider.semantic @anthropic_build_chat_request {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "ai"
    attr private = true
    tag "src/ax/ai/anthropic/api.ts"
    type signature = "(AxChatRequest) -> json throws"
    body @entry(%request: AxChatRequest) {
      %payload = core.map
      %model = core.get %request["model"] default "claude-3-7-sonnet-latest"
      core.set %payload["model"] = %model
      %empty_prompt = core.list
      %prompt = core.get %request["chat_prompt"] default %empty_prompt
      %supports_mid = core.call intrinsic.string.starts_with(%model, "claude-opus-4-8")
      %system = core.list
      %messages = core.list
      %seen_non_system = core.let false
      core.for %message in %prompt {
        %role = core.get %message["role"] default ""
        %is_system = core.call intrinsic.eq(%role, "system")
        core.if %is_system {
          %hoist_later = core.call intrinsic.not(%supports_mid)
          %hoist = core.call intrinsic.or(%hoist_later, %seen_non_system)
          %should_preserve = core.call intrinsic.and(%supports_mid, %seen_non_system)
          core.if %should_preserve {
            %mapped_system = core.call @anthropic_message_impl(%message)
            core.append %messages, %mapped_system
          } else {
            %sys_item = core.map
            core.set %sys_item["type"] = "text"
            %sys_text = core.get %message["content"] default ""
            core.set %sys_item["text"] = %sys_text
            %cache = core.get %message["cache"] default false
            core.if %cache {
              %cache_control = core.call intrinsic.json.parse("{\"type\":\"ephemeral\"}")
              core.set %sys_item["cache_control"] = %cache_control
            }
            core.append %system, %sys_item
          }
        } else {
          %seen_non_system = core.let true
          %mapped = core.call @anthropic_message_impl(%message)
          core.append %messages, %mapped
        }
      }
      %system_count = core.call intrinsic.len(%system)
      %has_system = core.call intrinsic.gt(%system_count, 0)
      core.if %has_system {
        core.set %payload["system"] = %system
      }
      core.set %payload["messages"] = %messages
      %empty_model_config = core.map
      %model_config = core.get %request["model_config"] default %empty_model_config
      core.call @anthropic_apply_model_config_impl(%payload, %model_config, %model)
      %response_format = core.get %request["response_format"]
      %has_response_format = core.call intrinsic.truthy(%response_format)
      core.if %has_response_format {
        %format_type = core.get %response_format["type"] default ""
        %is_json_schema = core.call intrinsic.eq(%format_type, "json_schema")
        core.if %is_json_schema {
          %schema_container = core.get %response_format["schema"]
          %schema = core.get %schema_container["schema"] default %schema_container
          %output_config = core.get %payload["output_config"] default %empty_model_config
          %format = core.map
          core.set %format["type"] = "json_schema"
          core.set %format["schema"] = %schema
          core.set %output_config["format"] = %format
          core.set %payload["output_config"] = %output_config
        }
      }
      %empty_functions = core.list
      %functions = core.get %request["functions"] default %empty_functions
      %has_functions = core.call intrinsic.truthy(%functions)
      core.if %has_functions {
        %tools = core.list
        core.for %fn in %functions {
          %tool = core.call @anthropic_tool_spec_impl(%fn)
          core.append %tools, %tool
        }
        core.set %payload["tools"] = %tools
        %tool_choice = core.call @anthropic_tool_choice_impl(%request)
        %has_choice = core.call intrinsic.is_not_none(%tool_choice)
        core.if %has_choice {
          core.set %payload["tool_choice"] = %tool_choice
        }
      }
      core.return %payload
    }
  }

  op ax.provider.semantic @anthropic_apply_model_config_impl {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "ai"
    attr private = true
    tag "anthropic-model-config-core-helper"
    type signature = "(json, json, string) -> void throws"
    body @entry(%payload: json, %model_config: json, %model: string) {
      core.call @openai_copy_config_key_impl(%payload, %model_config, "maxTokens", "max_tokens")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "max_tokens", "max_tokens")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "stopSequences", "stop_sequences")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "stop_sequences", "stop_sequences")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "temperature", "temperature")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "topP", "top_p")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "top_p", "top_p")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "topK", "top_k")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "top_k", "top_k")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "stream", "stream")
      %has_max = core.get %payload["max_tokens"]
      %missing_max = core.call intrinsic.is_none(%has_max)
      core.if %missing_max {
        core.set %payload["max_tokens"] = 40000
      }
      %n = core.get %model_config["n"]
      %has_n = core.call intrinsic.is_not_none(%n)
      core.if %has_n {
        %too_many = core.call intrinsic.gt(%n, 1)
        core.if %too_many {
          %error = core.call intrinsic.ai.error.unsupported("Anthropic does not support sampling (n > 1)")
          core.raise %error
        }
      }
      %budget = core.get %model_config["thinkingTokenBudget"]
      %budget_alt = core.get %model_config["thinking_token_budget"] default %budget
      %has_budget = core.call intrinsic.truthy(%budget_alt)
      core.if %has_budget {
        %thinking_config = core.call @anthropic_thinking_config_impl(%model, %budget_alt)
        %thinking = core.get %thinking_config["thinking"]
        %has_thinking = core.call intrinsic.is_not_none(%thinking)
        core.if %has_thinking {
          core.set %payload["thinking"] = %thinking
        }
        %output_config = core.get %thinking_config["output_config"]
        %has_output = core.call intrinsic.is_not_none(%output_config)
        core.if %has_output {
          core.set %payload["output_config"] = %output_config
        }
      }
      %effort = core.get %model_config["effort"]
      %has_effort = core.call intrinsic.truthy(%effort)
      core.if %has_effort {
        %output_config = core.get %payload["output_config"] default %model_config
        core.set %output_config["effort"] = %effort
        core.set %payload["output_config"] = %output_config
      }
      core.return
    }
  }

  op ax.provider.semantic @anthropic_thinking_config_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "anthropic-thinking-core-helper"
    type signature = "(string, string) -> json"
    body @entry(%model: string, %level: string) {
      %out = core.map
      %is_none = core.call intrinsic.eq(%level, "none")
      core.if %is_none {
        core.return %out
      }
      %budget = core.let 10000
      %effort = core.let "medium"
      %is_minimal = core.call intrinsic.eq(%level, "minimal")
      core.if %is_minimal {
        %budget = core.let 1024
        %effort = core.let "low"
      }
      %is_low = core.call intrinsic.eq(%level, "low")
      core.if %is_low {
        %budget = core.let 5000
        %effort = core.let "low"
      }
      %is_high = core.call intrinsic.eq(%level, "high")
      core.if %is_high {
        %budget = core.let 20000
        %effort = core.let "high"
      }
      %is_highest = core.call intrinsic.eq(%level, "highest")
      core.if %is_highest {
        %budget = core.let 32000
        %effort = core.let "max"
      }
      %is_48 = core.call intrinsic.string.starts_with(%model, "claude-opus-4-8")
      %is_47 = core.call intrinsic.string.starts_with(%model, "claude-opus-4-7")
      %is_46 = core.call intrinsic.string.starts_with(%model, "claude-opus-4-6")
      %is_47_plus = core.call intrinsic.or(%is_48, %is_47)
      %is_adaptive = core.call intrinsic.or(%is_47_plus, %is_46)
      core.if %is_adaptive {
        %thinking = core.map
        core.set %thinking["type"] = "adaptive"
        core.set %out["thinking"] = %thinking
        %output_config = core.map
        core.set %output_config["effort"] = %effort
        core.set %out["output_config"] = %output_config
      } else {
        %thinking = core.map
        core.set %thinking["type"] = "enabled"
        core.set %thinking["budget_tokens"] = %budget
        core.set %out["thinking"] = %thinking
        %is_45 = core.call intrinsic.string.starts_with(%model, "claude-opus-4-5")
        core.if %is_45 {
          %output_config = core.map
          %is_max = core.call intrinsic.eq(%effort, "max")
          core.if %is_max {
            core.set %output_config["effort"] = "high"
          } else {
            core.set %output_config["effort"] = %effort
          }
          core.set %out["output_config"] = %output_config
        }
      }
      core.return %out
    }
  }

  op ax.provider.semantic @anthropic_message_impl {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "ai"
    attr private = true
    tag "anthropic-message-core-helper"
    type signature = "(json) -> json throws"
    body @entry(%message: json) {
      %role = core.get %message["role"] default "user"
      %out = core.map
      %is_system = core.call intrinsic.eq(%role, "system")
      core.if %is_system {
        core.set %out["role"] = "system"
        %system_content = core.get %message["content"] default ""
        core.set %out["content"] = %system_content
        core.return %out
      }
      %is_function = core.call intrinsic.eq(%role, "function")
      core.if %is_function {
        core.set %out["role"] = "user"
        %content = core.list
        %block = core.map
        core.set %block["type"] = "tool_result"
        %result = core.get %message["result"] default ""
        core.set %block["content"] = %result
        %function_id = core.get %message["function_id"]
        %function_id_camel = core.get %message["functionId"] default %function_id
        core.set %block["tool_use_id"] = %function_id_camel
        %is_error = core.get %message["is_error"] default false
        %is_error_camel = core.get %message["isError"] default %is_error
        core.if %is_error_camel {
          core.set %block["is_error"] = true
        }
        %cache = core.get %message["cache"] default false
        core.if %cache {
          %cache_control = core.call intrinsic.json.parse("{\"type\":\"ephemeral\"}")
          core.set %block["cache_control"] = %cache_control
        }
        core.append %content, %block
        core.set %out["content"] = %content
        core.return %out
      }
      %is_assistant = core.call intrinsic.eq(%role, "assistant")
      core.if %is_assistant {
        core.set %out["role"] = "assistant"
        %blocks = core.list
        %content_value = core.get %message["content"] default ""
        %has_content = core.call intrinsic.truthy(%content_value)
        core.if %has_content {
          %text_block = core.map
          core.set %text_block["type"] = "text"
          core.set %text_block["text"] = %content_value
          core.append %blocks, %text_block
        }
        %empty_calls = core.list
        %calls = core.get %message["function_calls"] default %empty_calls
        %calls_camel = core.get %message["functionCalls"] default %calls
        core.for %call in %calls_camel {
          %function = core.get %call["function"]
          %name = core.get %function["name"] default ""
          %params = core.get %function["params"] default %empty_calls
          %params_is_string = core.type_is %params type "string"
          core.if %params_is_string {
            core.try {
              %parsed = core.call intrinsic.json.parse(%params)
              %params = core.let %parsed
            } catch %parse_error {
              %params = core.map
            }
          }
          %tool_use = core.map
          core.set %tool_use["type"] = "tool_use"
          %id = core.get %call["id"] default %name
          core.set %tool_use["id"] = %id
          core.set %tool_use["name"] = %name
          core.set %tool_use["input"] = %params
          core.append %blocks, %tool_use
        }
        %cache = core.get %message["cache"] default false
        core.if %cache {
          %count = core.call intrinsic.len(%blocks)
          %has_blocks = core.call intrinsic.gt(%count, 0)
          core.if %has_blocks {
            %index = core.call intrinsic.add(%count, -1)
            %last = core.get %blocks[%index]
            %cache_control = core.call intrinsic.json.parse("{\"type\":\"ephemeral\"}")
            core.set %last["cache_control"] = %cache_control
          }
        }
        %count = core.call intrinsic.len(%blocks)
        %has_blocks = core.call intrinsic.gt(%count, 0)
        core.if %has_blocks {
          core.set %out["content"] = %blocks
        } else {
          core.set %out["content"] = ""
        }
        core.return %out
      }
      core.set %out["role"] = "user"
      %raw_content = core.get %message["content"] default ""
      %cache = core.get %message["cache"] default false
      %content_is_string = core.type_is %raw_content type "string"
      %not_cache = core.call intrinsic.not(%cache)
      %plain_string = core.call intrinsic.and(%content_is_string, %not_cache)
      core.if %plain_string {
        core.set %out["content"] = %raw_content
      } else {
        %parts = core.call @anthropic_content_parts_impl(%raw_content)
        core.if %cache {
          %count = core.call intrinsic.len(%parts)
          %has_parts = core.call intrinsic.gt(%count, 0)
          core.if %has_parts {
            %index = core.call intrinsic.add(%count, -1)
            %last = core.get %parts[%index]
            %cache_control = core.call intrinsic.json.parse("{\"type\":\"ephemeral\"}")
            core.set %last["cache_control"] = %cache_control
          }
        }
        core.set %out["content"] = %parts
      }
      core.return %out
    }
  }

  op ax.provider.semantic @anthropic_content_parts_impl {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "ai"
    attr private = true
    tag "anthropic-content-core-helper"
    type signature = "(json) -> list<json> throws"
    body @entry(%content: json) {
      %parts = core.list
      %is_list = core.type_is %content type "list"
      core.if %is_list {
        core.for %part in %content {
          %mapped = core.call @anthropic_content_part_impl(%part)
          core.append %parts, %mapped
        }
      } else {
        %part = core.map
        core.set %part["type"] = "text"
        core.set %part["text"] = %content
        core.append %parts, %part
      }
      core.return %parts
    }
  }

  op ax.provider.semantic @anthropic_content_part_impl {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "ai"
    attr private = true
    tag "anthropic-content-core-helper"
    type signature = "(json) -> json throws"
    body @entry(%part: json) {
      %type = core.get %part["type"] default "text"
      %is_text = core.call intrinsic.eq(%type, "text")
      core.if %is_text {
        %out = core.map
        core.set %out["type"] = "text"
        %text = core.get %part["text"] default ""
        core.set %out["text"] = %text
        %cache = core.get %part["cache"] default false
        core.if %cache {
          %cache_control = core.call intrinsic.json.parse("{\"type\":\"ephemeral\"}")
          core.set %out["cache_control"] = %cache_control
        }
        core.return %out
      }
      %is_image = core.call intrinsic.eq(%type, "image")
      core.if %is_image {
        %out = core.map
        core.set %out["type"] = "image"
        %source = core.map
        core.set %source["type"] = "base64"
        %mime = core.get %part["mimeType"] default "image/png"
        core.set %source["media_type"] = %mime
        %image_alt = core.get %part["data"]
        %image = core.get %part["image"] default %image_alt
        core.set %source["data"] = %image
        core.set %out["source"] = %source
        %cache = core.get %part["cache"] default false
        core.if %cache {
          %cache_control = core.call intrinsic.json.parse("{\"type\":\"ephemeral\"}")
          core.set %out["cache_control"] = %cache_control
        }
        core.return %out
      }
      %message = core.call intrinsic.string.format("Anthropic content type not supported: {}", %type)
      %error = core.call intrinsic.ai.error.unsupported(%message)
      core.raise %error
    }
  }

  op ax.provider.semantic @anthropic_tool_spec_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "anthropic-tool-core-helper"
    type signature = "(json) -> json"
    body @entry(%fn: json) {
      %tool = core.map
      %name = core.get %fn["name"]
      %description = core.get %fn["description"] default ""
      %empty_schema = core.map
      %parameters = core.get %fn["parameters"] default %empty_schema
      core.set %tool["name"] = %name
      core.set %tool["description"] = %description
      core.set %tool["input_schema"] = %parameters
      %cache = core.get %fn["cache"] default false
      core.if %cache {
        %cache_control = core.call intrinsic.json.parse("{\"type\":\"ephemeral\"}")
        core.set %tool["cache_control"] = %cache_control
      }
      core.return %tool
    }
  }

  op ax.provider.semantic @anthropic_tool_choice_impl {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "ai"
    attr private = true
    tag "anthropic-tool-core-helper"
    type signature = "(json) -> json throws"
    body @entry(%request: json) {
      %function_call = core.get %request["function_call"] default "auto"
      %choice = core.map
      %is_none = core.call intrinsic.eq(%function_call, "none")
      core.if %is_none {
        %error = core.call intrinsic.ai.error.unsupported("functionCall none not supported")
        core.raise %error
      }
      %is_required = core.call intrinsic.eq(%function_call, "required")
      core.if %is_required {
        core.set %choice["type"] = "any"
        core.return %choice
      }
      %is_auto = core.call intrinsic.eq(%function_call, "auto")
      core.if %is_auto {
        core.set %choice["type"] = "auto"
        core.return %choice
      }
      %function = core.get %function_call["function"]
      %name = core.get %function["name"]
      %has_name = core.call intrinsic.truthy(%name)
      core.if %has_name {
        core.set %choice["type"] = "tool"
        core.set %choice["name"] = %name
        core.return %choice
      }
      %none = core.call intrinsic.none()
      core.return %none
    }
  }

  op ax.provider.semantic @anthropic_normalize_chat_response {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "ai"
    attr private = true
    tag "src/ax/ai/anthropic/api.ts"
    type signature = "(json, string, string) -> AxChatResponse throws"
    body @entry(%raw: json, %ai_name: string, %model: string) {
      %type = core.get %raw["type"] default ""
      %is_error = core.call intrinsic.eq(%type, "error")
      core.if %is_error {
        %error_body = core.get %raw["error"]
        %message = core.get %error_body["message"] default "Anthropic API error"
        %error = core.call intrinsic.ai.error.refusal(%message, %raw)
        core.raise %error
      }
      %stop_reason = core.get %raw["stop_reason"]
      %is_refusal = core.call intrinsic.eq(%stop_reason, "refusal")
      core.if %is_refusal {
        %details = core.get %raw["stop_details"]
        %message = core.get %details["explanation"] default "Anthropic refused to fulfill this request"
        %error = core.call intrinsic.ai.error.refusal(%message, %raw)
        core.raise %error
      }
      %text_parts = core.list
      %function_calls = core.list
      %thought_parts = core.list
      %thought_blocks = core.list
      %citations = core.list
      %empty_content = core.list
      %content = core.get %raw["content"] default %empty_content
      core.for %block in %content {
        core.call @anthropic_merge_response_block_impl(%text_parts, %function_calls, %thought_parts, %thought_blocks, %citations, %block)
      }
      %result = core.map
      core.set %result["index"] = 0
      %id = core.get %raw["id"] default "0"
      core.set %result["id"] = %id
      %finish = core.call @anthropic_finish_reason_impl(%stop_reason)
      %has_finish = core.call intrinsic.is_not_none(%finish)
      core.if %has_finish {
        core.set %result["finish_reason"] = %finish
      }
      %text = core.call intrinsic.string.join("", %text_parts)
      core.set %result["content"] = %text
      core.set %result["function_calls"] = %function_calls
      %has_calls = core.call intrinsic.truthy(%function_calls)
      core.if %has_calls {
        core.set %result["finish_reason"] = "function_call"
      }
      %has_thought = core.call intrinsic.truthy(%thought_parts)
      core.if %has_thought {
        %thought = core.call intrinsic.string.join("", %thought_parts)
        core.set %result["thought"] = %thought
        core.set %result["thought_blocks"] = %thought_blocks
      }
      %has_citations = core.call intrinsic.truthy(%citations)
      core.if %has_citations {
        core.set %result["citations"] = %citations
      }
      %results = core.list
      core.append %results, %result
      %usage_raw = core.get %raw["usage"]
      %usage = core.call @anthropic_usage_impl(%usage_raw)
      %raw_model = core.get %raw["model"] default %model
      %model_usage = core.call @ai_model_usage_impl(%ai_name, %raw_model, %usage)
      %out = core.map
      core.set %out["results"] = %results
      core.set %out["remote_id"] = %id
      core.set %out["model_usage"] = %model_usage
      core.return %out
    }
  }

  op ax.provider.semantic @anthropic_merge_response_block_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "anthropic-output-core-helper"
    type signature = "(list<json>, list<json>, list<json>, list<json>, list<json>, json) -> void"
    body @entry(%text_parts: list<json>, %function_calls: list<json>, %thought_parts: list<json>, %thought_blocks: list<json>, %citations: list<json>, %block: json) {
      %type = core.get %block["type"] default ""
      %is_text = core.call intrinsic.eq(%type, "text")
      core.if %is_text {
        %text = core.get %block["text"] default ""
        core.append %text_parts, %text
        core.call @anthropic_append_citations_impl(%citations, %block)
      }
      %is_tool = core.call intrinsic.eq(%type, "tool_use")
      core.if %is_tool {
        %function = core.map
        %name = core.get %block["name"] default ""
        %input = core.get %block["input"] default ""
        core.set %function["name"] = %name
        core.set %function["params"] = %input
        %call = core.map
        %id = core.get %block["id"] default %name
        core.set %call["id"] = %id
        core.set %call["type"] = "function"
        core.set %call["function"] = %function
        core.append %function_calls, %call
      }
      %is_thinking = core.call intrinsic.eq(%type, "thinking")
      core.if %is_thinking {
        %thinking = core.get %block["thinking"] default ""
        core.append %thought_parts, %thinking
        %thought_block = core.map
        core.set %thought_block["data"] = %thinking
        core.set %thought_block["encrypted"] = false
        %signature = core.get %block["signature"]
        %has_signature = core.call intrinsic.is_not_none(%signature)
        core.if %has_signature {
          core.set %thought_block["signature"] = %signature
        }
        core.append %thought_blocks, %thought_block
      }
      %is_redacted = core.call intrinsic.eq(%type, "redacted_thinking")
      core.if %is_redacted {
        %data = core.get %block["data"]
        %data_alt = core.get %block["thinking"] default %data
        core.append %thought_parts, %data_alt
        %thought_block = core.map
        core.set %thought_block["data"] = %data_alt
        core.set %thought_block["encrypted"] = true
        %signature = core.get %block["signature"]
        %has_signature = core.call intrinsic.is_not_none(%signature)
        core.if %has_signature {
          core.set %thought_block["signature"] = %signature
        }
        core.append %thought_blocks, %thought_block
      }
      core.return
    }
  }

  op ax.provider.semantic @anthropic_append_citations_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "anthropic-citations-core-helper"
    type signature = "(list<json>, json) -> void"
    body @entry(%out: list<json>, %block: json) {
      %empty = core.list
      %citations = core.get %block["citations"] default %empty
      core.for %citation in %citations {
        %url = core.get %citation["url"]
        %has_url = core.call intrinsic.truthy(%url)
        core.if %has_url {
          %item = core.map
          core.set %item["url"] = %url
          %title = core.get %citation["title"]
          %has_title = core.call intrinsic.is_not_none(%title)
          core.if %has_title {
            core.set %item["title"] = %title
          }
          %snippet = core.get %citation["cited_text"]
          %has_snippet = core.call intrinsic.is_not_none(%snippet)
          core.if %has_snippet {
            core.set %item["snippet"] = %snippet
          }
          core.append %out, %item
        }
      }
      core.return
    }
  }

  op ax.provider.semantic @anthropic_finish_reason_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "anthropic-output-core-helper"
    type signature = "(json) -> string"
    body @entry(%reason: json) {
      %missing = core.call intrinsic.is_none(%reason)
      core.if %missing {
        %none = core.call intrinsic.none()
        core.return %none
      }
      %is_max = core.call intrinsic.eq(%reason, "max_tokens")
      %is_context = core.call intrinsic.eq(%reason, "model_context_window_exceeded")
      %is_length = core.call intrinsic.or(%is_max, %is_context)
      core.if %is_length {
        core.return "length"
      }
      %is_tool = core.call intrinsic.eq(%reason, "tool_use")
      core.if %is_tool {
        core.return "function_call"
      }
      %is_refusal = core.call intrinsic.eq(%reason, "refusal")
      core.if %is_refusal {
        core.return "content_filter"
      }
      core.return "stop"
    }
  }

  op ax.provider.semantic @anthropic_usage_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "anthropic-usage-core-helper"
    type signature = "(json) -> json"
    body @entry(%usage: json) {
      %has_usage = core.call intrinsic.truthy(%usage)
      core.if %has_usage {
      } else {
        %none = core.call intrinsic.none()
        core.return %none
      }
      %out = core.map
      %prompt = core.get %usage["input_tokens"] default 0
      %completion = core.get %usage["output_tokens"] default 0
      %cache_creation = core.get %usage["cache_creation_input_tokens"] default 0
      %cache_read = core.get %usage["cache_read_input_tokens"] default 0
      %total_base = core.call intrinsic.add(%prompt, %completion)
      %total_cache = core.call intrinsic.add(%cache_creation, %cache_read)
      %total = core.call intrinsic.add(%total_base, %total_cache)
      core.set %out["prompt_tokens"] = %prompt
      core.set %out["completion_tokens"] = %completion
      core.set %out["total_tokens"] = %total
      %has_creation = core.call intrinsic.gt(%cache_creation, 0)
      core.if %has_creation {
        core.set %out["cache_creation_tokens"] = %cache_creation
      }
      %has_read = core.call intrinsic.gt(%cache_read, 0)
      core.if %has_read {
        core.set %out["cache_read_tokens"] = %cache_read
      }
      %speed = core.get %usage["speed"]
      %has_speed = core.call intrinsic.is_not_none(%speed)
      core.if %has_speed {
        core.set %out["speed"] = %speed
      }
      core.return %out
    }
  }

  op ax.provider.semantic @anthropic_normalize_stream_delta {
