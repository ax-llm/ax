  op ax.provider.semantic @openai_responses_build_chat_request {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr effect = "throws"
    tag "src/ax/ai/openai/responses_api.ts"
    type signature = "(AxChatRequest) -> json throws"
    body @entry(%request: AxChatRequest) {
      %payload = core.map
      %model = core.get %request["model"] default "gpt-4o"
      core.set %payload["model"] = %model
      %empty_prompt = core.list
      %prompt = core.get %request["chat_prompt"] default %empty_prompt
      %input = core.list
      %instructions = core.call intrinsic.none()
      core.for %message in %prompt {
        %role = core.get %message["role"]
        %is_system = core.call intrinsic.eq(%role, "system")
        core.if %is_system {
          %system_content = core.get %message["content"] default ""
          %instructions = core.let %system_content
        } else {
          %item = core.call @openai_responses_input_item_impl(%message)
          core.append %input, %item
        }
      }
      %has_instructions = core.call intrinsic.is_not_none(%instructions)
      core.if %has_instructions {
        core.set %payload["instructions"] = %instructions
      } else {
      }
      core.set %payload["input"] = %input
      %empty_functions = core.list
      %functions = core.get %request["functions"] default %empty_functions
      %has_functions = core.call intrinsic.truthy(%functions)
      core.if %has_functions {
        %tools = core.list
        core.for %fn in %functions {
          %tool = core.call @openai_responses_tool_spec_impl(%fn)
          core.append %tools, %tool
        }
        core.set %payload["tools"] = %tools
        %tool_choice = core.get %request["function_call"] default "auto"
        core.set %payload["tool_choice"] = %tool_choice
      } else {
      }
      %response_format = core.get %request["response_format"]
      %has_response_format = core.call intrinsic.truthy(%response_format)
      core.if %has_response_format {
        %format_type = core.get %response_format["type"] default "text"
        %is_json_schema = core.call intrinsic.eq(%format_type, "json_schema")
        %format = core.map
        core.if %is_json_schema {
          %schema = core.get %response_format["schema"]
          core.set %format["type"] = "json_schema"
          core.set %format["json_schema"] = %schema
        } else {
          core.set %format["type"] = %format_type
        }
        %text_config = core.map
        core.set %text_config["format"] = %format
        core.set %payload["text"] = %text_config
      } else {
      }
      %empty_model_config = core.map
      %model_config = core.get %request["model_config"] default %empty_model_config
      %stream = core.get %model_config["stream"] default false
      core.set %payload["stream"] = %stream
      core.call @openai_responses_apply_model_config_impl(%payload, %model_config)
      %reasoning = core.get %model_config["reasoning"]
      %has_reasoning = core.call intrinsic.truthy(%reasoning)
      core.if %has_reasoning {
        core.set %payload["reasoning"] = %reasoning
      } else {
      }
      %include = core.get %model_config["include"]
      %has_include = core.call intrinsic.truthy(%include)
      core.if %has_include {
        core.set %payload["include"] = %include
      } else {
      }
      %parallel = core.get %model_config["parallel_tool_calls"]
      %has_parallel = core.call intrinsic.is_not_none(%parallel)
      core.if %has_parallel {
        core.set %payload["parallel_tool_calls"] = %parallel
      } else {
      }
      core.return %payload
    }
  }

  op ax.provider.semantic @openai_responses_apply_model_config_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "openai-responses-model-config-core-helper"
    type signature = "(json, json) -> void"
    body @entry(%payload: json, %model_config: json) {
      core.call @openai_copy_config_key_impl(%payload, %model_config, "maxTokens", "max_output_tokens")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "max_tokens", "max_output_tokens")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "temperature", "temperature")
