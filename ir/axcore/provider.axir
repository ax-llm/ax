  op ax.provider.semantic @grok_build_speak_request {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "src/ax/ai/x-grok/api.ts"
    type signature = "(json) -> json"
    body @entry(%request: json) {
      %payload = core.map
      %request_input = core.get %request["input"] default ""
      %text = core.get %request["text"] default %request_input
      %voice = core.get %request["voice"] default "eve"
      %voice_id = core.get %voice["id"] default %voice
      %language = core.get %request["language"] default "auto"
      %format = core.get %request["format"] default "mp3"
      %is_pcm16 = core.call intrinsic.eq(%format, "pcm16")
      %is_raw = core.call intrinsic.eq(%format, "raw")
      %is_pcm_like = core.call intrinsic.or(%is_pcm16, %is_raw)
      %codec = core.let %format
      core.if %is_pcm_like {
        %codec = core.let "pcm"
      } else {
        %is_ulaw = core.call intrinsic.eq(%format, "ulaw")
        core.if %is_ulaw {
          %codec = core.let "mulaw"
        }
      }
      %output_format = core.map
      core.set %output_format["codec"] = %codec
      %sample_rate_alt = core.get %request["sample_rate"]
      %sample_rate = core.get %request["sampleRate"] default %sample_rate_alt
      %has_sample_rate = core.call intrinsic.is_not_none(%sample_rate)
      core.if %has_sample_rate {
        core.set %output_format["sample_rate"] = %sample_rate
      }
      core.set %payload["text"] = %text
      core.set %payload["voice_id"] = %voice_id
      core.set %payload["language"] = %language
      core.set %payload["output_format"] = %output_format
      core.return %payload
    }
  }

