\"web_search\":false,\"context_fetching\":false}},\"caching\":{\"supported\":false,\"types\":[]}}},\"grok\":{\"provider\":\"grok\",\"id\":\"grok\",\"name\":\"Grok\",\"baseUrl\":\"https://api.x.ai/v1\",\"auth\":\"bearer\",\"defaultModel\":\"grok-4.3\",\"operations\":{\"chat\":{\"method\":\"POST\",\"path\":\"/chat/completions\",\"body\":\"json\",\"stream\":false},\"stream_chat\":{\"method\":\"POST\",\"path\":\"/chat/completions\",\"body\":\"json\",\"stream\":true}},\"features\":{\"functions\":true,\"streaming\":true,\"structured_outputs\":true,\"multi_turn\":true,\"thinking\":true,\"media\":{\"images\":{\"supported\":true,\"formats\":[\"image/jpeg\",\"image/png\"],\"maxSize\":20971520},\"audio\":{\"supported\":false,\"formats\":[],\"output\":{\"supported\":false,\"formats\":[]}},\"files\":{\"supported\":false,\"formats\":[],\"upload_method\":\"none\"},\"urls\":{\"supported\":false,\"web_search\":true,\"context_fetching\":false}},\"caching\":{\"supported\":false,\"types\":[]}}}}")
      %openai_family_descriptor = core.get %openai_family[%provider_id]
      %is_openai_family = core.call intrinsic.is_not_none(%openai_family_descriptor)
      core.if %is_openai_family {
        %is_grok_family = core.call intrinsic.eq(%provider_id, "grok")
        core.if %is_grok_family {
          %family_operations = core.get %openai_family_descriptor["operations"]
          %grok_realtime_audio = core.call intrinsic.json.parse("{\"method\":\"WS\",\"path\":\"/realtime\",\"body\":\"events\",\"stream\":true,\"grammar\":\"openai_realtime_compatible\",\"url\":\"wss://api.x.ai/v1/realtime\",\"defaultModel\":\"grok-voice-think-fast-1.0\",\"audio\":{\"input\":{\"formats\":[\"pcm16\",\"pcm\"],\"sampleRate\":24000},\"output\":{\"formats\":[\"pcm16\",\"pcm\"],\"sampleRate\":24000,\"voices\":[\"eve\",\"ara\",\"rex\",\"sal\",\"leo\"],\"defaultVoice\":\"eve\"}},\"validation\":{\"structuredOutputWithAudio\":false}}")
          core.set %family_operations["realtime_audio"] = %grok_realtime_audio
          core.set %openai_family_descriptor["defaultRealtimeModel"] = "grok-voice-think-fast-1.0"
          %family_features = core.get %openai_family_descriptor["features"]
          %family_media = core.get %family_features["media"]
          %grok_audio = core.call intrinsic.json.parse("{\"supported\":true,\"formats\":[\"pcm16\",\"pcm\"],\"output\":{\"supported\":true,\"formats\":[\"pcm16\",\"pcm\"],\"voices\":[\"eve\",\"ara\",\"rex\",\"sal\",\"leo\"]},\"realtime\":true}")
          core.set %family_media["audio"] = %grok_audio
        } else {
        }
        core.return %openai_family_descriptor
      } else {
      }
      %is_responses = core.call intrinsic.eq(%provider_id, "openai-responses")
      %is_gemini = core.call intrinsic.eq(%provider_id, "google-gemini")
      %is_anthropic = core.call intrinsic.eq(%provider_id, "anthropic")
      %descriptor = core.map
      %operations = core.map
      %features = core.map
      %media = core.map
      %audio = core.map
      %audio_output = core.map
      core.set %descriptor["provider"] = %provider_id
      core.set %features["functions"] = true
      core.set %features["streaming"] = true
      core.set %features["structured_outputs"] = true
      core.set %features["multi_turn"] = true
      core.set %features["thinking"] = false
      %image_media = core.call intrinsic.json.parse("{\"supported\":true,\"formats\":[\"image/jpeg\",\"image/png\",\"image/webp\"]}")
      core.set %media["images"] = %image_media
      core.if %is_responses {
        core.set %descriptor["baseUrl"] = "https://api.openai.com/v1"
        core.set %descriptor["auth"] = "bearer"
        core.set %descriptor["id"] = "openai-responses"
        core.set %descriptor["name"] = "openai-responses"
        core.set %descriptor["defaultModel"] = "gpt-4o"
        core.set %descriptor["defaultEmbedModel"] = "text-embedding-ada-002"
        %responses_chat = core.call intrinsic.json.parse("{\"method\":\"POST\",\"path\":\"/responses\",\"body\":\"json\",\"stream\":false}")
        %responses_stream = core.call intrinsic.json.parse("{\"method\":\"POST\",\"path\":\"/responses\",\"body\":\"json\",\"stream\":true}")
        %responses_embed = core.call intrinsic.json.parse("{\"method\":\"POST\",\"path\":\"/embeddings\",\"body\":\"json\",\"stream\":false}")
        %responses_transcribe = core.call intrinsic.json.parse("{\"method\":\"POST\",\"path\":\"/audio/transcriptions\",\"body\":\"multipart\",\"stream\":false}")
        %responses_speak = core.call intrinsic.json.parse("{\"method\":\"POST\",\"path\":\"/audio/speech\",\"body\":\"json\",\"stream\":false}")
        %responses_realtime = core.call intrinsic.json.parse("{\"method\":\"WS\",\"path\":\"/realtime\",\"body\":\"events\",\"stream\":true}")
        %responses_realtime_audio = core.call intrinsic.json.parse("{\"method\":\"WS\",\"path\":\"/realtime\",\"body\":\"events\",\"stream\":true,\"grammar\":\"openai_realtime_compatible\",\"audio\":{\"input\":{\"formats\":[\"pcm16\",\"pcm\"],\"sampleRate\":24000},\"output\":{\"formats\":[\"pcm16\",\"pcm\"],\"sampleRate\":24000,\"voices\":[\"alloy\",\"ash\",\"ballad\",\"coral\",\"echo\",\"sage\",\"shimmer\",\"verse\"],\"defaultVoice\":\"alloy\"}},\"validation\":{\"structuredOutputWithAudio\":false}}")
        core.set %operations["chat"] = %responses_chat
        core.set %operations["stream_chat"] = %responses_stream
        core.set %operations["embed"] = %responses_embed
        core.set %operations["transcribe"] = %responses_transcribe
        core.set %operations["speak"] = %responses_speak
        core.set %operations["realtime"] = %responses_realtime
        core.set %operations["realtime_audio"] = %responses_realtime_audio
        core.set %audio["supported"] = true
        %audio_formats = core.call intrinsic.json.parse("[\"wav\",\"mp3\",\"pcm16\"]")
        core.set %audio["formats"] = %audio_formats
        core.set %audio_output["supported"] = true
        core.set %audio_output["formats"] = %audio_formats
      } else {
        core.if %is_gemini {
          core.set %descriptor["baseUrl"] = "https://generativelanguage.googleapis.com/v1beta"
          core.set %descriptor["auth"] = "api_key_query"
          core.set %descriptor["apiKeyQuery"] = "key"
          core.set %descriptor["id"] = "google-gemini"
          core.set %descriptor["name"] = "GoogleGeminiAI"
          core.set %descriptor["defaultModel"] = "gemini-2.5-flash"
          core.set %descriptor["defaultEmbedModel"] = "gemini-embedding-2"
          %gemini_chat = core.call intrinsic.json.parse("{\"method\":\"POST\",\"path\":\"/models/{model}:generateContent\",\"body\":\"json\",\"stream\":false}")
          %gemini_stream = core.call intrinsic.json.parse("{\"method\":\"POST\",\"path\":\"/models/{model}:streamGenerateContent?alt=sse\",\"body\":\"json\",\"stream\":true}")
          %gemini_embed = core.call intrinsic.json.parse("{\"method\":\"POST\",\"path\":\"/models/{model}:batchEmbedContents\",\"body\":\"json\",\"stream\":false}")
          %gemini_realtime_audio = core.call intrinsic.json.parse("{\"method\":\"WS\",\"path\":\"/ws/google.ai.generativelanguage.v1beta.GenerativeService.BidiGenerateContent\",\"body\":\"events\",\"stream\":true,\"grammar\":\"gemini_live_bidi\",\"defaultModel\":\"gemini-2.5-flash-native-audio-preview-12-2025\",\"audio\":{\"input\":{\"formats\":[\"pcm16\",\"pcm\"],\"sampleRate\":16000},\"output\":{\"formats\":[\"pcm16\",\"pcm\"],\"sampleRate\":24000,\"voices\":[\"Kore\",\"Puck\",\"Charon\",\"Fenrir\",\"Aoede\"],\"defaultVoice\":\"Kore\"}},\"validation\":{\"pcmInputOnly\":true,\"rejectStructuredOutputWithAudio\":true}}")
          core.set %operations["chat"] = %gemini_chat
          core.set %operations["stream_chat"] = %gemini_stream
          core.set %operations["embed"] = %gemini_embed
          core.set %operations["realtime_audio"] = %gemini_realtime_audio
          %gemini_images = core.call intrinsic.json.parse("{\"supported\":true,\"formats\":[\"image/jpeg\",\"image/png\",\"image/gif\",\"image/webp\"],\"maxSize\":20971520}")
          core.set %media["images"] = %gemini_images
          core.set %audio["supported"] = true
          %gemini_audio_formats = core.call intrinsic.json.parse("[\"wav\",\"mp3\",\"aac\",\"ogg\"]")
          core.set %audio["formats"] = %gemini_audio_formats
          core.set %audio_output["supported"] = true
          %gemini_audio_output_formats = core.call intrinsic.json.parse("[\"pcm16\",\"pcm\"]")
          core.set %audio_output["formats"] = %gemini_audio_output_formats
          %gemini_audio_voices = core.call intrinsic.json.parse("[\"Kore\",\"Puck\",\"Charon\",\"Fenrir\",\"Aoede\"]")
          core.set %audio_output["voices"] = %gemini_audio_voices
          %gemini_files = core.call intrinsic.json.parse("{\"supported\":true,\"formats\":[\"application/pdf\",\"text/plain\",\"text/csv\",\"text/html\",\"text/xml\"],\"upload_method\":\"cloud\"}")
          core.set %media["files"] = %gemini_files
          %gemini_urls = core.call intrinsic.json.parse("{\"supported\":true,\"web_search\":true,\"context_fetching\":true}")
          core.set %media["urls"] = %gemini_urls
          %gemini_caching = core.call intrinsic.json.parse("{\"supported\":true,\"types\":[\"persistent\"]}")
          core.set %features["caching"] = %gemini_caching
          core.set %features["thinking"] = true
        } else {
          core.if %is_anthropic {
            core.set %descriptor["baseUrl"] = "https://api.anthropic.com/v1"
            core.set %descriptor["auth"] = "anthropic_key"
            core.set %descriptor["id"] = "anthropic"
            core.set %descriptor["name"] = "anthropic"
            core.set %descriptor["defaultModel"] = "claude-3-7-sonnet-latest"
            %extra_headers = core.call intrinsic.json.parse("{\"anthropic-version\":\"2023-06-01\",\"anthropic-beta\":\"structured-outputs-2025-11-13, web-search-2025-03-05\"}")
            core.set %descriptor["headers"] = %extra_headers
            %anthropic_chat = core.call intrinsic.json.parse("{\"method\":\"POST\",\"path\":\"/messages\",\"body\":\"json\",\"stream\":false}")
            %anthropic_stream = core.call intrinsic.json.parse("{\"method\":\"POST\",\"path\":\"/messages\",\"body\":\"json\",\"stream\":true}")
            core.set %operations["chat"] = %anthropic_chat
            core.set %operations["stream_chat"] = %anthropic_stream
            %anthropic_images = core.call intrinsic.json.parse("{\"supported\":true,\"formats\":[\"image/jpeg\",\"image/png\",\"image/gif\",\"image/webp\"]}")
            core.set %media["images"] = %anthropic_images
            core.set %audio["supported"] = false
            %empty_anthropic_audio_formats = core.list
            core.set %audio["formats"] = %empty_anthropic_audio_formats
            core.set %audio_output["supported"] = false
            core.set %audio_output["formats"] = %empty_anthropic_audio_formats
            %anthropic_caching = core.call intrinsic.json.parse("{\"supported\":true,\"types\":[\"ephemeral_block\"]}")
            core.set %features["caching"] = %anthropic_caching
            core.set %features["thinking"] = true
          } else {
            core.set %descriptor["baseUrl"] = "https://api.openai.com/v1"
            core.set %descriptor["auth"] = "bearer"
            core.set %descriptor["id"] = "openai-compatible"
            core.set %descriptor["name"] = "openai"
            core.set %descriptor["defaultModel"] = "gpt-4.1-mini"
            core.set %descriptor["defaultEmbedModel"] = "text-embedding-3-small"
            %compatible_chat = core.call intrinsic.json.parse("{\"method\":\"POST\",\"path\":\"/chat/completions\",\"body\":\"json\",\"stream\":false}")
            %compatible_stream = core.call intrinsic.json.parse("{\"method\":\"POST\",\"path\":\"/chat/completions\",\"body\":\"json\",\"stream\":true}")
            %compatible_embed = core.call intrinsic.json.parse("{\"method\":\"POST\",\"path\":\"/embeddings\",\"body\":\"json\",\"stream\":false}")
            core.set %operations["chat"] = %compatible_chat
            core.set %operations["stream_chat"] = %compatible_stream
            core.set %operations["embed"] = %compatible_embed
            core.set %audio["supported"] = false
            %empty_audio_formats = core.list
            core.set %audio["formats"] = %empty_audio_formats
            core.set %audio_output["supported"] = false
            core.set %audio_output["formats"] = %empty_audio_formats
          }
        }
      }
      core.set %audio["output"] = %audio_output
      core.set %media["audio"] = %audio
      %existing_files = core.get %media["files"]
      %has_files = core.call intrinsic.is_not_none(%existing_files)
      core.if %has_files {
      } else {
        %files_media = core.call intrinsic.json.parse("{\"supported\":false,\"formats\":[],\"upload_method\":\"none\"}")
        core.set %media["files"] = %files_media
      }
      %existing_urls = core.get %media["urls"]
      %has_urls = core.call intrinsic.is_not_none(%existing_urls)
      core.if %has_urls {
      } else {
        %urls_media = core.call intrinsic.json.parse("{\"supported\":false,\"web_search\":false,\"context_fetching\":false}")
        core.set %media["urls"] = %urls_media
      }
      core.set %features["media"] = %media
      %existing_caching = core.get %features["caching"]
      %has_caching = core.call intrinsic.is_not_none(%existing_caching)
      core.if %has_caching {
      } else {
        %caching = core.call intrinsic.json.parse("{\"supported\":false,\"types\":[]}")
        core.set %features["caching"] = %caching
      }
      core.set %descriptor["operations"] = %operations
      core.set %descriptor["features"] = %features
      core.return %descriptor
    }
  }

  op ax.provider.semantic @provider_operation_descriptor {
    attr core_kind = "func"
    attr emit_module = "ai"
    tag "provider-operation-descriptor"
    type signature = "(profile:string, operation:string) -> json"
    body @entry(%profile: string, %operation: string) {
      %descriptor = core.call @provider_descriptor(%profile)
      %operations = core.get %descriptor["operations"]
      %operation_desc = core.get %operations[%operation]
      %missing = core.call intrinsic.is_none(%operation_desc)
      core.if %missing {
        %message = core.call intrinsic.string.format("provider operation is not supported: {}", %operation)
        %error = core.call intrinsic.ai.error.unsupported(%message)
        core.raise %error
      } else {
      }
      core.return %operation_desc
    }
  }

  op ax.provider.semantic @provider_realtime_audio_descriptor {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr effect = "throws"
    tag "provider-realtime-audio-descriptor"
    type signature = "(profile:string) -> json throws"
    body @entry(%profile: string) {
      %descriptor = core.call @provider_operation_descriptor(%profile, "realtime_audio")
      core.return %descriptor
    }
  }

  op ax.provider.semantic @provider_build_realtime_audio_setup {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr effect = "throws"
    tag "provider-realtime-audio-operation"
    type signature = "(profile:string, request:json) -> json throws"
    body @entry(%profile: string, %request: json) {
      %descriptor = core.call @provider_realtime_audio_descriptor(%profile)
      %grammar = core.get %descriptor["grammar"] default "openai_realtime_compatible"
      %is_gemini_live = core.call intrinsic.eq(%grammar, "gemini_live_bidi")
      core.if %is_gemini_live {
        %setup = core.call @gemini_live_bidi_build_setup(%descriptor, %request)
        core.return %setup
      } else {
      }
      %openai_setup = core.call @openai_realtime_compatible_build_setup(%descriptor, %request)
      core.return %openai_setup
    }
  }

  op ax.provider.semantic @provider_build_realtime_audio_input {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr effect = "throws"
    tag "provider-realtime-audio-operation"
    type signature = "(profile:string, request:json) -> list<json> throws"
    body @entry(%profile: string, %request: json) {
      %descriptor = core.call @provider_realtime_audio_descriptor(%profile)
      %grammar = core.get %descriptor["grammar"] default "openai_realtime_compatible"
      %is_gemini_live = core.call intrinsic.eq(%grammar, "gemini_live_bidi")
      core.if %is_gemini_live {
        %input = core.call @gemini_live_bidi_build_input(%descriptor, %request)
        core.return %input
      } else {
      }
      %openai_input = core.call @openai_realtime_compatible_build_input(%descriptor, %request)
      core.return %openai_input
    }
  }

  op ax.provider.semantic @openai_realtime_compatible_build_setup {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "openai-compatible-realtime-audio-core-helper"
    type signature = "(descriptor:json, request:json) -> json"
    body @entry(%descriptor: json, %request: json) {
      %audio_descriptor = core.get %descriptor["audio"]
      %output_audio_descriptor = core.get %audio_descriptor["output"]
      %default_voice = core.get %output_audio_descriptor["defaultVoice"] default "alloy"
      %request_audio = core.get %request["audio"]
      %request_output_audio = core.get %request_audio["output"]
      %request_voice = core.get %request_output_audio["voice"] default %default_voice
      %voice_id = core.get %request_voice["id"] default %request_voice
      %output_rate = core.get %request_output_audio["sampleRate"]
      %output_rate_snake = core.get %request_output_audio["sample_rate"] default %output_rate
      %default_output_rate = core.get %output_audio_descriptor["sampleRate"] default 24000
      %output_sample_rate = core.get %request_output_audio["rate"] default %output_rate_snake
      %has_output_sample_rate = core.call intrinsic.is_not_none(%output_sample_rate)
      core.if %has_output_sample_rate {
      } else {
        %output_sample_rate = core.let %default_output_rate
      }
      %input_audio_descriptor = core.get %audio_descriptor["input"]
      %request_input_audio = core.get %request_audio["input"]
      %input_rate = core.get %request_input_audio["sampleRate"]
      %input_rate_snake = core.get %request_input_audio["sample_rate"] default %input_rate
      %default_input_rate = core.get %input_audio_descriptor["sampleRate"] default 24000
      %input_sample_rate = core.get %request_input_audio["rate"] default %input_rate_snake
      %has_input_sample_rate = core.call intrinsic.is_not_none(%input_sample_rate)
      core.if %has_input_sample_rate {
      } else {
        %input_sample_rate = core.let %default_input_rate
      }
      %session = core.map
      core.set %session["voice"] = %voice_id
      %turn_detection_none = core.call intrinsic.none()
      core.set %session["turn_detection"] = %turn_detection_none
      %audio = core.map
      %input = core.map
      %input_format = core.map
      core.set %input_format["type"] = "audio/pcm"
      core.set %input_format["rate"] = %input_sample_rate
      core.set %input["format"] = %input_format
      core.set %audio["input"] = %input
      %output = core.map
      %output_format = core.map
      core.set %output_format["type"] = "audio/pcm"
      core.set %output_format["rate"] = %output_sample_rate
      core.set %output["format"] = %output_format
      core.set %audio["output"] = %output
      core.set %session["audio"] = %audio
      %modalities = core.call intrinsic.json.parse("[\"audio\"]")
      core.set %session["modalities"] = %modalities
      %instructions = core.call @realtime_request_system_instruction_impl(%request)
      %has_instructions = core.call intrinsic.truthy(%instructions)
      core.if %has_instructions {
        core.set %session["instructions"] = %instructions
      } else {
      }
      %out = core.map
      core.set %out["type"] = "session.update"
      core.set %out["session"] = %session
      core.return %out
    }
  }

  op ax.provider.semantic @openai_realtime_compatible_build_input {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "openai-compatible-realtime-audio-core-helper"
    type signature = "(descriptor:json, request:json) -> list<json>"
    body @entry(%descriptor: json, %request: json) {
      %events = core.list
      %messages = core.call @realtime_request_user_messages_impl(%request)
      core.for %message in %messages {
        %content = core.get %message["content"] default ""
        %parts = core.call @openai_realtime_content_parts_impl(%content)
        %item = core.map
        core.set %item["type"] = "message"
        core.set %item["role"] = "user"
        core.set %item["content"] = %parts
        %event = core.map
        core.set %event["type"] = "conversation.item.create"
        core.set %event["item"] = %item
        core.append %events, %event
      }
      %response = core.map
      %response_modalities = core.call intrinsic.json.parse("[\"audio\"]")
      core.set %response["modalities"] = %response_modalities
      %response_event = core.map
      core.set %response_event["type"] = "response.create"
      core.set %response_event["response"] = %response
      core.append %events, %response_event
      core.return %events
    }
