    body @entry(%event: json, %state: json, %ai_name: string, %model: string) {
      %type = core.get %event["type"] default ""
      %is_error = core.call intrinsic.eq(%type, "error")
      core.if %is_error {
        %error_body = core.get %event["error"]
        %message = core.get %error_body["message"] default "Anthropic stream error"
        %error = core.call intrinsic.ai.error.refusal(%message, %event)
        core.raise %error
      }
      %index = core.let 0
      %is_start = core.call intrinsic.eq(%type, "message_start")
      core.if %is_start {
        %message = core.get %event["message"]
        %id = core.get %message["id"] default ""
        core.set %state["remote_id"] = %id
        %usage_raw = core.get %message["usage"]
        %usage = core.call @anthropic_usage_impl(%usage_raw)
        core.set %state["usage"] = %usage
        %result = core.map
        core.set %result["index"] = %index
