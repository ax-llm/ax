          %url = core.get %retrieved["uri"] default ""
          core.set %item["url"] = %url
          %title = core.get %retrieved["title"]
          %has_title = core.call intrinsic.is_not_none(%title)
          core.if %has_title {
            core.set %item["title"] = %title
