  op ax.provider.semantic @gemini_message_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr effect = "throws"
    attr private = true
    tag "gemini-message-core-helper"
    type signature = "(json) -> json throws"
    body @entry(%message: json) {
      %role = core.get %message["role"]
      %is_user = core.call intrinsic.eq(%role, "user")
      core.if %is_user {
        %content = core.get %message["content"] default ""
        %parts = core.call @gemini_content_parts_impl(%content)
        %out = core.map
        core.set %out["role"] = "user"
        core.set %out["parts"] = %parts
        core.return %out
      } else {
      }
      %is_assistant = core.call intrinsic.eq(%role, "assistant")
      core.if %is_assistant {
        %parts = core.list
        %content = core.get %message["content"] default ""
        %has_content = core.call intrinsic.truthy(%content)
        core.if %has_content {
          %text_part = core.map
          core.set %text_part["text"] = %content
          core.append %parts, %text_part
        } else {
        }
        %empty_calls = core.list
        %calls = core.get %message["function_calls"] default %empty_calls
        %calls_camel = core.get %message["functionCalls"] default %calls
        core.for %call in %calls_camel {
          %function = core.get %call["function"]
          %name = core.get %function["name"]
          %empty_args = core.map
          %args = core.get %function["params"] default %empty_args
          %args_is_string = core.type_is %args type "string"
          core.if %args_is_string {
            core.try {
              %parsed = core.call intrinsic.json.parse(%args)
              %args = core.let %parsed
            } catch %parse_error {
              %args = core.map
            }
          } else {
          }
          %function_call = core.map
          core.set %function_call["name"] = %name
          core.set %function_call["args"] = %args
          %part = core.map
          core.set %part["functionCall"] = %function_call
          core.append %parts, %part
        }
        %out = core.map
        core.set %out["role"] = "model"
        core.set %out["parts"] = %parts
        core.return %out
      } else {
      }
      %is_function = core.call intrinsic.eq(%role, "function")
      core.if %is_function {
        %name = core.get %message["name"]
        %function_id = core.get %message["function_id"] default %name
        %function_id_camel = core.get %message["functionId"] default %function_id
        %result_value = core.get %message["result"]
        %response = core.map
        core.set %response["result"] = %result_value
        %function_response = core.map
        core.set %function_response["name"] = %function_id_camel
        core.set %function_response["response"] = %response
        %part = core.map
        core.set %part["functionResponse"] = %function_response
        %parts = core.list
        core.append %parts, %part
        %out = core.map
        core.set %out["role"] = "user"
        core.set %out["parts"] = %parts
        core.return %out
      } else {
      }
