      core.call @openai_copy_config_key_impl(%payload, %model_config, "temperature", "temperature")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "topP", "top_p")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "top_p", "top_p")
