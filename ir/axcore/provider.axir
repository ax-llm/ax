      %default_voice = core.get %output_audio_descriptor["defaultVoice"] default "Kore"
      %voice = core.get %request_output_audio["voice"] default %default_voice
      %voice_name = core.get %voice["name"] default %voice
      %setup = core.map
      core.set %setup["model"] = %model
      %generation_config = core.map
      %modalities = core.call intrinsic.json.parse("[\"AUDIO\"]")
      core.set %generation_config["responseModalities"] = %modalities
      %speech_config = core.map
      %voice_config = core.map
      %prebuilt_voice = core.map
      core.set %prebuilt_voice["voiceName"] = %voice_name
      core.set %voice_config["prebuiltVoiceConfig"] = %prebuilt_voice
      core.set %speech_config["voiceConfig"] = %voice_config
      core.set %generation_config["speechConfig"] = %speech_config
      core.set %setup["generationConfig"] = %generation_config
      %include_transcript = core.get %request_output_audio["transcript"] default true
      core.if %include_transcript {
        %transcript = core.map
        core.set %setup["outputAudioTranscription"] = %transcript
      } else {
      }
      %instructions = core.call @realtime_request_system_instruction_impl(%request)
      %has_instructions = core.call intrinsic.truthy(%instructions)
      core.if %has_instructions {
