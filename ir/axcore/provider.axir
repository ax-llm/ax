              %next_image = core.map
              core.set %next_image["url"] = %url
              core.set %part["image_url"] = %next_image
            } else {
            }
          }
        } else {
        }
      }
      core.return %payload
    }
  }

  op ax.provider.semantic @provider_apply_grok_chat_quirks {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "grok-openai-compatible-quirks"
    type signature = "(payload:json, request:json, model_config:json) -> json"
    body @entry(%payload: json, %request: json, %model_config: json) {
      %model = core.get %payload["model"] default ""
      %is_grok43 = core.call intrinsic.eq(%model, "grok-4.3")
      %is_grok43_latest = core.call intrinsic.eq(%model, "grok-4.3-latest")
      %is_grok43_any = core.call intrinsic.or(%is_grok43, %is_grok43_latest)
      core.if %is_grok43_any {
        %budget_snake = core.get %model_config["thinking_token_budget"]
