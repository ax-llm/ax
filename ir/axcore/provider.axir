        core.return "length"
      } else {
      }
      %is_tool = core.call intrinsic.eq(%reason, "tool_use")
      core.if %is_tool {
        core.return "function_call"
      } else {
      }
      %is_refusal = core.call intrinsic.eq(%reason, "refusal")
      core.if %is_refusal {
        core.return "content_filter"
      } else {
      }
      core.return "stop"
    }
  }

  op ax.provider.semantic @anthropic_usage_impl {
    attr core_kind = "func"
