        core.if %has_thinking {
          core.set %payload["thinking"] = %thinking
        } else {
        }
        %output_config = core.get %thinking_config["output_config"]
        %has_output = core.call intrinsic.is_not_none(%output_config)
        core.if %has_output {
          core.set %payload["output_config"] = %output_config
        } else {
        }
      } else {
      }
      %effort = core.get %model_config["effort"]
      %has_effort = core.call intrinsic.truthy(%effort)
      core.if %has_effort {
        %output_config = core.get %payload["output_config"] default %model_config
        core.set %output_config["effort"] = %effort
        core.set %payload["output_config"] = %output_config
      } else {
      }
      core.return
    }
  }

  op ax.provider.semantic @anthropic_thinking_config_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "anthropic-thinking-core-helper"
    type signature = "(string, string) -> json"
    body @entry(%model: string, %level: string) {
      %out = core.map
      %is_none = core.call intrinsic.eq(%level, "none")
      core.if %is_none {
        core.return %out
      } else {
      }
      %budget = core.let 10000
      %effort = core.let "medium"
      %is_minimal = core.call intrinsic.eq(%level, "minimal")
      core.if %is_minimal {
        %budget = core.let 1024
        %effort = core.let "low"
      } else {
      }
      %is_low = core.call intrinsic.eq(%level, "low")
      core.if %is_low {
        %budget = core.let 5000
        %effort = core.let "low"
      } else {
      }
      %is_high = core.call intrinsic.eq(%level, "high")
      core.if %is_high {
        %budget = core.let 20000
        %effort = core.let "high"
      } else {
      }
      %is_highest = core.call intrinsic.eq(%level, "highest")
      core.if %is_highest {
        %budget = core.let 32000
        %effort = core.let "max"
      } else {
      }
      %is_48 = core.call intrinsic.string.starts_with(%model, "claude-opus-4-8")
      %is_47 = core.call intrinsic.string.starts_with(%model, "claude-opus-4-7")
      %is_46 = core.call intrinsic.string.starts_with(%model, "claude-opus-4-6")
      %is_47_plus = core.call intrinsic.or(%is_48, %is_47)
      %is_adaptive = core.call intrinsic.or(%is_47_plus, %is_46)
      core.if %is_adaptive {
        %thinking = core.map
        core.set %thinking["type"] = "adaptive"
        core.set %out["thinking"] = %thinking
        %output_config = core.map
        core.set %output_config["effort"] = %effort
        core.set %out["output_config"] = %output_config
      } else {
        %thinking = core.map
        core.set %thinking["type"] = "enabled"
        core.set %thinking["budget_tokens"] = %budget
        core.set %out["thinking"] = %thinking
        %is_45 = core.call intrinsic.string.starts_with(%model, "claude-opus-4-5")
        core.if %is_45 {
          %output_config = core.map
          %is_max = core.call intrinsic.eq(%effort, "max")
          core.if %is_max {
            core.set %output_config["effort"] = "high"
          } else {
