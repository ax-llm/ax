        core.set %part["text"] = %instructions
        %parts = core.list
        core.append %parts, %part
        %system_instruction = core.map
        core.set %system_instruction["parts"] = %parts
        core.set %setup["systemInstruction"] = %system_instruction
      } else {
      }
      %out = core.map
      core.set %out["setup"] = %setup
      core.return %out
    }
