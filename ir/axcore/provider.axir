      %completion = core.get %usage["output_tokens"] default 0
      %cache_creation = core.get %usage["cache_creation_input_tokens"] default 0
      %cache_read = core.get %usage["cache_read_input_tokens"] default 0
      %total_base = core.call intrinsic.add(%prompt, %completion)
      %total_cache = core.call intrinsic.add(%cache_creation, %cache_read)
      %total = core.call intrinsic.add(%total_base, %total_cache)
      core.set %out["prompt_tokens"] = %prompt
      core.set %out["completion_tokens"] = %completion
      core.set %out["total_tokens"] = %total
      %has_creation = core.call intrinsic.gt(%cache_creation, 0)
      core.if %has_creation {
        core.set %out["cache_creation_tokens"] = %cache_creation
      } else {
      }
      %has_read = core.call intrinsic.gt(%cache_read, 0)
      core.if %has_read {
        core.set %out["cache_read_tokens"] = %cache_read
      } else {
      }
      %speed = core.get %usage["speed"]
      %has_speed = core.call intrinsic.is_not_none(%speed)
      core.if %has_speed {
        core.set %out["speed"] = %speed
      } else {
      }
      core.return %out
    }
  }

