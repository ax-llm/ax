  op ax.provider.semantic @provider_model_catalog {
    attr core_kind = "func"
    attr emit_module = "ai"
    tag "provider-model-catalog-runtime"
    type signature = "(options:json) -> json"
    body @entry(%options: json) {
      %registry = core.call @provider_model_catalog_registry()
      %type_raw = core.let "all"
      %options_is_string = core.type_is %options type "string"
      core.if %options_is_string {
        %type_raw = core.let %options
      } else {
        %empty_map = core.map
        %opts = core.let %options
        %opts_missing = core.call intrinsic.is_none(%opts)
        core.if %opts_missing {
          %opts = core.let %empty_map
        }
        %candidate = core.get %opts["type"] default "all"
        %candidate_is_list = core.type_is %candidate type "list"
        core.if %candidate_is_list {
          %type_raw = core.call intrinsic.list.get(%candidate, 0, "all")
        } else {
          %type_raw = core.let %candidate
        }
      }
      %type_name = core.call intrinsic.string.lower(%type_raw)
      %selected = core.get %registry[%type_name] default null
      %missing = core.call intrinsic.is_none(%selected)
      core.if %missing {
        %selected = core.get %registry["all"]
      }
      core.return %selected
    }
  }

  op ax.provider.semantic @provider_route_request_requirements {
    attr core_kind = "func"
    attr emit_module = "ai"
    tag "provider-routing-runtime"
    type signature = "(request:json) -> json"
    body @entry(%request: json) {
      %requirements = core.map
      core.set %requirements["hasImages"] = false
      core.set %requirements["hasAudio"] = false
      core.set %requirements["hasAudioOutput"] = false
      core.set %requirements["hasFiles"] = false
      core.set %requirements["hasUrls"] = false
      core.set %requirements["requiresFunctions"] = false
      core.set %requirements["requiresStreaming"] = false
      core.set %requirements["requiresCaching"] = false
      %content_types = core.list
      core.set %requirements["contentTypes"] = %content_types
      core.set %requirements["estimatedTokens"] = 0
      %empty_list = core.list
      %prompt = core.get %request["chatPrompt"] default %empty_list
      %prompt_count_initial = core.call intrinsic.len(%prompt)
      %prompt_empty = core.call intrinsic.eq(%prompt_count_initial, 0)
      core.if %prompt_empty {
        %prompt = core.get %request["chat_prompt"] default %prompt
      }
      core.for %message in %prompt {
        %content = core.get %message["content"] default null
        %content_is_list = core.type_is %content type "list"
        core.if %content_is_list {
          core.for %part in %content {
            %part_type = core.get %part["type"] default "text"
            %known_type = core.call intrinsic.contains(%content_types, %part_type)
            %new_type = core.call intrinsic.not(%known_type)
            core.if %new_type {
              core.append %content_types, %part_type
            }
            %is_image = core.call intrinsic.eq(%part_type, "image")
            core.if %is_image {
              core.set %requirements["hasImages"] = true
              %cached = core.get %part["cache"] default false
              core.if %cached {
                core.set %requirements["requiresCaching"] = true
              }
            }
            %is_audio = core.call intrinsic.eq(%part_type, "audio")
            core.if %is_audio {
              core.set %requirements["hasAudio"] = true
              %cached_audio = core.get %part["cache"] default false
              core.if %cached_audio {
                core.set %requirements["requiresCaching"] = true
              }
            }
            %is_file = core.call intrinsic.eq(%part_type, "file")
            core.if %is_file {
              core.set %requirements["hasFiles"] = true
              %cached_file = core.get %part["cache"] default false
              core.if %cached_file {
                core.set %requirements["requiresCaching"] = true
              }
            }
            %is_url = core.call intrinsic.eq(%part_type, "url")
            core.if %is_url {
              core.set %requirements["hasUrls"] = true
              %cached_url = core.get %part["cache"] default false
              core.if %cached_url {
                core.set %requirements["requiresCaching"] = true
              }
            }
            %cached_part = core.get %part["cache"] default false
            core.if %cached_part {
              core.set %requirements["requiresCaching"] = true
            }
          }
        }
        %message_cached = core.get %message["cache"] default false
        core.if %message_cached {
          core.set %requirements["requiresCaching"] = true
        }
      }
      %functions = core.get %request["functions"] default %empty_list
      %functions_count = core.call intrinsic.len(%functions)
      %has_functions = core.call intrinsic.gt(%functions_count, 0)
      core.if %has_functions {
        core.set %requirements["requiresFunctions"] = true
      }
      %model_config = core.get %request["modelConfig"] default null
      %model_config_missing = core.call intrinsic.is_none(%model_config)
      core.if %model_config_missing {
        %model_config = core.get %request["model_config"] default null
      }
      %stream = core.get %model_config["stream"] default false
      core.if %stream {
        core.set %requirements["requiresStreaming"] = true
      }
      %audio_config = core.get %model_config["audio"] default null
      %audio_output = core.get %audio_config["output"] default null
      %audio_output_enabled = core.get %audio_output["enabled"] default false
      core.if %audio_output_enabled {
        core.set %requirements["hasAudioOutput"] = true
      }
      %capabilities = core.get %request["capabilities"] default null
      %requires_images = core.get %capabilities["requiresImages"] default false
      core.if %requires_images {
        core.set %requirements["hasImages"] = true
      }
      %requires_audio = core.get %capabilities["requiresAudio"] default false
      core.if %requires_audio {
        core.set %requirements["hasAudio"] = true
      }
      %requires_audio_output = core.get %capabilities["requiresAudioOutput"] default false
      core.if %requires_audio_output {
        core.set %requirements["hasAudioOutput"] = true
      }
      %requires_files = core.get %capabilities["requiresFiles"] default false
      core.if %requires_files {
        core.set %requirements["hasFiles"] = true
      }
      %requires_web_search = core.get %capabilities["requiresWebSearch"] default false
      core.if %requires_web_search {
        core.set %requirements["hasUrls"] = true
      }
      core.return %requirements
    }
  }

  op ax.provider.semantic @provider_features_support {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "provider-routing-runtime"
    type signature = "(features:json, path:string) -> bool"
    body @entry(%features: json, %path: string) {
      %media = core.get %features["media"] default null
      %caching = core.get %features["caching"] default null
      %is_functions = core.call intrinsic.eq(%path, "functions")
      core.if %is_functions {
        %value = core.get %features["functions"] default false
        core.return %value
      }
      %is_streaming = core.call intrinsic.eq(%path, "streaming")
      core.if %is_streaming {
        %value_streaming = core.get %features["streaming"] default false
        core.return %value_streaming
      }
      %is_images = core.call intrinsic.eq(%path, "images")
      core.if %is_images {
        %images = core.get %media["images"] default null
        %value_images = core.get %images["supported"] default false
        core.return %value_images
      }
      %is_audio = core.call intrinsic.eq(%path, "audio")
      core.if %is_audio {
        %audio = core.get %media["audio"] default null
        %value_audio = core.get %audio["supported"] default false
        core.return %value_audio
      }
      %is_files = core.call intrinsic.eq(%path, "files")
      core.if %is_files {
        %files = core.get %media["files"] default null
        %value_files = core.get %files["supported"] default false
        core.return %value_files
      }
      %is_urls = core.call intrinsic.eq(%path, "urls")
      core.if %is_urls {
        %urls = core.get %media["urls"] default null
        %value_urls = core.get %urls["supported"] default false
        core.return %value_urls
      }
      %is_caching = core.call intrinsic.eq(%path, "caching")
      core.if %is_caching {
        %value_caching = core.get %caching["supported"] default false
        core.return %value_caching
      }
      core.return false
    }
  }

  op ax.provider.semantic @provider_route_score {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "provider-routing-runtime"
    type signature = "(provider:json, requirements:json) -> json"
    body @entry(%provider: json, %requirements: json) {
      %features = core.get %provider["features"] default null
      %score = core.let 10
      %missing = core.list
      %supported = core.list
      %needs_images = core.get %requirements["hasImages"] default false
      core.if %needs_images {
        %ok_images = core.call @provider_features_support(%features, "images")
        core.if %ok_images {
          %score = core.call intrinsic.add(%score, 25)
          core.append %supported, "Images"
        } else {
          core.append %missing, "Image support"
        }
      }
      %needs_audio = core.get %requirements["hasAudio"] default false
      core.if %needs_audio {
        %ok_audio = core.call @provider_features_support(%features, "audio")
        core.if %ok_audio {
          %score = core.call intrinsic.add(%score, 25)
          core.append %supported, "Audio"
        } else {
          core.append %missing, "Audio support"
        }
      }
      %needs_files = core.get %requirements["hasFiles"] default false
      core.if %needs_files {
        %ok_files = core.call @provider_features_support(%features, "files")
        core.if %ok_files {
          %score = core.call intrinsic.add(%score, 25)
          core.append %supported, "Files"
        } else {
          core.append %missing, "File support"
        }
      }
      %needs_urls = core.get %requirements["hasUrls"] default false
      core.if %needs_urls {
        %ok_urls = core.call @provider_features_support(%features, "urls")
        core.if %ok_urls {
          %score = core.call intrinsic.add(%score, 25)
          core.append %supported, "URLs"
        } else {
          core.append %missing, "URL/Web search support"
        }
      }
      %needs_functions = core.get %requirements["requiresFunctions"] default false
      core.if %needs_functions {
        %ok_functions = core.call @provider_features_support(%features, "functions")
        core.if %ok_functions {
          %score = core.call intrinsic.add(%score, 15)
          core.append %supported, "Functions"
        } else {
          core.append %missing, "Function calling"
        }
      }
      %needs_streaming = core.get %requirements["requiresStreaming"] default false
      core.if %needs_streaming {
        %ok_streaming = core.call @provider_features_support(%features, "streaming")
        core.if %ok_streaming {
          %score = core.call intrinsic.add(%score, 10)
          core.append %supported, "Streaming"
        } else {
          core.append %missing, "Streaming responses"
        }
      }
      %needs_caching = core.get %requirements["requiresCaching"] default false
      core.if %needs_caching {
        %ok_caching = core.call @provider_features_support(%features, "caching")
        core.if %ok_caching {
          %score = core.call intrinsic.add(%score, 8)
          core.append %supported, "Caching"
        } else {
          core.append %missing, "Content caching"
        }
      }
      %thinking = core.get %features["thinking"] default false
      core.if %thinking {
        %score = core.call intrinsic.add(%score, 2)
      }
      %multi_turn = core.get %features["multiTurn"] default null
      %multi_turn_missing = core.call intrinsic.is_none(%multi_turn)
      core.if %multi_turn_missing {
        %multi_turn = core.get %features["multi_turn"] default false
      }
      core.if %multi_turn {
        %score = core.call intrinsic.add(%score, 2)
      }
      %missing_count = core.call intrinsic.len(%missing)
      %penalty = core.call intrinsic.mul(%missing_count, -10)
      %score = core.call intrinsic.add(%score, %penalty)
      %score = core.call intrinsic.add(%score, 0)
      %out = core.map
      core.set %out["provider"] = %provider
      core.set %out["score"] = %score
      core.set %out["missingCapabilities"] = %missing
      core.set %out["supportedCapabilities"] = %supported
      core.return %out
    }
  }

  op ax.provider.semantic @provider_route_recommendation {
    attr core_kind = "func"
    attr emit_module = "ai"
    tag "provider-routing-runtime"
    type signature = "(providers:list<json>, request:json, options:json) -> json throws"
    body @entry(%providers: json, %request: json, %options: json) {
      %provider_count = core.call intrinsic.len(%providers)
      %has_providers = core.call intrinsic.gt(%provider_count, 0)
      %no_providers = core.call intrinsic.not(%has_providers)
      core.if %no_providers {
        %error = core.call intrinsic.error.runtime("Provider selection failed: No providers available")
        core.raise %error
      }
      %requirements = core.call @provider_route_request_requirements(%request)
      %best = core.call intrinsic.list.get(%providers, 0, null)
      %best_score = core.let -999999
      %best_missing = core.list
      core.for %provider in %providers {
        %score_entry = core.call @provider_route_score(%provider, %requirements)
        %score = core.get %score_entry["score"] default 0
        %better = core.call intrinsic.gt(%score, %best_score)
        core.if %better {
          %best_score = core.let %score
          %best = core.let %provider
          %best_missing = core.get %score_entry["missingCapabilities"] default %best_missing
        }
      }
      %require_exact = core.get %options["requireExactMatch"] default false
      %allow_degradation = core.get %options["allowDegradation"] default true
      %missing_count = core.call intrinsic.len(%best_missing)
      %has_missing = core.call intrinsic.gt(%missing_count, 0)
      core.if %require_exact {
        core.if %has_missing {
          %missing_text = core.call intrinsic.string.join(", ", %best_missing)
          %message = core.call intrinsic.string.format("Provider selection failed: No providers fully support the request requirements: {}", %missing_text)
          %error_exact = core.call intrinsic.error.runtime(%message)
          core.raise %error_exact
        }
      }
      %degradation_disallowed = core.call intrinsic.not(%allow_degradation)
      core.if %degradation_disallowed {
        core.if %has_missing {
          %best_name_for_error = core.get %best["name"] default "provider"
          %missing_text_no_degrade = core.call intrinsic.string.join(", ", %best_missing)
          %message_no_degrade = core.call intrinsic.string.format("Provider selection failed: Best available provider ({}) is missing: {}", %best_name_for_error, %missing_text_no_degrade)
          %error_no_degrade = core.call intrinsic.error.runtime(%message_no_degrade)
          core.raise %error_no_degrade
        }
      }
      %features = core.get %best["features"] default null
      %processing = core.list
      %degradations = core.list
      %warnings = core.list
      %needs_images = core.get %requirements["hasImages"] default false
      core.if %needs_images {
        %ok_images = core.call @provider_features_support(%features, "images")
        %missing_images = core.call intrinsic.not(%ok_images)
        core.if %missing_images {
          core.append %degradations, "Images will be converted to text descriptions"
          core.append %processing, "Image-to-text conversion"
        }
      }
      %needs_audio = core.get %requirements["hasAudio"] default false
      core.if %needs_audio {
        %ok_audio = core.call @provider_features_support(%features, "audio")
        %missing_audio = core.call intrinsic.not(%ok_audio)
        core.if %missing_audio {
          core.append %degradations, "Audio will be transcribed to text"
          core.append %processing, "Audio-to-text transcription"
        }
      }
      %needs_files = core.get %requirements["hasFiles"] default false
      core.if %needs_files {
        %ok_files = core.call @provider_features_support(%features, "files")
        %missing_files = core.call intrinsic.not(%ok_files)
        core.if %missing_files {
          core.append %degradations, "File content will be extracted to text"
          core.append %processing, "File-to-text extraction"
        }
      }
      %needs_urls = core.get %requirements["hasUrls"] default false
      core.if %needs_urls {
        %ok_urls = core.call @provider_features_support(%features, "urls")
        %missing_urls = core.call intrinsic.not(%ok_urls)
        core.if %missing_urls {
          core.append %degradations, "URL content will be pre-fetched"
          core.append %processing, "URL content fetching"
        }
      }
      %needs_streaming = core.get %requirements["requiresStreaming"] default false
      core.if %needs_streaming {
        %ok_streaming = core.call @provider_features_support(%features, "streaming")
        %missing_streaming = core.call intrinsic.not(%ok_streaming)
        core.if %missing_streaming {
          core.append %warnings, "Streaming not supported - will use non-streaming mode"
        }
      }
      %needs_caching = core.get %requirements["requiresCaching"] default false
      core.if %needs_caching {
        %ok_caching = core.call @provider_features_support(%features, "caching")
        %missing_caching = core.call intrinsic.not(%ok_caching)
        core.if %missing_caching {
          core.append %warnings, "Content caching not supported"
        }
      }
      %out = core.map
      core.set %out["provider"] = %best
      %provider_name = core.get %best["name"] default ""
      core.set %out["providerName"] = %provider_name
      core.set %out["processingApplied"] = %processing
      core.set %out["degradations"] = %degradations
      core.set %out["warnings"] = %warnings
      core.set %out["requirements"] = %requirements
      core.return %out
    }
  }

  op ax.provider.semantic @provider_route_any_supports {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "provider-routing-runtime"
    type signature = "(providers:list<json>, path:string) -> bool"
    body @entry(%providers: json, %path: string) {
      %ok = core.let false
      core.for %provider in %providers {
        %features = core.get %provider["features"] default null
        %supported = core.call @provider_features_support(%features, %path)
        core.if %supported {
          %ok = core.let true
        }
      }
      core.return %ok
    }
  }

  op ax.provider.semantic @provider_route_validation {
    attr core_kind = "func"
    attr emit_module = "ai"
    tag "provider-routing-runtime"
    type signature = "(providers:list<json>, request:json, processing:json, options:json) -> json throws"
    body @entry(%providers: json, %request: json, %processing: json, %options: json) {
      %issues = core.list
      %recommendations = core.list
      %result = core.map
      %recommendation = core.call @provider_route_recommendation(%providers, %request, %options)
      %degradations = core.get %recommendation["degradations"] default %issues
      core.for %degradation in %degradations {
        core.append %issues, %degradation
      }
      %warnings = core.get %recommendation["warnings"] default %issues
      core.for %warning in %warnings {
        core.append %issues, %warning
      }
      %degradation_count = core.call intrinsic.len(%degradations)
      %has_degradations = core.call intrinsic.gt(%degradation_count, 0)
      core.if %has_degradations {
        core.append %recommendations, "Consider using a provider that natively supports all media types"
      }
      %requirements = core.get %recommendation["requirements"] default null
      %needs_images = core.get %requirements["hasImages"] default false
      core.if %needs_images {
        %image_processor = core.get %processing["imageToText"] default null
        %has_image_processor = core.call intrinsic.is_not_none(%image_processor)
        %has_image_provider = core.call @provider_route_any_supports(%providers, "images")
        %no_image_processor = core.call intrinsic.not(%has_image_processor)
        %no_image_provider = core.call intrinsic.not(%has_image_provider)
        %image_problem = core.call intrinsic.and(%no_image_processor, %no_image_provider)
        core.if %image_problem {
          core.append %issues, "No image processing service available and no providers support images"
          core.append %recommendations, "Add imageToText processing service or use image-capable provider"
        }
      }
      %needs_audio = core.get %requirements["hasAudio"] default false
      core.if %needs_audio {
        %audio_processor = core.get %processing["audioToText"] default null
        %has_audio_processor = core.call intrinsic.is_not_none(%audio_processor)
        %has_audio_provider = core.call @provider_route_any_supports(%providers, "audio")
        %no_audio_processor = core.call intrinsic.not(%has_audio_processor)
        %no_audio_provider = core.call intrinsic.not(%has_audio_provider)
        %audio_problem = core.call intrinsic.and(%no_audio_processor, %no_audio_provider)
        core.if %audio_problem {
          core.append %issues, "No audio processing service available and no providers support audio"
          core.append %recommendations, "Add audioToText processing service or use audio-capable provider"
        }
      }
      %issue_count = core.call intrinsic.len(%issues)
      %no_issues = core.call intrinsic.eq(%issue_count, 0)
      %can_handle = core.call intrinsic.or(%no_issues, %has_degradations)
      core.set %result["canHandle"] = %can_handle
      core.set %result["issues"] = %issues
      core.set %result["recommendations"] = %recommendations
      core.return %result
    }
  }

  op ax.provider.semantic @provider_balancer_retry_policy {
    attr core_kind = "func"
    attr emit_module = "ai"
    tag "provider-balancer-runtime"
    type signature = "(options:json) -> json"
    body @entry(%options: json) {
      %out = core.map
      %strategy = core.get %options["strategy"] default "metric"
      core.set %out["strategy"] = %strategy
      %max_retries = core.get %options["maxRetries"] default null
      %max_retries_missing = core.call intrinsic.is_none(%max_retries)
      core.if %max_retries_missing {
        %max_retries = core.get %options["max_retries"] default 3
      }
      core.set %out["maxRetries"] = %max_retries
      %initial_backoff = core.get %options["initialBackoffMs"] default null
      %initial_backoff_missing = core.call intrinsic.is_none(%initial_backoff)
      core.if %initial_backoff_missing {
        %initial_backoff = core.get %options["initial_backoff_ms"] default 1000
      }
      core.set %out["initialBackoffMs"] = %initial_backoff
      %max_backoff = core.get %options["maxBackoffMs"] default null
      %max_backoff_missing = core.call intrinsic.is_none(%max_backoff)
      core.if %max_backoff_missing {
        %max_backoff = core.get %options["max_backoff_ms"] default 32000
      }
      core.set %out["maxBackoffMs"] = %max_backoff
      %debug = core.get %options["debug"] default true
      core.set %out["debug"] = %debug
      core.return %out
    }
  }

  op ax.provider.semantic @provider_balancer_metric_score {
    attr core_kind = "func"
    attr emit_module = "ai"
    tag "provider-balancer-runtime"
    type signature = "(metrics:json) -> number"
    body @entry(%metrics: json) {
      %latency = core.get %metrics["latency"] default null
      %chat = core.get %latency["chat"] default null
      %mean = core.get %chat["mean"] default 0
      core.return %mean
    }
  }

  op ax.provider.semantic @provider_balancer_candidate_allowed {
    attr core_kind = "func"
    attr emit_module = "ai"
    tag "provider-balancer-runtime"
    type signature = "(features:json, request:json) -> bool"
    body @entry(%features: json, %request: json) {
      %format = core.get %request["responseFormat"] default null
      %format_missing = core.call intrinsic.is_none(%format)
      core.if %format_missing {
        %format = core.get %request["response_format"] default null
      }
      %format_type = core.get %format["type"] default ""
      %requires_structured = core.call intrinsic.eq(%format_type, "json_schema")
      core.if %requires_structured {
        %structured = core.get %features["structuredOutputs"] default null
        %structured_missing = core.call intrinsic.is_none(%structured)
        core.if %structured_missing {
          %structured = core.get %features["structured_outputs"] default false
        }
        %no_structured = core.call intrinsic.not(%structured)
        core.if %no_structured {
          core.return false
        }
      }
      %capabilities = core.get %request["capabilities"] default null
      %media = core.get %features["media"] default null
      %requires_images = core.get %capabilities["requiresImages"] default null
      %requires_images_missing = core.call intrinsic.is_none(%requires_images)
      core.if %requires_images_missing {
        %requires_images = core.get %capabilities["requires_images"] default false
      }
      core.if %requires_images {
        %images = core.get %media["images"] default null
        %images_ok = core.get %images["supported"] default false
        %images_bad = core.call intrinsic.not(%images_ok)
        core.if %images_bad {
          core.return false
        }
      }
      %requires_audio = core.get %capabilities["requiresAudio"] default null
      %requires_audio_missing = core.call intrinsic.is_none(%requires_audio)
      core.if %requires_audio_missing {
        %requires_audio = core.get %capabilities["requires_audio"] default false
      }
      core.if %requires_audio {
        %audio = core.get %media["audio"] default null
        %audio_ok = core.get %audio["supported"] default false
        %audio_bad = core.call intrinsic.not(%audio_ok)
        core.if %audio_bad {
          core.return false
        }
      }
      core.return true
    }
  }

  op ax.provider.semantic @provider_routing_stats {
    attr core_kind = "func"
    attr emit_module = "ai"
    tag "provider-routing-runtime"
    type signature = "(providers:list<json>) -> json"
    body @entry(%providers: json) {
      %matrix = core.map
      %functions = core.list
      %streaming = core.list
      %images = core.list
      %audio = core.list
      %files = core.list
      %urls = core.list
      %caching = core.list
      core.for %provider in %providers {
        %name = core.get %provider["name"] default ""
        %features = core.get %provider["features"] default null
        %ok_functions = core.call @provider_features_support(%features, "functions")
        core.if %ok_functions {
          core.append %functions, %name
        }
        %ok_streaming = core.call @provider_features_support(%features, "streaming")
        core.if %ok_streaming {
          core.append %streaming, %name
        }
        %ok_images = core.call @provider_features_support(%features, "images")
        core.if %ok_images {
          core.append %images, %name
        }
        %ok_audio = core.call @provider_features_support(%features, "audio")
        core.if %ok_audio {
          core.append %audio, %name
        }
        %ok_files = core.call @provider_features_support(%features, "files")
        core.if %ok_files {
          core.append %files, %name
        }
        %ok_urls = core.call @provider_features_support(%features, "urls")
        core.if %ok_urls {
          core.append %urls, %name
        }
        %ok_caching = core.call @provider_features_support(%features, "caching")
        core.if %ok_caching {
          core.append %caching, %name
        }
      }
      %functions_count = core.call intrinsic.len(%functions)
      %has_functions = core.call intrinsic.gt(%functions_count, 0)
      core.if %has_functions {
        core.set %matrix["Functions"] = %functions
      }
      %streaming_count = core.call intrinsic.len(%streaming)
      %has_streaming = core.call intrinsic.gt(%streaming_count, 0)
      core.if %has_streaming {
        core.set %matrix["Streaming"] = %streaming
      }
      %images_count = core.call intrinsic.len(%images)
      %has_images = core.call intrinsic.gt(%images_count, 0)
      core.if %has_images {
        core.set %matrix["Images"] = %images
      }
      %audio_count = core.call intrinsic.len(%audio)
      %has_audio = core.call intrinsic.gt(%audio_count, 0)
      core.if %has_audio {
        core.set %matrix["Audio"] = %audio
      }
      %files_count = core.call intrinsic.len(%files)
      %has_files = core.call intrinsic.gt(%files_count, 0)
      core.if %has_files {
        core.set %matrix["Files"] = %files
      }
      %urls_count = core.call intrinsic.len(%urls)
      %has_urls = core.call intrinsic.gt(%urls_count, 0)
      core.if %has_urls {
        core.set %matrix["URLs"] = %urls
      }
      %caching_count = core.call intrinsic.len(%caching)
      %has_caching = core.call intrinsic.gt(%caching_count, 0)
      core.if %has_caching {
        core.set %matrix["Caching"] = %caching
      }
      %first = core.call intrinsic.list.get(%providers, 0, null)
      %recommended = core.get %first["name"] default "None"
      %out = core.map
      %total = core.call intrinsic.len(%providers)
      core.set %out["totalProviders"] = %total
      core.set %out["capabilityMatrix"] = %matrix
      core.set %out["recommendedProvider"] = %recommended
      core.return %out
    }
  }

