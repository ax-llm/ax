      core.call @openai_copy_config_key_impl(%payload, %model_config, "top_p", "top_p")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "presencePenalty", "presence_penalty")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "presence_penalty", "presence_penalty")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "frequencyPenalty", "frequency_penalty")
      core.call @openai_copy_config_key_impl(%payload, %model_config, "frequency_penalty", "frequency_penalty")
      core.return
    }
  }

