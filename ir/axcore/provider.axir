        core.set %out["remote_id"] = %id
        %model_usage = core.call @ai_model_usage_impl(%ai_name, %model, %usage)
        core.set %out["model_usage"] = %model_usage
        core.return %out
      }
      %remote_id = core.get %state["remote_id"]
      %is_block_start = core.call intrinsic.eq(%type, "content_block_start")
      core.if %is_block_start {
        %block = core.get %event["content_block"]
        %block_type = core.get %block["type"] default ""
        %is_text = core.call intrinsic.eq(%block_type, "text")
        core.if %is_text {
          %result = core.map
          core.set %result["index"] = %index
          %text = core.get %block["text"] default ""
          core.set %result["content"] = %text
          %citations = core.list
          core.call @anthropic_append_citations_impl(%citations, %block)
          %has_citations = core.call intrinsic.truthy(%citations)
          core.if %has_citations {
            core.set %result["citations"] = %citations
          }
          %results = core.list
          core.append %results, %result
          %out = core.map
          core.set %out["results"] = %results
          core.set %out["remote_id"] = %remote_id
          core.return %out
        }
        %is_thinking = core.call intrinsic.eq(%block_type, "thinking")
        core.if %is_thinking {
          %thinking = core.get %block["thinking"] default ""
          %thought_block = core.map
          core.set %thought_block["data"] = %thinking
          core.set %thought_block["encrypted"] = false
          %blocks = core.list
          core.append %blocks, %thought_block
          %result = core.map
          core.set %result["index"] = %index
          core.set %result["thought"] = %thinking
          core.set %result["thought_blocks"] = %blocks
          %results = core.list
          core.append %results, %result
          %out = core.map
          core.set %out["results"] = %results
          core.set %out["remote_id"] = %remote_id
          core.return %out
        }
        %is_tool = core.call intrinsic.eq(%block_type, "tool_use")
        core.if %is_tool {
          %event_index = core.get %event["index"] default 0
          %key = core.call intrinsic.string.format("tool_id_{}", %event_index)
          %name_key = core.call intrinsic.string.format("tool_name_{}", %event_index)
          %id = core.get %block["id"] default ""
          %name = core.get %block["name"] default ""
          core.set %state[%key] = %id
          core.set %state[%name_key] = %name
          %function = core.map
          core.set %function["name"] = %name
          core.set %function["params"] = ""
          %call = core.map
          core.set %call["id"] = %id
          core.set %call["type"] = "function"
          core.set %call["function"] = %function
          %calls = core.list
          core.append %calls, %call
          %result = core.map
          core.set %result["index"] = %index
          core.set %result["function_calls"] = %calls
          %results = core.list
          core.append %results, %result
          %out = core.map
          core.set %out["results"] = %results
          core.set %out["remote_id"] = %remote_id
          core.return %out
        }
      }
      %is_delta = core.call intrinsic.eq(%type, "content_block_delta")
      core.if %is_delta {
        %delta = core.get %event["delta"]
