  op ax.provider.semantic @gemini_live_bidi_build_input {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr effect = "throws"
    attr private = true
    tag "gemini-live-bidi-realtime-audio-core-helper"
    type signature = "(descriptor:json, request:json) -> list<json> throws"
    body @entry(%descriptor: json, %request: json) {
      %events = core.list
      %messages = core.call @realtime_request_user_messages_impl(%request)
      core.for %message in %messages {
        %content = core.get %message["content"] default ""
        %is_list = core.type_is %content type "list"
        %text_parts = core.list
        %audio_events = core.list
        core.if %is_list {
          core.for %part in %content {
            %part_type = core.get %part["type"] default "text"
            %is_text = core.call intrinsic.eq(%part_type, "text")
            core.if %is_text {
              %text_part = core.map
              %text = core.get %part["text"] default ""
              core.set %text_part["text"] = %text
              core.append %text_parts, %text_part
            } else {
            }
            %is_audio = core.call intrinsic.eq(%part_type, "audio")
            core.if %is_audio {
              %format = core.get %part["format"] default "pcm16"
              %format_lower = core.call intrinsic.string.lower(%format)
              %is_pcm16 = core.call intrinsic.eq(%format_lower, "pcm16")
              %is_pcm = core.call intrinsic.eq(%format_lower, "pcm")
              %valid_pcm = core.call intrinsic.or(%is_pcm16, %is_pcm)
              core.if %valid_pcm {
              } else {
                %error = core.call intrinsic.ai.error.unsupported("Gemini Live audio input must be PCM")
                core.raise %error
              }
              %data = core.get %part["data"] default ""
              %sample_rate = core.get %part["sampleRate"]
              %sample_rate_snake = core.get %part["sample_rate"] default %sample_rate
              %sample_rate_final = core.let %sample_rate_snake
              %has_sample_rate = core.call intrinsic.is_not_none(%sample_rate_final)
              core.if %has_sample_rate {
              } else {
                %sample_rate_final = core.let 16000
              }
              %mime = core.call intrinsic.string.format("audio/pcm;rate={}", %sample_rate_final)
              %audio = core.map
              core.set %audio["data"] = %data
              core.set %audio["mimeType"] = %mime
              %realtime_input = core.map
              core.set %realtime_input["audio"] = %audio
              %audio_event = core.map
              core.set %audio_event["realtimeInput"] = %realtime_input
              core.append %audio_events, %audio_event
            } else {
            }
          }
        } else {
          %text_part = core.map
          core.set %text_part["text"] = %content
          core.append %text_parts, %text_part
        }
        %text_count = core.call intrinsic.len(%text_parts)
        %has_text = core.call intrinsic.gt(%text_count, 0)
        core.if %has_text {
          %turn = core.map
          core.set %turn["role"] = "user"
          core.set %turn["parts"] = %text_parts
          %turns = core.list
          core.append %turns, %turn
          %client_content = core.map
          core.set %client_content["turns"] = %turns
          core.set %client_content["turnComplete"] = false
          %content_event = core.map
          core.set %content_event["clientContent"] = %client_content
          core.append %events, %content_event
        } else {
        }
        core.for %audio_event in %audio_events {
          core.append %events, %audio_event
        }
      }
      %stream_end = core.map
      core.set %stream_end["audioStreamEnd"] = true
      %end_event = core.map
      core.set %end_event["realtimeInput"] = %stream_end
      core.append %events, %end_event
      core.return %events
    }
  }

  op ax.provider.semantic @realtime_request_system_instruction_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "provider-realtime-audio-core-helper"
    type signature = "(request:json) -> string"
    body @entry(%request: json) {
      %direct = core.get %request["instructions"]
      %has_direct = core.call intrinsic.truthy(%direct)
      core.if %has_direct {
        core.return %direct
      } else {
      }
      %empty_prompt = core.list
      %prompt = core.get %request["chat_prompt"] default %empty_prompt
      %parts = core.list
      core.for %message in %prompt {
        %role = core.get %message["role"]
        %is_system = core.call intrinsic.eq(%role, "system")
        core.if %is_system {
          %content = core.get %message["content"] default ""
          core.append %parts, %content
        } else {
        }
      }
      %out = core.call intrinsic.string.join("\n", %parts)
      core.return %out
    }
  }

  op ax.provider.semantic @realtime_request_user_messages_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "provider-realtime-audio-core-helper"
    type signature = "(request:json) -> list<json>"
