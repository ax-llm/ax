  op ax.provider.semantic @anthropic_build_chat_request {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr effect = "throws"
    tag "src/ax/ai/anthropic/api.ts"
    type signature = "(AxChatRequest) -> json throws"
    body @entry(%request: AxChatRequest) {
      %payload = core.map
      %model = core.get %request["model"] default "claude-3-7-sonnet-latest"
      core.set %payload["model"] = %model
      %empty_prompt = core.list
      %prompt = core.get %request["chat_prompt"] default %empty_prompt
      %supports_mid = core.call intrinsic.string.starts_with(%model, "claude-opus-4-8")
      %system = core.list
      %messages = core.list
      %seen_non_system = core.let false
      core.for %message in %prompt {
        %role = core.get %message["role"] default ""
        %is_system = core.call intrinsic.eq(%role, "system")
        core.if %is_system {
          %hoist_later = core.call intrinsic.not(%supports_mid)
          %hoist = core.call intrinsic.or(%hoist_later, %seen_non_system)
          %should_preserve = core.call intrinsic.and(%supports_mid, %seen_non_system)
          core.if %should_preserve {
            %mapped_system = core.call @anthropic_message_impl(%message)
            core.append %messages, %mapped_system
          } else {
            %sys_item = core.map
            core.set %sys_item["type"] = "text"
            %sys_text = core.get %message["content"] default ""
            core.set %sys_item["text"] = %sys_text
            %cache = core.get %message["cache"] default false
            core.if %cache {
              %cache_control = core.call intrinsic.json.parse("{\"type\":\"ephemeral\"}")
              core.set %sys_item["cache_control"] = %cache_control
            } else {
            }
            core.append %system, %sys_item
          }
        } else {
          %seen_non_system = core.let true
          %mapped = core.call @anthropic_message_impl(%message)
          core.append %messages, %mapped
        }
      }
      %system_count = core.call intrinsic.len(%system)
      %has_system = core.call intrinsic.gt(%system_count, 0)
      core.if %has_system {
        core.set %payload["system"] = %system
      } else {
      }
      core.set %payload["messages"] = %messages
      %empty_model_config = core.map
      %model_config = core.get %request["model_config"] default %empty_model_config
      core.call @anthropic_apply_model_config_impl(%payload, %model_config, %model)
      %response_format = core.get %request["response_format"]
      %has_response_format = core.call intrinsic.truthy(%response_format)
      core.if %has_response_format {
        %format_type = core.get %response_format["type"] default ""
        %is_json_schema = core.call intrinsic.eq(%format_type, "json_schema")
        core.if %is_json_schema {
          %schema_container = core.get %response_format["schema"]
          %schema = core.get %schema_container["schema"] default %schema_container
          %output_config = core.get %payload["output_config"] default %empty_model_config
          %format = core.map
          core.set %format["type"] = "json_schema"
          core.set %format["schema"] = %schema
          core.set %output_config["format"] = %format
          core.set %payload["output_config"] = %output_config
        } else {
        }
      } else {
      }
      %empty_functions = core.list
      %functions = core.get %request["functions"] default %empty_functions
      %has_functions = core.call intrinsic.truthy(%functions)
      core.if %has_functions {
        %tools = core.list
        core.for %fn in %functions {
          %tool = core.call @anthropic_tool_spec_impl(%fn)
          core.append %tools, %tool
        }
        core.set %payload["tools"] = %tools
        %tool_choice = core.call @anthropic_tool_choice_impl(%request)
        %has_choice = core.call intrinsic.is_not_none(%tool_choice)
        core.if %has_choice {
          core.set %payload["tool_choice"] = %tool_choice
        } else {
        }
      } else {
      }
      core.return %payload
    }
  }

  op ax.provider.semantic @anthropic_apply_model_config_impl {
