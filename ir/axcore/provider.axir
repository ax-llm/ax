  op ax.provider.semantic @anthropic_message_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr effect = "throws"
    attr private = true
    tag "anthropic-message-core-helper"
    type signature = "(json) -> json throws"
    body @entry(%message: json) {
      %role = core.get %message["role"] default "user"
      %out = core.map
      %is_system = core.call intrinsic.eq(%role, "system")
      core.if %is_system {
        core.set %out["role"] = "system"
        %system_content = core.get %message["content"] default ""
        core.set %out["content"] = %system_content
        core.return %out
      } else {
      }
      %is_function = core.call intrinsic.eq(%role, "function")
      core.if %is_function {
        core.set %out["role"] = "user"
        %content = core.list
        %block = core.map
        core.set %block["type"] = "tool_result"
        %result = core.get %message["result"] default ""
        core.set %block["content"] = %result
        %function_id = core.get %message["function_id"]
        %function_id_camel = core.get %message["functionId"] default %function_id
        core.set %block["tool_use_id"] = %function_id_camel
        %is_error = core.get %message["is_error"] default false
        %is_error_camel = core.get %message["isError"] default %is_error
        core.if %is_error_camel {
          core.set %block["is_error"] = true
        } else {
        }
        %cache = core.get %message["cache"] default false
        core.if %cache {
          %cache_control = core.call intrinsic.json.parse("{\"type\":\"ephemeral\"}")
          core.set %block["cache_control"] = %cache_control
        } else {
        }
        core.append %content, %block
        core.set %out["content"] = %content
        core.return %out
      } else {
      }
      %is_assistant = core.call intrinsic.eq(%role, "assistant")
      core.if %is_assistant {
        core.set %out["role"] = "assistant"
        %blocks = core.list
        %content_value = core.get %message["content"] default ""
        %has_content = core.call intrinsic.truthy(%content_value)
        core.if %has_content {
          %text_block = core.map
          core.set %text_block["type"] = "text"
          core.set %text_block["text"] = %content_value
          core.append %blocks, %text_block
        } else {
        }
        %empty_calls = core.list
        %calls = core.get %message["function_calls"] default %empty_calls
        %calls_camel = core.get %message["functionCalls"] default %calls
        core.for %call in %calls_camel {
          %function = core.get %call["function"]
          %name = core.get %function["name"] default ""
          %params = core.get %function["params"] default %empty_calls
          %params_is_string = core.type_is %params type "string"
          core.if %params_is_string {
            core.try {
              %parsed = core.call intrinsic.json.parse(%params)
              %params = core.let %parsed
            } catch %parse_error {
              %params = core.map
            }
          } else {
          }
          %tool_use = core.map
          core.set %tool_use["type"] = "tool_use"
          %id = core.get %call["id"] default %name
          core.set %tool_use["id"] = %id
          core.set %tool_use["name"] = %name
          core.set %tool_use["input"] = %params
          core.append %blocks, %tool_use
        }
        %cache = core.get %message["cache"] default false
        core.if %cache {
          %count = core.call intrinsic.len(%blocks)
          %has_blocks = core.call intrinsic.gt(%count, 0)
          core.if %has_blocks {
            %index = core.call intrinsic.add(%count, -1)
            %last = core.get %blocks[%index]
            %cache_control = core.call intrinsic.json.parse("{\"type\":\"ephemeral\"}")
            core.set %last["cache_control"] = %cache_control
          } else {
          }
        } else {
        }
        %count = core.call intrinsic.len(%blocks)
        %has_blocks = core.call intrinsic.gt(%count, 0)
        core.if %has_blocks {
          core.set %out["content"] = %blocks
        } else {
          core.set %out["content"] = ""
        }
        core.return %out
      } else {
      }
      core.set %out["role"] = "user"
      %raw_content = core.get %message["content"] default ""
      %cache = core.get %message["cache"] default false
      %content_is_string = core.type_is %raw_content type "string"
      %not_cache = core.call intrinsic.not(%cache)
      %plain_string = core.call intrinsic.and(%content_is_string, %not_cache)
      core.if %plain_string {
        core.set %out["content"] = %raw_content
      } else {
        %parts = core.call @anthropic_content_parts_impl(%raw_content)
        core.if %cache {
          %count = core.call intrinsic.len(%parts)
          %has_parts = core.call intrinsic.gt(%count, 0)
          core.if %has_parts {
            %index = core.call intrinsic.add(%count, -1)
            %last = core.get %parts[%index]
            %cache_control = core.call intrinsic.json.parse("{\"type\":\"ephemeral\"}")
            core.set %last["cache_control"] = %cache_control
          } else {
          }
        } else {
        }
        core.set %out["content"] = %parts
      }
      core.return %out
    }
  }

  op ax.provider.semantic @anthropic_content_parts_impl {
