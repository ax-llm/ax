        %has_retrieved_uri = core.call intrinsic.truthy(%retrieved_uri)
        %has_media = core.call intrinsic.truthy(%media_id)
        %has_retrieved = core.call intrinsic.or(%has_retrieved_uri, %has_media)
        core.if %has_retrieved {
          %item = core.map
          %url = core.get %retrieved["uri"] default ""
          core.set %item["url"] = %url
          %title = core.get %retrieved["title"]
          %has_title = core.call intrinsic.is_not_none(%title)
          core.if %has_title {
            core.set %item["title"] = %title
          } else {
          }
          core.if %has_media {
            core.set %item["mediaId"] = %media_id
          } else {
          }
          %pages = core.get %retrieved["page_numbers"]
          %has_pages = core.call intrinsic.is_not_none(%pages)
          core.if %has_pages {
            core.set %item["pageNumbers"] = %pages
          } else {
          }
          core.append %out, %item
        } else {
        }
      }
      core.return %out
    }
