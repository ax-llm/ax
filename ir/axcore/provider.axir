  op ax.provider.semantic @provider_normalize_profile {
    attr core_kind = "func"
    attr emit_module = "ai"
    tag "provider-profile-registry"
    type signature = "(profile:string) -> string"
    body @entry(%profile: string) {
      %normalized = core.call intrinsic.string.lower(%profile)
      %is_responses_dash = core.call intrinsic.eq(%normalized, "openai-responses")
      %is_responses_under = core.call intrinsic.eq(%normalized, "openai_responses")
      %is_responses_alias = core.call intrinsic.eq(%normalized, "responses")
      %is_responses_one = core.call intrinsic.or(%is_responses_dash, %is_responses_under)
      %is_responses = core.call intrinsic.or(%is_responses_one, %is_responses_alias)
      %is_gemini_google = core.call intrinsic.eq(%normalized, "google-gemini")
      %is_gemini_google_under = core.call intrinsic.eq(%normalized, "google_gemini")
      %is_gemini_alias = core.call intrinsic.eq(%normalized, "gemini")
      %is_gemini_one = core.call intrinsic.or(%is_gemini_google, %is_gemini_google_under)
      %is_gemini = core.call intrinsic.or(%is_gemini_one, %is_gemini_alias)
      %is_anthropic_main = core.call intrinsic.eq(%normalized, "anthropic")
      %is_anthropic_alias = core.call intrinsic.eq(%normalized, "claude")
      %is_anthropic = core.call intrinsic.or(%is_anthropic_main, %is_anthropic_alias)
      %provider_id = core.let "openai-compatible"
      core.if %is_responses {
        %provider_id = core.let "openai-responses"
      } else {
        core.if %is_gemini {
          %provider_id = core.let "google-gemini"
        } else {
          core.if %is_anthropic {
            %provider_id = core.let "anthropic"
          } else {
          }
        }
      }
      core.return %provider_id
    }
  }

