            %excluded_websites = core.get %source["excluded_websites"] default %excluded_websites_camel
            %allowed_websites_camel = core.get %source["allowedWebsites"]
            %allowed_websites = core.get %source["allowed_websites"] default %allowed_websites_camel
            %safe_search_camel = core.get %source["safeSearch"]
            %safe_search = core.get %source["safe_search"] default %safe_search_camel
            %x_handles_camel = core.get %source["xHandles"]
            %x_handles = core.get %source["x_handles"] default %x_handles_camel
            %links = core.get %source["links"]
            %has_source_type = core.call intrinsic.is_not_none(%source_type)
            core.if %has_source_type {
