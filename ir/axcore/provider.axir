  op ax.provider.semantic @gemini_normalize_chat_response {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr effect = "throws"
    tag "src/ax/ai/google-gemini/api.ts"
    type signature = "(json, string, string) -> AxChatResponse throws"
    body @entry(%raw: json, %ai_name: string, %model: string) {
      %empty_candidates = core.list
      %candidates = core.get %raw["candidates"] default %empty_candidates
      %results = core.list
      %maps_widget_token = core.call intrinsic.none()
      core.for %candidate in %candidates {
        %result = core.map
        core.set %result["index"] = 0
        %finish = core.get %candidate["finishReason"] default "STOP"
        %is_max = core.call intrinsic.eq(%finish, "MAX_TOKENS")
        core.if %is_max {
          core.set %result["finish_reason"] = "length"
        } else {
          %is_stop = core.call intrinsic.eq(%finish, "STOP")
          core.if %is_stop {
            core.set %result["finish_reason"] = "stop"
          } else {
            %message = core.call intrinsic.string.format("Gemini finish reason was blocked: {}", %finish)
            %error = core.call intrinsic.ai.error.refusal(%message, %raw)
            core.raise %error
          }
        }
        %empty_content = core.map
        %content = core.get %candidate["content"] default %empty_content
        %empty_parts = core.list
        %parts = core.get %content["parts"] default %empty_parts
        %text_parts = core.list
        %function_calls = core.list
        core.for %part in %parts {
          core.call @gemini_merge_response_part_impl(%result, %text_parts, %function_calls, %part)
        }
        %content_text = core.call intrinsic.string.join("", %text_parts)
        core.set %result["content"] = %content_text
        core.set %result["function_calls"] = %function_calls
        %call_count = core.call intrinsic.len(%function_calls)
        %has_calls = core.call intrinsic.gt(%call_count, 0)
        core.if %has_calls {
          core.set %result["finish_reason"] = "function_call"
        } else {
        }
        %citations = core.call @gemini_extract_citations_impl(%candidate)
        %has_citations = core.call intrinsic.truthy(%citations)
        core.if %has_citations {
          core.set %result["citations"] = %citations
        } else {
        }
        core.append %results, %result
        %grounding = core.get %candidate["groundingMetadata"]
        %token = core.get %grounding["googleMapsWidgetContextToken"]
        %has_token = core.call intrinsic.truthy(%token)
        core.if %has_token {
          %maps_widget_token = core.let %token
        } else {
        }
      }
      %usage_raw = core.get %raw["usageMetadata"]
      %usage = core.call @gemini_usage_impl(%usage_raw)
      %model_version = core.get %raw["modelVersion"]
      %raw_model = core.get %raw["modelVersion"] default %model
      %model_usage = core.call @ai_model_usage_impl(%ai_name, %raw_model, %usage)
      %out = core.map
      core.set %out["results"] = %results
      %remote_id = core.get %raw["responseId"]
      %has_remote = core.call intrinsic.truthy(%remote_id)
      core.if %has_remote {
        core.set %out["remote_id"] = %remote_id
      } else {
      }
      core.set %out["model_usage"] = %model_usage
      %has_model_version = core.call intrinsic.truthy(%model_version)
      %has_widget = core.call intrinsic.is_not_none(%maps_widget_token)
      %has_metadata = core.call intrinsic.or(%has_model_version, %has_widget)
      core.if %has_metadata {
        %google = core.map
        core.if %has_model_version {
          core.set %google["modelVersion"] = %model_version
        } else {
        }
        core.if %has_widget {
          core.set %google["mapsWidgetContextToken"] = %maps_widget_token
        } else {
        }
        %metadata = core.map
        core.set %metadata["google"] = %google
        core.set %out["provider_metadata"] = %metadata
      } else {
      }
      core.return %out
    }
  }

  op ax.provider.semantic @gemini_merge_response_part_impl {
