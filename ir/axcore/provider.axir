  op ax.provider.semantic @anthropic_finish_reason_impl {
    attr core_kind = "func"
    attr emit_module = "ai"
    attr private = true
    tag "anthropic-output-core-helper"
    type signature = "(json) -> string"
    body @entry(%reason: json) {
