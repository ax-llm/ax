          attr result = %system_message
        }
        op core.call {
          attr args = [%messages, 1, %messages]
          attr callee = "intrinsic.list.get"
          attr result = %user_message
        }
        op core.list {
          attr result = %ordered_messages
        }
        op core.append {
          attr target = %ordered_messages
          attr value = %system_message
        }
        op core.for {
          attr in = %example_messages
          attr item = %example_message
          region @body {
            block @each_example {
              op core.append {
                attr target = %ordered_messages
                attr value = %example_message
              }
            }
          }
        }
        op core.for {
          attr in = %demo_messages
          attr item = %demo_message
          region @body {
            block @each_demo {
              op core.append {
                attr target = %ordered_messages
                attr value = %demo_message
