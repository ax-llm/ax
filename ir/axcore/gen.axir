                      region @catch {
                        block @catch {
                          op core.call {
                            attr args = [%attempt, %validation_retries]
                            attr callee = "intrinsic.gte"
                            attr result = %retries_exhausted
                          }
                          op core.if {
                            attr condition = %retries_exhausted
