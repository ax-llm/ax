                attr result = %calls
              }
              op core.call {
                attr args = [%calls]
                attr callee = "intrinsic.len"
                attr result = %call_count
              }
              op core.call {
                attr args = [%call_count, 0]
                attr callee = "intrinsic.gt"
                attr result = %has_calls
              }
              op core.if {
                attr condition = %has_calls
                region @then {
                  block @then {
                    op core.call {
                      attr args = [%messages, %response, %calls]
                      attr callee = @append_tool_call_messages_impl
                    }
                    op core.for {
                      attr in = %calls
                      attr item = %call
                      region @body {
                        block @each_call {
                          op core.try {
                            attr error = %tool_error
                            region @try {
                              block @try {
                                op core.call {
                                  attr args = [%functions, %call]
                                  attr callee = @execute_tool_call
