                    op core.call {
                      attr args = [%gen, %calls]
                      attr callee = @should_continue_steps
                      attr result = %continue_after_tools
                    }
                    op core.if {
                      attr condition = %continue_after_tools
                      region @then {
                        block @then {
                          op core.continue {
                          }
                        }
                      }
                      region @else {
                        block @else {
                          op core.call {
                            attr args = [%output_fields, %last_tool_result]
                            attr callee = "validate_output"
                            attr result = %validated_tool_result
                          }
                          op core.call {
                            attr args = [%gen, %validated_tool_result]
                            attr callee = @apply_field_processors
                            attr result = %processed_tool_result
                          }
                          op core.call {
                            attr args = [%gen, %processed_tool_result]
                            attr callee = @run_assertions
                          }
                          op core.call {
                            attr args = [%output_fields, %processed_tool_result]
                            attr callee = "strip_internal"
                            attr result = %public_tool_result
                          }
                          op core.call {
                            attr args = [%gen]
                            attr callee = "intrinsic.axgen.memory_cleanup_corrections"
                          }
                          op core.call {
                            attr args = [%gen, %values, %public_tool_result, "ok"]
                            attr callee = @record_trace
                          }
                          op core.return {
                            attr value = %public_tool_result
                          }
                        }
                      }
                    }
                  }
                }
                region @else {
                  block @else {
                    op core.try {
                      attr error = %validation_error
                      region @try {
                        block @try {
                          op core.get {
                            attr default = ""
                            attr key = "content"
                            attr result = %content
                            attr target = %response
                          }
                          op core.call {
                            attr args = [%content]
                            attr callee = @parse_output_impl
                            attr result = %output
                          }
                          op core.call {
                            attr args = [%output_fields, %output]
                            attr callee = "validate_output"
                            attr result = %validated
                          }
                          op core.call {
                            attr args = [%gen, %validated]
                            attr callee = @apply_field_processors
                            attr result = %processed
                          }
                          op core.call {
                            attr args = [%gen, %processed]
                            attr callee = @run_assertions
                          }
                          op core.call {
                            attr args = [%output_fields, %processed]
                            attr callee = "strip_internal"
                            attr result = %public_output
                          }
                          op core.call {
                            attr args = [%gen]
                            attr callee = "intrinsic.axgen.memory_cleanup_corrections"
                          }
                          op core.call {
                            attr args = [%gen, %values, %public_output, "ok"]
                            attr callee = @record_trace
                          }
                          op core.return {
                            attr value = %public_output
                          }
