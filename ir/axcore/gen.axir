                                op core.append {
                                  attr target = %messages
                                  attr value = %tool_error_message
                                }
                                op core.call {
                                  attr args = [%gen, %call, %tool_error_message, false]
                                  attr callee = "intrinsic.axgen.memory_add_function_result"
                                }
                                op core.call {
                                  attr args = [%gen, %call, %tool_error_message, "error"]
                                  attr callee = "intrinsic.axgen.record_function_call"
                                }
