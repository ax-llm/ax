module @ax.gen version "0.1" {
  dialect @ax.gen version "0.1"

  op ax.gen.semantic @build_gen_chat_request {
    attr core_kind = "func"
    attr emit_module = "gen"
    attr private = true
    ref prompt = @render_prompt
    type signature = "(AxGen, list<json>, json) -> AxChatRequest throws"
    body @entry(%gen: AxGen, %messages: list<json>, %options: json) {
      %model_config = core.map
      %stream_value = core.get %options["stream"] default false
      %stream_bool = core.call intrinsic.truthy(%stream_value)
      core.set %model_config["stream"] = %stream_bool
      %temperature = core.get %options["temperature"]
      %has_temperature = core.call intrinsic.is_not_none(%temperature)
      core.if %has_temperature {
        core.set %model_config["temperature"] = %temperature
      }
      %max_tokens = core.get %options["max_tokens"]
      %has_max_tokens = core.call intrinsic.is_not_none(%max_tokens)
      core.if %has_max_tokens {
        core.set %model_config["max_tokens"] = %max_tokens
      }
      %top_p = core.get %options["top_p"]
      %has_top_p = core.call intrinsic.is_not_none(%top_p)
      core.if %has_top_p {
        core.set %model_config["top_p"] = %top_p
      }
      %presence_penalty = core.get %options["presence_penalty"]
      %has_presence_penalty = core.call intrinsic.is_not_none(%presence_penalty)
      core.if %has_presence_penalty {
        core.set %model_config["presence_penalty"] = %presence_penalty
      }
      %frequency_penalty = core.get %options["frequency_penalty"]
      %has_frequency_penalty = core.call intrinsic.is_not_none(%frequency_penalty)
      core.if %has_frequency_penalty {
        core.set %model_config["frequency_penalty"] = %frequency_penalty
      }
      %n = core.get %options["n"]
      %has_n = core.call intrinsic.is_not_none(%n)
      core.if %has_n {
        core.set %model_config["n"] = %n
      }
      %stop_sequences = core.get %options["stop_sequences"]
      %has_stop_sequences = core.call intrinsic.is_not_none(%stop_sequences)
      core.if %has_stop_sequences {
        core.set %model_config["stop_sequences"] = %stop_sequences
      }
      %request = core.map
      %model = core.get %options["model"]
      core.set %request["model"] = %model
      core.set %request["chat_prompt"] = %messages
      %functions = core.get %gen["functions"]
      %function_specs = core.list
      core.for %fn in %functions {
        %spec = core.call @tool_spec_impl(%fn)
        core.append %function_specs, %spec
      }
      core.set %request["functions"] = %function_specs
      %mode_snake = core.get %options["function_call_mode"]
      %mode_raw = core.get %options["functionCallMode"] default %mode_snake
      %mode = core.call @function_call_mode_impl(%mode_raw)
      core.set %request["function_call"] = %mode
      // Force structured output for code-emitting stages (RLM distiller/executor:
      // `-> {}:code`). Generic json_object lets a live model pick its own keys and
      // answer directly; a strict json_schema requires the exact output field name
      // (e.g. javascriptCode), so the model emits runnable code, not prose. Mirrors
      // TS AxGen, which uses a strict json_schema for structured output. Other
      // signatures keep json_object (unchanged behavior).
      %signature = core.get %gen["signature"]
      %output_fields = core.get %signature["output_fields"]
      %has_code_field = core.let false
      core.for %of in %output_fields {
        %of_type = core.get %of["type"]
        %of_type_name = core.get %of_type["name"]
        %of_is_code = core.call intrinsic.eq(%of_type_name, "code")
        core.if %of_is_code {
          %has_code_field = core.let true
        }
      }
      %response_format = core.map
      core.if %has_code_field {
        %schema_options = core.map
        core.set %schema_options["strictStructuredOutputs"] = true
        %code_schema = core.call @schema_to_json_schema_impl(%output_fields, "output", %schema_options)
        %code_schema_wrap = core.map
        core.set %code_schema_wrap["name"] = "output"
        core.set %code_schema_wrap["strict"] = true
        core.set %code_schema_wrap["schema"] = %code_schema
        core.set %response_format["type"] = "json_schema"
        core.set %response_format["schema"] = %code_schema_wrap
      } else {
        core.set %response_format["type"] = "json_object"
      }
      core.set %request["response_format"] = %response_format
      core.set %request["model_config"] = %model_config
      core.return %request
    }
  }

  op ax.gen.semantic @forward {
    attr core_kind = "method"
    attr effect = "throws"
    attr emit_module = "gen"
    attr emit_name = "_forward_impl"
    ref execute_tool = @execute_tool_call
    ref strip = @strip_internal_fields
    ref validate = @validate_output
    tag "src/ax/dsp/generate.ts"
    type signature = "(AxGen, AIClient, json, options?:json) -> json throws"
    body @entry(%gen: AxGen, %client: AIClient, %values: json, %options: json) {
      %base_options = core.get %gen["options"]
      %runtime_options = core.call intrinsic.map.merge(%base_options, %options)
      %signature = core.get %gen["signature"]
      %input_fields = core.get %signature["input_fields"]
      core.call @validate_fields(%input_fields, %values, "input")
      %prompt_template = core.get %gen["prompt_template"]
      %messages = core.call intrinsic.object.call_method(%prompt_template, "render", %values)
      %example_messages = core.call @render_examples(%gen)
      %demo_messages = core.call @render_demos(%gen)
      %system_message = core.call intrinsic.list.get(%messages, 0, %messages)
      %user_message = core.call intrinsic.list.get(%messages, 1, %messages)
      %ordered_messages = core.list
      core.append %ordered_messages, %system_message
      core.for %example_message in %example_messages {
        core.append %ordered_messages, %example_message
      }
      core.for %demo_message in %demo_messages {
        core.append %ordered_messages, %demo_message
      }
      core.append %ordered_messages, %user_message
      %cached_messages = core.call intrinsic.axgen.apply_context_cache(%gen, %ordered_messages, %options)
      %messages = core.let %cached_messages
      core.call intrinsic.axgen.memory_add_request(%gen, %messages)
      %validation_retries_snake = core.get %runtime_options["validation_retries"] default 2
      %validation_retries = core.get %runtime_options["validationRetries"] default %validation_retries_snake
      %infra_retries_snake = core.get %runtime_options["infra_retries"] default 2
      %infra_retries = core.get %runtime_options["infraRetries"] default %infra_retries_snake
      %attempt = core.const 0
      %output_fields = core.get %signature["output_fields"]
      %functions = core.get %gen["functions"]
      %last_tool_result = core.call intrinsic.none()
      core.loop {
        %request = core.call @build_gen_chat_request(%gen, %messages, %runtime_options)
        %response = core.call @complete_with_retries_impl(%client, %request, %infra_retries)
        core.call intrinsic.axgen.memory_add_response(%gen, %request, %response)
        core.call intrinsic.axgen.record_chat_log(%gen, %request, %response)
        %calls = core.call @response_function_calls_impl(%response)
        %call_count = core.call intrinsic.len(%calls)
        %has_calls = core.call intrinsic.gt(%call_count, 0)
        core.if %has_calls {
          core.call @append_tool_call_messages_impl(%messages, %response, %calls)
          core.for %call in %calls {
            core.try {
              %tool_result = core.call @execute_tool_call(%functions, %call)
              %last_tool_result = core.let %tool_result
              %tool_message = core.call @tool_result_message_impl(%call, %tool_result)
              core.append %messages, %tool_message
              core.call intrinsic.axgen.memory_add_function_result(%gen, %call, %tool_result, true)
              core.call intrinsic.axgen.record_function_call(%gen, %call, %tool_result, "ok")
            } catch %tool_error {
              %tool_error_message = core.call @tool_error_message_impl(%call, %tool_error)
              core.append %messages, %tool_error_message
              core.call intrinsic.axgen.memory_add_function_result(%gen, %call, %tool_error_message, false)
              core.call intrinsic.axgen.record_function_call(%gen, %call, %tool_error_message, "error")
            }
          }
          %continue_after_tools = core.call @should_continue_steps(%gen, %calls)
          core.if %continue_after_tools {
            core.continue
          } else {
            %validated_tool_result = core.call @validate_output(%output_fields, %last_tool_result)
            %processed_tool_result = core.call @apply_field_processors(%gen, %validated_tool_result)
            core.call @run_assertions(%gen, %processed_tool_result)
            %public_tool_result = core.call @strip_internal_fields(%output_fields, %processed_tool_result)
            core.call intrinsic.axgen.memory_cleanup_corrections(%gen)
            core.call @record_trace(%gen, %values, %public_tool_result, "ok")
            core.return %public_tool_result
          }
        } else {
          core.try {
            %content = core.get %response["content"] default ""
            %output = core.call @parse_output_impl(%content)
            %validated = core.call @validate_output(%output_fields, %output)
            %processed = core.call @apply_field_processors(%gen, %validated)
            core.call @run_assertions(%gen, %processed)
            %public_output = core.call @strip_internal_fields(%output_fields, %processed)
            core.call intrinsic.axgen.memory_cleanup_corrections(%gen)
            core.call @record_trace(%gen, %values, %public_output, "ok")
            core.return %public_output
          } catch %validation_error {
            %retries_exhausted = core.call intrinsic.gte(%attempt, %validation_retries)
            core.if %retries_exhausted {
              core.raise %validation_error
            }
            %next_attempt = core.call intrinsic.add(%attempt, 1)
            %attempt = core.let %next_attempt
            core.call @append_assertion_retry_messages(%messages, %response, %validation_error)
            core.call intrinsic.axgen.memory_add_correction(%gen, %response, %validation_error)
            core.continue
          }
        }
      }
      core.raise "unreachable AxGen forward loop exit"
    }
  }

  op ax.gen.semantic @set_examples {
    attr core_kind = "func"
    attr emit_module = "gen"
    attr private = true
    tag "examples-host-boundary"
    type signature = "(AxGen, list<json>) -> AxGen"
    body @entry(%gen: AxGen, %examples: list<json>) {
      core.set %gen["examples"] = %examples
      core.return %gen
    }
  }

  op ax.gen.semantic @set_demos {
    attr core_kind = "func"
    attr emit_module = "gen"
    attr private = true
    tag "demos-host-boundary"
    type signature = "(AxGen, list<json>) -> AxGen"
    body @entry(%gen: AxGen, %demos: list<json>) {
      core.set %gen["demos"] = %demos
      core.return %gen
    }
  }

  op ax.gen.semantic @render_examples {
    attr core_kind = "func"
    attr emit_module = "gen"
    attr private = true
    tag "examples-render-order-core-owned"
    type signature = "(AxGen) -> list<json>"
    body @entry(%gen: AxGen) {
      %messages = core.call intrinsic.axgen.render_examples(%gen)
      core.return %messages
    }
  }

  op ax.gen.semantic @render_demos {
    attr core_kind = "func"
    attr emit_module = "gen"
    attr private = true
    tag "demos-render-order-core-owned"
    type signature = "(AxGen) -> list<json>"
    body @entry(%gen: AxGen) {
      %messages = core.call intrinsic.axgen.render_demos(%gen)
      core.return %messages
    }
  }

  op ax.gen.semantic @apply_field_processors {
    attr core_kind = "func"
    attr emit_module = "gen"
    attr private = true
    tag "field-processors-host-boundary"
    type signature = "(AxGen, json) -> json throws"
    body @entry(%gen: AxGen, %output: json) {
      %processed = core.call intrinsic.axgen.apply_field_processors(%gen, %output)
      core.return %processed
    }
  }

  op ax.gen.semantic @run_assertions {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "gen"
    attr private = true
    tag "assertions-host-boundary"
    type signature = "(AxGen, json) -> void throws"
    body @entry(%gen: AxGen, %output: json) {
      core.call intrinsic.axgen.run_assertions(%gen, %output)
      core.return
    }
  }

  op ax.gen.semantic @append_assertion_retry_messages {
    attr core_kind = "func"
    attr emit_module = "gen"
    attr private = true
    tag "assertion-retry-message-core-helper"
    type signature = "(list<json>, json, error) -> void"
    body @entry(%messages: list<json>, %response: json, %error: error) {
      core.call @append_validation_retry_messages_impl(%messages, %response, %error)
      core.return
    }
  }

  op ax.gen.semantic @record_trace {
    attr core_kind = "func"
    attr emit_module = "gen"
    attr private = true
    tag "trace-capture-host-boundary"
    type signature = "(AxGen, json, json, string) -> void"
    body @entry(%gen: AxGen, %input: json, %output: json, %status: string) {
      core.call intrinsic.axgen.record_trace(%gen, %input, %output, %status)
      core.return
    }
  }

  op ax.gen.semantic @should_continue_steps {
    attr core_kind = "func"
    attr emit_module = "gen"
    attr private = true
    tag "stop-functions-host-boundary"
    type signature = "(AxGen, list<json>) -> bool"
    body @entry(%gen: AxGen, %calls: list<json>) {
      %should_continue = core.call intrinsic.axgen.should_continue_steps(%gen, %calls)
      core.return %should_continue
    }
  }

  op ax.gen.semantic @retry_policy {
    attr core_kind = "semantic"
    tag "validation-vs-infra-retry"
    type fields = "validationRetries:i64,infraRetries:i64"
  }

  op ax.gen.semantic @complete_with_retries_impl {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "gen"
    attr private = true
    tag "infra-retry-core-helper"
    type signature = "(AIClient, AxChatRequest, i64) -> json throws"
    body @entry(%client: AIClient, %request: AxChatRequest, %retries: i64) {
      %attempt = core.const 0
      %last_error = core.call intrinsic.none()
      core.loop {
        core.try {
          %response = core.call intrinsic.ai.complete_once(%client, %request)
          core.return %response
        } catch %error {
          %last_error = core.let %error
          %exhausted = core.call intrinsic.gte(%attempt, %retries)
          core.if %exhausted {
            core.raise %error
          }
          core.call intrinsic.retry.sleep(%attempt)
          %next_attempt = core.call intrinsic.add(%attempt, 1)
          %attempt = core.let %next_attempt
          core.continue
        }
      }
      core.raise %last_error
    }
  }

  op ax.gen.semantic @parse_output_impl {
    attr core_kind = "func"
    attr effect = "throws"
    attr emit_module = "gen"
    attr private = true
    tag "parse-structured-output-core-helper"
    type signature = "(string) -> json throws"
    body @entry(%content: string) {
      %text = core.string_trim %content
      %output = core.call intrinsic.json.parse(%text)
      core.return %output
    }
  }

  op ax.gen.semantic @tool_spec_impl {
    attr core_kind = "func"
    attr emit_module = "gen"
    attr private = true
    tag "tool-spec-core-helper"
    type signature = "(Tool) -> json"
    body @entry(%fn: Tool) {
      %spec = core.map
      %name = core.get %fn["name"]
      %description = core.get %fn["description"]
      %parameters = core.get %fn["parameters"]
      core.set %spec["name"] = %name
      core.set %spec["description"] = %description
      core.set %spec["parameters"] = %parameters
      core.return %spec
    }
  }

  op ax.gen.semantic @function_call_mode_impl {
    attr core_kind = "func"
    attr emit_module = "gen"
    attr private = true
    tag "function-call-mode-core-helper"
    type signature = "(json) -> string"
    body @entry(%mode: json) {
      %missing = core.call intrinsic.is_none(%mode)
      core.if %missing {
        core.return "auto"
      }
      %is_native = core.call intrinsic.eq(%mode, "native")
      %is_auto = core.call intrinsic.eq(%mode, "auto")
      %native_or_auto = core.call intrinsic.or(%is_native, %is_auto)
      core.if %native_or_auto {
        core.return "auto"
      }
      %is_prompt = core.call intrinsic.eq(%mode, "prompt")
      core.if %is_prompt {
        core.return "none"
      }
      core.return %mode
    }
  }

  op ax.gen.semantic @response_function_calls_impl {
    attr core_kind = "func"
    attr emit_module = "gen"
    attr private = true
    tag "response-function-calls-core-helper"
    type signature = "(json) -> list<json>"
    body @entry(%response: json) {
      %empty = core.list
      %calls = core.get %response["function_calls"] default %empty
      core.return %calls
    }
  }

  op ax.gen.semantic @append_tool_call_messages_impl {
    attr core_kind = "func"
    attr emit_module = "gen"
    attr private = true
    tag "tool-call-message-core-helper"
    type signature = "(list<json>, json, list<json>) -> void"
    body @entry(%messages: list<json>, %response: json, %calls: list<json>) {
      %chat_calls = core.list
      core.for %call in %calls {
        %chat_call = core.call @completion_call_to_chat_impl(%call)
        core.append %chat_calls, %chat_call
      }
      %content = core.get %response["content"] default ""
      %message = core.map
      core.set %message["role"] = "assistant"
      core.set %message["content"] = %content
      core.set %message["function_calls"] = %chat_calls
      core.append %messages, %message
      core.return
    }
  }

  op ax.gen.semantic @completion_call_to_chat_impl {
    attr core_kind = "func"
    attr emit_module = "gen"
    attr private = true
    tag "completion-call-to-chat-core-helper"
    type signature = "(json) -> json"
    body @entry(%call: json) {
      %id = core.get %call["id"]
      %name = core.get %call["name"]
      %params = core.get %call["params"]
      %function = core.map
      core.set %function["name"] = %name
      core.set %function["params"] = %params
      %out = core.map
      core.set %out["id"] = %id
      core.set %out["type"] = "function"
      core.set %out["function"] = %function
      core.return %out
    }
  }

  op ax.gen.semantic @tool_result_message_impl {
    attr core_kind = "func"
    attr emit_module = "gen"
    attr private = true
    tag "tool-result-message-core-helper"
    type signature = "(json, json) -> json"
    body @entry(%call: json, %result: json) {
      %id = core.get %call["id"]
      %result_json = core.call intrinsic.json.stringify(%result)
      %message = core.map
      core.set %message["role"] = "function"
      core.set %message["function_id"] = %id
      core.set %message["result"] = %result_json
      core.return %message
    }
  }

  op ax.gen.semantic @tool_error_message_impl {
    attr core_kind = "func"
    attr emit_module = "gen"
    attr private = true
    tag "tool-error-message-core-helper"
    type signature = "(json, error) -> json"
    body @entry(%call: json, %error: error) {
      %id = core.get %call["id"]
      %error_text = core.call intrinsic.exception.message(%error)
      %payload = core.map
      core.set %payload["error"] = %error_text
      %payload_json = core.call intrinsic.json.stringify(%payload)
      %message = core.map
      core.set %message["role"] = "function"
      core.set %message["function_id"] = %id
      core.set %message["result"] = %payload_json
      core.set %message["is_error"] = true
      core.return %message
    }
  }

  op ax.gen.semantic @append_validation_retry_messages_impl {
    attr core_kind = "func"
    attr emit_module = "gen"
    attr private = true
    tag "validation-retry-message-core-helper"
    type signature = "(list<json>, json, error) -> void"
    body @entry(%messages: list<json>, %response: json, %error: error) {
      %content = core.get %response["content"] default ""
      %assistant_message = core.map
      core.set %assistant_message["role"] = "assistant"
      core.set %assistant_message["content"] = %content
      core.append %messages, %assistant_message
      %error_text = core.call intrinsic.exception.message(%error)
      %prefix_message = core.call intrinsic.add("The previous response failed validation: ", %error_text)
      %retry_content = core.call intrinsic.add(%prefix_message, ". Return only corrected JSON.")
      %retry_message = core.map
      core.set %retry_message["role"] = "user"
      core.set %retry_message["content"] = %retry_content
      core.append %messages, %retry_message
      core.return
    }
  }
}
