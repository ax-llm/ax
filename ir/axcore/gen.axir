        op core.call {
          attr args = [%gen, %messages]
          attr callee = "intrinsic.axgen.memory_add_request"
        }
        op core.get {
          attr default = 2
          attr key = "validation_retries"
          attr result = %validation_retries_snake
          attr target = %runtime_options
        }
        op core.get {
          attr default = %validation_retries_snake
          attr key = "validationRetries"
          attr result = %validation_retries
          attr target = %runtime_options
        }
        op core.get {
          attr default = 2
          attr key = "infra_retries"
          attr result = %infra_retries_snake
          attr target = %runtime_options
        }
        op core.get {
          attr default = %infra_retries_snake
          attr key = "infraRetries"
          attr result = %infra_retries
          attr target = %runtime_options
        }
        op core.const {
          attr result = %attempt
          attr value = 0
        }
        op core.get {
          attr key = "output_fields"
          attr result = %output_fields
          attr target = %signature
        }
        op core.get {
          attr key = "functions"
          attr result = %functions
          attr target = %gen
        }
        op core.call {
          attr callee = "intrinsic.none"
          attr result = %last_tool_result
        }
        op core.loop {
          region @body {
            block @forward_loop {
              op core.call {
                attr args = [%gen, %messages, %runtime_options]
                attr callee = @build_gen_chat_request
                attr result = %request
