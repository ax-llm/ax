    tag "axmcp"
    type signature = "(mcp?:list<AxMCPClient>, ucp?:list<AxUCPClient>, options?:json) -> AxExecutionContext"
  }

  op ax.mcp.record @AxMCPContinuationState {
    attr core_kind = "record"
    attr public = true
    tag "axmcp"
    type fields = "namespaces:list<string>,tasks:list<json>,subscriptions:list<json>,catalogFingerprint:string"
  }

  op ax.mcp.record @AxMCPCatalogSnapshot {
    attr core_kind = "record"
    attr public = true
    tag "axmcp"
    type fields = "namespace:string,protocolVersion?:string,revision:number,serverInfo?:json,serverCapabilities:json,tools:list<json>,prompts:list<json>,resources:list<json>,resourceTemplates:list<json>,subscriptions:list<string>"
  }

  op ax.mcp.record @AxMCPResourceSubscriptionPlan {
