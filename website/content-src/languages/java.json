{
  "id": "java",
  "label": "Java",
  "shortLabel": "Java",
  "fence": "java",
  "packageName": "dev.axllm:ax",
  "install": [
    "// Gradle (build.gradle):",
    "implementation 'dev.axllm:ax:22.0.4'",
    "// Maven (pom.xml):",
    "<dependency>",
    "  <groupId>dev.axllm</groupId>",
    "  <artifactId>ax</artifactId>",
    "  <version>22.0.4</version>",
    "</dependency>"
  ],
  "exampleRoot": "packages/java/examples",
  "academy": {
    "unitExamples": {
      "dspy": "src/examples/java/generation/StructuredGenerationExample.java",
      "models-signatures": "src/examples/java/generation/StructuredGenerationExample.java",
      "axgen": "src/examples/java/generation/BasicGenerationExample.java",
      "axflow": "src/examples/java/flows/BranchFlowExample.java",
      "axagent": "src/examples/java/short-agents/ToolsAgentExample.java",
      "rlm": "src/examples/java/long-agents/IncidentLogForensicsExample.java",
      "peek-context": "src/examples/java/long-agents/CodebasePeekMapExample.java",
      "optimization": "src/examples/java/optimization/AxgenOptimizationExample.java",
      "mcp": "src/examples/java/mcp/NativeMCPToolsExample.java",
      "notifications": "src/examples/java/mcp/ResourceWakeAgentExample.java",
      "production": "src/examples/java/long-agents/SmartDefaultsAgentExample.java"
    },
    "capstoneExample": "src/examples/java/mcp/TaskResumeFlowExample.java",
    "exerciseAnswers": {
      "signature-semantic-contract": ["Ax.s", "s"],
      "ai-providers-models": ["Ax.ai", "ai"],
      "fluent-fields-validation": ["Ax.f", "f"],
      "typed-tools": ["Ax.fn", "fn"],
      "optimize-gen-flow": ["AxGEPA"]
    },
    "snippets": {
      "flow": [
        "AxGen step = Ax.ax(\"request:string -> route:class \\\"support, sales, engineering\\\"\");",
        "AxFlow program = Ax.flow(Map.of(\"id\", \"supportRouter\"))",
        "    .execute(\"classify\", step)",
        "    .returns(Map.of(\"route\", \"classify\"));"
      ],
      "rlm": [
        "AxAgent investigator = Ax.agent(signature, Map.of(",
        "    \"contextFields\", List.of(\"logs\"),",
        "    \"contextPolicy\", Map.of(\"preset\", \"lean\", \"budget\", \"balanced\"),",
        "    \"runtime\", Map.of(\"language\", \"JavaScript\")));"
      ],
      "contextMap": [
        "AxAgent analyst = Ax.agent(signature, Map.of(",
        "    \"contextFields\", List.of(\"codebase\"),",
        "    \"contextPolicy\", Map.of(\"preset\", \"adaptive\", \"budget\", \"balanced\"),",
        "    \"contextMap\", Map.of(\"maxChars\", 1800, \"infiniteEvolve\", false, \"evolveSteps\", 1)));"
      ],
      "memorySkills": [
        "AxAgent assistant = Ax.agent(signature, Map.of(",
        "    \"memoriesCatalog\", memories,",
        "    \"skillsCatalog\", skills));"
      ]
    }
  },
  "apiKind": "axir",
  "optimizeName": "AxGEPA",
  "optimizeIntro": "Use the generated `AxGEPA` optimizer surface for portable GEPA tuning. TypeScript also exposes the convenience `optimize()` helper; generated packages currently keep the optimizer explicit.",
  "apiReference": "/java/api/reference/",
  "apiSections": {
    "ai": ["AxAI"],
    "ax": ["AxGen", "Tools"],
    "s": ["Signatures"],
    "agent": ["Agents And RLM", "Runtime Profiles", "MCP"],
    "optimize": ["Optimizers"]
  },
  "snippets": {
    "ai": {
      "audio": [
        "// Realtime audio over WebSocket — uses the JDK's built-in WebSocket (no extra dependency)",
        "OpenAIResponsesClient client = new OpenAIResponsesClient(Map.of(\"model\", \"gpt-realtime-2\", \"api_key\", System.getenv(\"OPENAI_APIKEY\")));",
        "Map<String, Object> request = Map.of(\"model\", \"gpt-realtime-2\", \"chat_prompt\", List.of(Map.of(\"role\", \"user\", \"content\", \"Say hello.\")), \"audio\", Map.of(\"output\", Map.of(\"voice\", \"alloy\")));",
        "Map<String, Object> result = client.realtimeChat(request, null);  // one merged turn: transcript + base64 PCM audio",
        "// Realtime models also route transparently through chat(); chat() accepts input_audio parts; transcribe()/speak() do batch STT/TTS."
      ]
    },
    "quickStart": [
      "import dev.axllm.ax.Ax;",
      "",
      "var llm = Ax.ai(\"openai\", Map.of(\"apiKey\", System.getenv(\"OPENAI_API_KEY\")));",
      "var classify = Ax.ax(\"review:string -> sentiment:class \\\"positive, negative, neutral\\\"\");"
    ],
    "dspy": [
      "var qa = Ax.ax(\"question:string -> answer:string, confidence:number\");"
    ],
    "signature": [
      "var sig = Ax.s(\"email:string -> priority:class \\\"high, normal, low\\\"\");"
    ],
    "ax": ["var answer = Ax.ax(\"question:string -> answer:string\");"],
    "agent": ["var helper = Ax.agent(\"question:string -> answer:string\");"],
    "llm": [
      "var client = Ax.ai(\"openai\", Map.of(\"apiKey\", System.getenv(\"OPENAI_API_KEY\")));"
    ],
    "telemetry": [
      "var program = Ax.ax(\"text:string -> label:string\");",
      "var usage = program.getUsage();"
    ],
    "optimize": [
      "var engine = new AxGEPA(reflectionClient, Map.of());",
      "var result = engine.optimize(request, evaluator);"
    ],
    "playbook": [
      "AxPlaybook pb = Ax.playbook(program, Map.of(\"studentAI\", studentAI));",
      "pb.evolve(examples, metric, Map.of());   // grow a playbook offline from examples",
      "pb.update(Map.of(\"example\", ex, \"prediction\", pred, \"feedback\", \"...\"));",
      "pb.applyTo(program);"
    ]
  },
  "snippetGroups": {
    "tools": {
      "basic": [
        "Tool search = Ax.fn(\"search\")",
        "    .description(\"Search docs\")",
        "    .arg(\"query\", Ax.f().string(\"Search query\"))",
        "    .handler(args -> List.of(\"hit for \" + args.get(\"query\")))",
        "    .build();"
      ],
      "standardSchema": [
        "// TypeScript owns the zod/valibot/arktype Standard Schema adapters.",
        "// Generated packages expose the same Ax concept as JSON-schema-compatible tool descriptors.",
        "Tool lookup = Ax.fn(\"lookupProduct\")",
        "    .description(\"Look up product inventory\")",
        "    .arg(\"productName\", Ax.f().string(\"Exact product name\"))",
        "    .build();"
      ],
      "namespaces": [
        "Tool policy = Ax.fn(\"findPolicy\")",
        "    .description(\"Find policies\")",
        "    .arg(\"topic\", Ax.f().string())",
        "    .handler(args -> List.of(\"policy: \" + args.get(\"topic\")))",
        "    .build();",
        "// Group related tools under domain namespaces where the package surface supports it.",
        "// Runtime calls should read like kb.findPolicy(...) or billing.lookupInvoice(...)."
      ],
      "ax": [
        "var answer = Ax.ax(\"question:string -> answer:string\");",
        "var out = answer.forward(llm, Map.of(",
        "    \"question\", \"Can this customer get a refund?\"",
        "), Map.of(\"functions\", List.of(search)));"
      ],
      "agentFlat": [
        "var assistant = Ax.agent(\"message:string -> reply:string\", Map.of(",
        "    \"functions\", List.of(search),",
        "    \"contextFields\", List.of()",
        "));"
      ],
      "agentGroups": [
        "var assistant = Ax.agent(\"message:string -> reply:string\", Map.of(",
        "    \"functionDiscovery\", true,",
        "    \"functions\", List.of(Map.of(",
        "        \"namespace\", \"kb\",",
        "        \"title\", \"Knowledge Base\",",
        "        \"selectionCriteria\", \"Use for policy or documentation lookup.\",",
        "        \"functions\", List.of(search)",
        "    ))",
        "));"
      ]
    },
    "mcp": {
      "native": {
        "sourcePath": "src/examples/java/mcp/NativeMCPToolsExample.java",
        "code": [
          "AxMCPClient mcp = new AxMCPClient(new AxMCPStreamableHTTPTransport(endpoint), Map.of(\"namespace\", \"inventory\"));",
          "      AxMCPClient.CatalogSnapshot catalog = mcp.inspectCatalog();",
          "AxGen program = new AxGen(Ax.s(\"request:string -> answer:string\"), Map.of(\"mcp\", mcp));",
          "      mcp.close();"
        ]
      },
      "resourceWake": {
        "sourcePath": "src/examples/java/mcp/ResourceWakeAgentExample.java",
        "code": [
          "AxMCPEventSource source=new AxMCPEventSource(client,\"inventory\",\"tenant:demo\",\"authenticated\",AxMCPEventSource.all());",
          "runtime.start();",
          "if(!completed.await(60,TimeUnit.SECONDS))throw new IllegalStateException(\"Timed out waiting for an MCP resource notification\");"
        ]
      },
      "taskResume": {
        "sourcePath": "src/examples/java/mcp/TaskResumeFlowExample.java",
        "code": [
          "client.init();",
          "String taskId=String.valueOf(castMap(client.callTool(\"start_reindex\",Map.of(\"scope\",\"all\")).get(\"task\")).get(\"taskId\"));",
          "source.start(event->runtime.publish(event,source.identityScope(),source.trust()));"
        ]
      }
    },
    "event": {
      "wake": {
        "sourcePath": "src/examples/java/mcp/ResourceWakeAgentExample.java",
        "code": [
          "runtime.start();",
          "if(!completed.await(60,TimeUnit.SECONDS))throw new IllegalStateException(\"Timed out waiting for an MCP resource notification\");"
        ]
      },
      "resume": {
        "sourcePath": "src/examples/java/mcp/TaskResumeFlowExample.java",
        "code": [
          "runtime.start();",
          "runtime.publish(new AxEventEnvelope(\"task-start\",\"app://tasks\",\"app.task.started\",Map.of(\"taskId\",taskId,\"taskKey\",\"inventory:\"+taskId)),\"tenant:demo\",\"authenticated\");",
          "source.start(event->runtime.publish(event,source.identityScope(),source.trust()));"
        ]
      },
      "ucp": {
        "sourcePath": "src/examples/ucp-webhook-wake-agent.ts",
        "code": [
          "  const receipt = await source.ingest(request);",
          "  if (!receipt.accepted) return new Response(null, { status: 503 });"
        ]
      }
    }
  }
}
