    "flow": {
      "branch": {
        "sourcePath": "src/examples/java/flows/BranchFlowExample.java",
        "verified": true,
        "requiresCredentials": true,
        "code": [
          "AxGen classifier = Ax.ax(\"request:string -> route:class \\\"support, sales, engineering\\\"\");",
          "AxGen responder = Ax.ax(\"request:string, route:string -> response:string\");",
          "AxFlow program = Ax.flow(Map.of(\"id\", \"examples.branchFlow\"))",
          "    .execute(\"classifier\", classifier, Map.of(\"reads\", List.of(\"request\"), \"writes\", List.of(\"classifierResult\", \"route\")))",
          "    .execute(\"responder\", responder, Map.of(\"reads\", List.of(\"request\", \"route\"), \"writes\", List.of(\"responderResult\", \"response\")))",
          "    .returns(Map.of(\"route\", \"route\", \"response\", \"response\"));"
        ]
      },
      "parallel": {
        "sourcePath": "src/examples/java/flows/ParallelFlowExample.java",
