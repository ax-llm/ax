  "snippetGroups": {
    "tools": {
      "basic": [
        "from axllm import f, fn",
        "",
        "search = (",
        "    fn('search')",
        "    .description('Search docs')",
        "    .arg('query', f.string('Search query'))",
        "    .handler(lambda args: ['hit for ' + args['query']])",
        "    .build()",
        ")"
      ],
      "standardSchema": [
        "# TypeScript owns the zod/valibot/arktype Standard Schema adapters.",
        "# Generated packages expose the same Ax concept as JSON-schema-compatible tool descriptors.",
        "lookup_product = (",
        "    fn('lookupProduct')",
        "    .description('Look up product inventory')",
        "    .arg('productName', f.string('Exact product name'))",
        "    .handler(lambda args: {'price': 79.99, 'inStock': True})",
        "    .build()",
        ")"
      ],
      "namespaces": [
        "policy = (",
        "    fn('findPolicy')",
        "    .namespace('kb')",
        "    .description('Find policies')",
        "    .arg('topic', f.string())",
        "    .handler(lambda args: ['policy: ' + args['topic']])",
        "    .build()",
        ")",
        "# Put related generated-package tools under domain namespaces where the package surface supports it.",
        "# Runtime calls should read like kb.findPolicy(...) or billing.lookupInvoice(...)."
      ],
      "ax": [
        "answer = ax('question:string -> answer:string')",
        "out = answer.forward(llm, {'question': 'Can this customer get a refund?'}, {'functions': [search]})"
      ],
      "agentFlat": [
        "assistant = agent('message:string -> reply:string', {",
        "    'functions': [search],",
        "    'contextFields': [],",
        "})"
      ],
      "agentGroups": [
        "assistant = agent('message:string -> reply:string', {",
        "    'functionDiscovery': True,",
        "    'functions': [{",
        "        'namespace': 'kb',",
        "        'title': 'Knowledge Base',",
        "        'selectionCriteria': 'Use for policy or documentation lookup.',",
        "        'functions': [search],",
        "    }],",
        "})"
      ]
    }
  }
