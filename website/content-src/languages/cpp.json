{
  "id": "cpp",
  "label": "C++",
  "shortLabel": "C++",
  "fence": "cpp",
  "packageName": "axllm",
  "install": [
    "include(FetchContent)",
    "FetchContent_Declare(axllm GIT_REPOSITORY https://github.com/ax-llm/ax GIT_TAG main SOURCE_SUBDIR packages/cpp)",
    "FetchContent_MakeAvailable(axllm)",
    "target_link_libraries(your_app PRIVATE axllm::axllm)"
  ],
  "exampleRoot": "packages/cpp/examples",
  "apiKind": "axir",
  "optimizeName": "AxGEPA",
  "optimizeIntro": "Use the generated `AxGEPA` optimizer surface for portable GEPA tuning. TypeScript also exposes the convenience `optimize()` helper; generated packages currently keep the optimizer explicit.",
  "apiReference": "/cpp/api/reference/",
  "apiSections": {
    "ai": ["AxAI"],
    "ax": ["AxGen", "Tools"],
    "s": ["Signatures"],
    "agent": ["Agents And RLM", "Runtime Profiles", "MCP"],
    "optimize": ["Optimizers"]
  },
  "snippets": {
    "ai": {
      "audio": [
        "// Realtime audio over WebSocket — build with -DAXLLM_ENABLE_REALTIME=ON",
        "axllm::OpenAIResponsesClient client(axllm::object({{\"model\", \"gpt-realtime-2\"}, {\"api_key\", std::getenv(\"OPENAI_APIKEY\")}}));",
        "axllm::Value request = axllm::object({{\"model\", \"gpt-realtime-2\"}, {\"chat_prompt\", axllm::array({axllm::object({{\"role\", \"user\"}, {\"content\", \"Say hello.\"}})})}, {\"audio\", axllm::object({{\"output\", axllm::object({{\"voice\", \"alloy\"}})}})}});",
        "axllm::Value result = client.realtime_chat(request, nullptr);  // one merged turn: transcript + base64 PCM audio",
        "// Realtime models also route transparently through chat(); chat() accepts input_audio parts; transcribe()/speak() do batch STT/TTS."
      ]
    },
    "quickStart": [
      "#include <axllm/axllm.hpp>",
      "",
      "auto llm = axllm::ai(\"openai\", axllm::object({{\"apiKey\", std::getenv(\"OPENAI_API_KEY\")}}));",
      "auto classify = axllm::ax(\"review:string -> sentiment:class \\\"positive, negative, neutral\\\"\");"
    ],
    "dspy": [
      "auto qa = axllm::ax(\"question:string -> answer:string, confidence:number\");"
    ],
    "signature": [
      "auto sig = axllm::s(\"email:string -> priority:class \\\"high, normal, low\\\"\");"
    ],
    "ax": ["auto answer = axllm::ax(\"question:string -> answer:string\");"],
    "agent": [
      "auto helper = axllm::agent(\"question:string -> answer:string\");"
    ],
    "llm": [
      "auto client = axllm::ai(\"openai\", axllm::object({{\"apiKey\", std::getenv(\"OPENAI_API_KEY\")}}));"
    ],
    "telemetry": [
      "auto program = axllm::ax(\"text:string -> label:string\");",
      "auto usage = program.getUsage();"
    ],
    "optimize": [
      "auto engine = axllm::AxGEPA(reflectionClient, axllm::object({}));",
      "auto result = engine.optimize(request, evaluator);"
    ],
    "playbook": [
      "auto pb = axllm::playbook(program, student_ai);",
      "pb.evolve(examples, metric);   // grow a playbook offline from examples",
      "auto rendered = pb.render();   // the playbook is now applied to the program",
      "auto state = pb.to_json();     // persist; restore later with playbook(...).load(state)"
    ]
  },
  "snippetGroups": {
    "tools": {
      "basic": [
        "auto search = axllm::Tool(",
        "  \"search\",",
        "  \"Search docs\",",
        "  axllm::object({",
        "    {\"type\", \"object\"},",
        "    {\"properties\", axllm::object({{\"query\", axllm::object({{\"type\", \"string\"}})}})},",
        "    {\"required\", axllm::array({\"query\"})}",
        "  }),",
        "  [](axllm::Value) { return axllm::object({{\"title\", \"Ax docs\"}}); }",
        ");"
      ],
      "standardSchema": [
        "// TypeScript owns the zod/valibot/arktype Standard Schema adapters.",
        "// Generated packages expose the same Ax concept as JSON-schema-compatible tool descriptors.",
        "auto lookup = axllm::Tool(",
        "  \"lookupProduct\",",
        "  \"Look up product inventory\",",
        "  axllm::object({{\"type\", \"object\"}}),",
        "  handler",
        ");"
      ],
      "namespaces": [
        "auto policy = axllm::Tool(\"findPolicy\", \"Find policies\", axllm::object({}), handler);",
        "// Group related tools under domain namespaces where the package surface supports it.",
        "// Runtime calls should read like kb.findPolicy(...) or billing.lookupInvoice(...)."
      ],
      "ax": [
        "auto answer = axllm::ax(\"question:string -> answer:string\");",
        "auto out = answer.forward(llm, axllm::object({",
        "  {\"question\", \"Can this customer get a refund?\"}",
        "}), axllm::object({{\"functions\", axllm::array({search})}}));"
      ],
      "agentFlat": [
        "auto assistant = axllm::agent(\"message:string -> reply:string\", axllm::object({",
        "  {\"functions\", axllm::array({search})},",
        "  {\"contextFields\", axllm::array({})}",
        "}));"
      ],
      "agentGroups": [
        "auto assistant = axllm::agent(\"message:string -> reply:string\", axllm::object({",
        "  {\"functionDiscovery\", true},",
        "  {\"functions\", axllm::array({axllm::object({",
        "    {\"namespace\", \"kb\"},",
        "    {\"title\", \"Knowledge Base\"},",
        "    {\"selectionCriteria\", \"Use for policy or documentation lookup.\"},",
        "    {\"functions\", axllm::array({search})}",
        "  })})}",
        "}));"
      ]
    },
    "mcp": {
      "native": {
        "sourcePath": "src/examples/cpp/mcp/native_mcp_tools.cpp",
        "code": [
          "auto mcp = std::make_shared<axllm::AxMCPClient>(transport, axllm::object({{\"namespace\", \"inventory\"}}));",
          "axllm::AxExecutionContext context({mcp});",
          "context.attach(program);",
          "  mcp->close();"
        ]
      },
      "resourceWake": {
        "sourcePath": "src/examples/cpp/mcp/resource_wake_agent.cpp",
        "code": [
          "auto source=std::make_shared<axllm::AxMCPEventSource>(client,\"inventory\",\"tenant:demo\",\"authenticated\",std::vector<std::string>{\"demo://inventory\"});",
          "runtime.register_target(std::move(target)).add_source(source).start();",
          "if(!changed.wait_for(lock,std::chrono::seconds(60),[&]{return complete;}))throw std::runtime_error(\"Timed out waiting for an MCP resource notification\");"
        ]
      },
      "taskResume": {
        "sourcePath": "src/examples/cpp/mcp/task_resume_flow.cpp",
        "code": [
          "auto result=client->call_tool(\"start_reindex\",axllm::object({{\"scope\",\"all\"}}));",
          "source->start_scoped([&](axllm::AxEventEnvelope inbound,std::string scope,std::string trust){runtime.publish(inbound,scope,trust);});"
        ]
      }
    },
    "event": {
      "wake": {
        "sourcePath": "src/examples/cpp/mcp/resource_wake_agent.cpp",
        "code": [
          "runtime.register_target(std::move(target)).add_source(source).start();",
          "if(!changed.wait_for(lock,std::chrono::seconds(60),[&]{return complete;}))throw std::runtime_error(\"Timed out waiting for an MCP resource notification\");"
        ]
      },
      "resume": {
        "sourcePath": "src/examples/cpp/mcp/task_resume_flow.cpp",
        "code": [
          "runtime.publish(event,\"tenant:demo\",\"authenticated\");",
          "source->start_scoped([&](axllm::AxEventEnvelope inbound,std::string scope,std::string trust){runtime.publish(inbound,scope,trust);});"
        ]
      },
      "ucp": {
        "sourcePath": "src/examples/ucp-webhook-wake-agent.ts",
        "code": [
          "  const receipt = await source.ingest(request);",
          "  if (!receipt.accepted) return new Response(null, { status: 503 });"
        ]
      }
    }
  }
}
