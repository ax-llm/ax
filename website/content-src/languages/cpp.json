      "dspy": "src/examples/cpp/generation/structured_generation.cpp",
      "models-signatures": "src/examples/cpp/generation/structured_generation.cpp",
      "axgen": "src/examples/cpp/generation/basic_generation.cpp",
      "axflow": "src/examples/cpp/flows/branch_flow.cpp",
      "axagent": "src/examples/cpp/short-agents/tools_agent.cpp",
      "rlm": "src/examples/cpp/long-agents/incident_log_forensics.cpp",
      "peek-context": "src/examples/cpp/long-agents/codebase_peek_map.cpp",
      "optimization": "src/examples/cpp/optimization/axgen_optimization.cpp",
      "mcp": "src/examples/cpp/mcp/native_mcp_tools.cpp",
      "notifications": "src/examples/cpp/mcp/resource_wake_agent.cpp",
      "production": "src/examples/cpp/long-agents/smart_defaults_agent.cpp"
    },
    "capstoneExample": "src/examples/cpp/mcp/task_resume_flow.cpp",
    "exerciseAnswers": {
      "signature-semantic-contract": ["axllm::s", "s"],
      "ai-providers-models": ["axllm::ai", "ai"],
      "fluent-fields-validation": ["FieldType"],
      "typed-tools": ["Tool"],
      "optimize-gen-flow": ["AxGEPA"]
    },
    "snippets": {
      "flow": [
        "std::string mermaid = R\"(flowchart TD",
        "  %%ax classify: request:string -> route:class \"support, sales\"",
        "  classify{route})\";",
        "auto program = axllm::flow(mermaid);",
        "std::cout << program.str();"
      ],
      "rlm": [
        "auto investigator = axllm::agent(signature, axllm::object({",
        "    {\"contextFields\", axllm::array({\"logs\"})},",
        "    {\"contextPolicy\", axllm::object({{\"preset\", \"lean\"}, {\"budget\", \"balanced\"}})},",
        "    {\"runtime\", axllm::object({{\"language\", \"JavaScript\"}})},",
        "}));"
      ],
      "contextMap": [
        "auto analyst = axllm::agent(signature, axllm::object({",
        "    {\"contextFields\", axllm::array({\"codebase\"})},",
        "    {\"contextPolicy\", axllm::object({{\"preset\", \"adaptive\"}, {\"budget\", \"balanced\"}})},",
        "    {\"contextMap\", axllm::object({{\"maxChars\", 1800}, {\"infiniteEvolve\", false}, {\"evolveSteps\", 1}})},",
        "}));"
      ],
      "memorySkills": [
        "auto assistant = axllm::agent(signature, axllm::object({",
        "    {\"memoriesCatalog\", memories},",
        "    {\"skillsCatalog\", skills},",
        "}));"
      ]
    }
  },
  "apiKind": "axir",
  "optimizeName": "AxGEPA",
  "optimizeIntro": "Use the generated `AxGEPA` optimizer surface for portable GEPA tuning. TypeScript also exposes the convenience `optimize()` helper; generated packages currently keep the optimizer explicit.",
  "apiReference": "/cpp/api/reference/",
  "apiSections": {
    "ai": ["AxAI"],
    "ax": ["AxGen", "Tools"],
    "s": ["Signatures"],
    "agent": ["Agents And RLM", "Runtime Profiles", "MCP"],
    "flow": ["Flow"],
    "optimize": ["Optimizers"]
  },
  "snippets": {
    "ai": {
      "audio": [
        "// Realtime audio over WebSocket — build with -DAXLLM_ENABLE_REALTIME=ON",
        "axllm::OpenAIResponsesClient client(axllm::object({{\"model\", \"gpt-realtime-2\"}, {\"api_key\", std::getenv(\"OPENAI_APIKEY\")}}));",
        "axllm::Value request = axllm::object({{\"model\", \"gpt-realtime-2\"}, {\"chat_prompt\", axllm::array({axllm::object({{\"role\", \"user\"}, {\"content\", \"Say hello.\"}})})}, {\"audio\", axllm::object({{\"output\", axllm::object({{\"voice\", \"alloy\"}})}})}});",
        "axllm::Value result = client.realtime_chat(request, nullptr);  // one merged turn: transcript + base64 PCM audio",
        "// Realtime models also route transparently through chat(); chat() accepts input_audio parts; transcribe()/speak() do batch STT/TTS."
      ]
    },
    "quickStart": [
      "#include <axllm/axllm.hpp>",
      "",
      "auto llm = axllm::ai(\"openai\", axllm::object({{\"apiKey\", std::getenv(\"OPENAI_API_KEY\")}}));",
      "auto classify = axllm::ax(\"review:string -> sentiment:class \\\"positive, negative, neutral\\\"\");"
    ],
    "dspy": [
      "auto qa = axllm::ax(\"question:string -> answer:string, confidence:number\");"
    ],
    "signature": [
      "auto sig = axllm::s(\"email:string -> priority:class \\\"high, normal, low\\\"\");"
    ],
    "ax": ["auto answer = axllm::ax(\"question:string -> answer:string\");"],
    "flow": [
      "std::string mermaid = R\"(flowchart TD",
      "  %%ax research: topicText:string -> factList:string[]",
      "  %%ax audience: topicText:string -> audienceAngle:string",
      "  %%ax join: factList:string[], audienceAngle:string -> briefText:string",
      "  research & audience --> join)\";",
      "auto program = axllm::flow(mermaid);",
      "std::cout << program.str();"
    ],
    "agent": [
      "auto helper = axllm::agent(\"question:string -> answer:string\");"
    ],
    "llm": [
      "auto client = axllm::ai(\"openai\", axllm::object({{\"apiKey\", std::getenv(\"OPENAI_API_KEY\")}}));"
    ],
    "telemetry": [
      "auto program = axllm::ax(\"text:string -> label:string\");",
      "auto usage = program.getUsage();"
    ],
    "optimize": [
      "auto engine = axllm::AxGEPA(reflectionClient, axllm::object({}));",
      "auto result = engine.optimize(request, evaluator);"
    ],
    "playbook": [
      "auto pb = axllm::playbook(program, student_ai);",
      "pb.evolve(examples, metric);   // grow a playbook offline from examples",
      "auto rendered = pb.render();   // the playbook is now applied to the program",
      "auto state = pb.to_json();     // persist; restore later with playbook(...).load(state)"
    ]
  },
  "snippetGroups": {
    "signatures": {
      "string": {
        "sourcePath": "src/examples/cpp/generation/basic_generation.cpp",
        "verified": true,
        "requiresCredentials": true,
        "code": [
          "auto program = axllm::ax(\"question:string -> answer:string\");",
          "auto output = program.forward(client, axllm::object({{\"question\", \"What is Ax?\"}}));"
        ]
      },
      "fluent": {
        "sourcePath": "src/examples/cpp/generation/signature-constraints.cpp",
        "verified": true,
        "requiresCredentials": true,
        "notes": [
          "C++ exposes the generated native signature records directly."
        ],
        "code": [
          "auto request_type = axllm::Core::record_new(\"FieldType\", axllm::object({",
          "  {\"name\", \"string\"}, {\"minLength\", 10}, {\"maxLength\", 500},",
          "}));",
          "auto request_field = field(\"requestText\", \"Request Text\", request_type);"
        ]
      },
      "validation": {
        "sourcePath": "src/examples/cpp/generation/signature-constraints.cpp",
        "verified": true,
        "requiresCredentials": true,
        "code": [
          "auto code_type = axllm::Core::record_new(\"FieldType\", axllm::object({",
          "  {\"name\", \"string\"},",
          "  {\"pattern\", \"^[A-Z]{3}-\\\\d{4}$\"},",
          "  {\"patternDescription\", \"Must look like ABC-1234\"},",
          "}));"
        ]
      },
      "hybrid": {
        "sourcePath": "src/examples/cpp/generation/signature-constraints.cpp",
        "verified": true,
        "requiresCredentials": true,
        "code": [
          "axllm::Core::validate_signature(signature);",
          "axllm::AxGen program = axllm::ax(signature);",
          "axllm::Value output = program.forward(client, inputs);"
        ]
      }
    },
    "flow": {
      "branch": {
        "sourcePath": "src/examples/cpp/flows/branch_flow.cpp",
        "verified": true,
        "requiresCredentials": true,
        "code": [
          "axllm::AxGen classifier = axllm::ax(\"request:string -> route:class \\\"support, sales, engineering\\\"\");",
          "axllm::AxGen responder = axllm::ax(\"request:string, route:string -> response:string\");",
          "axllm::AxFlow program = axllm::flow(axllm::object({{\"id\", \"examples.branchFlow\"}}))",
          "    .execute(\"classifier\", classifier, axllm::object({{\"reads\", axllm::array({\"request\"})}, {\"writes\", axllm::array({\"classifierResult\", \"route\"})}}))",
          "    .execute(\"responder\", responder, axllm::object({{\"reads\", axllm::array({\"request\", \"route\"})}, {\"writes\", axllm::array({\"responderResult\", \"response\"})}}))",
          "    .returns(axllm::object({{\"route\", \"route\"}, {\"response\", \"response\"}}));"
        ]
      },
      "parallel": {
        "sourcePath": "src/examples/cpp/flows/parallel-flow.cpp",
        "verified": true,
        "requiresCredentials": true,
        "code": [
          "axllm::AxFlow program = axllm::flow(axllm::object({{\"id\", \"examples.parallelFlow\"}}))",
          "    .execute(\"research\", research, axllm::object({{\"reads\", axllm::array({\"topicText\"})}, {\"writes\", axllm::array({\"researchResult\", \"factList\"})}}))",
          "    .execute(\"audience\", audience, axllm::object({{\"reads\", axllm::array({\"topicText\"})}, {\"writes\", axllm::array({\"audienceResult\", \"audienceAngle\"})}}))",
          "    .execute(\"join\", join, axllm::object({{\"reads\", axllm::array({\"factList\", \"audienceAngle\"})}, {\"writes\", axllm::array({\"joinResult\", \"briefText\"})}}))",
          "    .returns(axllm::object({{\"briefText\", \"briefText\"}}));"
        ]
      },
      "refine": {
        "sourcePath": "src/examples/cpp/flows/refine-flow.cpp",
        "verified": true,
        "requiresCredentials": true,
        "code": [
          "axllm::AxFlow program = axllm::flow(axllm::object({{\"id\", \"examples.refineFlow\"}}))",
          "    .execute(\"draft\", draft, axllm::object({{\"reads\", axllm::array({\"topicText\"})}, {\"writes\", axllm::array({\"draftResult\", \"draftText\"})}}))",
          "    .execute(\"critique\", critique, axllm::object({{\"reads\", axllm::array({\"draftText\"})}, {\"writes\", axllm::array({\"critiqueResult\", \"critiqueText\"})}}))",
          "    .execute(\"revise\", revise, axllm::object({{\"reads\", axllm::array({\"draftText\", \"critiqueText\"})}, {\"writes\", axllm::array({\"reviseResult\", \"revisedText\"})}}))",
          "    .returns(axllm::object({{\"revisedText\", \"revisedText\"}}));"
        ]
      }
    },
    "agents": {
