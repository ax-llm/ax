          "program := ax.NewFlow(map[string]ax.Value{\"id\": \"examples.branchFlow\"}).",
          "  Execute(\"classifier\", classifier, map[string]ax.Value{\"reads\": ax.Array(\"request\"), \"writes\": ax.Array(\"classifierResult\", \"route\")}).",
          "  Execute(\"responder\", responder, map[string]ax.Value{\"reads\": ax.Array(\"request\", \"route\"), \"writes\": ax.Array(\"responderResult\", \"response\")}).",
          "  Returns(map[string]ax.Value{\"route\": \"route\", \"response\": \"response\"})"
        ]
