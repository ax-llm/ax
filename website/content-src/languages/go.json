        "notes": [
          "Shortened from the checked-in scripted-client tool example."
        ],
        "code": [
          "search := axllm.Fn(\"search\").WithHandler(func(args map[string]axllm.Value) (axllm.Value, error) {",
          "  return axllm.Object(\"title\", \"Ax docs\"), nil",
          "})"
        ]
      },
      "standardSchema": [
        "// TypeScript owns the zod/valibot/arktype Standard Schema adapters.",
        "// Generated packages expose the same Ax concept as JSON-schema-compatible tool descriptors.",
        "lookup := axllm.Fn(\"lookupProduct\").WithHandler(func(args map[string]axllm.Value) (axllm.Value, error) {",
        "  return axllm.Object(\"price\", 79.99, \"inStock\", true), nil",
        "})"
      ],
      "namespaces": [
        "policy := axllm.Fn(\"findPolicy\").WithHandler(policyHandler)",
        "// Group related tools under domain namespaces where the package surface supports it.",
        "// Runtime calls should read like kb.findPolicy(...) or billing.lookupInvoice(...)."
      ],
      "ax": [
        "answer := axllm.NewAx(\"question:string -> answer:string\", nil)",
        "answer.Functions = []axllm.Tool{search}",
        "out, err := answer.Forward(context.Background(), client, map[string]axllm.Value{",
        "  \"question\": \"Can this customer get a refund?\",",
        "}, nil)"
      ],
      "agentFlat": [
        "assistant := axllm.NewAgent(\"message:string -> reply:string\", map[string]axllm.Value{",
        "  \"functions\": axllm.Array(search),",
        "  \"contextFields\": []axllm.Value{},",
        "})"
      ],
      "agentGroups": [
        "assistant := axllm.NewAgent(\"message:string -> reply:string\", map[string]axllm.Value{",
        "  \"functionDiscovery\": true,",
