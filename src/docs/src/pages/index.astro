---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/react/HeroSection';
import HighlightsSection from '../components/react/HighlightsSection';
import CodeExample from '../components/react/CodeExample';
import FeatureGrid from '../components/react/FeatureGrid';
import PatternsSection from '../components/react/PatternsSection';
import ProvidersSection from '../components/react/ProvidersSection';
import SignatureShowcase from '../components/react/SignatureShowcase';
import AgentSection from '../components/react/AgentSection';
import ProductionSection from '../components/react/ProductionSection';
import GraphJinSection from '../components/react/GraphJinSection';
---

<Layout title="Ax - Build Reliable AI Apps in TypeScript" isHomepage={true}>
  <HeroSection client:load />
  <HighlightsSection client:load />
  <CodeExample client:visible />
  <SignatureShowcase client:visible />
  <AgentSection client:visible />
  <ProductionSection client:visible />
  <FeatureGrid client:visible />
  <PatternsSection client:visible />
  <ProvidersSection client:visible />
  <GraphJinSection client:visible />
</Layout>
