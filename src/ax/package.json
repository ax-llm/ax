{
  "name": "@ax-llm/ax",
  "version": "21.0.7",
  "type": "module",
  "description": "The best library to work with LLMs",
  "repository": {
    "type": "git",
    "url": "https://github.com/ax-llm/ax.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "keywords": [],
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsup --watch",
    "build": "npm run build:templates && npm run build:index && tsup",
    "build:templates": "node ../../scripts/buildPromptTemplates.mjs",
    "build:index": "node --import=tsx ../../scripts/generateIndex.ts",
    "clean": "rm -rf dist",
    "test": "run-s test:*",
    "test:templates": "node ../../scripts/buildPromptTemplates.mjs --check",
    "test:index": "node --import=tsx ../../scripts/generateIndex.ts",
    "test:type-check": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:lint": "biome lint .",
    "test:format": "biome format .",
    "fix": "run-s fix:*",
    "fix:lint": "biome lint --write .",
    "fix:format": "biome format --write .",
    "doc:build:markdown": "typedoc --readme none",
    "coverage": "vitest run --coverage",
    "tsx": "node --env-file=.env --import=tsx",
    "release": "release-it",
    "publish": "npm run build && cd dist && npm publish",
    "postbuild": "node ../../scripts/postbuild.js"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0"
  },
  "peerDependencies": {
    "zod": "^3.24.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "tsd": {
    "directory": "./"
  },
  "files": [
    "**/*"
  ],
  "bugs": {
    "url": "https://github.com/@ax-llm/ax/issues"
  },
  "homepage": "https://github.com/ax-llm/ax#readme",
  "author": "Vikram <https://twitter.com/dosco>",
  "devDependencies": {}
}
